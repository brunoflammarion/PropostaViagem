@model SistemaUsuarios.Models.ViewModels.Analytics.DashboardAnalyticsViewModel
@using SistemaUsuarios.Models
@{
    ViewData["Title"] = "Radar de Propostas";
}

@functions {
    string StatusLabel(StatusProposta s) => s switch {
        StatusProposta.Rascunho  => "Rascunho",
        StatusProposta.Enviada   => "Enviada",
        StatusProposta.Aprovada  => "Aprovada",
        StatusProposta.Rejeitada => "Rejeitada",
        StatusProposta.Cancelada => "Cancelada",
        _ => s.ToString()
    };

    // CSS class suffix for status badges (paleta AT, sem conflito com agenttools-app.css)
    string StatusBadgeMod(StatusProposta s) => s switch {
        StatusProposta.Rascunho  => "s-rascunho",
        StatusProposta.Enviada   => "s-enviada",
        StatusProposta.Aprovada  => "s-aprovada",
        StatusProposta.Rejeitada => "s-rejeitada",
        StatusProposta.Cancelada => "s-cancelada",
        _ => "s-rascunho"
    };

    string FormatarData(DateTime? dt) {
        if (dt == null) return "—";
        var diff = DateTime.Now - dt.Value;
        if (diff.TotalMinutes < 2)  return "agora mesmo";
        if (diff.TotalMinutes < 60) return $"há {(int)diff.TotalMinutes}min";
        if (diff.TotalHours < 24)   return $"há {(int)diff.TotalHours}h";
        if (diff.TotalDays < 2)     return "ontem";
        if (diff.TotalDays < 7)     return $"há {(int)diff.TotalDays} dias";
        return dt.Value.ToString("dd/MM");
    }

    string DispositivoIcon(string? tipo) {
        var t = tipo?.ToLower() ?? "";
        if (t.Contains("mobile") || t.Contains("phone") || t.Contains("smartphone")) return "fa-mobile-alt";
        if (t.Contains("tablet")) return "fa-tablet-alt";
        if (t.Contains("desktop") || t.Contains("pc")) return "fa-desktop";
        return "fa-globe";
    }
}

<div class="container-fluid pb-5" id="analytics-dashboard-page">

    @* ── Header ── *@
    <div class="d-flex justify-content-between align-items-start mb-4 flex-wrap gap-2">
        <div>
            <nav aria-label="breadcrumb" class="mb-1">
                <ol class="breadcrumb mb-0" style="font-size:.8125rem;">
                    <li class="breadcrumb-item"><a href="/Proposta">Propostas</a></li>
                    <li class="breadcrumb-item active">Radar de Propostas</li>
                </ol>
            </nav>
            <h3 class="mb-0 fw-bold" style="color:#1a202c;">
                <i class="fas fa-radar me-2" style="color:#3A7CA5;"></i>Radar de Propostas
            </h3>
            <p class="text-muted mb-0" style="font-size:.875rem;">
                Acompanhe visualizações, interesse dos clientes e oportunidades de follow-up.
            </p>
        </div>
        <div class="d-flex gap-2 align-items-center flex-wrap">
            <a href="/Proposta" class="btn btn-sm btn-outline-secondary">
                <i class="fas fa-list me-1"></i>Propostas
            </a>
            <a href="/PropostaAnalyticsData/Dashboard" class="btn btn-sm btn-outline-secondary">
                <i class="fas fa-sync me-1"></i>Atualizar
            </a>
        </div>
    </div>

    @* ── 4 Summary Cards ── *@
    <div class="analytics-summary-grid">

        <div class="analytics-summary-card">
            <div class="analytics-card-icon" style="background:#eef4fb; color:#3A7CA5;">
                <i class="fas fa-eye"></i>
            </div>
            <div class="analytics-card-number">@Model.PropostasComVisualizacao</div>
            <div class="analytics-card-label">propostas com ao menos uma visualização</div>
            @if (Model.PropostasComVisualizacao > 0)
            {
                <div class="analytics-card-action">
                    <a href="#secao-radar" class="text-primary text-decoration-none" onclick="document.getElementById('secao-radar').scrollIntoView({behavior:'smooth'});return false;">
                        Ver detalhes <i class="fas fa-arrow-down ms-1" style="font-size:.7rem;"></i>
                    </a>
                </div>
            }
        </div>

        <div class="analytics-summary-card">
            <div class="analytics-card-icon" style="background:#fff7ed; color:#d97706;">
                <i class="fas fa-fire"></i>
            </div>
            <div class="analytics-card-number">@Model.ClientesQuentes</div>
            <div class="analytics-card-label">propostas visualizadas nos últimos 7 dias (não fechadas)</div>
            @if (Model.ClientesQuentes > 0)
            {
                <div class="analytics-card-action">
                    <a href="#secao-followup" class="text-warning text-decoration-none fw-semibold" onclick="document.getElementById('secao-followup').scrollIntoView({behavior:'smooth'});return false;">
                        Ver oportunidades <i class="fas fa-arrow-down ms-1" style="font-size:.7rem;"></i>
                    </a>
                </div>
            }
        </div>

        <div class="analytics-summary-card">
            <div class="analytics-card-icon" style="background:#f0fdf4; color:#16a34a;">
                <i class="fas fa-chart-line"></i>
            </div>
            <div class="analytics-card-number">@Model.TotalVisualizacoes</div>
            <div class="analytics-card-label">acessos totais às propostas públicas</div>
        </div>

        <div class="analytics-summary-card">
            <div class="analytics-card-icon" style="background:#fdf4ff; color:#9333ea;">
                <i class="fas fa-percentage"></i>
            </div>
            <div class="analytics-card-number">@Model.TaxaPropostasVisualizadas.ToString("F0")%</div>
            <div class="analytics-card-label">
                das @Model.TotalPropostas propostas foram abertas pelo menos uma vez
            </div>
        </div>

    </div>

    @* ── Filtros ── *@
    <div class="analytics-filters">
        <span class="filter-label">Período</span>
        <button type="button" class="filter-period-btn active" data-period="all">Tudo</button>
        <button type="button" class="filter-period-btn" data-period="30">Últimos 30 dias</button>
        <button type="button" class="filter-period-btn" data-period="7">Últimos 7 dias</button>
        <div class="filter-divider"></div>
        <span class="filter-label">Status</span>
        <select id="filtroStatus" class="form-select form-select-sm" style="width:auto; font-size:.8125rem;">
            <option value="">Todos</option>
            <option value="1">Rascunho</option>
            <option value="2">Enviada</option>
            <option value="3">Aprovada</option>
            <option value="4">Rejeitada</option>
            <option value="5">Cancelada</option>
        </select>
        <div class="filter-divider"></div>
        <div class="flex-grow-1" style="min-width:160px; max-width:280px;">
            <div class="input-group input-group-sm">
                <span class="input-group-text bg-transparent border-end-0">
                    <i class="fas fa-search text-muted" style="font-size:.75rem;"></i>
                </span>
                <input type="text" id="filtroBusca" class="form-control border-start-0"
                       placeholder="Buscar proposta ou cliente…"
                       style="font-size:.8125rem;">
            </div>
        </div>
        <span id="filtroResultado" class="text-muted ms-auto" style="font-size:.8rem; white-space:nowrap;"></span>
    </div>

    @* ── Main layout: tabela + follow-up ── *@
    <div class="row g-4 mb-4">

        @* ── Col esquerda: Propostas com maior interesse ── *@
        <div class="col-xl-8">
            <div class="analytics-section-card h-100" id="secao-radar">
                <div class="analytics-section-header">
                    <div>
                        <h6 class="analytics-section-title">
                            <i class="fas fa-trophy me-2" style="color:#f59e0b;"></i>Propostas com maior interesse
                        </h6>
                        <p class="analytics-section-subtitle">Ordenadas pela última visita mais recente</p>
                    </div>
                    <span class="badge bg-light text-secondary" id="contadorLinhas" style="font-size:.75rem;"></span>
                </div>

                @if (!Model.PropostasRadar.Any())
                {
                    <div class="analytics-empty-state">
                        <i class="fas fa-eye-slash empty-icon"></i>
                        <p class="empty-title">Nenhuma proposta visualizada ainda</p>
                        <p class="empty-text">Quando seus clientes abrirem os links das propostas, as visualizações aparecerão aqui.</p>
                        <a href="/Proposta" class="btn btn-sm btn-outline-primary">
                            <i class="fas fa-list me-1"></i>Ver propostas
                        </a>
                    </div>
                }
                else
                {
                    <div style="overflow-x:auto;">
                        <table class="radar-table" id="tabelaRadar">
                            <thead>
                                <tr>
                                    <th>Proposta</th>
                                    <th class="text-center">Visualizações</th>
                                    <th class="text-center">Avaliações</th>
                                    <th>Última visita</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var p in Model.PropostasRadar)
                                {
                                    <tr data-status="@((int)p.StatusProposta)"
                                        data-viz="@p.TotalVisualizacoes"
                                        data-ultima-viz="@(p.UltimaVisualizacao?.ToString("yyyy-MM-dd") ?? "")"
                                        data-busca="@(p.Titulo.ToLower()) @(p.ClienteNome?.ToLower() ?? "") @(p.DestinoNome?.ToLower() ?? "")">
                                        <td>
                                            <span class="radar-proposta-name" title="@p.Titulo">@p.Titulo</span>
                                            @if (!string.IsNullOrEmpty(p.ClienteNome) || !string.IsNullOrEmpty(p.DestinoNome))
                                            {
                                                <span class="radar-proposta-sub">
                                                    @if (!string.IsNullOrEmpty(p.ClienteNome))
                                                    {
                                                        <span><i class="fas fa-user me-1" style="font-size:.65rem;"></i>@p.ClienteNome</span>
                                                    }
                                                    @if (!string.IsNullOrEmpty(p.DestinoNome))
                                                    {
                                                        <span class="ms-2"><i class="fas fa-map-marker-alt me-1" style="font-size:.65rem;"></i>@p.DestinoNome</span>
                                                    }
                                                </span>
                                            }
                                        </td>
                                        <td class="text-center">
                                            <span class="viz-badge">
                                                <i class="fas fa-eye" style="color:#9ca3af; font-size:.75rem;"></i>
                                                @p.TotalVisualizacoes
                                            </span>
                                        </td>
                                        <td class="text-center">
                                            <span class="viz-badge">
                                                <i class="fas fa-star" style="color:#f59e0b; font-size:.75rem;"></i>
                                                @p.TotalAvaliacoes
                                            </span>
                                        </td>
                                        <td>
                                            <span style="font-size:.8125rem; color:@(p.UltimaVisualizacao >= DateTime.Now.AddDays(-2) ? "#16a34a" : "#6b7280");">
                                                @FormatarData(p.UltimaVisualizacao)
                                            </span>
                                        </td>
                                        <td class="text-end" style="white-space:nowrap;">
                                            <a href="/Proposta/Editar/@p.PropostaId"
                                               class="btn btn-outline-primary btn-sm" title="Editar proposta">
                                                <i class="fas fa-edit me-1"></i>Abrir
                                            </a>
                                            <a href="/PropostaAnalyticsData/PropostaDetalhada/@p.PropostaId"
                                               class="btn btn-outline-secondary btn-sm ms-1" title="Ver analytics detalhado">
                                                <i class="fas fa-chart-line"></i>
                                            </a>
                                            @if (p.ClienteId.HasValue)
                                            {
                                                <a href="/Cliente/Detalhe/@p.ClienteId"
                                                   class="btn btn-outline-secondary btn-sm ms-1" title="Ver cliente">
                                                    <i class="fas fa-user"></i>
                                                </a>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    <div id="tabelaVazia" class="analytics-empty-state" style="display:none;">
                        <i class="fas fa-filter empty-icon"></i>
                        <p class="empty-title">Nenhum resultado</p>
                        <p class="empty-text">Tente ajustar os filtros.</p>
                    </div>
                }
            </div>
        </div>

        @* ── Col direita: Oportunidades de follow-up ── *@
        <div class="col-xl-4">
            <div class="analytics-section-card h-100" id="secao-followup">
                <div class="analytics-section-header">
                    <div>
                        <h6 class="analytics-section-title">
                            <i class="fas fa-bell me-2" style="color:#d97706;"></i>Oportunidades de follow-up
                        </h6>
                        <p class="analytics-section-subtitle">Propostas que merecem contato agora</p>
                    </div>
                    @if (Model.OportunidadesFollowUp.Any())
                    {
                        <span class="followup-count-badge">@Model.OportunidadesFollowUp.Count</span>
                    }
                </div>

                @if (!Model.OportunidadesFollowUp.Any())
                {
                    <div class="analytics-empty-state">
                        <i class="fas fa-check-circle empty-icon"></i>
                        <p class="empty-title">Nenhuma oportunidade no momento</p>
                        <p class="empty-text">Propostas visualizadas recentemente aparecerão aqui.</p>
                    </div>
                }
                else
                {
                    <div class="followup-list">
                        @foreach (var op in Model.OportunidadesFollowUp)
                        {
                            <div class="followup-item">
                                <div class="followup-proposta" title="@op.PropostaTitulo">@op.PropostaTitulo</div>
                                <div class="followup-cliente">
                                    @if (!string.IsNullOrEmpty(op.ClienteNome))
                                    {
                                        <i class="fas fa-user me-1" style="font-size:.7rem; opacity:.6;"></i>@op.ClienteNome
                                        <span class="mx-1 text-muted">·</span>
                                    }
                                    <span class="at-status-badge @StatusBadgeMod(op.StatusProposta)">@StatusLabel(op.StatusProposta)</span>
                                    @if (op.UltimaVisualizacao.HasValue)
                                    {
                                        <span class="ms-1" style="font-size:.75rem; color:#9ca3af;">· @FormatarData(op.UltimaVisualizacao)</span>
                                    }
                                </div>
                                <div class="followup-motivo">@op.MotivoSugestao</div>
                                <div class="d-flex gap-2">
                                    <a href="/Proposta/Editar/@op.PropostaId" class="btn btn-primary btn-sm">
                                        <i class="fas fa-edit me-1"></i>Abrir proposta
                                    </a>
                                    @if (op.ClienteId.HasValue)
                                    {
                                        <a href="/Cliente/Detalhe/@op.ClienteId" class="btn btn-outline-secondary btn-sm">
                                            <i class="fas fa-user"></i>
                                        </a>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>

    </div>

    @* ── Atividade recente ── *@
    <div class="row g-4">
        <div class="col-12">
            <div class="analytics-section-card" id="secao-atividade">
                <div class="analytics-section-header">
                    <div>
                        <h6 class="analytics-section-title">
                            <i class="fas fa-stream me-2" style="color:#3A7CA5;"></i>Atividade recente
                        </h6>
                        <p class="analytics-section-subtitle">Últimas visualizações registradas nas suas propostas</p>
                    </div>
                </div>

                @if (!Model.AtividadeRecente.Any())
                {
                    <div class="analytics-empty-state">
                        <i class="fas fa-inbox empty-icon"></i>
                        <p class="empty-title">Nenhuma atividade ainda</p>
                        <p class="empty-text">
                            Quando seus clientes abrirem os links das propostas, cada visita aparecerá aqui em tempo real.
                        </p>
                    </div>
                }
                else
                {
                    <div class="activity-list">
                        @foreach (var ativ in Model.AtividadeRecente)
                        {
                            <div class="activity-item">
                                <div class="activity-icon">
                                    <i class="fas @DispositivoIcon(ativ.TipoDispositivo)"></i>
                                </div>
                                <div class="activity-body">
                                    <p class="activity-title" title="@ativ.PropostaTitulo">
                                        @if (!string.IsNullOrEmpty(ativ.ClienteNome))
                                        {
                                            <strong>@ativ.ClienteNome</strong>
                                            <span class="text-muted fw-normal"> visualizou </span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">Alguém visualizou </span>
                                        }
                                        <span>@ativ.PropostaTitulo</span>
                                    </p>
                                    <p class="activity-meta">
                                        @FormatarData(ativ.DataHoraVisualizacao)
                                        @if (!string.IsNullOrEmpty(ativ.Cidade))
                                        {
                                            <span class="mx-1">·</span>
                                            <i class="fas fa-map-marker-alt me-1"></i>@ativ.Cidade
                                            @if (!string.IsNullOrEmpty(ativ.Pais) && ativ.Pais != ativ.Cidade)
                                            {
                                                <span>, @ativ.Pais</span>
                                            }
                                        }
                                    </p>
                                </div>
                                <div class="flex-shrink-0">
                                    <a href="/Proposta/Editar/@ativ.PropostaId"
                                       class="btn btn-outline-secondary btn-sm" title="Abrir proposta">
                                        <i class="fas fa-external-link-alt"></i>
                                    </a>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>

</div>

@section Scripts {
<script>
(function () {
    'use strict';

    var rows = Array.from(document.querySelectorAll('#tabelaRadar tbody tr'));
    var emptyMsg = document.getElementById('tabelaVazia');
    var contador = document.getElementById('contadorLinhas');
    var today = new Date(); today.setHours(0,0,0,0);

    function aplicarFiltros() {
        var period  = document.querySelector('.filter-period-btn.active')?.dataset.period || 'all';
        var status  = document.getElementById('filtroStatus')?.value || '';
        var busca   = (document.getElementById('filtroBusca')?.value || '').toLowerCase().trim();
        var cutoff  = null;

        if (period === '7')  { cutoff = new Date(today); cutoff.setDate(today.getDate() - 7); }
        if (period === '30') { cutoff = new Date(today); cutoff.setDate(today.getDate() - 30); }

        var visiveis = 0;
        rows.forEach(function (row) {
            var rowStatus   = row.dataset.status;
            var rowBusca    = row.dataset.busca || '';
            var rowVizDate  = row.dataset.ultimaViz;
            var show = true;

            if (status && rowStatus !== status) show = false;
            if (busca && !rowBusca.includes(busca)) show = false;
            if (cutoff && rowVizDate) {
                var d = new Date(rowVizDate);
                if (d < cutoff) show = false;
            } else if (cutoff && !rowVizDate) {
                show = false;
            }

            row.style.display = show ? '' : 'none';
            if (show) visiveis++;
        });

        if (emptyMsg) emptyMsg.style.display = visiveis === 0 && rows.length > 0 ? '' : 'none';
        if (contador) contador.textContent = visiveis + ' proposta' + (visiveis !== 1 ? 's' : '');

        var resultado = document.getElementById('filtroResultado');
        if (resultado) {
            resultado.textContent = (period !== 'all' || status || busca)
                ? visiveis + ' resultado' + (visiveis !== 1 ? 's' : '')
                : '';
        }
    }

    // Period buttons
    document.querySelectorAll('.filter-period-btn').forEach(function (btn) {
        btn.addEventListener('click', function () {
            document.querySelectorAll('.filter-period-btn').forEach(function (b) { b.classList.remove('active'); });
            this.classList.add('active');
            aplicarFiltros();
        });
    });

    // Status select
    var filtroStatus = document.getElementById('filtroStatus');
    if (filtroStatus) filtroStatus.addEventListener('change', aplicarFiltros);

    // Search input (debounce 200ms)
    var filtroTimer;
    var filtroBusca = document.getElementById('filtroBusca');
    if (filtroBusca) {
        filtroBusca.addEventListener('input', function () {
            clearTimeout(filtroTimer);
            filtroTimer = setTimeout(aplicarFiltros, 200);
        });
    }

    // Init
    aplicarFiltros();
})();
</script>
}

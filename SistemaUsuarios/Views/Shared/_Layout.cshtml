@functions {
    static string LightenHex(string hex, int amt)
    {
        if (string.IsNullOrEmpty(hex) || !hex.StartsWith("#") || hex.Length != 7) return hex;
        try
        {
            int r = Math.Clamp(Convert.ToInt32(hex.Substring(1, 2), 16) + amt, 0, 255);
            int g = Math.Clamp(Convert.ToInt32(hex.Substring(3, 2), 16) + amt, 0, 255);
            int b = Math.Clamp(Convert.ToInt32(hex.Substring(5, 2), 16) + amt, 0, 255);
            return $"#{r:X2}{g:X2}{b:X2}";
        }
        catch { return hex; }
    }
}
@{
    var _uCorP = Context.Session.GetString("CorPrimaria");
    var _uCorS = Context.Session.GetString("CorSecundaria");
    var _uCorD = Context.Session.GetString("CorDestaque");
    bool _uHasTheme = !string.IsNullOrEmpty(_uCorP) && !string.IsNullOrEmpty(_uCorS) && !string.IsNullOrEmpty(_uCorD);
    var _uCorPLight = _uHasTheme ? LightenHex(_uCorP!, 28) : "";
    var _uCorDDark  = _uHasTheme ? LightenHex(_uCorD!, -18) : "";
    var _uFoto       = Context.Session.GetString("FotoPath");
    var _uNome       = Context.Session.GetString("UsuarioNome") ?? "Usuário";
    var _uIniciais   = string.Join("", _uNome.Split(' ', StringSplitOptions.RemoveEmptyEntries).Take(2).Select(p => char.ToUpper(p[0]).ToString()));
    var _uTipo       = Context.Session.GetString("TipoUsuario") ?? "Master";
    var _uIsMaster   = _uTipo != "Associado";
    var _uNomeMaster = Context.Session.GetString("NomeMaster");
}
<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(ViewData["Title"] ?? "Agent Tools") - Sistema de Viagens</title>
    <link rel="icon" type="image/x-icon" href="/favicon.ico">

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Font Awesome -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <!-- Custom styles (after Bootstrap so our rules win) -->
    <link href="~/css/custom.css" rel="stylesheet" asp-append-version="true">

    @await RenderSectionAsync("Styles", required: false)

    @if (_uHasTheme)
    {
        <style id="user-theme">
        :root {
            --at-brand:           @_uCorP;
            --at-brand-light:     @_uCorPLight;
            --at-secondary:       @_uCorS;
            --at-brand-active:    @_uCorD;
            --at-gradient-brand:  linear-gradient(135deg, @_uCorP 0%, @_uCorPLight 100%);
            --at-gradient-active: linear-gradient(135deg, @_uCorD 0%, @_uCorDDark 100%);
        }
        </style>
    }

    <!-- App layout override — carregado APÓS todos os outros CSS -->
    <link href="~/css/agenttools-app.css" rel="stylesheet" asp-append-version="true">
</head>
<body class="app-body">
<div class="app-shell">
    <!-- Navigation -->
    <nav class="navbar navbar-expand-lg app-navbar">
        <div class="container-fluid">
            <a class="navbar-brand d-inline-flex align-items-center gap-2" href="@Url.Action("Index", "Home")">
                <img src="~/images/logo.png" alt="AgentTools" width="40" height="40" style="display:block;flex-shrink:0;">
                <span class="brand-wordmark">Agent <strong>Tools</strong></span>
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Index" && ViewContext.RouteData.Values["controller"]?.ToString() == "Proposta" ? "active" : "")"
                           href="@Url.Action("Index", "Proposta")">
                            <i class="fas fa-list me-1"></i>Propostas
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Cliente" ? "active" : "")"
                           href="@Url.Action("Index", "Cliente")">
                            <i class="fas fa-users me-1"></i>Clientes
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "PropostaAnalyticsData" ? "active" : "")"
                           href="/PropostaAnalyticsData/Dashboard">
                            <i class="fas fa-chart-bar me-1"></i>Analytics
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Tarefa" ? "active" : "")"
                           href="@Url.Action("Index", "Tarefa")">
                            <i class="fas fa-tasks me-1"></i>Tarefas
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Oferta" ? "active" : "")"
                           href="@Url.Action("Index", "Oferta")">
                            <i class="fas fa-bullhorn me-1"></i>Ofertas
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Lead" ? "active" : "")"
                           href="@Url.Action("Index", "Lead")">
                            <i class="fas fa-user-plus me-1"></i>Leads
                        </a>
                    </li>
                    @if (Context.Session.GetString("UsuarioId") != null && _uIsMaster)
                    {
                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Usuario" && ViewContext.RouteData.Values["action"]?.ToString() == "GerenciarEquipe" ? "active" : "")"
                               href="@Url.Action("GerenciarEquipe", "Usuario")">
                                <i class="fas fa-users-cog me-1"></i>Equipe
                            </a>
                        </li>
                    }
                </ul>

                <ul class="navbar-nav">
                    @if (Context.Session.GetString("UsuarioId") != null)
                    {
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle d-flex align-items-center gap-2" href="#" id="navbarDropdown" role="button" data-bs-toggle="dropdown">
                                @if (!string.IsNullOrEmpty(_uFoto))
                                {
                                    <img src="@_uFoto" alt="" style="width:26px;height:26px;border-radius:50%;object-fit:cover;border:2px solid rgba(255,255,255,.35);flex-shrink:0;" />
                                }
                                else
                                {
                                    <span style="width:26px;height:26px;border-radius:50%;background:rgba(255,255,255,.18);display:inline-flex;align-items:center;justify-content:center;font-size:.65rem;font-weight:700;color:#fff;flex-shrink:0;letter-spacing:.02em;">@_uIniciais</span>
                                }
                                @_uNome
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end">
                                @if (!_uIsMaster && !string.IsNullOrEmpty(_uNomeMaster))
                                {
                                    <li class="px-3 py-2">
                                        <span class="d-flex align-items-center gap-1 text-muted" style="font-size:.75rem">
                                            <i class="fas fa-link me-1" style="color:var(--exec-accent)"></i>
                                            Agente de <strong class="text-dark ms-1">@_uNomeMaster</strong>
                                        </span>
                                    </li>
                                    <li><hr class="dropdown-divider my-1"></li>
                                }
                                <li>
                                    <a class="dropdown-item" href="@Url.Action("Index", "Usuario")">
                                        <i class="fas fa-user-circle me-2"></i>Meu Perfil
                                    </a>
                                </li>
                                @if (_uIsMaster)
                                {
                                    <li>
                                        <a class="dropdown-item" href="@Url.Action("GerenciarEquipe", "Usuario")">
                                            <i class="fas fa-users-cog me-2"></i>Gerenciar Equipe
                                        </a>
                                    </li>
                                }
                                <li><hr class="dropdown-divider"></li>
                                <li>
                                    <a class="dropdown-item" href="@Url.Action("Logout", "Auth")">
                                        <i class="fas fa-sign-out-alt me-2"></i>Sair
                                    </a>
                                </li>
                            </ul>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link" href="@Url.Action("Login", "Auth")">
                                <i class="fas fa-sign-in-alt me-1"></i>Entrar
                            </a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <main class="app-main">
    <div class="at-app-container@(ViewData["FullBleed"] != null ? " at-app-container--full-bleed" : "")" role="main">
        <!-- Mensagens de Feedback -->
        @if (TempData["Sucesso"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="fas fa-check-circle me-2"></i>
                @TempData["Sucesso"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        @if (TempData["Erro"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="fas fa-exclamation-circle me-2"></i>
                @TempData["Erro"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        @if (TempData["Aviso"] != null)
        {
            <div class="alert alert-warning alert-dismissible fade show" role="alert">
                <i class="fas fa-exclamation-triangle me-2"></i>
                @TempData["Aviso"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        @if (TempData["Info"] != null)
        {
            <div class="alert alert-info alert-dismissible fade show" role="alert">
                <i class="fas fa-info-circle me-2"></i>
                @TempData["Info"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <!-- Page Content -->
        @RenderBody()
    </div>
    </main>

    <!-- Footer -->
    <footer class="footer app-footer">
        <div class="container-fluid">
            <div class="row align-items-center">
                <div class="col-md-6">
                    <a href="@Url.Action("Index", "Home")" class="d-inline-flex align-items-center gap-2 text-decoration-none mb-1">
                        <img src="~/images/logo.png" alt="AgentTools" width="32" height="32" style="display:block;flex-shrink:0;opacity:.55;">
                        <span style="font-size:.95rem;font-weight:700;color:#1E4E8C;letter-spacing:-.01em;">Agent <strong>Tools</strong></span>
                    </a>
                    <p class="mb-0" style="font-size:.78rem;color:#687268;">Criando experiências inesquecíveis</p>
                </div>
                <div class="col-md-6 text-md-end mt-3 mt-md-0">
                    <div class="mb-1">
                        <a href="#" style="color:#687268;" class="me-3 text-decoration-none">
                            <i class="fab fa-facebook"></i>
                        </a>
                        <a href="#" style="color:#687268;" class="me-3 text-decoration-none">
                            <i class="fab fa-instagram"></i>
                        </a>
                        <a href="#" style="color:#687268;" class="text-decoration-none">
                            <i class="fab fa-whatsapp"></i>
                        </a>
                    </div>
                    <p class="mb-0">
                        <small style="color:#687268;opacity:.65;">
                            © @DateTime.Now.Year Agent Tools · Todos os direitos reservados
                        </small>
                    </p>
                </div>
            </div>
        </div>
    </footer>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Multi-photo upload component -->
    <script src="~/js/multi-photo.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
</div><!-- /.app-shell -->
</body>
</html>
@model SistemaUsuarios.Models.ViewModels.UsuarioViewModel
@using SistemaUsuarios.Models
@{
    ViewData["Title"] = "Configurações";

    var iniciais = string.Join("", (Model.Nome ?? "?").Split(' ', StringSplitOptions.RemoveEmptyEntries)
        .Take(2).Select(p => char.ToUpper(p[0]).ToString()));

    var statusLabel = Model.Status switch {
        StatusUsuario.Ativo     => ("Ativo",     "success"),
        StatusUsuario.Inativo   => ("Inativo",   "secondary"),
        StatusUsuario.Bloqueado => ("Bloqueado", "danger"),
        _                       => ("Novo",      "warning")
    };

    var erraSenha     = TempData["ErraSenha"]         as string;
    var sucessoSenha  = TempData["SucessoSenha"]      as string;
    var erroIdent     = TempData["ErroIdentidade"]    as string;
    var sucessoIdent  = TempData["SucessoIdentidade"] as string;

    var corP = Model.CorPrimaria   ?? "#0A1128";
    var corS = Model.CorSecundaria ?? "#65a3d4";
    var corD = Model.CorDestaque   ?? "#2ec4b6";
}

@section Styles {
<style>
/* ── Header de configurações ─────────────────────────── */
.cfg-header {
    background: linear-gradient(135deg, var(--exec-primary) 0%, var(--exec-primary-light, #1a2845) 100%);
    border-radius: 14px;
    padding: 28px 32px;
    color: #fff;
    margin-bottom: 24px;
    display: flex;
    align-items: center;
    gap: 22px;
}

.cfg-avatar {
    width: 76px; height: 76px;
    border-radius: 50%;
    flex-shrink: 0;
    background: rgba(255,255,255,.18);
    border: 3px solid rgba(255,255,255,.3);
    display: flex; align-items: center; justify-content: center;
    font-size: 1.7rem; font-weight: 700; color: #fff;
    letter-spacing: .04em; overflow: hidden;
}
.cfg-avatar img { width: 100%; height: 100%; object-fit: cover; border-radius: 50%; display: block; }

.cfg-nome  { font-size: 1.3rem; font-weight: 700; margin: 0 0 3px; }
.cfg-email { font-size: .87rem; opacity: .72; margin: 0 0 10px; }

/* ── Section cards ───────────────────────────────────── */
.section-card {
    border: 1px solid #e9ecef;
    border-radius: 12px;
    padding: 24px;
    background: #fff;
    margin-bottom: 20px;
}

.section-card h6 {
    font-size: .7rem; font-weight: 700;
    text-transform: uppercase; letter-spacing: .08em;
    color: #6c757d;
    margin-bottom: 20px; padding-bottom: 10px;
    border-bottom: 1px solid #f0f0f0;
}

/* ── Foto de perfil ──────────────────────────────────── */
.foto-current {
    width: 80px; height: 80px;
    border-radius: 50%; object-fit: cover;
    border: 3px solid #e2e8f0;
}

.foto-initials {
    width: 80px; height: 80px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 1.5rem; font-weight: 700; color: #fff;
}

.foto-drop {
    border: 2px dashed #dee2e6;
    border-radius: 10px;
    padding: 24px 20px;
    text-align: center;
    cursor: pointer;
    transition: border-color .2s, background .2s;
    position: relative;
}

.foto-drop:hover { border-color: var(--exec-secondary, #65a3d4); background: rgba(101,163,212,.04); }
.foto-drop input[type=file] { position: absolute; inset: 0; opacity: 0; cursor: pointer; width: 100%; height: 100%; }

/* ── Seletor de cores ────────────────────────────────── */
.color-item { display: flex; flex-direction: column; gap: 6px; }
.color-label { font-size: .8rem; font-weight: 600; color: #374151; }
.color-desc  { font-size: .73rem; color: #94a3b8; }

.color-picker-wrap {
    display: flex; align-items: center; gap: 10px;
    background: #f8f9fa; border: 1px solid #dee2e6;
    border-radius: 8px; padding: 7px 12px;
    cursor: pointer; transition: border-color .15s;
    width: 100%;
}
.color-picker-wrap:hover { border-color: #adb5bd; }

.color-swatch {
    width: 26px; height: 26px; border-radius: 5px;
    border: 2px solid rgba(0,0,0,.08); flex-shrink: 0;
}

.color-hex {
    font-size: .8rem; font-family: 'Courier New', monospace;
    color: #374151; flex: 1; text-transform: uppercase;
}

input[type="color"].hidden-picker {
    position: absolute; opacity: 0; width: 0; height: 0; pointer-events: none;
}

/* ── Preview do tema ─────────────────────────────────── */
.theme-preview {
    border-radius: 10px; overflow: hidden;
    border: 1px solid #e2e8f0;
    box-shadow: 0 2px 8px rgba(0,0,0,.06);
}

.preview-navbar {
    height: 34px; display: flex; align-items: center;
    padding: 0 12px; gap: 8px;
}

.preview-dot { width: 5px; height: 5px; border-radius: 50%; background: rgba(255,255,255,.45); }
.preview-bar { flex: 1; height: 2px; background: rgba(255,255,255,.18); border-radius: 2px; }
.preview-avatar-nav { width: 16px; height: 16px; border-radius: 50%; background: rgba(255,255,255,.22); }

.preview-body { background: #f1f3f4; padding: 12px; display: flex; flex-direction: column; gap: 8px; }

.preview-card {
    background: #fff; border-radius: 6px;
    padding: 10px; border: 1px solid #e9ecef;
    display: flex; flex-direction: column; gap: 6px;
}

.preview-card-head { height: 7px; border-radius: 3px; width: 55%; }
.preview-card-line { height: 5px; background: #e2e8f0; border-radius: 2px; }
.preview-card-line.short { width: 40%; }

.preview-btn {
    display: inline-flex; align-items: center; gap: 4px;
    padding: 5px 10px; border-radius: 4px;
    font-size: .65rem; font-weight: 600; color: #fff;
    width: fit-content; margin-top: 2px;
}

.preview-badges { display: flex; gap: 4px; flex-wrap: wrap; }

.preview-badge {
    padding: 2px 7px; border-radius: 50px;
    font-size: .6rem; font-weight: 600;
}

/* ── Modal de recorte de foto ────────────────────────── */
.crop-canvas-wrap {
    display: flex; justify-content: center;
    background: #111; border-radius: 10px;
    overflow: hidden; touch-action: none; user-select: none;
}
#cropCanvas { display: block; cursor: grab; max-width: 100%; height: auto; }
#cropCanvas:active { cursor: grabbing; }
.crop-zoom-row {
    display: flex; align-items: center; gap: 10px; margin-top: 14px;
}
.crop-zoom-btn {
    width: 32px; height: 32px; flex-shrink: 0;
    border: 1px solid #dee2e6; background: #fff; border-radius: 6px;
    cursor: pointer; display: inline-flex; align-items: center;
    justify-content: center; font-size: .85rem; color: #495057; padding: 0;
}
.crop-zoom-btn:hover { background: #f8f9fa; border-color: #adb5bd; }
.crop-preview-row {
    display: flex; align-items: center; gap: 12px;
    margin-top: 14px; border-top: 1px solid #f0f0f0; padding-top: 14px;
}
#previewCropCanvas {
    width: 52px; height: 52px; border-radius: 50%;
    border: 2px solid #dee2e6; flex-shrink: 0; display: block;
}
.crop-preview-label { font-size: .75rem; color: #6c757d; line-height: 1.5; }

@@media (max-width: 576px) {
    .cfg-header { flex-direction: column; text-align: center; }
    .cfg-avatar { margin: 0 auto; }
}
</style>
}

<div class="at-page">

    @if (TempData["Sucesso"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show mb-3 rounded-3" role="alert">
            <i class="fas fa-check-circle me-2"></i>@TempData["Sucesso"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Erro"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show mb-3 rounded-3" role="alert">
            <i class="fas fa-exclamation-circle me-2"></i>@TempData["Erro"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (!string.IsNullOrEmpty(sucessoIdent))
    {
        <div class="alert alert-success alert-dismissible fade show mb-3 rounded-3" role="alert">
            <i class="fas fa-palette me-2"></i>@sucessoIdent
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (!string.IsNullOrEmpty(erroIdent))
    {
        <div class="alert alert-danger alert-dismissible fade show mb-3 rounded-3" role="alert">
            <i class="fas fa-exclamation-circle me-2"></i>@erroIdent
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- ── Header do perfil ─────────────────────────────────── -->
    <div class="cfg-header">
        <div class="cfg-avatar">
            @if (!string.IsNullOrEmpty(Model.FotoPath))
            {
                <img src="@Model.FotoPath" alt="Foto de perfil" />
            }
            else
            {
                @iniciais
            }
        </div>
        <div>
            <p class="cfg-nome">@Model.Nome</p>
            <p class="cfg-email">@Model.Email</p>
            <div class="d-flex flex-wrap gap-3 align-items-center">
                <span style="font-size:.8rem;color:rgba(255,255,255,.65);">
                    <i class="fas fa-calendar-alt me-1"></i>Membro desde @(Model.DataCriacao?.ToString("MMM/yyyy") ?? "—")
                </span>
                <span class="badge bg-@statusLabel.Item2">@statusLabel.Item1</span>
            </div>
        </div>
    </div>

    <!-- ── Dados pessoais ────────────────────────────────────── -->
    <div class="section-card">
        <h6><i class="fas fa-user me-2"></i>Dados pessoais</h6>
        <form asp-controller="Usuario" asp-action="Index" method="post">
            @Html.AntiForgeryToken()
            <input asp-for="Id" type="hidden" />
            <input asp-for="Status" type="hidden" />
            <input asp-for="DataCriacao" type="hidden" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 mb-3 small rounded-3"></div>
            <div class="row g-3">
                <div class="col-sm-6">
                    <label asp-for="Nome" class="form-label fw-semibold" style="font-size:.82rem;"></label>
                    <input asp-for="Nome" class="form-control" maxlength="100" placeholder="Nome completo" />
                    <span asp-validation-for="Nome" class="text-danger small"></span>
                </div>
                <div class="col-sm-6">
                    <label asp-for="Email" class="form-label fw-semibold" style="font-size:.82rem;"></label>
                    <input asp-for="Email" class="form-control" type="email" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>
                <div class="col-sm-6">
                    <label asp-for="Telefone" class="form-label fw-semibold" style="font-size:.82rem;"></label>
                    <input asp-for="Telefone" class="form-control" id="telefoneInput" placeholder="(11) 99999-9999" maxlength="15" />
                    <span asp-validation-for="Telefone" class="text-danger small"></span>
                </div>
                <div class="col-sm-6">
                    <label asp-for="CPF" class="form-label fw-semibold" style="font-size:.82rem;"></label>
                    <input asp-for="CPF" class="form-control" id="cpfInput" placeholder="000.000.000-00" maxlength="14" />
                    <span asp-validation-for="CPF" class="text-danger small"></span>
                </div>
            </div>
            <div class="mt-4">
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-save me-2"></i>Salvar dados
                </button>
            </div>
        </form>
    </div>

    <!-- ── Foto de perfil ────────────────────────────────────── -->
    <div class="section-card">
        <h6><i class="fas fa-camera me-2"></i>Foto de perfil</h6>
        <div class="d-flex align-items-start gap-4 flex-wrap">
            <div class="text-center" style="flex-shrink:0;">
                @if (!string.IsNullOrEmpty(Model.FotoPath))
                {
                    <img src="@Model.FotoPath" alt="Foto atual" class="foto-current" />
                }
                else
                {
                    <div class="foto-initials" style="background:linear-gradient(135deg,@corP,@corD);">@iniciais</div>
                }
                <div class="text-muted mt-1" style="font-size:.73rem;">Foto atual</div>
            </div>
            <div class="flex-grow-1">
                <form asp-controller="Usuario" asp-action="AlterarFoto" method="post" enctype="multipart/form-data" id="formFoto">
                    @Html.AntiForgeryToken()
                    <div class="foto-drop" id="fotoDropZone">
                        <input type="file" name="foto" id="fotoInput" accept="image/*" />
                        <i class="fas fa-cloud-upload-alt" style="font-size:1.6rem;color:#adb5bd;display:block;margin-bottom:8px;"></i>
                        <div style="font-size:.88rem;font-weight:600;color:#495057;" id="fotoLabel">Clique ou arraste para alterar a foto</div>
                        <div class="text-muted mt-1" style="font-size:.77rem;">JPG, PNG, WebP · máximo 5 MB</div>
                    </div>
                    <div class="mt-3" id="fotoSubmitRow" style="display:none;">
                        <button type="submit" class="btn btn-primary btn-sm">
                            <i class="fas fa-upload me-1"></i>Salvar foto
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- ── Modal de recorte de foto ──────────────────────────── -->
    <div class="modal fade" id="cropModal" tabindex="-1" aria-labelledby="cropModalLabel"
         aria-hidden="true" data-bs-backdrop="static" data-bs-keyboard="false">
        <div class="modal-dialog modal-dialog-centered" style="max-width:380px;">
            <div class="modal-content">
                <div class="modal-header py-3">
                    <h6 class="modal-title mb-0" id="cropModalLabel">
                        <i class="fas fa-crop-alt me-2 text-primary"></i>Ajustar foto de perfil
                    </h6>
                </div>
                <div class="modal-body">
                    <div class="crop-canvas-wrap" id="cropWrap">
                        <canvas id="cropCanvas" width="320" height="320"></canvas>
                    </div>
                    <div class="crop-zoom-row">
                        <button type="button" class="crop-zoom-btn" id="zoomOutBtn" title="Reduzir">
                            <i class="fas fa-minus"></i>
                        </button>
                        <input type="range" id="zoomSlider" class="form-range" min="1" max="3" step="0.01" value="1">
                        <button type="button" class="crop-zoom-btn" id="zoomInBtn" title="Ampliar">
                            <i class="fas fa-plus"></i>
                        </button>
                    </div>
                    <div class="crop-preview-row">
                        <canvas id="previewCropCanvas" width="52" height="52"></canvas>
                        <div class="crop-preview-label">
                            <strong>Prévia do avatar</strong><br>
                            Arraste para reposicionar · use o slider para zoom
                        </div>
                    </div>
                </div>
                <div class="modal-footer py-2">
                    <button type="button" class="btn btn-outline-secondary btn-sm" id="cancelCropBtn">
                        Cancelar
                    </button>
                    <button type="button" class="btn btn-primary btn-sm" id="applyCropBtn">
                        <i class="fas fa-check me-1"></i>Aplicar recorte
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- ── Identidade visual ─────────────────────────────────── -->
    <div class="section-card">
        <h6><i class="fas fa-palette me-2"></i>Identidade visual e agência</h6>
        <p class="text-muted mb-4" style="font-size:.83rem;line-height:1.55;">
            Configure o nome da sua agência para ativar a captação pública, e personalize
            as cores da plataforma e das propostas enviadas aos clientes.
        </p>

        <form asp-controller="Usuario" asp-action="SalvarIdentidade" method="post" id="formIdentidade">
            @Html.AntiForgeryToken()

            <!-- Nome da agência -->
            <div class="mb-4 pb-4" style="border-bottom:1px solid #f0f0f0;">
                <div class="row g-3 align-items-start">
                    <div class="col-md-7">
                        <label class="color-label mb-1" for="nomeAgenciaInput">Nome da agência</label>
                        <div class="color-desc mb-2">Esse nome será exibido na sua página pública de captação de leads.</div>
                        <input type="text" id="nomeAgenciaInput" name="nomeAgencia"
                               class="form-control" maxlength="150"
                               value="@(Model.NomeAgencia ?? "")"
                               placeholder="Ex: Flammarion Travel & Concierge" />
                    </div>
                    @if (!string.IsNullOrEmpty(Model.SlugAgencia))
                    {
                        <div class="col-md-5">
                            <div class="color-label mb-1">Link público da agência</div>
                            <div class="color-desc mb-2">Compartilhe com seus clientes para captar leads.</div>
                            <div class="d-flex align-items-center gap-2">
                                <a href="/@Model.SlugAgencia" target="_blank"
                                   class="btn btn-sm btn-outline-primary"
                                   style="font-size:.77rem;white-space:nowrap;">
                                    <i class="fas fa-external-link-alt me-1"></i>/@Model.SlugAgencia
                                </a>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="col-md-5">
                            <div class="color-label mb-1">Link público</div>
                            <div class="color-desc">Preencha o nome da agência e salve para gerar seu link público.</div>
                        </div>
                    }
                </div>
            </div>
            <div class="row g-4 align-items-start">

                <!-- Seletores de cor -->
                <div class="col-md-7">
                    <div class="row g-3">

                        <!-- Cor Primária -->
                        <div class="col-12">
                            <div class="color-item">
                                <div class="color-label">Cor Primária</div>
                                <div class="color-desc">Navbar, cabeçalhos, elementos de identidade principal</div>
                                <div class="color-picker-wrap" onclick="document.getElementById('pickPrimaria').click();" style="position:relative;">
                                    <div class="color-swatch" id="swatchPrimaria" style="background:@corP;"></div>
                                    <span class="color-hex" id="hexPrimaria">@corP.ToUpper()</span>
                                    <i class="fas fa-chevron-down text-muted" style="font-size:.6rem;"></i>
                                    <input type="color" id="pickPrimaria" name="corPrimaria" value="@corP" class="hidden-picker"
                                           oninput="updateColor('Primaria', this.value)" />
                                </div>
                            </div>
                        </div>

                        <!-- Cor Secundária -->
                        <div class="col-12">
                            <div class="color-item">
                                <div class="color-label">Cor Secundária</div>
                                <div class="color-desc">Apoio visual, bordas de foco, elementos complementares</div>
                                <div class="color-picker-wrap" onclick="document.getElementById('pickSecundaria').click();" style="position:relative;">
                                    <div class="color-swatch" id="swatchSecundaria" style="background:@corS;"></div>
                                    <span class="color-hex" id="hexSecundaria">@corS.ToUpper()</span>
                                    <i class="fas fa-chevron-down text-muted" style="font-size:.6rem;"></i>
                                    <input type="color" id="pickSecundaria" name="corSecundaria" value="@corS" class="hidden-picker"
                                           oninput="updateColor('Secundaria', this.value)" />
                                </div>
                            </div>
                        </div>

                        <!-- Cor de Destaque -->
                        <div class="col-12">
                            <div class="color-item">
                                <div class="color-label">Cor de Destaque</div>
                                <div class="color-desc">Botões principais, badges, CTAs, pontos de atenção</div>
                                <div class="color-picker-wrap" onclick="document.getElementById('pickDestaque').click();" style="position:relative;">
                                    <div class="color-swatch" id="swatchDestaque" style="background:@corD;"></div>
                                    <span class="color-hex" id="hexDestaque">@corD.ToUpper()</span>
                                    <i class="fas fa-chevron-down text-muted" style="font-size:.6rem;"></i>
                                    <input type="color" id="pickDestaque" name="corDestaque" value="@corD" class="hidden-picker"
                                           oninput="updateColor('Destaque', this.value)" />
                                </div>
                            </div>
                        </div>

                    </div>

                    <div class="mt-4 d-flex flex-wrap gap-2 align-items-center">
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-palette me-2"></i>Salvar identidade visual
                        </button>
                        <button type="button" class="btn btn-outline-secondary btn-sm" onclick="resetarCores()">
                            <i class="fas fa-undo me-1"></i>Restaurar padrão
                        </button>
                    </div>
                    <div class="mt-2 text-muted" style="font-size:.76rem;">
                        <i class="fas fa-info-circle me-1"></i>
                        As alterações ficam visíveis imediatamente na interface e na próxima abertura de qualquer proposta.
                    </div>
                </div>

                <!-- Preview -->
                <div class="col-md-5">
                    <div class="color-label mb-2">Pré-visualização</div>
                    <div class="theme-preview">
                        <div class="preview-navbar" id="previewNavbar" style="background:@corP;">
                            <div class="preview-dot"></div>
                            <div class="preview-dot"></div>
                            <div class="preview-bar"></div>
                            <div class="preview-dot"></div>
                            <div class="preview-avatar-nav"></div>
                        </div>
                        <div class="preview-body">
                            <div class="preview-card">
                                <div class="preview-card-head" id="previewHead" style="background:@corP;"></div>
                                <div class="preview-card-line"></div>
                                <div class="preview-card-line short"></div>
                                <div class="preview-btn" id="previewBtn" style="background:@corD;">
                                    <i class="fas fa-check" style="font-size:.55rem;"></i>Salvar
                                </div>
                                <div class="preview-badges mt-1">
                                    <span class="preview-badge text-white" id="previewBadge1" style="background:@corP;">Primária</span>
                                    <span class="preview-badge text-white" id="previewBadge2" style="background:@corS;">Secundária</span>
                                    <span class="preview-badge text-white" id="previewBadge3" style="background:@corD;">Destaque</span>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="mt-2 text-center text-muted" style="font-size:.71rem;">
                        <i class="fas fa-eye me-1"></i>Muda em tempo real conforme você ajusta as cores
                    </div>
                </div>

            </div>
        </form>
    </div>

    <!-- ── Alterar senha ─────────────────────────────────────── -->
    <div class="section-card">
        <h6><i class="fas fa-lock me-2"></i>Alterar senha</h6>
        @if (!string.IsNullOrEmpty(erraSenha))
        {
            <div class="alert alert-danger py-2 mb-3 small rounded-3">
                <i class="fas fa-exclamation-circle me-1"></i>@erraSenha
            </div>
        }
        @if (!string.IsNullOrEmpty(sucessoSenha))
        {
            <div class="alert alert-success py-2 mb-3 small rounded-3">
                <i class="fas fa-check-circle me-1"></i>@sucessoSenha
            </div>
        }
        <form asp-controller="Usuario" asp-action="AlterarSenha" method="post">
            @Html.AntiForgeryToken()
            <div class="row g-3">
                <div class="col-sm-4">
                    <label class="form-label fw-semibold" style="font-size:.82rem;" for="senhaAtual">Senha atual</label>
                    <input type="password" id="senhaAtual" name="senhaAtual" class="form-control"
                           placeholder="••••••" autocomplete="current-password" />
                </div>
                <div class="col-sm-4">
                    <label class="form-label fw-semibold" style="font-size:.82rem;" for="novaSenha">Nova senha</label>
                    <input type="password" id="novaSenha" name="novaSenha" class="form-control"
                           placeholder="mín. 6 caracteres" autocomplete="new-password" />
                </div>
                <div class="col-sm-4">
                    <label class="form-label fw-semibold" style="font-size:.82rem;" for="confirmarSenha">Confirmar nova senha</label>
                    <input type="password" id="confirmarSenha" name="confirmarSenha" class="form-control"
                           placeholder="repita a senha" autocomplete="new-password" />
                </div>
            </div>
            <div class="mt-4">
                <button type="submit" class="btn btn-outline-secondary">
                    <i class="fas fa-key me-2"></i>Alterar senha
                </button>
            </div>
        </form>
    </div>

</div>

@section Scripts {
<script>
(function () {
    // Máscara de telefone
    var tel = document.getElementById('telefoneInput');
    if (tel) {
        tel.addEventListener('input', function () {
            var v = this.value.replace(/\D/g, '').slice(0, 11);
            if (v.length > 6)
                this.value = '(' + v.slice(0,2) + ') ' + v.slice(2, v.length > 10 ? 7 : 6) + '-' + v.slice(v.length > 10 ? 7 : 6);
            else if (v.length > 2)
                this.value = '(' + v.slice(0,2) + ') ' + v.slice(2);
            else if (v.length > 0)
                this.value = '(' + v;
        });
    }

    // Máscara de CPF
    var cpf = document.getElementById('cpfInput');
    if (cpf) {
        cpf.addEventListener('input', function () {
            var v = this.value.replace(/\D/g, '').slice(0, 11);
            if (v.length > 9)
                this.value = v.slice(0,3) + '.' + v.slice(3,6) + '.' + v.slice(6,9) + '-' + v.slice(9);
            else if (v.length > 6)
                this.value = v.slice(0,3) + '.' + v.slice(3,6) + '.' + v.slice(6);
            else if (v.length > 3)
                this.value = v.slice(0,3) + '.' + v.slice(3);
            else
                this.value = v;
        });
    }

    // ── Editor de recorte de foto ────────────────────────────
    (function () {
        var fotoInput   = document.getElementById('fotoInput');
        var fotoLabel   = document.getElementById('fotoLabel');
        var formFoto    = document.getElementById('formFoto');
        var cropCanvas  = document.getElementById('cropCanvas');
        var prevCanvas  = document.getElementById('previewCropCanvas');
        if (!fotoInput || !cropCanvas) return;

        var ctx         = cropCanvas.getContext('2d');
        var prevCtx     = prevCanvas.getContext('2d');
        var CANVAS_SIZE = 320;
        var OUTPUT_SIZE = 400;

        var img, scale, offsetX, offsetY;
        var isDragging  = false;
        var lastClientX, lastClientY;
        var touchStartDist, touchStartScale;
        var baseScale;

        // ── Inicializar estado ──────────────────────────────
        function initState() {
            baseScale = CANVAS_SIZE / Math.min(img.naturalWidth, img.naturalHeight);
            scale     = baseScale;
            offsetX   = (CANVAS_SIZE - img.naturalWidth  * scale) / 2;
            offsetY   = (CANVAS_SIZE - img.naturalHeight * scale) / 2;
            document.getElementById('zoomSlider').value = 1;
        }

        // ── Clamp: imagem sempre cobre o círculo ───────────
        function clamp() {
            var iw = img.naturalWidth  * scale;
            var ih = img.naturalHeight * scale;
            var r  = CANVAS_SIZE / 2 - 8;
            var cx = CANVAS_SIZE / 2;
            var cy = CANVAS_SIZE / 2;
            if (offsetX > cx - r)      offsetX = cx - r;
            if (offsetX + iw < cx + r) offsetX = cx + r - iw;
            if (offsetY > cy - r)      offsetY = cy - r;
            if (offsetY + ih < cy + r) offsetY = cy + r - ih;
        }

        // ── Desenhar canvas de crop ─────────────────────────
        function draw() {
            var r  = CANVAS_SIZE / 2 - 8;
            var cx = CANVAS_SIZE / 2;
            var cy = CANVAS_SIZE / 2;

            ctx.clearRect(0, 0, CANVAS_SIZE, CANVAS_SIZE);
            ctx.fillStyle = '#1a1a1a';
            ctx.fillRect(0, 0, CANVAS_SIZE, CANVAS_SIZE);
            ctx.drawImage(img, offsetX, offsetY, img.naturalWidth * scale, img.naturalHeight * scale);

            // Overlay fora do círculo
            ctx.save();
            ctx.beginPath();
            ctx.rect(0, 0, CANVAS_SIZE, CANVAS_SIZE);
            ctx.arc(cx, cy, r, 0, Math.PI * 2, true);
            ctx.closePath();
            ctx.fillStyle = 'rgba(0,0,0,0.52)';
            ctx.fill();
            ctx.restore();

            // Borda do círculo
            ctx.beginPath();
            ctx.arc(cx, cy, r, 0, Math.PI * 2);
            ctx.strokeStyle = 'rgba(255,255,255,.65)';
            ctx.lineWidth = 2;
            ctx.stroke();

            updatePreview();
        }

        // ── Preview circular pequeno ────────────────────────
        function updatePreview() {
            var ps = 52;
            var r  = CANVAS_SIZE / 2 - 8;
            var cx = CANVAS_SIZE / 2;
            var cy = CANVAS_SIZE / 2;
            prevCtx.clearRect(0, 0, ps, ps);
            prevCtx.save();
            prevCtx.beginPath();
            prevCtx.arc(ps / 2, ps / 2, ps / 2, 0, Math.PI * 2);
            prevCtx.clip();
            prevCtx.drawImage(cropCanvas, cx - r, cy - r, r * 2, r * 2, 0, 0, ps, ps);
            prevCtx.restore();
        }

        // ── Aplicar zoom mantendo centro ───────────────────
        function applyZoom(newScale) {
            var prevW = img.naturalWidth  * scale;
            var prevH = img.naturalHeight * scale;
            scale = Math.max(baseScale, Math.min(baseScale * 3, newScale));
            offsetX += (prevW - img.naturalWidth  * scale) / 2;
            offsetY += (prevH - img.naturalHeight * scale) / 2;
            clamp();
            draw();
            document.getElementById('zoomSlider').value = (scale / baseScale).toFixed(2);
        }

        // ── Abrir modal ─────────────────────────────────────
        function openCrop(file) {
            var reader = new FileReader();
            reader.onload = function (e) {
                img = new Image();
                img.onload = function () {
                    initState();
                    draw();
                    new bootstrap.Modal(document.getElementById('cropModal')).show();
                };
                img.src = e.target.result;
            };
            reader.readAsDataURL(file);
        }

        // ── Drag — mouse ────────────────────────────────────
        cropCanvas.addEventListener('mousedown', function (e) {
            isDragging = true; lastClientX = e.clientX; lastClientY = e.clientY;
            e.preventDefault();
        });
        document.addEventListener('mousemove', function (e) {
            if (!isDragging || !img) return;
            var rect  = cropCanvas.getBoundingClientRect();
            var ratio = cropCanvas.width / rect.width;
            offsetX  += (e.clientX - lastClientX) * ratio;
            offsetY  += (e.clientY - lastClientY) * ratio;
            lastClientX = e.clientX; lastClientY = e.clientY;
            clamp(); draw();
        });
        document.addEventListener('mouseup', function () { isDragging = false; });

        // ── Drag + pinch — touch ────────────────────────────
        cropCanvas.addEventListener('touchstart', function (e) {
            if (e.touches.length === 1) {
                isDragging = true;
                lastClientX = e.touches[0].clientX;
                lastClientY = e.touches[0].clientY;
            } else if (e.touches.length === 2) {
                isDragging = false;
                touchStartDist  = Math.hypot(e.touches[1].clientX - e.touches[0].clientX,
                                             e.touches[1].clientY - e.touches[0].clientY);
                touchStartScale = scale;
            }
            e.preventDefault();
        }, { passive: false });

        cropCanvas.addEventListener('touchmove', function (e) {
            if (!img) return;
            if (e.touches.length === 1 && isDragging) {
                var rect  = cropCanvas.getBoundingClientRect();
                var ratio = cropCanvas.width / rect.width;
                offsetX  += (e.touches[0].clientX - lastClientX) * ratio;
                offsetY  += (e.touches[0].clientY - lastClientY) * ratio;
                lastClientX = e.touches[0].clientX;
                lastClientY = e.touches[0].clientY;
                clamp(); draw();
            } else if (e.touches.length === 2) {
                var dist  = Math.hypot(e.touches[1].clientX - e.touches[0].clientX,
                                       e.touches[1].clientY - e.touches[0].clientY);
                applyZoom(touchStartScale * (dist / touchStartDist));
            }
            e.preventDefault();
        }, { passive: false });

        cropCanvas.addEventListener('touchend', function () { isDragging = false; });

        // ── Zoom — slider ───────────────────────────────────
        document.getElementById('zoomSlider').addEventListener('input', function () {
            if (!img) return;
            applyZoom(parseFloat(this.value) * baseScale);
        });

        // ── Zoom — botões ───────────────────────────────────
        document.getElementById('zoomOutBtn').addEventListener('click', function () {
            if (!img) return;
            applyZoom(scale - baseScale * 0.1);
        });
        document.getElementById('zoomInBtn').addEventListener('click', function () {
            if (!img) return;
            applyZoom(scale + baseScale * 0.1);
        });

        // ── Cancelar ────────────────────────────────────────
        document.getElementById('cancelCropBtn').addEventListener('click', function () {
            bootstrap.Modal.getInstance(document.getElementById('cropModal')).hide();
            fotoInput.value = '';
            fotoLabel.textContent = 'Clique ou arraste para alterar a foto';
            fotoLabel.style.color = '';
            fotoLabel.style.fontWeight = '';
        });

        // ── Aplicar recorte e enviar ────────────────────────
        document.getElementById('applyCropBtn').addEventListener('click', function () {
            var btn = this;
            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Salvando...';

            var r   = CANVAS_SIZE / 2 - 8;
            var cx  = CANVAS_SIZE / 2;
            var cy  = CANVAS_SIZE / 2;
            var off = document.createElement('canvas');
            off.width = off.height = OUTPUT_SIZE;
            var offCtx = off.getContext('2d');
            offCtx.fillStyle = '#ffffff';
            offCtx.fillRect(0, 0, OUTPUT_SIZE, OUTPUT_SIZE);
            offCtx.drawImage(cropCanvas, cx - r, cy - r, r * 2, r * 2, 0, 0, OUTPUT_SIZE, OUTPUT_SIZE);

            off.toBlob(function (blob) {
                if (!blob) {
                    btn.disabled = false;
                    btn.innerHTML = '<i class="fas fa-check me-1"></i>Aplicar recorte';
                    return;
                }
                bootstrap.Modal.getInstance(document.getElementById('cropModal')).hide();
                try {
                    var dt = new DataTransfer();
                    dt.items.add(new File([blob], 'foto-perfil.jpg', { type: 'image/jpeg' }));
                    fotoInput.files = dt.files;
                    formFoto.submit();
                } catch (_) {
                    var fd = new FormData(formFoto);
                    fd.set('foto', blob, 'foto-perfil.jpg');
                    fetch(formFoto.action, { method: 'POST', body: fd })
                        .then(function () { window.location.href = '/Usuario'; })
                        .catch(function () { window.location.href = '/Usuario'; });
                }
            }, 'image/jpeg', 0.92);
        });

        // ── Selecionar arquivo → abrir crop ─────────────────
        fotoInput.addEventListener('change', function () {
            if (!this.files || !this.files[0]) return;
            var file = this.files[0];
            if (file.size > 5 * 1024 * 1024) {
                alert('Arquivo muito grande. Máximo 5 MB.');
                this.value = ''; return;
            }
            if (!file.type.startsWith('image/')) {
                alert('Selecione apenas imagens (JPG, PNG, WebP).');
                this.value = ''; return;
            }
            fotoLabel.textContent = file.name;
            fotoLabel.style.color = 'var(--exec-primary, #0A1128)';
            fotoLabel.style.fontWeight = '600';
            openCrop(file);
        });
    })();
})();

// ── Helpers de cor ────────────────────────────────────────
function lightenHex(hex, amount) {
    if (!hex || hex.length !== 7) return hex;
    var r = Math.min(255, parseInt(hex.slice(1, 3), 16) + amount);
    var g = Math.min(255, parseInt(hex.slice(3, 5), 16) + amount);
    var b = Math.min(255, parseInt(hex.slice(5, 7), 16) + amount);
    return '#' + [r, g, b].map(function(v) { return Math.max(0,v).toString(16).padStart(2, '0'); }).join('');
}

// ── Atualizar preview e CSS vars em tempo real ────────────
function updateColor(tipo, value) {
    document.getElementById('swatch' + tipo).style.background = value;
    document.getElementById('hex' + tipo).textContent = value.toUpperCase();

    var p = document.getElementById('pickPrimaria').value;
    var s = document.getElementById('pickSecundaria').value;
    var d = document.getElementById('pickDestaque').value;

    // Atualiza preview visual
    document.getElementById('previewNavbar').style.background = p;
    document.getElementById('previewHead').style.background   = p;
    document.getElementById('previewBtn').style.background    = d;
    document.getElementById('previewBadge1').style.background = p;
    document.getElementById('previewBadge2').style.background = s;
    document.getElementById('previewBadge3').style.background = d;

    // Aplica CSS vars globais (live preview de toda a interface)
    var pLight = lightenHex(p, 28);
    var dDark  = lightenHex(d, -18);
    var root   = document.documentElement;
    root.style.setProperty('--exec-primary',          p);
    root.style.setProperty('--exec-primary-light',    pLight);
    root.style.setProperty('--exec-secondary',        s);
    root.style.setProperty('--exec-accent',           d);
    root.style.setProperty('--exec-gradient-primary', 'linear-gradient(135deg, ' + p + ' 0%, ' + pLight + ' 100%)');
    root.style.setProperty('--exec-gradient-accent',  'linear-gradient(135deg, ' + d + ' 0%, ' + dDark  + ' 100%)');
}

function resetarCores() {
    var def = { p: '#0A1128', s: '#65a3d4', d: '#2ec4b6' };
    document.getElementById('pickPrimaria').value   = def.p;
    document.getElementById('pickSecundaria').value = def.s;
    document.getElementById('pickDestaque').value   = def.d;
    updateColor('Primaria',   def.p);
    updateColor('Secundaria', def.s);
    updateColor('Destaque',   def.d);
}
</script>
}

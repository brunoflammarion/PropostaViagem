        <div class="bar-row"><span class="bar-l">Seguro Viagem</span><div class="bar-t"><div class="bar-f" data-w="38%"></div></div><span class="bar-p">2.4 ★</span></div>
      </div>
    </div>
  </div>
</section>

<section class="sec light" id="interativo" aria-labelledby="eng-h2">
  <div class="c">
    <div class="sec-header" data-a>
      <p class="ey">Proposta interativa</p>

                                    <select name="PropostasMes" class="form-select">
                                        <option value="">Selecione</option>
                                        <option>Até 10</option>
                                        <option>11 a 30</option>
                                        <option>31 a 100</option>
                                        <option>Mais de 100</option>
                                    </select>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">Plano de interesse</label>
                                    <select name="PlanoInteresse" class="form-select">
                                        <option value="">Selecione</option>
                                        <option>Individual mensal</option>
                                        <option>Individual anual</option>
                                        <option>Equipe mensal</option>
                                        <option>Equipe anual</option>
                                        <option>Ainda não sei</option>
                                    </select>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">Principal desafio hoje</label>
                                    <select name="DesafioAtual" class="form-select">
                                        <option value="">Selecione</option>
                                        <option>Demora para montar proposta</option>
                                        <option>Falta de padrão visual</option>
                                        <option>Organização de clientes</option>
                                        <option>Uso de IA</option>
                                        <option>Apresentação pouco profissional</option>
                                        <option>Outro</option>
                                    </select>
                                </div>

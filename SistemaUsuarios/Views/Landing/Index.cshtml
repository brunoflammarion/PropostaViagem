@section Scripts {
<script>
    // ── Navbar scroll ──────────────────────────────────────────
    const lpNav = document.getElementById('lpNav');
    window.addEventListener('scroll', () => {
        lpNav.classList.toggle('scrolled', window.scrollY > 50);
    });

    // ── Hamburger mobile ───────────────────────────────────────
    document.getElementById('hamburger').addEventListener('click', () => {
        document.getElementById('navLinks').classList.toggle('open');
    });
    document.getElementById('navLinks').querySelectorAll('a').forEach(a => {
        a.addEventListener('click', () => document.getElementById('navLinks').classList.remove('open'));
    });

    // ── Toggle preços ──────────────────────────────────────────
    const tog = document.getElementById('pricingToggle');
    const lblM = document.getElementById('lblMensal');
    const lblA = document.getElementById('lblAnual');
    const priceIDs = ['individual', 'equipe'];

    tog.addEventListener('change', () => {
        const anual = tog.checked;
        lblM.classList.toggle('active', !anual);
        lblA.classList.toggle('active', anual);
        priceIDs.forEach(id => {
            document.getElementById(`price-${id}-mensal`).style.display = anual ? 'none' : 'block';
            document.getElementById(`price-${id}-anual`).style.display  = anual ? 'block' : 'none';
        });
    });

    // ── Máscara de telefone ────────────────────────────────────
    document.getElementById('capTelefone').addEventListener('input', function () {
        let v = this.value.replace(/\D/g, '').slice(0, 11);
        if (v.length <= 10)       v = v.replace(/(\d{2})(\d{4})(\d{0,4})/, '($1) $2-$3');
        else                      v = v.replace(/(\d{2})(\d{5})(\d{0,4})/, '($1) $2-$3');
        this.value = v;
    });

    // ── Envio do formulário ────────────────────────────────────
    document.getElementById('captureForm').addEventListener('submit', async function (e) {
        e.preventDefault();

        const form    = this;
        const btn     = document.getElementById('btnCapture');
        const origTxt = btn.innerHTML;

        // Validação básica HTML5
        if (!form.checkValidity()) {
            form.reportValidity();
            return;
        }

        btn.disabled = true;
        btn.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>Enviando...';

        const formData = new FormData(form);

        try {
            const res  = await fetch('@Url.Action("Cadastro", "Landing")', { method: 'POST', body: formData });
            const data = await res.json();

            if (data.success) {
                document.getElementById('captureFormWrap').style.display = 'none';
                document.getElementById('captureSuccess').style.display  = 'block';
                if (data.redirectUrl) {
                    setTimeout(() => { window.location.href = data.redirectUrl; }, 2500);
                }
            } else {
                alert(data.message || 'Erro ao enviar. Tente novamente.');
                btn.disabled = false;
                btn.innerHTML = origTxt;
            }
        } catch {
            alert('Erro de conexão. Verifique sua internet e tente novamente.');
            btn.disabled = false;
            btn.innerHTML = origTxt;
        }
    });
</script>
}

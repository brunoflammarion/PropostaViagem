<script>
(function () {
  var nav = document.getElementById('nav');
  window.addEventListener('scroll', function () {
    nav.classList.toggle('scrolled', window.scrollY > 40);
  }, { passive: true });
  if (window.scrollY > 40) nav.classList.add('scrolled');

  var io = new IntersectionObserver(function (entries) {
    entries.forEach(function (e) {
      if (e.isIntersecting) { e.target.classList.add('vis'); io.unobserve(e.target); }
    });
  }, { threshold: 0.12, rootMargin: '-30px' });
  document.querySelectorAll('[data-a]').forEach(function (el) { io.observe(el); });

  var barObserver = new IntersectionObserver(function (entries) {
    entries.forEach(function (e) {
      if (e.isIntersecting) {
        e.target.querySelectorAll('.bar-f').forEach(function (bar) {
          var w = bar.getAttribute('data-w');
          if (w) setTimeout(function () { bar.style.width = w; }, 100);
        });
        barObserver.unobserve(e.target);
      }
    });
  }, { threshold: 0.3 });
  var anMock = document.querySelector('.an-mock');
  if (anMock) barObserver.observe(anMock);

  var form = document.getElementById('vip-form');
  var formBox = document.getElementById('form-box');
  var success = document.getElementById('form-success');
  var submitBtn = document.getElementById('f-submit');

  if (form) {
    form.addEventListener('submit', function (e) {
      var nome = document.getElementById('f-nome').value.trim();
      var email = document.getElementById('f-email').value.trim();
      var wpp = document.getElementById('f-wpp').value.trim();
      var agencia = document.getElementById('f-agencia').value.trim();
      var propostas = document.getElementById('f-propostas').value;
      if (!nome || !email || !wpp || !agencia || !propostas) {
        var first = form.querySelector('input:invalid, select:invalid');
        if (first) { first.focus(); first.style.borderColor = 'rgba(239,68,68,.7)'; }
        e.preventDefault();
        return;
      }
      submitBtn.disabled = true;
      submitBtn.textContent = 'Enviando...';
    });
    form.querySelectorAll('input, select').forEach(function (el) {
      el.addEventListener('input', function () { el.style.borderColor = ''; });
    });
  }

  // Sucesso via TempData
  @if (TempData["ListaVipSucesso"] != null) {
    <text>
    document.getElementById('form-box').classList.add('hidden');
    document.getElementById('form-success').classList.add('vis');
    </text>
  }

  document.querySelectorAll('a[href^="#"]').forEach(function (a) {
    a.addEventListener('click', function (e) {
      var target = document.querySelector(a.getAttribute('href'));
      if (target) {
        e.preventDefault();
        window.scrollTo({ top: target.getBoundingClientRect().top + window.scrollY - 72, behavior: 'smooth' });
      }
    });
  });
}());
</script>
</body>
</html>

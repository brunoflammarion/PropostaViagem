<!--  10. FORMULÁRIO DE CAPTURA                                   -->
<!-- ╚══════════════════════════════════════════════════════════╝ -->
<section class="lp-section lp-section-alt" id="acesso">
    <div class="container">
        <div class="row align-items-center g-5">
            <div class="col-lg-5" data-aos="fade-right">
                <div class="section-eyebrow">Acesso antecipado</div>
                <h2 class="section-title">Solicite seu acesso ao Agent tools</h2>
                <p class="section-lead">Preencha seus dados para começar o teste gratuito ou entrar na lista de acesso antecipado.</p>
                <div class="mt-4 d-flex flex-column gap-3">
                    <div class="d-flex align-items-center gap-2" style="font-size:0.9rem">
                        <i class="fas fa-check-circle text-success"></i>
                        <span>29 dias de teste gratuito, sem cartão</span>
                    </div>
                    <div class="d-flex align-items-center gap-2" style="font-size:0.9rem">
                        <i class="fas fa-check-circle text-success"></i>
                        <span>Acesso imediato após o cadastro</span>
                    </div>
                    <div class="d-flex align-items-center gap-2" style="font-size:0.9rem">
                        <i class="fas fa-check-circle text-success"></i>
                        <span>Cancelamento simples, sem burocracia</span>
                    </div>
                </div>
            </div>
            <div class="col-lg-6 offset-lg-1" data-aos="fade-left">
                <div class="capture-form">
                    <!-- Formulário -->
                    <div id="captureFormWrap">
                        <form id="captureForm" novalidate>
                            @Html.AntiForgeryToken()
                            <div class="row g-3">
                                <div class="col-12">
                                    <label class="form-label">Nome completo <span class="text-danger">*</span></label>
                                    <input type="text" name="Nome" class="form-control" placeholder="Seu nome" required minlength="2" />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">E-mail <span class="text-danger">*</span></label>
                                    <input type="email" name="Email" class="form-control" placeholder="seu@email.com" required />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">WhatsApp <span class="text-danger">*</span></label>
                                    <input type="tel" name="Telefone" id="capTelefone" class="form-control" placeholder="(11) 99999-9999" required />
                                </div>
                                <div class="col-12">
                                    <label class="form-label">Nome da agência</label>
                                    <input type="text" name="NomeAgencia" class="form-control" placeholder="Nome da sua agência (opcional)" />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">Tipo de atuação <span class="text-danger">*</span></label>
                                    <select name="TipoAgente" class="form-select" required>
                                        <option value="" disabled selected>Selecione</option>
                                        <option>Consultor independente</option>
                                        <option>Agência pequena</option>
                                        <option>Agência com equipe</option>
                                        <option>Outro</option>
                                    </select>
                                </div>
                                <div class="col-md-6">

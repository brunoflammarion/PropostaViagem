                                    <button type="submit" class="btn-capture" id="btnCapture">
                                        <i class="fas fa-rocket me-2"></i>Começar meu teste grátis
                                    </button>
                                    <p class="text-center text-muted mt-2" style="font-size:0.78rem">Sem cartão de crédito · 29 dias grátis · Cancele quando quiser</p>
                                </div>
                            </div>
                        </form>
                    </div>
                    <!-- Mensagem de sucesso -->
                    <div class="capture-success" id="captureSuccess">
                        <i class="fas fa-check-circle"></i>
                        <h4 class="fw-700 mb-2">Recebemos seu interesse!</h4>
                        <p class="text-muted">Em breve você receberá as próximas instruções para acessar o Agent tools.</p>
                    </div>
                </div>
            </div>
        </div>

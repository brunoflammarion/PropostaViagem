<!--  11. FAQ                                                     -->
<!-- ╚══════════════════════════════════════════════════════════╝ -->
<section class="lp-section" id="faq">
    <div class="container">
        <div class="text-center mb-5" data-aos="fade-up">
            <div class="section-eyebrow">Dúvidas frequentes</div>
            <h2 class="section-title">Perguntas frequentes</h2>
        </div>
        <div class="row justify-content-center">
            <div class="col-lg-8" data-aos="fade-up">
                <div class="accordion" id="faqAccordion">
                    @{
                        var faqs = new[] {
                            new { Q = "O teste grátis dura quanto tempo?", A = "O teste gratuito dura 29 dias, para você validar a criação de propostas, organização dos clientes e experiência digital do cliente final. Sem compromisso." },
                            new { Q = "O Agent tools substitui meu atendimento consultivo?", A = "Não. Ele ajuda a organizar, acelerar e valorizar seu atendimento. A consultoria continua sendo sua; a plataforma melhora a forma como ela é apresentada ao cliente." },
                            new { Q = "Consigo personalizar a proposta com a identidade da minha agência?", A = "Sim. A proposta pode usar cores, estilo e elementos visuais alinhados à sua marca." },
                            new { Q = "A plataforma usa IA?", A = "Sim. A IA apoia a criação de descrições, dicas de destino, gastronomia, atrações, informações práticas, cuidados e sugestões para enriquecer a proposta." },
                            new { Q = "O cliente precisa instalar algo?", A = "Não. O cliente acessa a proposta por link, com uma experiência digital simples e elegante, diretamente no navegador." },
                            new { Q = "Qual a diferença entre o plano Individual e o plano Equipe?", A = "O plano Individual é ideal para quem trabalha sozinho. O plano Equipe é indicado para agências com 2 a 5 usuários que precisam de organização compartilhada, padronização visual e gestão das propostas em equipe." },
                            new { Q = "Posso cancelar depois?", A = "Sim. A proposta da plataforma é ser simples e flexível. O cancelamento será tratado de forma direta, sem burocracia." },
                            new { Q = "Os valores já são definitivos?", A = "Os valores apresentados são condições iniciais de lançamento e podem mudar para novos clientes no futuro. Quem aderir agora garante as condições de lançamento." },
                        };
                    }
                    @for (int i = 0; i < faqs.Length; i++)
                    {
                        var faq = faqs[i];
                        <div class="faq-item accordion-item">
                            <h3 class="accordion-header">
                                <button class="accordion-button @(i > 0 ? "collapsed" : "")" type="button"
                                        data-bs-toggle="collapse" data-bs-target="#faq@(i)">
                                    @faq.Q
                                </button>
                            </h3>
                            <div id="faq@(i)" class="accordion-collapse collapse @(i == 0 ? "show" : "")" data-bs-parent="#faqAccordion">
                                <div class="accordion-body">@faq.A</div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</section>


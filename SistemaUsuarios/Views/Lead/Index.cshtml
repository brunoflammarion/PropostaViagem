@model List<SistemaUsuarios.Models.Lead>
@using SistemaUsuarios.Models
@{
    ViewData["Title"] = "Leads";
    int totalLeads = (int)(ViewBag.TotalLeads ?? 0);
    int leadsNovos = (int)(ViewBag.LeadsNovos ?? 0);
}

@section Styles {
<link rel="stylesheet" href="~/css/captacao.css" asp-append-version="true" />
}

<!-- ═══ HEADER ═══════════════════════════════════════════════════ -->
<div class="executive-header">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
        <div>
            <h2 class="exec-title"><i class="fas fa-user-plus me-2"></i>Leads</h2>
            <span class="exec-subtitle">@totalLeads lead(s) recebido(s) &bull; @leadsNovos novo(s)</span>
        </div>
        <a href="/Lead/Captacao" class="btn btn-primary exec-btn-create">
            <i class="fas fa-cog me-1"></i>Configurar Captação
        </a>
    </div>
</div>

<!-- ═══ ABAS ══════════════════════════════════════════════════════ -->
<div class="capture-tabs">
    <a href="/Lead" class="capture-tab active">
        <i class="fas fa-table me-1"></i>Leads
    </a>
    <a href="/Lead/Captacao" class="capture-tab">
        <i class="fas fa-bullseye me-1"></i>Captação
    </a>
</div>

@if (TempData["Sucesso"] != null)
{
    <div class="alert alert-success alert-dismissible fade show mb-3 rounded-3">
        <i class="fas fa-check-circle me-2"></i>@TempData["Sucesso"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- ═══ TABELA DE LEADS ══════════════════════════════════════════ -->
@if (!Model.Any())
{
    <div class="capture-empty-state">
        <div class="capture-empty-icon"><i class="fas fa-inbox"></i></div>
        <h5>Nenhum lead recebido ainda</h5>
        <p>Quando viajantes preencherem seu formulário público, os contatos aparecerão aqui.</p>
        <a href="/Lead/Captacao" class="btn btn-primary">
            <i class="fas fa-bullseye me-2"></i>Configurar captação pública
        </a>
    </div>
}
else
{
    <div class="card border-0 shadow-sm rounded-3 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="capture-table-head">
                    <tr>
                        <th style="width:200px;">Nome</th>
                        <th>WhatsApp</th>
                        <th>Destino</th>
                        <th>Data</th>
                        <th>Status</th>
                        <th style="width:100px;"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var lead in Model)
                    {
                        var (statusLabel, statusCss) = lead.Status switch
                        {
                            LeadStatus.Novo          => ("Novo",          "badge-novo"),
                            LeadStatus.Contatado     => ("Contatado",     "badge-contatado"),
                            LeadStatus.EmNegociacao  => ("Em negociação", "badge-negociacao"),
                            LeadStatus.Convertido    => ("Convertido",    "badge-convertido"),
                            LeadStatus.Perdido       => ("Perdido",       "badge-perdido"),
                            _                        => ("Novo",          "badge-novo"),
                        };
                        <tr>
                            <td>
                                <div class="lead-nome">@lead.FullName</div>
                                @if (!string.IsNullOrEmpty(lead.Email))
                                {
                                    <div class="lead-email">@lead.Email</div>
                                }
                            </td>
                            <td>
                                <a href="https://wa.me/@(lead.WhatsApp.Replace(" ","").Replace("-","").Replace("(","").Replace(")",""))"
                                   target="_blank" class="lead-whatsapp">
                                    <i class="fab fa-whatsapp me-1"></i>@lead.WhatsApp
                                </a>
                            </td>
                            <td>
                                <span class="lead-destino">@lead.Destination</span>
                                @if (!string.IsNullOrEmpty(lead.TravelDates))
                                {
                                    <div class="lead-detalhe"><i class="fas fa-calendar-alt me-1"></i>@lead.TravelDates</div>
                                }
                            </td>
                            <td class="text-muted" style="font-size:.8rem;white-space:nowrap;">
                                @lead.CreatedAt.ToString("dd/MM/yyyy HH:mm")
                            </td>
                            <td>
                                <span class="lead-badge @statusCss">@statusLabel</span>
                            </td>
                            <td>
                                <div class="dropdown">
                                    <button class="btn btn-sm btn-outline-secondary dropdown-toggle" data-bs-toggle="dropdown">
                                        <i class="fas fa-ellipsis-h"></i>
                                    </button>
                                    <ul class="dropdown-menu dropdown-menu-end">
                                        @foreach (var s in (LeadStatus[])Enum.GetValues(typeof(LeadStatus)))
                                        {
                                            if (s != lead.Status)
                                            {
                                                var label = s switch
                                                {
                                                    LeadStatus.Novo         => "Marcar como Novo",
                                                    LeadStatus.Contatado    => "Marcar como Contatado",
                                                    LeadStatus.EmNegociacao => "Em negociação",
                                                    LeadStatus.Convertido   => "Convertido",
                                                    LeadStatus.Perdido      => "Perdido",
                                                    _                       => s.ToString()
                                                };
                                                <li>
                                                    <form asp-controller="Lead" asp-action="AlterarStatus" method="post" class="d-inline">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="id" value="@lead.Id" />
                                                        <input type="hidden" name="status" value="@((int)s)" />
                                                        <button type="submit" class="dropdown-item">@label</button>
                                                    </form>
                                                </li>
                                            }
                                        }
                                    </ul>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@model List<SistemaUsuarios.Models.Lead>
@using SistemaUsuarios.Models
@{
    ViewData["Title"] = "Leads";
    int totalLeads = (int)(ViewBag.TotalLeads ?? 0);
    int leadsNovos = (int)(ViewBag.LeadsNovos ?? 0);
}

@section Styles {
<link rel="stylesheet" href="~/css/captacao.css" asp-append-version="true" />
}

@Html.AntiForgeryToken()

<!-- ═══ HEADER ═══════════════════════════════════════════════════ -->
<div class="executive-header">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
        <div>
            <h2 class="exec-title"><i class="fas fa-user-plus me-2"></i>Leads</h2>
            <span class="exec-subtitle">@totalLeads lead(s) recebido(s) &bull; @leadsNovos novo(s)</span>
        </div>
        <a href="/Lead/Captacao" class="btn btn-primary exec-btn-create">
            <i class="fas fa-cog me-1"></i>Configurar Captação
        </a>
    </div>
</div>

<!-- ═══ ABAS ══════════════════════════════════════════════════════ -->
<div class="capture-tabs">
    <a href="/Lead" class="capture-tab active">
        <i class="fas fa-table me-1"></i>Leads
    </a>
    <a href="/Lead/Captacao" class="capture-tab">
        <i class="fas fa-bullseye me-1"></i>Captação
    </a>
</div>

@if (TempData["Sucesso"] != null)
{
    <div class="alert alert-success alert-dismissible fade show mb-3 rounded-3">
        <i class="fas fa-check-circle me-2"></i>@TempData["Sucesso"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- ═══ TABELA DE LEADS ══════════════════════════════════════════ -->
@if (!Model.Any())
{
    <div class="capture-empty-state">
        <div class="capture-empty-icon"><i class="fas fa-inbox"></i></div>
        <h5>Nenhum lead recebido ainda</h5>
        <p>Quando viajantes preencherem seu formulário público, os contatos aparecerão aqui.</p>
        <a href="/Lead/Captacao" class="btn btn-primary">
            <i class="fas fa-bullseye me-2"></i>Configurar captação pública
        </a>
    </div>
}
else
{
    <div id="leadsTableCard" class="card border-0 shadow-sm rounded-3">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="capture-table-head">
                    <tr>
                        <th>Nome</th>
                        <th>WhatsApp</th>
                        <th>Destino</th>
                        <th style="white-space:nowrap;">Recebido em</th>
                        <th>Status</th>
                        <th style="min-width:220px;"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var lead in Model)
                    {
                        var (statusLabel, statusCss) = lead.Status switch
                        {
                            LeadStatus.Novo          => ("Novo",          "badge-novo"),
                            LeadStatus.Contatado     => ("Contatado",     "badge-contatado"),
                            LeadStatus.EmNegociacao  => ("Em negociação", "badge-negociacao"),
                            LeadStatus.Convertido    => ("Convertido",    "badge-convertido"),
                            LeadStatus.Perdido       => ("Perdido",       "badge-perdido"),
                            _                        => ("Novo",          "badge-novo"),
                        };
                        <tr>
                            <td>
                                <a href="/Lead/Detalhe/@lead.Id" class="lead-nome text-decoration-none">@lead.FullName</a>
                                @if (!string.IsNullOrEmpty(lead.Email))
                                {
                                    <div class="lead-email">@lead.Email</div>
                                }
                            </td>
                            <td>
                                <a href="https://wa.me/@(lead.WhatsApp.Replace(" ","").Replace("-","").Replace("(","").Replace(")",""))"
                                   target="_blank" class="lead-whatsapp">
                                    <i class="fab fa-whatsapp me-1"></i>@lead.WhatsApp
                                </a>
                            </td>
                            <td>
                                <span class="lead-destino">@lead.Destination</span>
                                @if (!string.IsNullOrEmpty(lead.TravelDates))
                                {
                                    <div class="lead-detalhe"><i class="fas fa-calendar-alt me-1"></i>@lead.TravelDates</div>
                                }
                            </td>
                            <td class="text-muted" style="font-size:.8rem;white-space:nowrap;">
                                @lead.CreatedAt.ToString("dd/MM/yyyy HH:mm")
                            </td>
                            <td>
                                <span class="lead-badge @statusCss">@statusLabel</span>
                            </td>
                            <td>
                                <div class="lead-actions">
                                    <a href="/Lead/Detalhe/@lead.Id"
                                       class="btn btn-sm btn-outline-primary">
                                        <i class="fas fa-eye me-1"></i>
                                        <span class="btn-text-full">Ver detalhes</span>
                                        <span class="btn-text-short d-none">Detalhes</span>
                                    </a>
                                    @if (lead.PropostaId.HasValue)
                                    {
                                        <a href="/Proposta/Editar/@lead.PropostaId"
                                           class="btn btn-sm btn-success">
                                            <i class="fas fa-file-alt me-1"></i>
                                            <span class="btn-text-full">Abrir proposta</span>
                                            <span class="btn-text-short d-none">Proposta</span>
                                        </a>
                                    }
                                    else
                                    {
                                        <button type="button"
                                                class="btn btn-sm btn-primary prep-btn"
                                                data-lead-id="@lead.Id"
                                                data-lead-nome="@Html.Raw(lead.FullName.Replace("\"", "&quot;"))">
                                            <i class="fas fa-file-alt me-1"></i>
                                            <span class="btn-text-full">Preparar proposta</span>
                                            <span class="btn-text-short d-none">Preparar</span>
                                        </button>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

<!-- Modal: confirmar preparar proposta -->
<div class="modal fade" id="modalPrepararProposta" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Preparar proposta</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p class="mb-1">Preparar proposta para <strong id="prepNomeLead"></strong>?</p>
                <p class="text-muted mb-0" style="font-size:.88rem;">Os dados disponíveis serão utilizados para criar o cliente e iniciar uma nova proposta. Você poderá revisar e completar as informações antes de publicar.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" id="btnConfirmarPrep" class="btn btn-primary btn-sm">
                    <i class="fas fa-file-alt me-1"></i>Preparar proposta
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    (function () {
        var prepLeadId   = null;
        var token        = document.querySelector('input[name="__RequestVerificationToken"]');
        var modalEl      = document.getElementById('modalPrepararProposta');
        var modal        = new bootstrap.Modal(modalEl);
        var btnConfirmar = document.getElementById('btnConfirmarPrep');

        // Delega clique nos botões "Preparar proposta"
        document.addEventListener('click', function (e) {
            var btn = e.target.closest('.prep-btn');
            if (!btn) return;
            prepLeadId = btn.dataset.leadId;
            document.getElementById('prepNomeLead').textContent = btn.dataset.leadNome;
            modal.show();
        });

        btnConfirmar.addEventListener('click', function () {
            if (!prepLeadId) return;

            // Estado de carregamento
            btnConfirmar.disabled = true;
            btnConfirmar.innerHTML = '<span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>Preparando...';

            var fd = new FormData();
            if (token) fd.append('__RequestVerificationToken', token.value);

            fetch('/Lead/PrepararProposta/' + prepLeadId, {
                method: 'POST',
                body: fd
            })
            .then(function (r) { return r.json(); })
            .then(function (data) {
                modal.hide();
                if (data.success) {
                    window.location.href = '/Proposta/Editar/' + data.propostaId;
                } else {
                    alert(data.message || 'Não foi possível preparar a proposta. Tente novamente.');
                    btnConfirmar.disabled = false;
                    btnConfirmar.innerHTML = '<i class="fas fa-file-alt me-1"></i>Preparar proposta';
                }
            })
            .catch(function () {
                modal.hide();
                alert('Não foi possível preparar a proposta. Tente novamente.');
                btnConfirmar.disabled = false;
                btnConfirmar.innerHTML = '<i class="fas fa-file-alt me-1"></i>Preparar proposta';
            });
        });

        // Resetar estado do botão ao fechar o modal
        modalEl.addEventListener('hidden.bs.modal', function () {
            btnConfirmar.disabled = false;
            btnConfirmar.innerHTML = '<i class="fas fa-file-alt me-1"></i>Preparar proposta';
            prepLeadId = null;
        });
    }());
</script>
}

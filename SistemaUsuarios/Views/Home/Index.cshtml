@model SistemaUsuarios.Models.ViewModels.HomeDashboardViewModel
@using SistemaUsuarios.Models
@using SistemaUsuarios.Models.ViewModels
@{
    ViewData["Title"] = "Início";

    var hora = DateTime.Now.Hour;
    var saudacao = hora < 12 ? "Bom dia" : hora < 18 ? "Boa tarde" : "Boa noite";
    var primeiroNome = Model.NomeUsuario.Split(' ')[0];
    var iniciais = string.Join("", Model.NomeUsuario
        .Split(' ', StringSplitOptions.RemoveEmptyEntries)
        .Take(2).Select(p => char.ToUpper(p[0]).ToString()));
    var agora = DateTime.Now;

    static string RelTime(DateTime dt, DateTime now)
    {
        var diff = now - dt;
        if (diff.TotalMinutes < 60) return $"há {(int)diff.TotalMinutes}min";
        if (diff.TotalHours   < 24) return $"há {(int)diff.TotalHours}h";
        if (diff.TotalDays    <  7) return $"há {(int)diff.TotalDays}d";
        return dt.ToString("dd/MM");
    }
}

@section Styles {
    <link rel="stylesheet" href="~/css/home-dashboard.css" />
}

<div class="home-dashboard">

<!-- ══════════════════════════════════════════════════════
     HERO — Saudação + Ações rápidas
══════════════════════════════════════════════════════ -->
<div class="home-hero">
    <div class="home-hero-identity">
        <div class="home-hero-avatar">
            @if (!string.IsNullOrEmpty(Model.FotoPath))
            {
                <img src="@Model.FotoPath" alt="@Model.NomeUsuario" />
            }
            else
            {
                @iniciais
            }
        </div>
        <div class="home-hero-txt">
            <h1>@saudacao, @primeiroNome.</h1>
            <p>Veja o que precisa da sua atenção hoje.</p>
        </div>
    </div>
    <div class="home-actions">
        <a href="@Url.Action("Criar", "Proposta")" class="home-actions-cta">
            <i class="fas fa-plus"></i> Nova proposta
        </a>
        <a href="@Url.Action("Index", "Lead")" class="home-actions-btn">
            <i class="fas fa-user-plus"></i> Leads
        </a>
        <a href="@Url.Action("Index", "Cliente")" class="home-actions-btn">
            <i class="fas fa-users"></i> Clientes
        </a>
        <a href="@Url.Action("Captacao", "Lead")" class="home-actions-btn">
            <i class="fas fa-link"></i> Captação
        </a>
    </div>
</div>

<!-- ══════════════════════════════════════════════════════
     4 CARDS PRINCIPAIS
══════════════════════════════════════════════════════ -->
<div class="home-summary-grid">

    <a href="@Url.Action("Index", "Lead")" class="home-summary-card home-card-leads">
        <div class="home-summary-icon"><i class="fas fa-user-plus"></i></div>
        <div class="home-summary-number">@Model.LeadsNovos</div>
        <div class="home-summary-label">Leads novos</div>
        <div class="home-summary-sub">aguardando primeiro contato</div>
        <span class="home-summary-action">
            Responder leads <i class="fas fa-arrow-right"></i>
        </span>
    </a>

    <a href="@Url.Action("Index", "Proposta")" class="home-summary-card home-card-viz">
        <div class="home-summary-icon"><i class="fas fa-eye"></i></div>
        <div class="home-summary-number">@Model.PropostasVisualizadas7d</div>
        <div class="home-summary-label">Propostas visualizadas</div>
        <div class="home-summary-sub">clientes abriram o link (7 dias)</div>
        <span class="home-summary-action">
            Fazer follow-up <i class="fas fa-arrow-right"></i>
        </span>
    </a>

    <a href="@Url.Action("Index", "Proposta")" class="home-summary-card home-card-andamento">
        <div class="home-summary-icon"><i class="fas fa-plane"></i></div>
        <div class="home-summary-number">@Model.ViagensAndamento</div>
        <div class="home-summary-label">Viagens em andamento</div>
        <div class="home-summary-sub">clientes viajando agora</div>
        <span class="home-summary-action">
            Acompanhar <i class="fas fa-arrow-right"></i>
        </span>
    </a>

    <a href="@Url.Action("Index", "Proposta")" class="home-summary-card home-card-proximas">
        <div class="home-summary-icon"><i class="fas fa-plane-departure"></i></div>
        <div class="home-summary-number">@Model.ViagensProximas15d</div>
        <div class="home-summary-label">Viagens próximas</div>
        <div class="home-summary-sub">começam nos próximos 15 dias</div>
        <span class="home-summary-action">
            Revisar detalhes <i class="fas fa-arrow-right"></i>
        </span>
    </a>

</div>

<!-- ══════════════════════════════════════════════════════
     LAYOUT 2 COLUNAS
══════════════════════════════════════════════════════ -->
<div class="row g-4">

    <!-- COLUNA PRINCIPAL -->
    <div class="col-lg-8">

        <!-- Fila de atenção -->
        <div class="attention-queue">
            <div class="home-section-head">
                <h2><i class="fas fa-list-check"></i>Sua fila de atenção</h2>
                @if (Model.FilaAtencao.Any())
                {
                    <a href="@Url.Action("Index", "Proposta")" class="home-section-link">
                        Ver tudo <i class="fas fa-arrow-right" style="font-size:.65rem;"></i>
                    </a>
                }
            </div>

            @if (!Model.FilaAtencao.Any())
            {
                <div class="home-empty">
                    <i class="fas fa-check-circle" style="color:#10b981;opacity:.5;"></i>
                    <p>Tudo certo por aqui. Nenhuma pendência importante no momento.</p>
                </div>
            }
            else
            {
                @foreach (var item in Model.FilaAtencao)
                {
                    <a href="@item.Url" class="attention-item @item.TipoCss">
                        <div class="atq-icon-wrap">
                            <i class="@item.TipoIcon"></i>
                        </div>
                        <div class="atq-body">
                            <div class="atq-nome">@item.NomeContato</div>
                            <div class="atq-desc">@item.Descricao</div>
                        </div>
                        <div class="atq-meta">
                            <span class="atq-badge">@item.TipoBadge</span>
                            <span class="atq-contexto">@item.Contexto</span>
                        </div>
                        <span class="atq-action">@item.AcaoLabel</span>
                    </a>
                }
            }
        </div>

        <!-- Continue de onde parou -->
        <div class="continue-list">
            <div class="home-section-head">
                <h2><i class="fas fa-history"></i>Continue de onde parou</h2>
                <a href="@Url.Action("Index", "Proposta")" class="home-section-link">
                    Ver propostas <i class="fas fa-arrow-right" style="font-size:.65rem;"></i>
                </a>
            </div>

            @if (!Model.ContinueList.Any())
            {
                <div class="home-empty">
                    <i class="fas fa-folder-open"></i>
                    <p>Nenhuma atividade recente encontrada.</p>
                </div>
            }
            else
            {
                @foreach (var item in Model.ContinueList)
                {
                    <a href="@item.Url" class="continue-item" data-tipo="@item.Tipo">
                        <div class="cnt-icon">
                            <i class="@item.TipoIcon"></i>
                        </div>
                        <div class="cnt-body">
                            <div class="cnt-tipo-tag">@item.Tipo</div>
                            <div class="cnt-nome">@item.Nome</div>
                            @if (!string.IsNullOrEmpty(item.Destino))
                            {
                                <div class="cnt-destino">
                                    <i class="fas fa-map-marker-alt me-1" style="font-size:.62rem;"></i>@item.Destino
                                </div>
                            }
                        </div>
                        <div class="cnt-right">
                            <span class="cnt-badge @item.StatusCss">@item.Status</span>
                            <span class="cnt-time">@RelTime(item.UltimaAtualizacao, agora)</span>
                        </div>
                    </a>
                }
            }
        </div>

    </div>

    <!-- SIDEBAR -->
    <div class="col-lg-4">

        <!-- Viagens e agenda -->
        <div class="home-section-head">
            <h2><i class="fas fa-calendar-alt"></i>Viagens e agenda</h2>
        </div>
        <div class="travel-agenda-card mb-4">
            @if (!Model.ViagensAgenda.Any())
            {
                <div class="home-empty" style="border:none;padding:24px;">
                    <i class="fas fa-umbrella-beach"></i>
                    <p>Sem viagens próximas ou em andamento.</p>
                </div>
            }
            else
            {
                @foreach (var v in Model.ViagensAgenda)
                {
                    <a href="@v.Url" class="travel-item">
                        <div class="travel-status-dot @(v.EmAndamento ? "travel-dot-andamento" : "travel-dot-proxima")"></div>
                        <div class="travel-body">
                            <div class="travel-titulo">@(v.ClienteNome ?? v.PropostaTitulo)</div>
                            @if (!string.IsNullOrEmpty(v.Destino))
                            {
                                <div class="travel-cliente">
                                    <i class="fas fa-map-marker-alt me-1" style="font-size:.6rem;"></i>@v.Destino
                                </div>
                            }
                            <div class="travel-datas">
                                <i class="fas fa-calendar me-1" style="font-size:.6rem;"></i>
                                @v.DataInicio.ToString("dd/MM") — @v.DataFim.ToString("dd/MM")
                            </div>
                        </div>
                        <span class="travel-badge @(v.EmAndamento ? "travel-badge-andamento" : "travel-badge-proxima")">
                            @(v.EmAndamento ? "Em andamento" : "Próxima")
                        </span>
                    </a>
                }
            }
        </div>

        <!-- Sua página pública / Captação -->
        @if (Model.Captacao != null)
        {
            <div class="home-section-head">
                <h2><i class="fas fa-link"></i>Sua página pública</h2>
            </div>
            <div class="public-page-card">
                <div class="public-page-header">
                    @if (!string.IsNullOrEmpty(Model.Captacao.NomeAgencia))
                    {
                        <span style="font-size:.85rem;font-weight:700;color:var(--exec-text);">
                            @Model.Captacao.NomeAgencia
                        </span>
                    }
                    else
                    {
                        <span style="font-size:.82rem;color:var(--exec-text-muted);">Sua agência</span>
                    }
                    <span class="public-page-status @(Model.Captacao.IsActive ? "public-status-ativa" : "public-status-inativa")">
                        <i class="fas fa-circle" style="font-size:.45rem;"></i>
                        @(Model.Captacao.IsActive ? "Ativa" : "Inativa")
                    </span>
                </div>

                @if (!string.IsNullOrEmpty(Model.Captacao.PublicUrl))
                {
                    <div class="public-page-link">@Model.Captacao.PublicUrl</div>
                    <div class="public-page-actions">
                        <button type="button" class="public-btn"
                                onclick="copiarLink('@Model.Captacao.PublicUrl', this)">
                            <i class="fas fa-copy"></i> Copiar link
                        </button>
                        <a href="@Url.Action("Captacao", "Lead")" class="public-btn">
                            <i class="fas fa-cog"></i> Configurar
                        </a>
                    </div>
                }
                else if (string.IsNullOrEmpty(Model.Captacao.SlugAgencia))
                {
                    <div class="public-page-cta">
                        <p>Configure sua página pública para receber leads de novos viajantes.</p>
                        <a href="@Url.Action("Captacao", "Lead")"
                           class="public-btn public-btn-primary"
                           style="width:auto;padding:8px 16px;">
                            <i class="fas fa-rocket"></i> Configurar captação
                        </a>
                    </div>
                }
                else
                {
                    <div class="public-page-cta">
                        <p>Ative a captação para começar a receber leads pelo link público.</p>
                        <a href="@Url.Action("Captacao", "Lead")"
                           class="public-btn public-btn-primary"
                           style="width:auto;padding:8px 16px;">
                            <i class="fas fa-toggle-on"></i> Ativar captação
                        </a>
                    </div>
                }
            </div>
        }

    </div>
</div>

</div><!-- .home-dashboard -->

@section Scripts {
<script>
function copiarLink(url, btn) {
    navigator.clipboard.writeText(url).then(function () {
        var orig = btn.innerHTML;
        btn.innerHTML = '<i class="fas fa-check"></i> Copiado!';
        btn.style.color = '#10b981';
        setTimeout(function () { btn.innerHTML = orig; btn.style.color = ''; }, 2000);
    });
}

</script>
}

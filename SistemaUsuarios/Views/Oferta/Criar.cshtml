// ════════════════════════════════════════════════════════════════════════
// EXPORTAR — renderiza nas dimensões reais e exporta PNG
// ════════════════════════════════════════════════════════════════════════
async function exportarOferta(userScale) {
    const tpl  = TEMPLATES[state.templateAtivo];
    if (!tpl) return;
    const fmt  = FORMATOS[state.formatoAtivo];
    const cols = getColors();

    // Renderiza em dimensão real em div temporário fora de tela
    const div  = document.createElement('div');
    div.style.cssText = `position:fixed;left:-9999px;top:-9999px;width:${fmt.w}px;height:${fmt.h}px;overflow:hidden;`;
    div.innerHTML = tpl.render(state.vars, cols, fmt.w, fmt.h);
    document.body.appendChild(div);

    try {
        const canvas = await html2canvas(div, {
            useCORS       : true,
            allowTaint    : true,
            scale         : userScale || 1,
            width         : fmt.w,
            height        : fmt.h,
            backgroundColor: null,
        });
        const link    = document.createElement('a');
        const nome    = document.getElementById('nomeOferta').value.trim() || 'oferta';
        link.download = `${nome.toLowerCase().replace(/\s+/g,'-')}-${state.formatoAtivo}.png`;
        link.href     = canvas.toDataURL('image/png');
        link.click();
    } catch (e) { alert('Erro ao exportar.\n' + e.message); }
    finally { document.body.removeChild(div); }
}

function csrf() {
    return document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
}

// ════════════════════════════════════════════════════════════════════════
// MINIATURAS DOS TEMPLATES
// ════════════════════════════════════════════════════════════════════════
function renderThumbs() {
    document.querySelectorAll('.template-thumb-canvas').forEach(canvas => {
        const tplId = canvas.dataset.template;
        const tpl   = TEMPLATES[tplId]; if (!tpl) return;
        const div   = document.createElement('div');
        div.style.cssText = 'position:fixed;left:-9999px;top:-9999px;width:500px;height:500px;overflow:hidden;';
        div.innerHTML = tpl.render(state.vars, getColors(), 500, 500);
        document.body.appendChild(div);
        const cw = canvas.width, ch = canvas.height;
        html2canvas(div, { useCORS:true, allowTaint:true, scale: cw/500, width:500, height:500 })
            .then(c => { canvas.getContext('2d').drawImage(c, 0, 0, cw, ch); })
            .finally(() => document.body.removeChild(div));
    });
}


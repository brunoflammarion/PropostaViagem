@model SistemaUsuarios.Models.ViewModels.OfertaViewModel
@using System.Text.Json
@{
    ViewData["Title"] = Model.Id.HasValue ? "Editar Oferta" : "Nova Oferta";

    var corPrimaria   = (string)(ViewBag.CorPrimaria  ?? "#1a1a2e");
    var corSecundaria = (string)(ViewBag.CorSecundaria ?? "#e94560");
    var corDestaque   = (string)(ViewBag.CorDestaque  ?? "#0f3460");
    var nomeAgencia   = (string)(ViewBag.NomeAgencia  ?? "");
    var logoPath      = (string)(ViewBag.LogoPath     ?? "");

    var modelJson = JsonSerializer.Serialize(new {
        id                  = Model.Id?.ToString() ?? "",
        nome                = Model.Nome ?? "",
        templateId          = Model.TemplateId ?? "destino",
        cor1                = Model.Cor1 ?? corPrimaria,
        cor2                = Model.Cor2 ?? corSecundaria,
        cor3                = Model.Cor3 ?? corDestaque,
        imagemPrincipalPath = Model.ImagemPrincipalPath ?? "",
        logoPath            = Model.LogoPath ?? logoPath,
        slotsJson           = Model.SlotsJson ?? "",
        tituloPrincipal     = Model.TituloPrincipal ?? "",
        subtitulo           = Model.Subtitulo ?? "",
        textoPrincipal      = Model.DescricaoCurta ?? "",      // usa DescricaoCurta como textoPrincipal
        descricaoCurta      = Model.DescricaoCurta ?? "",
        textoComplementar   = Model.TextoComplementar ?? "",
        rodape              = Model.Rodape ?? "",
        cta                 = Model.Cta ?? "Solicite já!",
        preco               = Model.Preco ?? "",
        precoAnterior       = Model.PrecoAnterior ?? "",
        textoAPartirDe      = Model.TextoAPartirDe ?? "a partir de",
        condicaoEspecial    = Model.CondicaoEspecial ?? "",
        parcelamento        = Model.Parcelamento ?? "",
        textoUrgencia       = Model.TextoUrgencia ?? "",
        validadeOferta      = Model.ValidadeOferta ?? "",
        destino             = Model.Destino ?? "",
        origem              = Model.Origem ?? "",
        periodoViagem       = Model.PeriodoViagem ?? "",
        qtdNoites           = Model.QtdNoites ?? "",
        companhiaAerea      = Model.CompanhiaAerea ?? "",
        hotel               = Model.Hotel ?? "",
        regimeHospedagem    = Model.RegimeHospedagem ?? "",
        inclusoesOferta     = Model.InclusoesOferta ?? "",
        observacoesCurtas   = Model.ObservacoesCurtas ?? "",
        regrasCondicoes     = Model.RegrasCondicoes ?? "",
        whatsApp            = Model.WhatsApp ?? "",
        telefone            = Model.Telefone ?? "",
        email               = Model.Email ?? "",
        instagram           = Model.Instagram ?? "",
        site                = Model.Site ?? "",
        nomeAgencia         = Model.NomeAgencia ?? nomeAgencia,
        seloPromocional     = Model.SeloPromocional ?? "",
        tagPromocional      = Model.TagPromocional ?? "",
        textoInstitucional  = Model.TextoInstitucional ?? "",
    });
}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,700;0,9..40,900;1,9..40,400&family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400;1,700&display=swap" rel="stylesheet">
<style>
body { overflow: hidden; }

.oferta-shell {
    display: flex;
    flex-direction: column;
    height: calc(100vh - var(--exec-header-height, 70px));
    overflow: hidden;
}

/* ── Top bar ── */
.oferta-topbar {
    flex-shrink: 0;
    background: #1e293b;
    border-bottom: 1px solid #0f172a;
    padding: 0 16px;
    height: 52px;
    display: flex;
    align-items: center;
    gap: 10px;
    z-index: 20;
}
.oferta-topbar .tb-nome {
    background: #0f172a;
    border: 1px solid #334155;
    color: #f1f5f9;
    border-radius: 6px;
    padding: 6px 10px;
    font-size: .82rem;
    width: 220px;
    flex-shrink: 0;
}
.oferta-topbar .tb-nome::placeholder { color: #475569; }
.oferta-topbar .tb-nome:focus { outline: none; border-color: #3b82f6; }
.tb-sep { width: 1px; height: 28px; background: #334155; flex-shrink: 0; }
.btn-salvar-oferta {
    background: #3b82f6; color: #fff; border: none; border-radius: 6px;
    padding: 7px 16px; font-size: .82rem; font-weight: 600;
    cursor: pointer; display: flex; align-items: center; gap: 6px; transition: background .15s;
}
.btn-salvar-oferta:hover { background: #2563eb; }
.btn-exportar-primary {
    background: #16a34a; color: #fff; border: none; border-radius: 6px;
    padding: 7px 18px; font-size: .82rem; font-weight: 700;
    cursor: pointer; display: flex; align-items: center; gap: 6px; transition: background .15s;
}
.btn-exportar-primary:hover { background: #15803d; }
.btn-exportar-2x {
    background: transparent; color: #94a3b8; border: 1px solid #334155;
    border-radius: 6px; padding: 7px 12px; font-size: .78rem;
    cursor: pointer; display: flex; align-items: center; gap: 5px;
    transition: color .15s, border-color .15s;
}
.btn-exportar-2x:hover { color: #f1f5f9; border-color: #64748b; }
.voltar-link {
    color: #64748b; font-size: .8rem; text-decoration: none;
    display: flex; align-items: center; gap: 5px; padding: 6px 8px;
    border-radius: 5px; transition: color .15s, background .15s;
}
.voltar-link:hover { color: #f1f5f9; background: rgba(255,255,255,.05); }
.tb-spacer { flex: 1; }
.tb-export-label { font-size: .7rem; color: #64748b; font-weight: 600; letter-spacing: .04em; text-transform: uppercase; }

/* ── Body 3 colunas ── */
.oferta-body { display: flex; flex: 1; overflow: hidden; }

/* ── Painel esquerdo ── */
.oferta-form {
    width: 296px; min-width: 260px;
    background: #f8f9fb;
    border-right: 1px solid #e2e8f0;
    overflow-y: auto; display: flex; flex-direction: column;
}
.oferta-form::-webkit-scrollbar { width: 4px; }
.oferta-form::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 4px; }

.fsec { padding: 10px 12px 4px; }
.fsec-title {
    font-size: .63rem; font-weight: 800; letter-spacing: .1em;
    text-transform: uppercase; color: #94a3b8; margin-bottom: 6px;
    display: flex; align-items: center; gap: 5px;
}
.frow { margin-bottom: 6px; }
.frow label { font-size: .7rem; color: #64748b; display: block; margin-bottom: 2px; }
.finput {
    width: 100%; border: 1px solid #e2e8f0; border-radius: 6px;
    padding: 5px 8px; font-size: .8rem; background: #fff;
    transition: border-color .15s, box-shadow .15s; box-sizing: border-box;
}
.finput:focus { outline: none; border-color: #93c5fd; box-shadow: 0 0 0 3px rgba(147,197,253,.18); }
textarea.finput { resize: vertical; }

/* Cor pickers */
.color-row { display: flex; gap: 8px; margin-bottom: 6px; }
.color-chip { flex: 1; text-align: center; }
.color-chip label { font-size: .62rem; color: #64748b; display: block; margin-bottom: 2px; }
.color-chip input[type=color] {
    width: 100%; height: 30px; border: 1px solid #e2e8f0; border-radius: 5px; cursor: pointer; padding: 2px;
}

/* Upload areas */
.img-upload-area, .logo-upload-area {
    border: 2px dashed #cbd5e1; border-radius: 8px; padding: 10px;
    text-align: center; cursor: pointer; background: #fff;
    transition: border-color .15s; margin-bottom: 6px;
}
.img-upload-area:hover, .logo-upload-area:hover { border-color: #93c5fd; }
.img-upload-area img, .logo-upload-area img { max-height: 70px; max-width: 100%; object-fit: contain; margin-bottom: 3px; }
.upload-placeholder { font-size: .71rem; color: #94a3b8; }

/* Linha com botões P/M/G */
.frow-inline { display: flex; align-items: flex-end; gap: 6px; margin-bottom: 6px; }
.frow-inline .finput-wrap { flex: 1; min-width: 0; }
.frow-inline label { font-size: .7rem; color: #64748b; display: block; margin-bottom: 2px; }

/* Slot control: empilha .szg e .clrg na vertical */
.slot-ctrl {
    display: flex; flex-direction: column; gap: 3px;
    flex-shrink: 0; align-self: flex-end; margin-bottom: 1px;
}

/* Grupo P/M/G */
.szg { display: flex; gap: 2px; }
.szb {
    border: 1px solid #e2e8f0; border-radius: 4px; background: #fff;
    font-size: .64rem; font-weight: 700; color: #94a3b8;
    padding: 3px 6px; cursor: pointer; line-height: 1;
    transition: border-color .15s, background .15s, color .15s;
}
.szb:hover { border-color: #93c5fd; color: #2563eb; background: #eff6ff; }
.szb.ativo { background: #1e293b; border-color: #1e293b; color: #fff; }

/* Grupo de cor — A ● ● ● */
.clrg { display: flex; gap: 2px; align-items: center; }
.clrb {
    border: 1.5px solid #e2e8f0; border-radius: 4px; background: #fff;
    font-size: .58rem; font-weight: 800; color: #94a3b8;
    width: 20px; height: 18px; padding: 0; cursor: pointer;
    display: flex; align-items: center; justify-content: center; line-height: 1;
    transition: border-color .15s, color .15s;
}
.clrb:hover { border-color: #93c5fd; color: #2563eb; }
.clrb.ativo { border-color: #1e293b; color: #1e293b; border-width: 2px; }
.clrb[data-val="principal"],
.clrb[data-val="destaque"],
.clrb[data-val="acento"] { border-radius: 50%; width: 16px; height: 16px; }
.clrb[data-val="principal"].ativo,
.clrb[data-val="destaque"].ativo,
.clrb[data-val="acento"].ativo { outline: 2px solid #1e293b; outline-offset: 1px; }

/* Rich text editor — Descrição geral */
.rte-wrap { border: 1px solid #e2e8f0; border-radius: 6px; overflow: hidden; background: #fff; }
.rte-tb { display: flex; gap: 2px; padding: 4px 6px; background: #f8fafc; border-bottom: 1px solid #e2e8f0; align-items: center; }
.rte-btn { border: 1px solid transparent; border-radius: 4px; background: transparent; font-size: .68rem; font-weight: 700; color: #64748b; width: 22px; height: 22px; padding: 0; cursor: pointer; display: flex; align-items: center; justify-content: center; line-height: 1; transition: all .12s; }
.rte-btn:hover { border-color: #93c5fd; color: #2563eb; background: #eff6ff; }
.rte-btn.on { background: #1e293b; border-color: #1e293b; color: #fff; }
.rte-sep { width: 1px; height: 14px; background: #e2e8f0; margin: 0 3px; flex-shrink: 0; }
.rte-ed { padding: 7px 9px; min-height: 58px; max-height: 112px; overflow-y: auto; font-size: .80rem; line-height: 1.52; outline: none; cursor: text; color: #374151; white-space: pre-wrap; word-break: break-word; }
.rte-ed:focus { background: #f0f9ff; }
.rte-ed:empty::before { content: attr(data-ph); color: #a0aec0; pointer-events: none; font-style: normal; }
.rte-ed b, .rte-ed strong { font-weight: 700; }
.rte-ed i, .rte-ed em { font-style: italic; }
.rte-ed [data-sz="S"] { font-size: .78em; }
.rte-ed [data-sz="L"] { font-size: 1.25em; }

/* Destaque block */
.destaque-block {
    background: #f0f9ff; border: 1px solid #bae6fd; border-radius: 8px;
    padding: 8px 10px; margin-bottom: 6px;
}
.destaque-row { display: flex; gap: 6px; margin-bottom: 4px; align-items: flex-end; }
.destaque-row label { font-size: .7rem; color: #0369a1; display: block; margin-bottom: 2px; }
.destaque-row .finput { border-color: #bae6fd; }
.destaque-row .finput:focus { border-color: #38bdf8; box-shadow: 0 0 0 3px rgba(56,189,248,.15); }
.parcelas-row { display: flex; gap: 6px; align-items: flex-end; margin-bottom: 4px; }
.parcelas-row label { font-size: .7rem; color: #0369a1; display: block; margin-bottom: 2px; }
.parcelas-n { width: 54px; }
.parcelas-sep { font-size: .8rem; color: #64748b; font-weight: 600; padding-bottom: 6px; flex-shrink: 0; }

/* Divider */
.fsec-divider { height: 1px; background: #e2e8f0; margin: 4px 0; }

/* ── Painel central: preview ── */
.oferta-preview-col {
    flex: 1; background: #dde1e7;
    display: flex; flex-direction: column; align-items: center; overflow: hidden;
}
.oferta-formato-bar {
    flex-shrink: 0; width: 100%; background: #f1f5f9;
    border-bottom: 1px solid #e2e8f0; padding: 8px 16px;
    display: flex; align-items: center; gap: 8px; justify-content: center;
}
.formato-label { font-size: .72rem; font-weight: 700; color: #64748b; letter-spacing: .06em; text-transform: uppercase; margin-right: 4px; }
.formato-btn {
    display: flex; align-items: center; gap: 5px;
    padding: 5px 13px; border: 1px solid #cbd5e1; border-radius: 6px;
    background: #fff; font-size: .76rem; font-weight: 600; color: #475569;
    cursor: pointer; transition: border-color .15s, background .15s, color .15s; white-space: nowrap;
}
.formato-btn:hover { border-color: #94a3b8; background: #f8fafc; }
.formato-btn.ativo { background: #1e293b; border-color: #1e293b; color: #fff; }
.formato-btn i { font-size: .8rem; }
.oferta-preview-scroll {
    flex: 1; width: 100%; overflow: auto;
    display: flex; align-items: center; justify-content: center; padding: 20px;
}
#oferta-preview {
    flex-shrink: 0; position: relative; overflow: hidden;
    box-shadow: 0 8px 40px rgba(0,0,0,.28); border-radius: 4px; background: #fff;
    transition: width .2s, height .2s;
}

/* ── Painel direito: templates ── */
.oferta-painel-templates {
    width: 200px; min-width: 186px;
    background: #f8f9fb; border-left: 1px solid #e2e8f0;
    overflow-y: auto; padding: 12px 10px 20px;
}
.oferta-painel-templates::-webkit-scrollbar { width: 3px; }
.oferta-painel-templates::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 4px; }
.tpl-cat-title {
    font-size: .6rem; font-weight: 800; letter-spacing: .1em;
    text-transform: uppercase; color: #94a3b8; margin: 14px 0 6px;
    display: flex; align-items: center; gap: 4px;
}
.tpl-cat-title:first-child { margin-top: 0; }
.tpl-cat-divider { height: 1px; background: #e2e8f0; margin: 10px 0 12px; }
.template-card {
    border: 2px solid #e2e8f0; border-radius: 8px; margin-bottom: 10px;
    cursor: pointer; overflow: hidden; transition: border-color .15s, box-shadow .15s; background: #fff;
}
.template-card:hover { border-color: #93c5fd; }
.template-card.ativo { border-color: #3b82f6; box-shadow: 0 0 0 3px rgba(59,130,246,.18); }
.template-card .thumb { height: 82px; overflow: hidden; position: relative; }
.template-card .thumb-label {
    font-size: .72rem; font-weight: 600; color: #374151;
    padding: 5px 8px 6px; display: flex; align-items: center; gap: 4px;
}
.template-card.ativo .thumb-label { color: #2563eb; }
</style>

<div class="oferta-shell">

  <!-- ── Top bar ── -->
  <div class="oferta-topbar">
    <a asp-action="Index" class="voltar-link" title="Voltar">
      <i class="fas fa-arrow-left"></i>
    </a>
    <div class="tb-sep"></div>
    <input type="text" id="nomeOferta" class="tb-nome" placeholder="Nome interno da oferta" />
    <button class="btn-salvar-oferta" onclick="salvarOferta()">
      <i class="fas fa-save"></i> Salvar
    </button>
    <div class="tb-spacer"></div>
    <span class="tb-export-label">Exportar</span>
    <button class="btn-exportar-primary" onclick="exportarOferta(1)">
      <i class="fas fa-download"></i> Baixar PNG
    </button>
    <button class="btn-exportar-2x" onclick="exportarOferta(2)" title="Alta resolução 2×">
      <i class="fas fa-expand-arrows-alt"></i> 2×
    </button>
  </div>

  <div class="oferta-body">

    <!-- ── ESQUERDA: formulário ── -->
    <div class="oferta-form">

      <!-- Imagem -->
      <div class="fsec">
        <div class="fsec-title"><i class="fas fa-image"></i> Imagem</div>
        <div class="img-upload-area" id="uploadArea" onclick="document.getElementById('inputImagem').click()">
          <div id="imgPreviewWrap" style="display:none;"><img id="imgPreview" src="" alt="preview" /></div>
          <div id="imgPlaceholder" class="upload-placeholder">
            <i class="fas fa-cloud-upload-alt d-block mb-1" style="font-size:1.3rem;color:#94a3b8;"></i>
            Clique para enviar
          </div>
        </div>
        <input type="file" id="inputImagem" accept="image/*" style="display:none;" />
        <input type="hidden" id="imagemPrincipalPath" />
      </div>

      <!-- Logo -->
      <div class="fsec">
        <div class="fsec-title"><i class="fas fa-store"></i> Logo</div>
        <div class="logo-upload-area" id="uploadLogoArea" onclick="document.getElementById('inputLogo').click()">
          <div id="logoPreviewWrap" style="display:none;"><img id="logoPreview" src="" alt="logo" style="max-height:36px;" /></div>
          <div id="logoPlaceholder" class="upload-placeholder"><i class="fas fa-store me-1"></i>Logo da agência</div>
        </div>
        <input type="file" id="inputLogo" accept="image/*" style="display:none;" />
        <input type="hidden" id="logoPath" />
      </div>

      <!-- Cores -->
      <div class="fsec">
        <div class="fsec-title"><i class="fas fa-palette"></i> Cores</div>
        <div class="color-row">
          <div class="color-chip">
            <label>Principal</label>
            <input type="color" id="cor1" data-var="cor1" />
          </div>
          <div class="color-chip">
            <label>Destaque</label>
            <input type="color" id="cor2" data-var="cor2" />
          </div>
          <div class="color-chip">
            <label>Acento</label>
            <input type="color" id="cor3" data-var="cor3" />
          </div>
        </div>
      </div>

      <div class="fsec-divider"></div>

      <!-- Conteúdo -->
      <div class="fsec">
        <div class="fsec-title"><i class="fas fa-heading"></i> Conteúdo</div>

        <div class="frow-inline">
          <div class="finput-wrap">
            <label>Título</label>
            <input type="text" class="finput" data-var="tituloPrincipal" placeholder="Ex: Paris Inesquecível" />
          </div>
          <div class="slot-ctrl">
            <div class="szg" data-size-key="titulo">
              <button class="szb" data-val="pequeno">P</button>
              <button class="szb" data-val="medio">M</button>
              <button class="szb" data-val="grande">G</button>
            </div>
            <div class="clrg" data-color-key="titulo">
              <button class="clrb ativo" data-val="auto" title="Auto">A</button>
              <button class="clrb" data-val="principal" title="Principal"></button>
              <button class="clrb" data-val="destaque" title="Destaque"></button>
              <button class="clrb" data-val="acento" title="Acento"></button>
            </div>
          </div>
        </div>

        <div class="frow-inline">
          <div class="finput-wrap">
            <label>Subtítulo</label>
            <input type="text" class="finput" data-var="subtitulo" placeholder="Ex: Viagem dos sonhos" />
          </div>
          <div class="slot-ctrl">
            <div class="szg" data-size-key="subtitulo">
              <button class="szb" data-val="pequeno">P</button>
              <button class="szb" data-val="medio">M</button>
              <button class="szb" data-val="grande">G</button>
            </div>
            <div class="clrg" data-color-key="subtitulo">
              <button class="clrb ativo" data-val="auto" title="Auto">A</button>
              <button class="clrb" data-val="principal" title="Principal"></button>
              <button class="clrb" data-val="destaque" title="Destaque"></button>
              <button class="clrb" data-val="acento" title="Acento"></button>
            </div>
          </div>
        </div>

        <div class="frow-inline">
          <div class="finput-wrap">
            <label>Descrição</label>
            <div class="rte-wrap">
              <div class="rte-tb">
                <button class="rte-btn" data-cmd="bold"   title="Negrito"><b>B</b></button>
                <button class="rte-btn" data-cmd="italic" title="Itálico"><i>I</i></button>
                <div class="rte-sep"></div>
                <button class="rte-btn" data-cmd="sz" data-sz="S" title="Texto pequeno" style="font-size:.55rem;">S</button>
                <button class="rte-btn" data-cmd="sz" data-sz="N" title="Tamanho normal">N</button>
                <button class="rte-btn" data-cmd="sz" data-sz="L" title="Texto grande"  style="font-size:.85rem;">G</button>
              </div>
              <div class="rte-ed" id="rteDescricao" contenteditable="true"
                   data-ph="Inclui aéreo, hotel 4★ e café da manhã."></div>
            </div>
          </div>
          <div class="slot-ctrl" style="align-self:flex-start;margin-top:20px;">
            <div class="szg" data-size-key="descricao">
              <button class="szb" data-val="pequeno">P</button>
              <button class="szb" data-val="medio">M</button>
              <button class="szb" data-val="grande">G</button>
            </div>
            <div class="clrg" data-color-key="descricao">
              <button class="clrb ativo" data-val="auto" title="Auto">A</button>
              <button class="clrb" data-val="principal" title="Principal"></button>
              <button class="clrb" data-val="destaque" title="Destaque"></button>
              <button class="clrb" data-val="acento" title="Acento"></button>
            </div>
          </div>
        </div>
      </div>

      <div class="fsec-divider"></div>

      <!-- Destaque Comercial -->
      <div class="fsec">
        <div class="fsec-title"><i class="fas fa-tag"></i> Destaque Comercial</div>
        <div class="destaque-block">

          <div class="destaque-row">
            <div style="flex:1;">
              <label>Valor total</label>
              <input type="text" class="finput" data-var="preco" placeholder="R$ 2.890" />
            </div>
            <div class="slot-ctrl" style="align-self:flex-end;">
              <div class="szg" data-size-key="preco">
                <button class="szb" data-val="pequeno">P</button>
                <button class="szb" data-val="medio">M</button>
                <button class="szb" data-val="grande">G</button>
              </div>
              <div class="clrg" data-color-key="preco">
                <button class="clrb ativo" data-val="auto" title="Auto">A</button>
                <button class="clrb" data-val="principal" title="Principal"></button>
                <button class="clrb" data-val="destaque" title="Destaque"></button>

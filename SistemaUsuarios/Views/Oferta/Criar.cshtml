// ════════════════════════════════════════════════════════════════════════
// HELPERS
// ════════════════════════════════════════════════════════════════════════
function esc(s) {
    if (!s) return '';
    return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

/** Nível 2 — multilinha: escapa HTML e converte \n em <br> */
function fmtMulti(s) {
    if (!s) return '';
    return esc(s).replace(/\n/g, '<br>');
}

/** Nível 3 — rico controlado: preserva apenas <b>, </b>, <br> — sanitiza todo o resto */
function fmtRich(s) {
    if (!s) return '';
    // Remove qualquer tag que não seja <b>, </b> ou <br>
    return s.replace(/<(?!\/?b\b|br\s*\/?\s*)[^>]*>/gi, '');
}

/** Sanitiza output do contenteditable → canonical: <b>, <i>, <span data-sz>, <br> */
function sanitizeRte(html) {
    if (!html) return '';
    const tmp = document.createElement('div');
    tmp.innerHTML = html;
    function clean(n) {
        if (n.nodeType === 3) return n.textContent;
        if (n.nodeType !== 1) return '';
        const tag = n.tagName.toLowerCase();
        const inner = Array.from(n.childNodes).map(clean).join('');
        if (tag === 'b' || tag === 'strong') return inner ? `<b>${inner}</b>` : '';
        if (tag === 'i' || tag === 'em')     return inner ? `<i>${inner}</i>` : '';
        if (tag === 'br') return '<br>';
        if (tag === 'div' || tag === 'p') return (inner || '') + '<br>';
        if (tag === 'span' && (n.dataset.sz === 'S' || n.dataset.sz === 'L'))
            return `<span data-sz="${n.dataset.sz}">${inner}</span>`;
        return inner;
    }
    let r = Array.from(tmp.childNodes).map(clean).join('');
    return r.replace(/(<br\s*\/?>\s*){3,}/gi, '<br><br>').replace(/^(<br\s*\/?>)+|(<br\s*\/?>)+$/gi, '');
}

/** Renderiza HTML de Descrição geral com estilos inline para canvas */
function fmtDesc(html, baseFS) {
    if (!html) return '';
    const tmp = document.createElement('div');
    tmp.innerHTML = sanitizeRte(html);
    function proc(n) {
        if (n.nodeType === 3) return esc(n.textContent);
        if (n.nodeType !== 1) return '';
        const tag = n.tagName.toLowerCase();
        const inner = Array.from(n.childNodes).map(proc).join('');
        if (tag === 'br') return '<br>';
        if (tag === 'b')  return `<span style="font-weight:700;">${inner}</span>`;
        if (tag === 'i')  return `<span style="font-style:italic;">${inner}</span>`;
        if (tag === 'span' && n.dataset.sz) {
            const m = n.dataset.sz === 'S' ? 0.78 : 1.25;
            return `<span style="font-size:${Math.round(baseFS * m)}px;">${inner}</span>`;
        }
        return inner;
    }
    return Array.from(tmp.childNodes).map(proc).join('');
}

// ── Ícones de marca (SVG inline) ─────────────────────────────────────────
function icoWA(sz) {
    return `<svg xmlns="http://www.w3.org/2000/svg" width="${sz}" height="${sz}" viewBox="0 0 32 32" style="display:inline-block;vertical-align:middle;flex-shrink:0;"><circle cx="16" cy="16" r="16" fill="#25D366"/><path fill="#fff" d="M16 6.4A9.6 9.6 0 0 0 7.87 20.94L7.2 25l4.2-.44A9.6 9.6 0 1 0 16 6.4zm5.2 12.96c-.26.66-1.18 1.22-2 1.32-.52.08-1.18.14-3.44-.78-2.9-1.22-4.64-4.12-4.78-4.3-.14-.18-1.3-1.74-1.3-3.32 0-1.58.82-2.36 1.14-2.68.28-.3.66-.44.92-.44l.66.01c.22 0 .5-.02.76.58.28.64.9 2.22.98 2.38.08.16.14.36.02.58l-.4.54-.52.56c-.18.18-.36.38-.16.72.64 1.08 1.44 2 2.38 2.66.68.48 1.44.88 2.24 1.14.28.1.54.08.74-.14l.7-.82c.22-.28.42-.22.7-.12l2.14 1.04c.24.12.4.18.44.3.04.56-.1 1.06-.38 1.44z"/></svg>`;
}
function icoIG(sz) {
    return `<svg xmlns="http://www.w3.org/2000/svg" width="${sz}" height="${sz}" viewBox="0 0 32 32" style="display:inline-block;vertical-align:middle;flex-shrink:0;"><rect width="32" height="32" rx="8" fill="#E1306C"/><rect x="8" y="8" width="16" height="16" rx="4" fill="none" stroke="#fff" stroke-width="2"/><circle cx="16" cy="16" r="4.4" fill="none" stroke="#fff" stroke-width="2"/><circle cx="22.5" cy="9.5" r="1.6" fill="#fff"/></svg>`;
}
function cntWA(val, sz) {
    if (!val) return '';
    return `<span style="display:inline-flex;align-items:center;gap:5px;">${icoWA(sz)}${esc(val)}</span>`;
}
function cntIG(val, sz) {
    if (!val) return '';
    return `<span style="display:inline-flex;align-items:center;gap:5px;">${icoIG(sz)}${esc(val)}</span>`;
}

// ════════════════════════════════════════════════════════════════════════
// COMPOSITION ENGINE — design tokens · font scale · slot constraints
// Fonte única de verdade: todos os tamanhos de fonte são fração de w (largura total do canvas)
// Garante escala consistente independente do formato (post/story/facebook) e do template
// ════════════════════════════════════════════════════════════════════════

// Design tokens — Typography, spacing, radius (all as fraction of canvas width w)
const T = {
    // Títulos — sempre relativos ao w total, nunca ao painel parcial
    TIT_MAX : .066,   // 71px(1080) heroi full-bleed
    TIT_XL  : .055,   // 59px titulo prominente
    TIT_LG  : .044,   // 48px titulo padrao grande
    TIT_MD  : .033,   // 36px titulo painel dividido
    TIT_SM  : .023,   // 25px minimo legivel
    // Corpo & UI
    SUB     : .023,   // 25px subtitulo
    BODY_LG : .020,   // 22px
    BODY_MD : .018,   // 19px
    BODY_SM : .016,   // 17px legenda
    MICRO   : .014,   // 15px
    // Comercio
    PRC_HERO: .082,   // 89px preco heroi
    PRC_LG  : .068,   // 73px preco grande
    PRC_MD  : .053,   // 57px preco padrao
    PRC_SM  : .039,   // 42px preco compacto
    BADGE   : .020,   // 22px etiqueta
    CTA     : .025,   // 27px
    FOOTER  : .016,   // 17px
    // Espaçamento
    SP_XS: .010, SP_SM: .022, SP_MD: .038, SP_LG: .054,
    // Raio de borda
    BR_SM: .008, BR_MD: .014, BR_LG: .026, BR_PILL: .048,
};

// Restrições por slot — ideal de chars e limite máximo
const SLOT_RULES = {
    titulo    : { ideal: 22, maxChars: 55  },
    subtitulo : { ideal: 38, maxChars: 60  },
    descricao : { ideal: 90, maxChars: 128 },
    textoPrinc: { ideal:110, maxChars: 170 },
    etiqueta  : { ideal: 18, maxChars: 32  },
};

// Densidade do conteúdo: 'low' | 'medium' | 'high'
// Leva em conta os quatro principais campos de texto
function density(vars) {
    const total = ['tituloPrincipal','subtitulo','textoComplementar','textoPrincipal']
        .reduce((n,k) => n + (vars[k]||'').replace(/<[^>]+>/g,'').length, 0);
    return total < 160 ? 'low' : total < 380 ? 'medium' : 'high';
}

// Multiplicadores de escala por template × densidade
// Layout heuristic: conteúdo leve → fontes maiores; denso → comprimido
const DENSITY_SCALE = {
    destino    : {low:1.10, medium:1.00, high:0.86},
    comercial  : {low:1.05, medium:1.00, high:0.88},
    promocional: {low:1.12, medium:1.00, high:0.85},
    relampago  : {low:1.08, medium:1.00, high:0.86},
    apartirde  : {low:1.05, medium:1.00, high:0.88},
    sonhos     : {low:1.15, medium:1.00, high:0.84},
    condicao   : {low:1.05, medium:1.00, high:0.90},
    combo      : {low:1.05, medium:1.00, high:0.88},
    premium    : {low:1.10, medium:1.00, high:0.86},
};

// ── Size System (3 níveis: P / M / G) ────────────────────────────────────
const SIZES = { pequeno: 1.00, medio: 1.55, grande: 1.90 };
const SIZE_OPACITY_MAP = { pequeno: 1.00, medio: 1.00, grande: 1.00 };

function getSizeScale(key) { return SIZES[state.sizes[key] || 'medio'] || 1; }
function getSizeOpacity(key) { return SIZE_OPACITY_MAP[state.sizes[key] || 'medio'] || 1; }

const SLOT_KEY_MAP = {
    titulo        : 'titulo',
    subtitulo     : 'subtitulo',
    descricao     : 'descricao',
    textoPrinc    : 'descricao',
    etiqueta      : 'etiqueta',
    preco         : 'preco',
    parcelamento  : 'parcelamento',
    precoAnterior : 'precoAnterior',
};

function slotScale(tplId, slotKey) {
    const k = SLOT_KEY_MAP[slotKey] || slotKey;
    return getSizeScale(k);
}
function slotOpacity(tplId, slotKey) {
    const k = SLOT_KEY_MAP[slotKey] || slotKey;
    return getSizeOpacity(k);
}
// Retorna a cor do slot: respeita override do usuário ou usa o fallback do template
function slotColor(key, cols, fallback) {
    const c = state.colors?.[key] || 'auto';
    if (c === 'principal') return cols.c1;
    if (c === 'destaque')  return cols.c2;
    if (c === 'acento')    return cols.c3;
    return fallback;
}

// px(w, token, scale?) — converte token para pixels
function px(w, token, scale) { return Math.round(w * token * (scale||1)); }

// fitTitle — dimensionamento adaptativo de título, consistente entre todos os templates
// maxT/minT são constantes T.TIT_xxx, sempre relativas ao w total do canvas
// szScale = slotScale() do slot titulo; aplica após density scale, com clamping
function fitTitle(text, w, tplId, dens, maxT, minT, szScale) {
    const ds  = DENSITY_SCALE[tplId]?.[dens] || 1;
    const ss  = szScale || 1;
    const len = text ? text.replace(/<[^>]+>/g,'').length : 0;
    const r   = Math.min(1, SLOT_RULES.titulo.ideal / Math.max(1, len));
    const raw = w * (minT + (maxT - minT) * r) * ds * ss;
    return Math.round(Math.max(w * T.TIT_SM, Math.min(w * T.TIT_MAX * 1.7, raw)));
}

function trunc(s, max) {
    if (!s) return '';
    s = s.replace(/<[^>]+>/g,'').trim();
    return s.length > max ? s.slice(0,max).trimEnd()+'…' : s;
}

function bulletsHTML(text, maxItems, iconColor, fs, gap) {
    if (!text) return '';
    const lines = text.replace(/<[^>]+>/g,'').split('\n').filter(l=>l.trim()).slice(0,maxItems);
    if (!lines.length) return '';
    return lines.map(l=>`<div style="display:flex;align-items:flex-start;gap:${gap}px;margin-bottom:${Math.round(gap*.8)}px;"><span style="color:${iconColor};font-weight:800;font-size:${fs}px;flex-shrink:0;line-height:1.4;">✓</span><span style="font-size:${fs}px;line-height:1.36;color:inherit;">${esc(l.trim())}</span></div>`).join('');
}

const SLOT_MAP = {
    titulo    : 'tituloPrincipal',
    subtitulo : 'subtitulo',
    descricao : 'textoComplementar',
    textoPrinc: '',
    etiqueta  : 'seloPromocional',
};
function sv(tpl, slotKey, vars) {
    return vars[SLOT_MAP[slotKey] || ''] || '';
}

/** Dimensões do preview baseado no formato ativo. */
function previewSize() {
    const fmt = FORMATOS[state.formatoAtivo];
    const el  = document.getElementById('oferta-preview');
    // Calcula escala visual para caber na área disponível
    return { w: fmt.previewW, h: fmt.previewH, realW: fmt.w, realH: fmt.h };
}

function getColors() {
    return { c1: state.vars.cor1||'#1a1a2e', c2: state.vars.cor2||'#e94560', c3: state.vars.cor3||'#0f3460' };
}


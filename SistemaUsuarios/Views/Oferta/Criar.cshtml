        ['fTituloPrincipal',    state.vars.tituloPrincipal||''],
        ['fSubtitulo',          state.vars.subtitulo||''],
        ['fDescricaoCurta',     state.vars.textoPrincipal||''],  // textoPrincipal → descricaoCurta
        ['fTextoComplementar',  state.vars.textoComplementar||''],
        ['fRodape',             state.vars.rodape||''],
        ['fCta',                state.vars.cta||''],
        ['fPreco',              state.vars.preco||''],
        ['fPrecoAnterior',      state.vars.precoAnterior||''],
        ['fTextoAPartirDe',     state.vars.textoAPartirDe||''],
        ['fCondicaoEspecial',   state.vars.condicaoEspecial||''],
        ['fParcelamento',       state.vars.parcelamento||''],
        ['fTextoUrgencia',      state.vars.textoUrgencia||''],
        ['fValidadeOferta',     state.vars.validadeOferta||''],
        ['fDestino',            state.vars.destino||''],
        ['fOrigem',             state.vars.origem||''],
        ['fPeriodoViagem',      state.vars.periodoViagem||''],
        ['fQtdNoites',          state.vars.qtdNoites||''],
        ['fCompanhiaAerea',     state.vars.companhiaAerea||''],
        ['fHotel',              state.vars.hotel||''],
        ['fRegimeHospedagem',   state.vars.regimeHospedagem||''],
        ['fInclusoesOferta',    state.vars.inclusoesOferta||''],
        ['fObservacoesCurtas',  state.vars.observacoesCurtas||''],
        ['fRegrasCondicoes',    state.vars.regrasCondicoes||''],
        ['fWhatsApp',           state.vars.whatsApp||''],
        ['fTelefone',           state.vars.telefone||''],
        ['fEmail',              state.vars.email||''],
        ['fInstagram',          state.vars.instagram||''],
        ['fSite',               state.vars.site||''],
        ['fNomeAgencia',        state.vars.nomeAgencia||''],
        ['fSeloPromocional',    state.vars.seloPromocional||''],
        ['fTagPromocional',     state.vars.tagPromocional||''],

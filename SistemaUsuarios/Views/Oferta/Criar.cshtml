        'regimeHospedagem','inclusoesOferta','observacoesCurtas','regrasCondicoes',
        'whatsApp','telefone','email','instagram','site','nomeAgencia',
        'seloPromocional','tagPromocional','textoInstitucional',
    ];
    campos.forEach(f => { state.vars[f] = o[f] || ''; });
    state.vars.imagemPrincipal = o.imagemPrincipalPath || '';
    state.vars.logo            = o.logoPath || '';

    // Restaura tamanhos e cores salvos
    if (o.slotsJson) {
        try {
            const parsed = JSON.parse(o.slotsJson);
            if (parsed?.sizes)  Object.assign(state.sizes,  parsed.sizes);
            if (parsed?.colors) Object.assign(state.colors, parsed.colors);
        } catch(e) {}
    }

    // Preenche inputs visíveis (exclui textoComplementar — tratado pelo RTE)
    document.querySelectorAll('[data-var]').forEach(el => {
        if (el.dataset.var === 'textoComplementar') return;
        const v = state.vars[el.dataset.var];
        if (v !== undefined) el.value = v;
    });

    // Restaura RTE da Descrição geral
    rteEd.innerHTML = sanitizeRte(o.textoComplementar || '') || '';
    rteSyncDesc();

    // Desmonta parcelamento salvo em N × valor
    if (state.vars.parcelamento) {
        const m = state.vars.parcelamento.match(/^(\d+)x?\s*(?:de\s*)?(.+)$/i);
        if (m) {
            document.getElementById('inputParcelas').value = m[1];
            document.getElementById('inputValorParcelado').value = m[2].trim();
        } else {
            document.getElementById('inputValorParcelado').value = state.vars.parcelamento;
        }
    }

    // Aplica tamanhos nos botões P/M/G
    Object.entries(state.sizes).forEach(([key, val]) => {
        document.querySelectorAll(`.szg[data-size-key="${key}"] .szb`).forEach(btn => {
            btn.classList.toggle('ativo', btn.dataset.val === val);
        });
    });

    // Aplica cores nos botões de cor
    Object.entries(state.colors).forEach(([key, val]) => {
        document.querySelectorAll(`.clrg[data-color-key="${key}"] .clrb`).forEach(btn => {
            btn.classList.toggle('ativo', btn.dataset.val === val);
        });
    });
    updateColorSwatches();

    // Restaura template
    state.templateAtivo = o.templateId || 'promocional';
    document.querySelectorAll('.template-card').forEach(c => c.classList.remove('ativo'));
    const ac = document.querySelector(`.template-card[data-template="${state.templateAtivo}"]`);
    if (ac) ac.classList.add('ativo');

    // Exibe preview de imagem/logo existentes
    if (state.vars.imagemPrincipal) {
        document.getElementById('imagemPrincipalPath').value = state.vars.imagemPrincipal;
        document.getElementById('imgPreview').src = state.vars.imagemPrincipal;
        document.getElementById('imgPreviewWrap').style.display = 'block';
        document.getElementById('imgPlaceholder').style.display = 'none';
    }
    if (state.vars.logo) {
        document.getElementById('logoPath').value = state.vars.logo;
        document.getElementById('logoPreview').src = state.vars.logo;
        document.getElementById('logoPreviewWrap').style.display = 'block';
        document.getElementById('logoPlaceholder').style.display = 'none';
    }

    renderPreview();
    renderThumbs();
})();
</script>

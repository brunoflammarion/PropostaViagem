<!-- ══ html2canvas ═══════════════════════════════════════════════════════ -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"
        integrity="sha512-BNaRQnYJYiPSqHHDb58B0yaPfCu+Wgds8Gp/gU33kqBtgNS4tSPHuGibyoeqMV/TJlSKda6FXzoEyYGjTe+vXA=="
        crossorigin="anonymous" referrerpolicy="no-referrer"></script>

<script>
// ════════════════════════════════════════════════════════════════════════
// ESTADO GLOBAL
// ════════════════════════════════════════════════════════════════════════
const OFERTA_ID      = '@(Model.Id?.ToString() ?? "")';
const OFERTA_INICIAL = @Html.Raw(modelJson);

// Formatos disponíveis: dimensões reais para exportação, escala para preview
const FORMATOS = {
    post     : { w: 1080, h: 1080, label: '1080 × 1080 px',  previewW: 460, previewH: 460 },
    story    : { w: 1080, h: 1920, label: '1080 × 1920 px',  previewW: 258, previewH: 460 },
    facebook : { w: 1200, h: 628,  label: '1200 × 628 px',   previewW: 460, previewH: 240 },
};

const state = {
    templateAtivo : 'promocional',
    formatoAtivo  : 'post',
    vars          : {},
    sizes: {
        titulo       : 'medio',
        subtitulo    : 'medio',
        descricao    : 'medio',
        preco        : 'grande',
        parcelamento : 'medio',
        precoAnterior: 'pequeno',
        etiqueta     : 'pequeno',
    },
    colors: {
        titulo       : 'auto',
        subtitulo    : 'auto',
        descricao    : 'auto',
        preco        : 'auto',
        parcelamento : 'auto',
        precoAnterior: 'auto',
        etiqueta     : 'auto',
    },
};

// ════════════════════════════════════════════════════════════════════════
// DEFINIÇÃO DOS TEMPLATES
// Slots padronizados em todos os templates: titulo, subtitulo, descricao, textoPrinc, etiqueta
// ════════════════════════════════════════════════════════════════════════
const TEMPLATES = {

    // ── 1. DESTINO — Full-bleed editorial; imagem protagonista ──────────
    destino: {
        id: 'destino', nome: 'Destino Viagem',
        slots: {
            titulo    : { label:'Título',           varPadrao:'tituloPrincipal',   compat:['tituloPrincipal','destino'] },
            subtitulo : { label:'Subtítulo',         varPadrao:'subtitulo',         compat:['subtitulo','periodoViagem','hotel'] },
            descricao : { label:'Descrição',         varPadrao:'textoComplementar', compat:['textoComplementar','condicaoEspecial','inclusoesOferta'] },
            textoPrinc: { label:'Texto principal',   varPadrao:'textoPrincipal',    compat:['textoPrincipal','inclusoesOferta','observacoesCurtas'] },
            etiqueta  : { label:'Etiqueta / Oferta', varPadrao:'seloPromocional',   compat:['seloPromocional','tagPromocional','textoUrgencia'] },
        },
        render(vars, cols, w, h) {
            const { c1, c2, c3 } = cols;
            const fw = w > h ? Math.round(h * 1.6) : w;
            const img      = vars.imagemPrincipal || '';
            const titulo   = sv(this,'titulo',vars);
            const subtit   = trunc(sv(this,'subtitulo',vars), 55);
            const desc     = sv(this,'descricao',vars);
            const textoPr  = trunc(sv(this,'textoPrinc',vars), 120);
            const etiqueta = sv(this,'etiqueta',vars);
            const ftrH     = Math.round(h * .072);
            const sp       = Math.round(w * .046);
            const dens     = density(vars);
            const tituloFS = fitTitle(titulo, fw, 'destino', dens, T.TIT_MAX, T.TIT_LG, slotScale('destino','titulo'));
            const subFS    = px(fw, T.SUB,     slotScale('destino','subtitulo'));
            const dscFS    = px(fw, T.BODY_MD, slotScale('destino','descricao'));
            const txtFS    = px(fw, T.BODY_MD, slotScale('destino','textoPrinc'));
            const etqFS    = px(fw, T.BADGE,   slotScale('destino','etiqueta'));
            const tituloClr   = slotColor('titulo',        cols, '#fff');
            const subtitClr   = slotColor('subtitulo',     cols, 'rgba(255,255,255,.80)');
            const descClr     = slotColor('descricao',     cols, 'rgba(255,255,255,.68)');
            const precoClr    = slotColor('preco',         cols, '#fff');
            const parcClr     = slotColor('parcelamento',  cols, 'rgba(255,255,255,.55)');
            const antClr      = slotColor('precoAnterior', cols, 'rgba(255,255,255,.38)');
            const etqColor    = slotColor('etiqueta',      cols, c2); // badge bg
            return `
<div style="width:${w}px;height:${h}px;position:relative;overflow:hidden;font-family:'Segoe UI',Arial,sans-serif;box-sizing:border-box;">
  ${img ? `<div style="position:absolute;inset:0;background-image:url('${img}');background-size:cover;background-position:center;"></div>` : `<div style="position:absolute;inset:0;background:linear-gradient(150deg,${c1} 0%,${c3} 55%,${c1}bb 100%);"></div>`}
  <div style="position:absolute;top:0;left:0;right:0;height:${Math.round(h*.36)}px;background:linear-gradient(to bottom,rgba(0,0,0,.55),transparent);"></div>
  <div style="position:absolute;bottom:0;left:0;right:0;height:${Math.round(h*.72)}px;background:linear-gradient(to top,${c1}f8 0%,${c1}cc 22%,${c1}66 48%,transparent 100%);"></div>
  <div style="position:absolute;top:${Math.round(h*.034)}px;left:${sp}px;right:${sp}px;display:flex;justify-content:space-between;align-items:flex-start;">
    ${etiqueta ? `<div style="background:${etqColor};color:#fff;padding:${Math.round(h*.009)}px ${Math.round(w*.032)}px;border-radius:${Math.round(w*.05)}px;font-size:${etqFS}px;font-weight:800;letter-spacing:.06em;text-transform:uppercase;box-shadow:0 3px 12px rgba(0,0,0,.35);">${esc(etiqueta)}</div>` : '<span></span>'}
    ${vars.logo ? `<img src="${vars.logo}" style="height:${Math.round(h*.065)}px;max-width:${Math.round(w*.24)}px;object-fit:contain;filter:drop-shadow(0 1px 6px rgba(0,0,0,.5));" crossorigin="anonymous"/>` : ''}
  </div>
  <div style="position:absolute;bottom:${ftrH + Math.round(h*.018)}px;left:${sp}px;right:${sp}px;">
    ${vars.destino && titulo !== vars.destino ? `<div style="color:${c2};font-size:${Math.round(fw*.017)}px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;margin-bottom:${Math.round(h*.006)}px;text-shadow:0 1px 5px rgba(0,0,0,.4);">📍 ${esc(vars.destino)}</div>` : ''}
    ${titulo ? `<div style="color:${tituloClr};font-size:${tituloFS}px;font-weight:900;line-height:1.06;margin-bottom:${Math.round(h*.008)}px;text-shadow:0 3px 14px rgba(0,0,0,.55);overflow:hidden;">${esc(titulo)}</div>` : ''}
    ${subtit ? `<div style="color:${subtitClr};font-size:${subFS}px;font-weight:500;margin-bottom:${Math.round(h*.01)}px;overflow:hidden;white-space:nowrap;text-overflow:ellipsis;">${esc(subtit)}</div>` : ''}
    ${desc ? `<div style="color:${descClr};font-size:${dscFS}px;line-height:1.4;margin-bottom:${Math.round(h*.012)}px;overflow:hidden;opacity:${slotOpacity('destino','descricao')};">${fmtDesc(desc,dscFS)}</div>` : (textoPr ? `<div style="color:rgba(255,255,255,.62);font-size:${txtFS}px;line-height:1.4;margin-bottom:${Math.round(h*.012)}px;overflow:hidden;opacity:${slotOpacity('destino','textoPrinc')};">${fmtRich(textoPr)}</div>` : '')}
    <div style="display:flex;align-items:flex-end;justify-content:space-between;gap:${Math.round(w*.012)}px;flex-wrap:wrap;">
      ${vars.preco ? `<div><div style="color:rgba(255,255,255,.5);font-size:${Math.round(fw*.014)}px;text-transform:uppercase;letter-spacing:.06em;">${esc(vars.textoAPartirDe||'a partir de')}</div>${vars.precoAnterior?`<div style="color:${antClr};font-size:${Math.round(fw*.016)}px;text-decoration:line-through;">${esc(vars.precoAnterior)}</div>`:''}<div style="color:${precoClr};font-size:${Math.round(fw*.055)}px;font-weight:900;line-height:1;text-shadow:0 2px 10px rgba(0,0,0,.4);">${esc(vars.preco)}</div>${vars.parcelamento?`<div style="color:${parcClr};font-size:${Math.round(fw*.015)}px;">${esc(vars.parcelamento)}</div>`:''}</div>` : '<div></div>'}
      ${vars.cta ? `<div style="background:${c2};color:#fff;padding:${Math.round(h*.018)}px ${Math.round(w*.034)}px;border-radius:${Math.round(w*.012)}px;font-size:${Math.round(fw*.021)}px;font-weight:800;white-space:nowrap;box-shadow:0 4px 16px rgba(0,0,0,.35);flex-shrink:0;">${esc(vars.cta)}</div>` : ''}
    </div>
  </div>
  <div style="position:absolute;bottom:0;left:0;right:0;height:${ftrH}px;background:rgba(0,0,0,.42);padding:0 ${sp}px;display:flex;align-items:center;justify-content:space-between;">
    <span style="color:rgba(255,255,255,.82);font-size:${Math.round(ftrH*.3)}px;font-weight:600;">${esc(vars.nomeAgencia||'')}</span>
    <span style="color:rgba(255,255,255,.72);font-size:${Math.round(ftrH*.28)}px;display:inline-flex;align-items:center;gap:5px;">${vars.whatsApp?cntWA(vars.whatsApp,Math.round(ftrH*.32)):(vars.instagram?cntIG(vars.instagram,Math.round(ftrH*.32)):'')}</span>
  </div>
</div>`;
        }
    },

    // ── 2. COMERCIAL — Split estruturado; copy + preço como argumento ─────
    comercial: {
        id: 'comercial', nome: 'Comercial Split',
        slots: {
            titulo    : { label:'Título',           varPadrao:'tituloPrincipal',   compat:['tituloPrincipal','destino'] },
            subtitulo : { label:'Subtítulo',         varPadrao:'subtitulo',         compat:['subtitulo','periodoViagem','hotel'] },
            descricao : { label:'Descrição',         varPadrao:'textoComplementar', compat:['textoComplementar','condicaoEspecial','observacoesCurtas'] },
            textoPrinc: { label:'Texto principal',   varPadrao:'textoPrincipal',    compat:['textoPrincipal','inclusoesOferta'] },
            etiqueta  : { label:'Etiqueta / Oferta', varPadrao:'seloPromocional',   compat:['seloPromocional','tagPromocional','textoUrgencia'] },
        },
        render(vars, cols, w, h) {
            const { c1, c2, c3 } = cols;
            const fw = w > h ? Math.round(h * 1.6) : w;
            const img      = vars.imagemPrincipal || '';
            const titulo   = sv(this,'titulo',vars);
            const subtit   = trunc(sv(this,'subtitulo',vars), 55);
            const desc     = sv(this,'descricao',vars);
            const textoPr  = sv(this,'textoPrinc',vars);
            const etiqueta = sv(this,'etiqueta',vars);
            const isStory  = h > w;
            const isFb     = w > h;
            const imgW     = isStory ? 0 : (isFb ? Math.floor(w*.36) : Math.floor(w*.40));
            const hdrH     = Math.round(h * .092);
            const ftrH     = Math.round(h * .088);

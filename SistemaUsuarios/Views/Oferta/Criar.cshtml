        ['fCor2',               state.vars.cor2||''],
        ['fCor3',               state.vars.cor3||''],
        ['fImagemPrincipalPath',state.vars.imagemPrincipal||document.getElementById('imagemPrincipalPath').value],
        ['fLogoPath',           state.vars.logo||document.getElementById('logoPath').value],

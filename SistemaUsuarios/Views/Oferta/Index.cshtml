@model IEnumerable<SistemaUsuarios.Models.Oferta>
@{
    ViewData["Title"] = "Minhas Ofertas";

    // Mapeamento template → (nome, icone, cor-badge)
    (string nome, string icone, string cor) GetTemplateInfo(string tplId) => tplId switch
    {
        "comercial"   => ("Comercial",   "fa-tags",           "bg-success"),
        "promocional" => ("Promocional", "fa-fire",           "bg-danger"),
        _             => ("Destino",     "fa-map-marker-alt", "bg-primary"),
    };
}

<div class="container-fluid py-4">

    <!-- Header ──────────────────────────────────────────────────────────────── -->
    <div class="d-flex align-items-center justify-content-between mb-4">
        <div>
            <h2 class="mb-0 fw-bold" style="font-size:1.55rem;">
                <i class="fas fa-bullhorn me-2 text-primary"></i>Ofertas
            </h2>
            <p class="text-muted mb-0 small mt-1">Crie peças promocionais prontas para divulgação</p>
        </div>
        <a asp-action="Criar" class="btn btn-primary">
            <i class="fas fa-plus me-1"></i>Nova Oferta
        </a>
    </div>

    <!-- Alertas ─────────────────────────────────────────────────────────────── -->
    @if (TempData["Sucesso"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle me-1"></i>@TempData["Sucesso"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Erro"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="fas fa-exclamation-circle me-1"></i>@TempData["Erro"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Conteúdo ─────────────────────────────────────────────────────────────── -->
    @if (!Model.Any())
    {
        <div class="card border-0 shadow-sm text-center py-5">
            <div class="card-body">
                <div style="font-size:3.5rem; opacity:.25; margin-bottom:16px;">
                    <i class="fas fa-bullhorn"></i>
                </div>
                <h5 class="text-muted fw-semibold mb-1">Nenhuma oferta criada ainda</h5>
                <p class="text-muted small mb-4">Crie sua primeira peça promocional em poucos minutos.</p>
                <a asp-action="Criar" class="btn btn-primary px-4">
                    <i class="fas fa-plus me-1"></i>Criar primeira oferta
                </a>
            </div>
        </div>
    }
    else
    {
        <div class="row g-3">
            @foreach (var oferta in Model)
            {
                var tpl = GetTemplateInfo(oferta.TemplateId);

                <div class="col-sm-6 col-md-4 col-xl-3">
                    <div class="card border-0 shadow-sm h-100" style="border-radius:12px; overflow:hidden;">

                        <!-- Thumbnail area com cor do template -->
                        <div style="height:130px; background:@(oferta.Cor1 ?? "#1a1a2e"); position:relative; overflow:hidden;">
                            @if (!string.IsNullOrEmpty(oferta.ImagemPrincipalPath))
                            {
                                <img src="@oferta.ImagemPrincipalPath"
                                     style="width:100%;height:100%;object-fit:cover;opacity:.55;" />
                            }
                            <!-- Gradient overlay -->
                            <div style="position:absolute;inset:0;background:linear-gradient(to bottom,transparent 40%,rgba(0,0,0,.6));"></div>

                            <!-- Template badge -->
                            <span class="badge @tpl.cor position-absolute"
                                  style="top:10px;left:10px;font-size:.68rem;letter-spacing:.04em;">
                                <i class="fas @tpl.icone me-1"></i>@tpl.nome
                            </span>

                            <!-- Destino ou título -->
                            <div class="position-absolute" style="bottom:10px;left:12px;right:12px;">
                                <div class="text-white fw-bold" style="font-size:.85rem;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">
                                    @(oferta.Destino ?? oferta.TituloPrincipal ?? "—")
                                </div>
                                @if (!string.IsNullOrEmpty(oferta.Preco))
                                {
                                    <div style="color:@(oferta.Cor3 ?? "#e94560");font-size:.78rem;font-weight:700;">
                                        @oferta.Preco
                                    </div>
                                }
                            </div>
                        </div>

                        <!-- Card body -->
                        <div class="card-body pb-2">
                            <h6 class="fw-bold mb-0" style="font-size:.9rem;">@oferta.Nome</h6>
                            <small class="text-muted">
                                <i class="fas fa-clock me-1"></i>@oferta.DataCriacao.ToString("dd/MM/yyyy")
                                @if (!string.IsNullOrEmpty(oferta.Usuario?.Nome))
                                {
                                    <span class="ms-1">· @oferta.Usuario.Nome</span>
                                }
                            </small>
                        </div>

                        <!-- Actions -->
                        <div class="card-footer bg-transparent border-0 pt-0 pb-3 px-3 d-flex gap-2">
                            <a asp-action="Editar" asp-route-id="@oferta.Id"
                               class="btn btn-sm btn-outline-primary flex-grow-1">
                                <i class="fas fa-edit me-1"></i>Editar / Exportar
                            </a>
                            <form asp-action="Duplicar" method="post" class="d-inline"
                                  onsubmit="return confirm('Duplicar a oferta «@oferta.Nome»? Uma cópia será criada para edição.')">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@oferta.Id" />
                                <button type="submit" class="btn btn-sm btn-outline-secondary" title="Duplicar oferta">
                                    <i class="fas fa-copy"></i>
                                </button>
                            </form>
                            <form asp-action="Excluir" method="post" class="d-inline"
                                  onsubmit="return confirm('Excluir a oferta «@oferta.Nome»? Esta ação não pode ser desfeita.')">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@oferta.Id" />
                                <button type="submit" class="btn btn-sm btn-outline-danger" title="Excluir">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            }
        </div>
    }

</div>

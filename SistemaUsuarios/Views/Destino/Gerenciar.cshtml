@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sortablejs@latest/Sortable.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js" crossorigin="anonymous"></script>

    <script>
        $(document).ready(function () {
            $('#nomeDestino').on('input', function () {
                const termo = $(this).val();
                if (termo.length < 3) {
                    $('#sugestoesDestino').empty();
                    return;
                }

                $.get('/Destino/BuscarSugestoes', { termo }, function (data) {
                    if (typeof data === "string") {
                        data = JSON.parse(data);
                    }

                    if (!data || !data.predictions) return;

                    const sugestoes = data.predictions.map(p => {
                        const descricao = p.description;
                        const placeId = p.place_id;
                        return `<a href="#" class="list-group-item list-group-item-action" data-id="${placeId}" data-desc="${descricao}">${descricao}</a>`;
                    });

                    $('#sugestoesDestino').html(sugestoes.join(''));
                });
            });

            $('#sugestoesDestino').on('click', 'a', function (e) {
                e.preventDefault();
                const descricao = $(this).data('desc');
                const placeId = $(this).data('id');

                $('#nomeDestino').val(descricao);
                $('#sugestoesDestino').empty();

                // Faz chamada para buscar cidade e país
                $.get('/Destino/BuscarDetalhes', { placeId }, function (data) {
                    if (data && data.cidade) {
                        $('#campoCidade').val(data.cidade);
                    }
                    if (data && data.pais) {
                        $('#campoPais').val(data.pais);
                    }
                    if (data && data.latitude) {
                        $('#latitude').val(data.latitude.toString());

                    }
                    if (data && data.longitude) {
                        $('#longitude').val(data.longitude.toString());
                    }
                    // Chamar LLM para preencher descrição
                    $.ajax({
                        url: '/Destino/GerarDescricao',
                        type: 'POST',
                        data: { nome: descricao },
                        success: function (data) {
                            console.log("🔍 JSON recebido:", data);

                            $('#descricaoDestino').val(data.descricao || '');

                            if (Array.isArray(data.atracoes)) {
                                const textoAtracoes = data.atracoes.map(a =>
                                    `• ${a.nome}: ${a.descricao} (Público: ${a.tipoPublico})`
                                ).join('\n');
                                $('#atracoesDestino').val(textoAtracoes);
                            }

                            if (Array.isArray(data.gastronomia)) {
                                const textoGastronomia = data.gastronomia.map(g =>
                                    `• ${g.nome} (${g.tipoCulinaria}) - Prato: ${g.pratoDestaque} | Perfil: ${g.perfilIdeal}`
                                ).join('\n');
                                $('#gastronomiaDestino').val(textoGastronomia);
                            }

                            if (data.informacoesPraticas) {
                                const i = data.informacoesPraticas;
                                const textoInfo = `• Melhor época: ${i.melhorEpoca}\n` +
                                    `• Clima médio: ${i.climaMedio}\n` +
                                    `• Transporte: ${i.meiosTransporte}\n` +
                                    `• Documentos: ${i.documentosExigidos}\n` +
                                    `• Dicas: ${i.dicasGerais}`;
                                $('#infoPraticasDestino').val(textoInfo);
                            }

                            if (data.pratosTipicos) {
                                const m = data.pratosTipicos;
                                const textoMala = `• nome: ${m.nome}\n` +
                                    `• descricao: ${m.descricao}\n` +
                                    `• ocasião: ${m.ocasião}`+
                                    `• ganchoComercial: ${m.ganchoComercial}`;
                                $('#malaDestino').val(textoMala);
                            }

                            if (data.malaViagem) {
                                const m = data.malaViagem;
                                const textoMala = `• Roupas: ${m.roupasAdequadas}\n` +
                                    `• Itens obrigatórios: ${m.itensObrigatorios}\n` +
                                    `• Acessórios úteis: ${m.acessoriosUteis}`;
                                $('#malaDestino').val(textoMala);
                            }

                            if (data.cuidados) {
                                const c = data.cuidados;
                                const textoCuidados = `• Segurança: ${c.seguranca}\n` +
                                    `• Regiões a evitar: ${c.regioesEvitar}\n` +
                                    `• Vacinas: ${c.vacinasRecomendadas}\n` +
                                    `• Golpes: ${c.golpesComuns}\n` +
                                    `• Orientações: ${c.orientacoesPraticas}`;
                                $('#cuidadosDestino').val(textoCuidados);
                            }
                        }
                        ,
                        error: function () {
                            alert('Erro ao gerar descritivo.');
                        }
                    });
                });                             
                console.log("Selecionado:", descricao, placeId);
            });
    });        
    </script>

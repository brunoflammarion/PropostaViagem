@model SistemaUsuarios.Models.Proposta
@using System.Text.RegularExpressions
@using System.Text.Json
@{
    ViewData["Title"] = $"Gerenciar Destinos - {Model.Titulo}";
}
@functions {
    static string RenderLlmBlock(string? json)
    {
        if (string.IsNullOrWhiteSpace(json)) return "";

        JsonDocument? doc = null;
        try { doc = JsonDocument.Parse(json); }
        catch { }

        if (doc == null)
            return $"<p class=\"small text-muted fst-italic\">{System.Net.WebUtility.HtmlEncode(json)}</p>";

        var sb = new System.Text.StringBuilder();
        var root = doc.RootElement;

        if (root.ValueKind == JsonValueKind.Array)
        {
            foreach (var item in root.EnumerateArray())
            {
                sb.Append("<div class=\"rev-arr-item\">");
                if (item.ValueKind == JsonValueKind.Object)
                    AppendObjectProps(sb, item);
                else
                    sb.Append($"<span class=\"rev-insight-value\">{System.Net.WebUtility.HtmlEncode(GetJsonString(item))}</span>");
                sb.Append("</div>");
            }
        }
        else if (root.ValueKind == JsonValueKind.Object)
        {
            AppendObjectProps(sb, root);
        }
        else
        {
            sb.Append($"<p class=\"rev-insight-value\">{System.Net.WebUtility.HtmlEncode(GetJsonString(root))}</p>");
        }

        doc.Dispose();
        return sb.ToString();
    }

    static void AppendObjectProps(System.Text.StringBuilder sb, JsonElement obj)
    {
        foreach (var prop in obj.EnumerateObject())
        {
            var val = GetJsonString(prop.Value);
            if (string.IsNullOrWhiteSpace(val)) continue;
            var enc = System.Net.WebUtility.HtmlEncode(val);
            var label = System.Net.WebUtility.HtmlEncode(LlmLabel(prop.Name));
            var nomeLower = prop.Name.ToLowerInvariant();

            if (nomeLower.Contains("gancho"))
                sb.Append($"<div class=\"rev-gancho\"><i class=\"fas fa-bolt text-warning me-1\"></i>{enc}</div>");
            else if (nomeLower.Contains("referencia") || nomeLower.Contains("referência"))
                sb.Append($"<div class=\"mb-1\"><span class=\"rev-insight-label\">Referência</span> <span class=\"text-muted small fst-italic\">{enc}</span></div>");
            else
                sb.Append($"<div class=\"mb-2\"><div class=\"rev-insight-label\">{label}</div><div class=\"rev-insight-value\">{enc}</div></div>");
        }
    }

    static string GetJsonString(JsonElement el)
    {
        return el.ValueKind switch
        {
            JsonValueKind.String => el.GetString() ?? "",
            JsonValueKind.Number => el.ToString(),
            JsonValueKind.True   => "Sim",
            JsonValueKind.False  => "Não",
            JsonValueKind.Array  => string.Join(", ",
                el.EnumerateArray().Select(e => GetJsonString(e)).Where(s => !string.IsNullOrEmpty(s))),
            _ => ""
        };
    }

    static string LlmLabel(string key)
    {
        if (string.IsNullOrEmpty(key)) return key;
        var s = Regex.Replace(key, "([A-Z])", " $1").Trim();
        return char.ToUpper(s[0]) + s[1..];
    }

    static string RenderTemasAccordion(SistemaUsuarios.Models.Destino d, string accId)
    {
        var sb = new System.Text.StringBuilder();
        sb.Append($"<div class=\"accordion\" id=\"{System.Net.WebUtility.HtmlEncode(accId)}\">");

        if (!string.IsNullOrEmpty(d.CuidadosLLM))
        {
            var id = "cuidados-" + d.Id.ToString("N");
            sb.Append(AccordionItem(accId, id,
                "fas fa-exclamation-triangle text-danger", "Cuidados &amp; Atenção",
                "border-danger", RenderLlmBlock(d.CuidadosLLM)));
        }

        if (!string.IsNullOrEmpty(d.GastronomiaLLM) || !string.IsNullOrEmpty(d.PratosTipicosLLM))
        {
            var id = "gastro-" + d.Id.ToString("N");
            var gastroHtml = new System.Text.StringBuilder();
            if (!string.IsNullOrEmpty(d.GastronomiaLLM))
                gastroHtml.Append(RenderLlmBlock(d.GastronomiaLLM));
            if (!string.IsNullOrEmpty(d.PratosTipicosLLM))
            {
                if (!string.IsNullOrEmpty(d.GastronomiaLLM))
                    gastroHtml.Append("<hr class=\"my-2\" />");
                gastroHtml.Append("<div class=\"rev-insight-label mb-2\">Pratos Típicos</div>");
                gastroHtml.Append(RenderLlmBlock(d.PratosTipicosLLM));
            }
            sb.Append(AccordionItem(accId, id,
                "fas fa-utensils text-warning", "Gastronomia &amp; Pratos",
                "border-warning", gastroHtml.ToString()));
        }

        if (!string.IsNullOrEmpty(d.AtracoesLLM))
        {
            var id = "atracoes-" + d.Id.ToString("N");
            sb.Append(AccordionItem(accId, id,
                "fas fa-map-marked-alt text-info", "Atrações &amp; Pontos de Interesse",
                "border-info", RenderLlmBlock(d.AtracoesLLM)));
        }

        if (!string.IsNullOrEmpty(d.InformacoesPraticasLLM))
        {
            var id = "infoprat-" + d.Id.ToString("N");
            sb.Append(AccordionItem(accId, id,
                "fas fa-info-circle text-primary", "Informações Práticas",
                "border-primary", RenderLlmBlock(d.InformacoesPraticasLLM)));
        }

        if (!string.IsNullOrEmpty(d.MalaViagemLLM))
        {
            var id = "mala-" + d.Id.ToString("N");
            sb.Append(AccordionItem(accId, id,
                "fas fa-suitcase text-secondary", "Mala de Viagem",
                "border-secondary", RenderLlmBlock(d.MalaViagemLLM)));
        }

        sb.Append("</div>");
        return sb.ToString();
    }

    static string AccordionItem(string parentId, string itemId,
        string iconCls, string label, string borderCls, string bodyHtml)
    {
        return "<div class=\"accordion-item " + borderCls + " border-opacity-25 rounded-3 mb-2 overflow-hidden\">"
             + "<h2 class=\"accordion-header\">"
             + "<button class=\"accordion-button collapsed py-2 px-3\" type=\"button\""
             + " data-bs-toggle=\"collapse\" data-bs-target=\"#" + itemId + "\""
             + " data-bs-parent=\"#" + parentId + "\">"
             + "<i class=\"" + iconCls + " me-2\" style=\"font-size:.85rem;\"></i>"
             + "<span class=\"small fw-semibold\">" + label + "</span>"
             + "</button></h2>"
             + "<div id=\"" + itemId + "\" class=\"accordion-collapse collapse\">"
             + "<div class=\"accordion-body py-2 px-3\">" + bodyHtml + "</div>"
             + "</div></div>";
    }
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2><i class="fas fa-map-marked-alt me-2"></i>Gerenciar Destinos</h2>
        <h5 class="text-muted">@Model.Titulo</h5>
    </div>
    <div>
        <a href="/Proposta" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left me-1"></i>Voltar às Propostas
        </a>
        <a href="/Proposta/Detalhes/@Model.Id" class="btn btn-outline-info">
            <i class="fas fa-eye me-1"></i>Ver Proposta
        </a>
    </div>
</div>

<div class="container-fluid">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/Proposta">Propostas</a></li>
            <li class="breadcrumb-item"><a href="/Proposta/Detalhes/@Model.Id">@Model.Titulo</a></li>
            <li class="breadcrumb-item active">Editar</li>
        </ol>
    </nav>

    <!-- Header com Progress -->
    <div class="row mb-4">
        <div class="col-md-12">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h2><i class="fas fa-edit me-2 text-primary"></i>Editar Proposta de Viagem</h2>
                    <p class="text-muted mb-0">Atualize as informações da sua proposta personalizada</p>
                </div>
                <div class="btn-group">
                    <a href="/Proposta/Detalhes/@Model.Id" class="btn btn-outline-info">
                        <i class="fas fa-eye me-1"></i>Visualizar
                    </a>
                    @if (Model.LinkPublicoAtivo)
                    {
                        <a href="/Proposta/Publico/@Model.Id" target="_blank" class="btn btn-outline-success">
                            <i class="fas fa-external-link-alt me-1"></i>Ver Público
                        </a>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Progress Steps -->
    <div class="row mb-4">
        <div class="col-md-12">
            <div class="card">
                <div class="card-body py-2">
                    <div class="d-flex justify-content-center align-items-center">
                        <div class="step-progress">
                            <div class="step active">
                                <div class="step-circle">
                                    <i class="fas fa-file-alt"></i>
                                </div>
                                <div class="step-label">Informações Básicas</div>
                            </div>
                            <div class="step-line"></div>
                            <div class="step active">
                                <div class="step-circle">
                                    <i class="fas fa-map-marked-alt"></i>
                                </div>
                                <div class="step-label">Destinos & Fotos</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>


<!-- Informações da Proposta -->
<div class="row mb-4">
    <div class="col-md-12">
        <div class="card">
            <div class="card-body">
                <div class="row">
                    <div class="col-md-2">
                        @if (!string.IsNullOrEmpty(Model.FotoCapa))
                        {
                            <img src="@Model.FotoCapa" alt="Foto da Proposta" class="img-fluid rounded" style="max-height: 80px; object-fit: cover;" />
                        }
                        else
                        {
                            <div class="bg-light d-flex align-items-center justify-content-center rounded" style="height: 80px;">
                                <i class="fas fa-image fa-2x text-muted"></i>
                            </div>
                        }
                    </div>
                    <div class="col-md-10">
                        <div class="row">
                            <div class="col-md-3">
                                <small class="text-muted">Período</small>
                                <p class="mb-0">
                                    @if (Model.DataInicio.HasValue && Model.DataFim.HasValue)
                                    {
                                        @Model.DataInicio.Value.ToString("dd/MM/yyyy") <span class="text-muted">até</span> @Model.DataFim.Value.ToString("dd/MM/yyyy")
                                    }
                                    else
                                    {
                                        <span class="text-muted">Não definido</span>
                                    }
                                </p>
                            </div>
                            <div class="col-md-2">
                                <small class="text-muted">Passageiros</small>
                                <p class="mb-0">@(Model.NumeroPassageiros + Model.NumeroCriancas) pessoas</p>
                            </div>
                            <div class="col-md-2">
                                <small class="text-muted">Status</small>
                                <p class="mb-0"><span class="badge bg-info">@Model.StatusProposta</span></p>
                            </div>
                            <div class="col-md-3">
                                <small class="text-muted">Destinos</small>
                                <p class="mb-0">@Model.Destinos.Count destino(s)</p>
                            </div>
                            <div class="col-md-2">
                                <small class="text-muted">Link Público</small>
                                <p class="mb-0">
                                    @if (Model.LinkPublicoAtivo)
                                    {
                                        <span class="text-success"><i class="fas fa-check"></i> Ativo</span>
                                    }
                                    else
                                    {
                                        <span class="text-danger"><i class="fas fa-times"></i> Inativo</span>
                                    }
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Lista de Destinos -->
@if (Model.Destinos.Any())
{
    <div class="row">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="mb-0"><i class="fas fa-list me-2"></i>Destinos da Viagem (@Model.Destinos.Count)</h5>
                    <small class="text-muted">Arraste para reordenar</small>
                </div>
                <div class="card-body p-0">
                    <div id="destinos-container" class="list-group list-group-flush">
                        @foreach (var destino in Model.Destinos.OrderBy(d => d.Ordem))
                        {
                            <div class="list-group-item" data-destino-id="@destino.Id">
                                <div class="row align-items-center">
                                    <!-- Handle de arrastar -->
                                    <div class="col-auto">
                                        <div class="drag-handle text-muted" style="cursor: move;">
                                            <i class="fas fa-grip-vertical"></i>
                                        </div>
                                    </div>

                                    <!-- Foto principal do destino -->
                                    <div class="col-auto">
                                        @if (destino.Fotos.Any(f => f.Principal))
                                        {
                                            var fotoPrincipal = destino.Fotos.First(f => f.Principal);
                                            <img src="@fotoPrincipal.CaminhoFoto" alt="@destino.Nome" class="img-thumbnail" style="width: 60px; height: 60px; object-fit: cover;" />
                                        }
                                        else if (destino.Fotos.Any())
                                        {
                                            var primeiraFoto = destino.Fotos.OrderBy(f => f.Ordem).First();
                                            <img src="@primeiraFoto.CaminhoFoto" alt="@destino.Nome" class="img-thumbnail" style="width: 60px; height: 60px; object-fit: cover;" />
                                        }
                                        else
                                        {
                                            <div class="bg-light d-flex align-items-center justify-content-center rounded" style="width: 60px; height: 60px;">
                                                <i class="fas fa-map-marker-alt text-muted"></i>
                                            </div>
                                        }
                                    </div>

                                    <!-- Informações do destino -->
                                    <div class="col">
                                        <div class="row">
                                            <div class="col-md-3">
                                                <h6 class="mb-1">@destino.Nome</h6>
                                                <small class="text-muted">
                                                    @if (!string.IsNullOrEmpty(destino.Cidade) || !string.IsNullOrEmpty(destino.Pais))
                                                    {
                                                        <i class="fas fa-globe me-1"></i>
                                                        @if (!string.IsNullOrEmpty(destino.Cidade))
                                                        {
                                                            @destino.Cidade
                                                        }
                                                        @if (!string.IsNullOrEmpty(destino.Pais))
                                                        {
                                                            @if (!string.IsNullOrEmpty(destino.Cidade))
                                                            {
                                                                <span>, </span>
                                                            }
                                                            @destino.Pais
                                                        }
                                                    }
                                                </small>
                                            </div>
                                            <div class="col-md-3">
                                                @if (destino.DataChegada.HasValue || destino.DataSaida.HasValue)
                                                {
                                                    <small class="text-muted">
                                                        <i class="fas fa-calendar me-1"></i>
                                                        @if (destino.DataChegada.HasValue)
                                                        {
                                                            @destino.DataChegada.Value.ToString("dd/MM")
                                                        }
                                                        @if (destino.DataSaida.HasValue)
                                                        {
                                                            <span> - @destino.DataSaida.Value.ToString("dd/MM")</span>
                                                        }
                                                    </small>
                                                }
                                            </div>
                                            <div class="col-md-2">
                                                <small class="text-muted">
                                                    <i class="fas fa-images me-1"></i>
                                                    @destino.Fotos.Count foto(s)
                                                </small>
                                            </div>
                                            <div class="col-md-4">
                                                @if (!string.IsNullOrEmpty(destino.Descricao))
                                                {
                                                    <small class="text-muted">
                                                        @if (destino.Descricao.Length > 80)
                                                        {
                                                            @(destino.Descricao.Substring(0, 80) + "...")
                                                        }
                                                        else
                                                        {
                                                            @destino.Descricao
                                                        }
                                                    </small>
                                                }
                                            </div>
                                        </div>
                                    </div>

                                    <!-- Ações -->
                                    <div class="col-auto">
                                        <div class="btn-group btn-group-sm">
                                            <button type="button" class="btn btn-outline-primary" data-bs-toggle="collapse" data-bs-target="#detalhes-@destino.Id">
                                                <i class="fas fa-chevron-down"></i>
                                            </button>
                                            <button type="button" class="btn btn-outline-success" onclick="abrirModalFoto('@destino.Id', '@destino.Nome')">
                                                <i class="fas fa-plus"></i> Foto
                                            </button>
                                            <button type="button" class="btn btn-outline-info" onclick="abrirModalHospedagem('@destino.Id', '@destino.Nome', '@(destino.Cidade ?? destino.Nome)')" title="Adicionar hospedagem">
                                                <i class="fas fa-hotel"></i> Hotel
                                            </button>
                                            <form asp-action="ExcluirDestino" method="post" style="display: inline;" onsubmit="return confirm('Tem certeza que deseja excluir este destino e todas suas fotos?');">
                                                <input type="hidden" name="id" value="@destino.Id" />
                                                <button type="submit" class="btn btn-outline-danger">
                                                    <i class="fas fa-trash"></i>
                                                </button>
                                            </form>
                                        </div>
                                    </div>
                                </div>

                                <!-- Detalhes expandidos do destino -->
                                <div class="collapse mt-3" id="detalhes-@destino.Id">
                                    <div class="border-top pt-3">
                                        <div class="row">
                                            <!-- Editar informações do destino -->
                                            <div class="col-md-6">
                                                <h6><i class="fas fa-edit me-1"></i>Editar Destino</h6>
                                                <form asp-action="EditarDestino" method="post">
                                                    <input type="hidden" name="id" value="@destino.Id" />
                                                    <div class="mb-2">
                                                        <input type="text" name="nome" class="form-control form-control-sm" value="@destino.Nome" placeholder="Nome do destino" />
                                                    </div>
                                                    <div class="row">
                                                        <div class="col-6 mb-2">
                                                            <input type="text" name="pais" class="form-control form-control-sm" value="@destino.Pais" placeholder="País" />
                                                        </div>
                                                        <div class="col-6 mb-2">
                                                            <input type="text" name="cidade" class="form-control form-control-sm" value="@destino.Cidade" placeholder="Cidade" />
                                                        </div>
                                                    </div>
                                                    <div class="row">
                                                        <div class="col-6 mb-2">
                                                            <input type="date" name="dataChegada" class="form-control form-control-sm" value="@destino.DataChegada?.ToString("yyyy-MM-dd")" />
                                                        </div>
                                                        <div class="col-6 mb-2">
                                                            <input type="date" name="dataSaida" class="form-control form-control-sm" value="@destino.DataSaida?.ToString("yyyy-MM-dd")" />
                                                        </div>
                                                    </div>
                                                    <div class="mb-2">
                                                        <textarea name="descricao" class="form-control form-control-sm" rows="3" placeholder="Descrição">@destino.Descricao</textarea>
                                                    </div>
                                                    <button type="submit" class="btn btn-sm btn-primary">
                                                        <i class="fas fa-save me-1"></i>Salvar
                                                    </button>
                                                </form>
                                            </div>

                                            <!-- Galeria de fotos -->
                                            <div class="col-md-6">
                                                <h6><i class="fas fa-images me-1"></i>Fotos (@destino.Fotos.Count)</h6>
                                                @if (destino.Fotos.Any())
                                                {
                                                    <div class="row g-2" id="fotos-@destino.Id">
                                                        @foreach (var foto in destino.Fotos.OrderBy(f => f.Ordem))
                                                        {
                                                            <div class="col-3" data-foto-id="@foto.Id">
                                                                <div class="position-relative">
                                                                    <img src="@foto.CaminhoFoto" alt="@foto.Descricao" class="img-fluid rounded" style="width: 100%; height: 80px; object-fit: cover;" />

                                                                    @if (foto.Principal)
                                                                    {
                                                                        <span class="position-absolute top-0 start-0 badge bg-success">
                                                                            <i class="fas fa-star"></i>
                                                                        </span>
                                                                    }

                                                                    <div class="position-absolute top-0 end-0">
                                                                        <div class="btn-group btn-group-sm">
                                                                            @if (!foto.Principal)
                                                                            {
                                                                                <form asp-controller="DestinoFoto" asp-action="DefinirPrincipal" method="post" style="display: inline;">
                                                                                    <input type="hidden" name="id" value="@foto.Id" />
                                                                                    <button type="submit" class="btn btn-outline-warning btn-sm" title="Definir como principal">
                                                                                        <i class="fas fa-star"></i>
                                                                                    </button>
                                                                                </form>
                                                                            }
                                                                            <form asp-controller="DestinoFoto" asp-action="ExcluirFoto" method="post" style="display: inline;" onsubmit="return confirm('Excluir esta foto?');">
                                                                                <input type="hidden" name="id" value="@foto.Id" />
                                                                                <button type="submit" class="btn btn-outline-danger btn-sm">
                                                                                    <i class="fas fa-trash"></i>
                                                                                </button>
                                                                            </form>
                                                                        </div>
                                                                    </div>

                                                                    @if (!string.IsNullOrEmpty(foto.Descricao))
                                                                    {
                                                                        <div class="position-absolute bottom-0 start-0 w-100 bg-dark bg-opacity-75 text-white p-1">
                                                                            <small>@foto.Descricao</small>
                                                                        </div>
                                                                    }
                                                                </div>
                                                            </div>
                                                        }
                                                    </div>
                                                }
                                                else
                                                {
                                                    <div class="text-center text-muted py-3">
                                                        <i class="fas fa-images fa-2x mb-2"></i>
                                                        <p class="mb-0">Nenhuma foto adicionada</p>
                                                        <small>Use o botão "+ Foto" para adicionar</small>
                                                    </div>
                                                }
                                            </div>
                                        </div>
                                    </div>

                                    <!-- Seção de Hospedagens -->
                                    <div class="border-top pt-3 mt-3">
                                        <div class="d-flex justify-content-between align-items-center mb-3">
                                            <h6 class="mb-0"><i class="fas fa-hotel me-2 text-info"></i>Hospedagens (@destino.Hospedagens.Count)</h6>
                                        </div>

                                        @foreach (var hospedagem in destino.Hospedagens.OrderBy(h => h.Ordem))
                                        {
                                            <div class="card mb-3 border-info hosp-card"
                                                 data-hosp-id="@hospedagem.Id"
                                                 data-hosp-nome="@hospedagem.Nome"
                                                 data-hosp-descricao="@hospedagem.Descricao"
                                                 data-hosp-endereco="@hospedagem.Endereco"
                                                 data-hosp-latitude="@hospedagem.Latitude?.ToString("G17", System.Globalization.CultureInfo.InvariantCulture)"
                                                 data-hosp-longitude="@hospedagem.Longitude?.ToString("G17", System.Globalization.CultureInfo.InvariantCulture)"
                                                 data-hosp-checkin="@(hospedagem.CheckIn?.ToString("yyyy-MM-ddTHH:mm") ?? "")"
                                                 data-hosp-checkout="@(hospedagem.CheckOut?.ToString("yyyy-MM-ddTHH:mm") ?? "")"
                                                 data-hosp-categoria="@((int)hospedagem.Categoria)"
                                                 data-hosp-tipopensao="@((int)hospedagem.TipoPensao)"
                                                 data-hosp-reserva="@hospedagem.Reserva"
                                                 data-hosp-observacoes="@hospedagem.Observacoes">
                                                <div class="card-header bg-light d-flex justify-content-between align-items-center py-2">
                                                    <div>
                                                        <span class="fw-semibold">@hospedagem.Nome</span>
                                                        <span class="badge bg-info ms-2">
                                                            @(hospedagem.Categoria switch {
                                                                SistemaUsuarios.Models.CategoriaHospedagem.Hotel => "Hotel",
                                                                SistemaUsuarios.Models.CategoriaHospedagem.Pousada => "Pousada",
                                                                SistemaUsuarios.Models.CategoriaHospedagem.Resort => "Resort",
                                                                SistemaUsuarios.Models.CategoriaHospedagem.HotelFazenda => "Hotel Fazenda",
                                                                SistemaUsuarios.Models.CategoriaHospedagem.AluguelCasa => "Aluguel de Casa",
                                                                SistemaUsuarios.Models.CategoriaHospedagem.Camping => "Camping",
                                                                _ => "Outros"
                                                            })
                                                        </span>
                                                        <span class="badge bg-secondary ms-1">
                                                            @(hospedagem.TipoPensao switch {
                                                                SistemaUsuarios.Models.TipoPensao.SemPensao => "Sem Pensão",
                                                                SistemaUsuarios.Models.TipoPensao.CafeDaManha => "Café da Manhã",
                                                                SistemaUsuarios.Models.TipoPensao.MeiaPensao => "Meia Pensão",
                                                                SistemaUsuarios.Models.TipoPensao.PensaoCompleta => "Pensão Completa",
                                                                SistemaUsuarios.Models.TipoPensao.AllInclusive => "All Inclusive",
                                                                _ => "Outros"
                                                            })
                                                        </span>
                                                        @if (hospedagem.CheckIn.HasValue || hospedagem.CheckOut.HasValue)
                                                        {
                                                            <small class="text-muted ms-2">
                                                                <i class="fas fa-calendar me-1"></i>
                                                                @hospedagem.CheckIn?.ToString("dd/MM/yyyy HH:mm") — @hospedagem.CheckOut?.ToString("dd/MM/yyyy HH:mm")
                                                            </small>
                                                        }
                                                    </div>
                                                    <div class="btn-group btn-group-sm">
                                                        <button type="button" class="btn btn-outline-primary btn-sm"
                                                                onclick="abrirModalEditarHospedagem(this.closest('.hosp-card'))"
                                                                title="Editar hospedagem">
                                                            <i class="fas fa-edit me-1"></i>Editar
                                                        </button>
                                                        <button type="button" class="btn btn-outline-secondary btn-sm"
                                                                data-bs-toggle="collapse"
                                                                data-bs-target="#hosp-det-@hospedagem.Id"
                                                                title="Gerenciar comodidades e acomodações">
                                                            <i class="fas fa-cog me-1"></i>Detalhes
                                                            <span class="badge bg-secondary ms-1">@hospedagem.Acomodacoes.Count acmd</span>
                                                            @if (hospedagem.Comodidades.Any())
                                                            {
                                                                <span class="badge bg-info ms-1">@hospedagem.Comodidades.Count comod</span>
                                                            }
                                                        </button>
                                                        <form asp-controller="Hospedagem" asp-action="Excluir" method="post" style="display:inline;" onsubmit="return confirm('Excluir esta hospedagem e todas suas acomodações?');">
                                                            <input type="hidden" name="id" value="@hospedagem.Id" />
                                                            <button type="submit" class="btn btn-outline-danger btn-sm"><i class="fas fa-trash"></i></button>
                                                        </form>
                                                    </div>
                                                </div>

                                                <div class="collapse" id="hosp-det-@hospedagem.Id">
                                                    <div class="card-body pt-2">

                                                        <!-- ===== SEÇÃO: COMODIDADES ===== -->
                                                        <div class="mb-3">
                                                            <h6 class="text-muted mb-2"><i class="fas fa-concierge-bell me-1"></i>Comodidades</h6>
                                                            @if (hospedagem.Comodidades.Any())
                                                            {
                                                                <div class="d-flex flex-wrap gap-1 mb-2">
                                                                    @foreach (var comodidade in hospedagem.Comodidades.OrderBy(c => c.Ordem))
                                                                    {
                                                                        <span class="badge bg-light text-dark border d-inline-flex align-items-center gap-1 py-1 px-2">
                                                                            <i class="fas fa-check-circle text-success" style="font-size:0.7rem;"></i>
                                                                            @comodidade.Nome
                                                                            <form asp-controller="Hospedagem" asp-action="ExcluirComodidade" method="post" style="display:inline;" onsubmit="return confirm('Remover comodidade?');">
                                                                                <input type="hidden" name="id" value="@comodidade.Id" />
                                                                                <button type="submit" class="btn p-0 ms-1 border-0 bg-transparent lh-1" title="Remover">
                                                                                    <i class="fas fa-times text-muted" style="font-size:0.6rem;"></i>
                                                                                </button>
                                                                            </form>
                                                                        </span>
                                                                    }
                                                                </div>
                                                            }
                                                            else
                                                            {
                                                                <p class="small text-muted mb-2">Nenhuma comodidade cadastrada.</p>
                                                            }
                                                            <form asp-controller="Hospedagem" asp-action="AdicionarComodidade" method="post" class="d-flex gap-1">
                                                                <input type="hidden" name="hospedagemId" value="@hospedagem.Id" />
                                                                <input type="text" name="nome" class="form-control form-control-sm" placeholder="Adicionar comodidade..." maxlength="200" style="max-width:220px;" />
                                                                <button type="submit" class="btn btn-sm btn-outline-secondary flex-shrink-0">
                                                                    <i class="fas fa-plus me-1"></i>Adicionar
                                                                </button>
                                                            </form>
                                                        </div>

                                                        <hr class="my-2" />

                                                        <!-- ===== SEÇÃO: ACOMODAÇÕES ===== -->
                                                        <h6 class="text-muted mb-2"><i class="fas fa-bed me-1"></i>Acomodações</h6>

                                                        @foreach (var acomodacao in hospedagem.Acomodacoes.OrderBy(a => a.Ordem))
                                                        {
                                                            <div class="card mb-2 border-light">
                                                                <div class="card-body p-2">
                                                                    <div class="d-flex justify-content-between align-items-start">
                                                                        <strong class="small">@acomodacao.Nome</strong>
                                                                        <div class="btn-group btn-group-sm">
                                                                            <button type="button" class="btn btn-outline-secondary btn-sm"
                                                                                    data-bs-toggle="collapse"
                                                                                    data-bs-target="#acmd-@acomodacao.Id"
                                                                                    title="Editar acomodação">
                                                                                <i class="fas fa-edit me-1"></i>Editar
                                                                            </button>
                                                                            <button type="button" class="btn btn-outline-success btn-sm"
                                                                                    onclick="abrirModalFotoAcomodacao('@acomodacao.Id', '@acomodacao.Nome')"
                                                                                    title="Adicionar foto">
                                                                                <i class="fas fa-camera me-1"></i>Foto
                                                                            </button>
                                                                            <form asp-controller="Hospedagem" asp-action="ExcluirAcomodacao" method="post" style="display:inline;" onsubmit="return confirm('Excluir esta acomodação?');">
                                                                                <input type="hidden" name="id" value="@acomodacao.Id" />
                                                                                <button type="submit" class="btn btn-outline-danger btn-sm"><i class="fas fa-trash"></i></button>
                                                                            </form>
                                                                        </div>
                                                                    </div>

                                                                    <!-- Miniaturas das fotos visíveis diretamente (sem precisar expandir) -->
                                                                    @if (acomodacao.Fotos.Any())
                                                                    {
                                                                        <div class="d-flex flex-wrap gap-1 mt-2">
                                                                            @foreach (var foto in acomodacao.Fotos.OrderBy(f => f.Ordem))
                                                                            {
                                                                                <div class="position-relative" style="width:64px;height:48px;">
                                                                                    <img src="@foto.CaminhoFoto" alt="@foto.Descricao" class="rounded" style="width:64px;height:48px;object-fit:cover;" />
                                                                                    @if (foto.Principal)
                                                                                    {
                                                                                        <span class="position-absolute top-0 start-0 badge bg-success" style="font-size:0.5rem;padding:2px;"><i class="fas fa-star"></i></span>
                                                                                    }
                                                                                    <form asp-controller="Hospedagem" asp-action="ExcluirFotoAcomodacao" method="post" style="display:inline;" onsubmit="return confirm('Excluir foto?');">
                                                                                        <input type="hidden" name="id" value="@foto.Id" />
                                                                                        <button type="submit" class="btn btn-danger btn-sm position-absolute top-0 end-0 p-0" style="width:16px;height:16px;font-size:0.55rem;line-height:1;"><i class="fas fa-times"></i></button>
                                                                                    </form>
                                                                                </div>
                                                                            }
                                                                        </div>
                                                                    }

                                                                    <!-- Formulário de edição inline -->
                                                                    <div class="collapse mt-2" id="acmd-@acomodacao.Id">
                                                                        <form asp-controller="Hospedagem" asp-action="EditarAcomodacao" method="post" class="mb-0">
                                                                            <input type="hidden" name="id" value="@acomodacao.Id" />
                                                                            <div class="mb-1">
                                                                                <label class="form-label form-label-sm mb-1 text-muted">Nome</label>
                                                                                <input type="text" name="nome" class="form-control form-control-sm" value="@acomodacao.Nome" required />
                                                                            </div>
                                                                            <div class="mb-1">
                                                                                <label class="form-label form-label-sm mb-1 text-muted">Descrição</label>
                                                                                <textarea name="descricao" class="form-control form-control-sm" rows="3" placeholder="Descreva o que inclui esta acomodação...">@acomodacao.Descricao</textarea>
                                                                            </div>
                                                                            <button type="submit" class="btn btn-sm btn-primary"><i class="fas fa-save me-1"></i>Salvar</button>
                                                                        </form>
                                                                    </div>
                                                                </div>
                                                            </div>
                                                        }

                                                        <!-- Adicionar nova acomodação -->
                                                        <div class="card border-light bg-light mt-2">
                                                            <div class="card-body p-2">
                                                                <p class="small text-muted mb-2 fw-semibold"><i class="fas fa-plus-circle me-1 text-success"></i>Nova Acomodação</p>
                                                                <form asp-controller="Hospedagem" asp-action="AdicionarAcomodacao" method="post">
                                                                    <input type="hidden" name="hospedagemId" value="@hospedagem.Id" />
                                                                    <div class="row g-1 mb-1">
                                                                        <div class="col-sm-4">
                                                                            <input type="text" name="nome" class="form-control form-control-sm" placeholder="Nome (ex: Suíte, Quarto...)" required />
                                                                        </div>
                                                                        <div class="col-sm-8">
                                                                            <input type="text" name="descricao" class="form-control form-control-sm" placeholder="Descrição resumida..." />
                                                                        </div>
                                                                    </div>
                                                                    <button type="submit" class="btn btn-sm btn-outline-success"><i class="fas fa-plus me-1"></i>Adicionar</button>
                                                                </form>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        }
                                    </div>

                                    @{
                                        var _accId = "acc-dest-" + destino.Id.ToString("N");
                                        var _hasInsights = !string.IsNullOrEmpty(destino.CuidadosLLM)
                                            || !string.IsNullOrEmpty(destino.GastronomiaLLM)
                                            || !string.IsNullOrEmpty(destino.PratosTipicosLLM)
                                            || !string.IsNullOrEmpty(destino.AtracoesLLM)
                                            || !string.IsNullOrEmpty(destino.InformacoesPraticasLLM)
                                            || !string.IsNullOrEmpty(destino.MalaViagemLLM);
                                    }
                                    @if (_hasInsights)
                                    {
                                        <!-- Insights para o Agente -->
                                        <div class="border-top pt-3 mt-3">
                                            <div class="dest-insights-panel">
                                                <div class="panel-title">
                                                    <i class="fas fa-brain me-1"></i>Insights para o Agente
                                                </div>
                                                @Html.Raw(RenderTemasAccordion(destino, _accId))
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
}
else
{
    <div class="text-center py-5">
        <i class="fas fa-map-marked-alt fa-4x text-muted mb-3"></i>
        <h5 class="text-muted">Nenhum destino adicionado</h5>
        <p class="text-muted">Comece adicionando o primeiro destino da viagem usando o formulário acima.</p>
    </div>
}

<!-- Adicionar Novo Destino -->
<div class="row mb-4">
    <div class="col-md-12">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0"><i class="fas fa-plus me-2"></i>Adicionar Novo Destino</h5>
            </div>
            <div class="card-body">
                <form asp-action="AdicionarDestino" method="post">
                    <input type="hidden" id="propostaId" name="propostaId" value="@Model.Id" />

                    <div class="row">
                        <div class="col-md-3 mb-3 position-relative">
                            <label class="form-label">Nome do Destino *</label>
                            <input type="text" name="nome" id="nomeDestino" class="form-control" placeholder="Ex: Paris, França" required autocomplete="off" />
                            <div id="sugestoesDestino" class="list-group mt-1" style="position: absolute; z-index: 9999; width: 100%;"></div>
                        </div>
                        <div class="col-md-2 mb-3">
                            <label class="form-label">País</label>
                            <input type="text" name="pais" class="form-control" placeholder="França" id="campoPais"  />
                        </div>
                        <div class="col-md-2 mb-3">
                            <label class="form-label">Cidade</label>
                            <input type="text" name="cidade" class="form-control" placeholder="Paris" id="campoCidade" />
                        </div>
                        <div class="col-md-2 mb-3">
                            <label class="form-label">Data Chegada</label>
                            <input type="date" name="dataChegada" class="form-control" />
                        </div>
                        <div class="col-md-2 mb-3">
                            <label class="form-label">Data Saída</label>
                            <input type="date" name="dataSaida" class="form-control" />
                        </div>
                        <div class="col-md-1 mb-3 d-flex align-items-end">
                            <button type="submit" class="btn btn-success w-100">
                                <i class="fas fa-plus"></i>
                            </button>
                        </div>
                        <div type="hidden" class="col-md-3 mb-3 position-relative">
                            <input type="hidden" name="latitude" id="latitude" />
                        </div>
                        <div type="hidden" class="col-md-3 mb-3 position-relative">
                            <input type="hidden" name="longitude" id="longitude" />
                        </div>
                    </div>

                    <div class="mb-2">
                    <label for="Nome" class="form-label">Destino/Cidade</label>
                    <input id="Nome" name="nome" class="form-control" />
                    </div>

                    <button type="button" id="btnGerarDesc" class="btn btn-outline-primary">
                    Gerar descrição com IA
                    </button>

                    <!-- Editor exibido após gerar -->
                    <div id="editor-llm" class="mt-3 d-none">
                    <label class="form-label">Descrição</label>
                    <textarea id="Descricao" name="descricao" rows="5" class="form-control"></textarea>

                    <!-- Preview de Insights para o Agente (preenchido via JS após geração) -->
                    <div id="novo-dest-insights" class="mt-3 d-none">
                        <div class="dest-insights-panel">
                            <div class="panel-title"><i class="fas fa-brain me-1"></i>Preview — Insights para o Agente</div>
                            <div id="novo-dest-insights-body" class="accordion"></div>
                        </div>
                    </div>

                    <!-- Se quiser salvar campos estruturados também -->
                    <label class="form-label mt-3">Atrações (JSON)</label>
                    <textarea id="AtracoesLLM" name="AtracoesLLM" rows="6" class="form-control"></textarea>

                    <label class="form-label mt-3">Pratos Tipicos (JSON)</label>
                    <textarea id="pratosTipicosLLM" name="pratosTipicosLLM" rows="5" class="form-control"></textarea>

                    <label class="form-label mt-3">Gastronomia (JSON)</label>
                    <textarea id="GastronomiaLLM" name="GastronomiaLLM" rows="6" class="form-control"></textarea>

                    <label class="form-label mt-3">Informações práticas (JSON)</label>
                    <textarea id="InformacoesPraticasLLM" name="InformacoesPraticasLLM" rows="6" class="form-control"></textarea>

                    <label class="form-label mt-3">Mala de viagem (JSON)</label>
                    <textarea id="MalaViagemLLM" name="MalaViagemLLM" rows="5" class="form-control"></textarea>

                    <label class="form-label mt-3">Cuidados (JSON)</label>
                    <textarea id="CuidadosLLM" name="CuidadosLLM" rows="5" class="form-control"></textarea>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>


<!-- Modal Universal para Upload de Foto - CORRIGIDO Z-INDEX -->
<div class="modal fade modal-upload-foto" id="modalUploadFoto" tabindex="-1" aria-labelledby="modalUploadFotoLabel" aria-hidden="true" data-bs-backdrop="static" data-bs-keyboard="false">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalUploadFotoLabel">
                    <i class="fas fa-camera me-2"></i>Adicionar Foto - <span id="nomeDestinoModal"></span>
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-controller="DestinoFoto" asp-action="AdicionarFoto" method="post" enctype="multipart/form-data" id="formUploadFoto">
                <div class="modal-body">
                    <input type="hidden" name="destinoId" id="destinoIdInput" value="" />

                    <div class="mb-3">
                        <label class="form-label fw-bold">
                            <i class="fas fa-image me-1"></i>Foto *
                        </label>
                        <input type="file" name="foto" id="fotoInput" class="form-control" accept="image/*" required />
                        <div class="form-text">
                            <i class="fas fa-info-circle me-1"></i>
                            Formatos: JPG, PNG, GIF, WebP (máx: 10MB)
                        </div>
                        <div id="previewContainer" class="mt-3" style="display: none;">
                            <img id="previewImage" class="img-fluid rounded" style="max-height: 200px;" />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">
                            <i class="fas fa-comment me-1"></i>Descrição <span class="text-muted">(Opcional)</span>
                        </label>
                        <input type="text" name="descricao" id="descricaoInput" class="form-control" 
                               placeholder="Descrição da foto (opcional)" maxlength="200" />
                        <div class="form-text">Descreva brevemente o que a foto mostra</div>
                    </div>

                    <div class="form-check">
                        <input type="checkbox" name="principal" id="principalInput" class="form-check-input" />
                        <label class="form-check-label" for="principalInput">
                            <i class="fas fa-star me-1"></i>Definir como foto principal deste destino
                        </label>
                        <div class="form-text">A foto principal aparece como destaque no destino</div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                        <i class="fas fa-times me-1"></i>Cancelar
                    </button>
                    <button type="submit" class="btn btn-success" id="btnUpload">
                        <i class="fas fa-upload me-1"></i>Adicionar Foto
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal: Adicionar Hospedagem -->
<div class="modal fade" id="modalAdicionarHospedagem" tabindex="-1" aria-hidden="true" data-bs-backdrop="static">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-info bg-opacity-10">
                <h5 class="modal-title"><i class="fas fa-hotel me-2 text-info"></i>Adicionar Hospedagem — <span id="nomeDestinoHospedagem"></span></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-controller="Hospedagem" asp-action="Adicionar" method="post" id="formAdicionarHospedagem">
                <div class="modal-body">
                    <input type="hidden" name="destinoId" id="destinoIdHospedagem" />
                    <input type="hidden" name="latitude" id="hospLatitude" />
                    <input type="hidden" name="longitude" id="hospLongitude" />
                    <input type="hidden" id="hospCidadeContexto" />

                    <!-- Nome com autocomplete -->
                    <div class="row">
                        <div class="col-md-8 mb-3 position-relative">
                            <label class="form-label fw-semibold">Nome da Hospedagem *</label>
                            <input type="text" name="nome" id="hospNomeInput" class="form-control" placeholder="Ex: Hotel Marriott, Pousada da Praia..." required autocomplete="off" />
                            <div id="hospSugestoes" class="list-group mt-1" style="position:absolute;z-index:9999;width:calc(100% - 24px);max-height:220px;overflow-y:auto;"></div>
                            <div class="form-text"><i class="fas fa-search me-1 text-muted"></i>Digite o nome para buscar sugestões no Google</div>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label fw-semibold">Categoria</label>
                            <select name="categoria" id="hospCategoriaSelect" class="form-select">
                                <option value="1">Hotel</option>
                                <option value="2">Pousada</option>
                                <option value="3">Resort</option>
                                <option value="4">Hotel Fazenda</option>
                                <option value="5">Aluguel de Casa</option>
                                <option value="6">Camping</option>
                                <option value="7">Outros</option>
                            </select>
                        </div>
                    </div>

                    <!-- Endereço preenchido automaticamente pelo Google -->
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Endereço</label>
                        <div class="input-group">
                            <input type="text" name="endereco" id="hospEnderecoInput" class="form-control" placeholder="Preenchido automaticamente ao selecionar sugestão" />
                            <span class="input-group-text text-muted" id="hospCoordBadge" style="font-size:0.75rem;display:none;">
                                <i class="fas fa-map-pin me-1 text-success"></i><span id="hospCoordTexto"></span>
                            </span>
                        </div>
                    </div>

                    <!-- Descrição com IA -->
                    <div class="mb-3">
                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <label class="form-label fw-semibold mb-0">Descrição</label>
                            <button type="button" id="btnGerarDescHosp" class="btn btn-outline-primary btn-sm" disabled>
                                <i class="fas fa-magic me-1"></i>Gerar com IA
                            </button>
                        </div>
                        <textarea name="descricao" id="hospDescricaoInput" class="form-control" rows="3" placeholder="Selecione uma sugestão ou clique em 'Gerar com IA' para preencher automaticamente..."></textarea>
                        <div id="hospIaLoader" class="text-center py-2 d-none">
                            <div class="spinner-border spinner-border-sm text-primary me-2"></div>
                            <small class="text-muted">Consultando IA...</small>
                        </div>
                    </div>

                    <!-- Comodidades (preenchidas pela IA, editáveis pelo usuário) -->
                    <input type="hidden" name="comodidadesJson" id="hospComodidadesJson" value="" />
                    <div class="mb-3" id="hospComodidadesDiv" style="display:none;">
                        <label class="form-label fw-semibold">Comodidades <small class="text-muted">(geradas pela IA — você pode adicionar ou remover)</small></label>
                        <div id="hospComodidadesBadges" class="d-flex flex-wrap gap-1 mb-2"></div>
                        <div class="input-group input-group-sm">
                            <input type="text" id="hospNovaComodidade" class="form-control" placeholder="Adicionar comodidade manualmente..." maxlength="200" />
                            <button type="button" class="btn btn-outline-secondary" id="btnHospAddComodidade">
                                <i class="fas fa-plus"></i>
                            </button>
                        </div>
                    </div>
                    <div class="mb-2" id="hospComodidadesDivEmpty">
                        <label class="form-label fw-semibold">Comodidades</label>
                        <div class="input-group input-group-sm">
                            <input type="text" id="hospNovaComodidadeEmpty" class="form-control" placeholder="Adicionar comodidade manualmente..." maxlength="200" />

                                                <option value="">— Selecionar —</option>
                                                <option value="1" selected="@(_cliGenero == 1 ? "selected" : null)">Masculino</option>
                                                <option value="2" selected="@(_cliGenero == 2 ? "selected" : null)">Feminino</option>
                                                <option value="3" selected="@(_cliGenero == 3 ? "selected" : null)">Outro</option>
                                            </select>
                                        </div>
                                        <div class="col-md-3">
                                            <label class="form-label form-label-sm mb-0">CPF</label>
                                            <input type="text" name="cpf" class="form-control form-control-sm"
                                                   value="@cliente.Cpf" maxlength="20"
                                                   placeholder="000.000.000-00" />
                                        </div>
                                        <div class="col-md-3">
                                            <label class="form-label form-label-sm mb-0">Nova Foto</label>
                                            <input type="file" name="foto" class="form-control form-control-sm"
                                                   accept="image/*" />

                                    <input type="date" name="dataNascimento" id="add-pax-dob"
                                           class="form-control form-control-sm" />
                                </div>
                                <div class="col-md-2">
                                    <label class="form-label form-label-sm mb-0">Gênero</label>
                                    <select name="genero" class="form-select form-select-sm">
                                        <option value="">—</option>
                                        <option value="1">Masculino</option>
                                        <option value="2">Feminino</option>
                                        <option value="3">Outro</option>
                                    </select>
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label form-label-sm mb-0">Relacionamento</label>
                                    <select name="relacionamento" class="form-select form-select-sm">
                                        <option value="">— Selecionar —</option>
                                        <option value="1">Filho</option>
                                        <option value="2">Filha</option>
                                        <option value="3">Amigo</option>
                                        <option value="4">Amiga</option>
                                        <option value="5">Esposa</option>
                                        <option value="6">Marido</option>
                                        <option value="7">Sogra</option>
                                        <option value="8">Sogro</option>
                                        <option value="9">Cunhado</option>
                                        <option value="10">Cunhada</option>
                                        <option value="11">Neto</option>
                                        <option value="12">Neta</option>
                                        <option value="13">Pai</option>
                                        <option value="14">Mãe</option>
                                        <option value="15">Irmão</option>
                                        <option value="16">Irmã</option>
                                        <option value="99">Outro</option>
                                    </select>
                                </div>
                                <div class="col-12">

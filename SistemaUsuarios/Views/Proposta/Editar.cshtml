                                    <input type="hidden" name="propostaId" value="@proposta.Id" />
                                    <div class="row g-2 mb-2">
                                        <div class="col-md-4">
                                            <label class="form-label form-label-sm mb-0">Nome <span class="text-danger">*</span></label>
                                            <input type="text" name="nome" class="form-control form-control-sm"
                                                   value="@cliente.Nome" required maxlength="200" />
                                        </div>
                                        <div class="col-md-4">
                                            <label class="form-label form-label-sm mb-0">Email</label>
                                            <input type="email" name="email" class="form-control form-control-sm"
                                                   value="@cliente.Email" maxlength="200" />
                                        </div>
                                        <div class="col-md-4">
                                            <label class="form-label form-label-sm mb-0">Telefone</label>
                                            <input type="text" name="telefone" class="form-control form-control-sm"
                                                   value="@cliente.Telefone" maxlength="30" />
                                        </div>
                                        <div class="col-md-3">
                                            <label class="form-label form-label-sm mb-0">Data de Nascimento</label>
                                            <input type="date" name="dataNascimento" class="form-control form-control-sm"
                                                   value="@cliente.DataNascimento?.ToString("yyyy-MM-dd")" />
                                        </div>
                                        <div class="col-md-3">
                                            <label class="form-label form-label-sm mb-0">Gênero</label>
                                            @{ var _cliGenero = (int?)cliente.Genero; }

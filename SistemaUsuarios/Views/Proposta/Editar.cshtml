        // ============================================================
        // ============================================================
        // MINI RICH EDITOR — DESCRIÇÃO DE HOSPEDAGEM
        // ============================================================
        function configurarHospRichEditors() {
            // Bold buttons
            document.querySelectorAll('.hosp-bold-btn').forEach(function(btn) {
                btn.addEventListener('click', function() {
                    const editorId = this.dataset.editor;
                    const editor = document.getElementById(editorId);
                    if (!editor) return;
                    editor.focus();
                    document.execCommand('bold', false, null);
                });
            });

            // Paste: strip to plain text
            document.querySelectorAll('.hosp-rich-desc').forEach(function(editor) {
                editor.addEventListener('paste', function(e) {
                    e.preventDefault();
                    const text = (e.clipboardData || window.clipboardData).getData('text/plain');
                    document.execCommand('insertText', false, text);
                });
            });

            // On form submit: sync innerHTML → hidden input (both add and edit forms)
            document.querySelectorAll('form[action*="Hospedagem/Editar"], form[action*="Hospedagem/Adicionar"]').forEach(function(form) {
                form.addEventListener('submit', function() {
                    const editor = this.querySelector('.hosp-rich-desc');
                    const hidden = this.querySelector('.hosp-rich-desc-val');
                    if (editor && hidden) {
                        hidden.value = editor.innerHTML.trim();
                    }
                });
            });
        }

        // VALIDAÇÃO FORMULÁRIOS
        // ============================================================
        function configurarValidacaoFormularios() {
            const formAdicionarDestino = document.querySelector('form[action*="AdicionarDestino"]');
            if (formAdicionarDestino) {
                formAdicionarDestino.addEventListener('submit', function (e) {
                    const dataChegada = this.querySelector('input[name="dataChegada"]')?.value;
                    const dataSaida   = this.querySelector('input[name="dataSaida"]')?.value;
                    if (dataChegada && dataSaida && new Date(dataChegada) > new Date(dataSaida)) {
                        e.preventDefault();
                        showErrorAlert('Data de saída deve ser posterior à data de chegada');
                    }
                });
            }
            document.querySelectorAll('form[action*="EditarDestino"]').forEach(function (form) {
                form.addEventListener('submit', function (e) {
                    const dataChegada = this.querySelector('input[name="dataChegada"]')?.value;
                    const dataSaida   = this.querySelector('input[name="dataSaida"]')?.value;
                    if (dataChegada && dataSaida && new Date(dataChegada) > new Date(dataSaida)) {
                        e.preventDefault();
                        showErrorAlert('Data de saída deve ser posterior à data de chegada');
                    }
                });
            });
        }

        // ============================================================
        // UTILITÁRIOS
        // ============================================================
        function getRequestVerificationToken() {
            const token = document.querySelector('input[name="__RequestVerificationToken"]');
            return token ? token.value : '';
        }

        function showSuccessAlert(message) {
            const alert = document.createElement('div');
            alert.className = 'alert alert-success alert-dismissible fade show position-fixed';
            alert.style.cssText = 'top:20px;right:20px;z-index:99999;min-width:300px;';
            alert.innerHTML = `<i class="fas fa-check me-2"></i>${message}<button type="button" class="btn-close" data-bs-dismiss="alert"></button>`;
            document.body.appendChild(alert);
            setTimeout(() => { if (alert.parentNode) alert.remove(); }, 3000);
        }

        function showErrorAlert(message) {
            const alert = document.createElement('div');
            alert.className = 'alert alert-danger alert-dismissible fade show position-fixed';
            alert.style.cssText = 'top:20px;right:20px;z-index:99999;min-width:300px;';
            alert.innerHTML = `<i class="fas fa-exclamation-triangle me-2"></i>${message}<button type="button" class="btn-close" data-bs-dismiss="alert"></button>`;
            document.body.appendChild(alert);
            setTimeout(() => { if (alert.parentNode) alert.remove(); }, 5000);
        }

        // ── Autocomplete de busca de cliente ─────────────────────────────────
        (function () {
            const input = document.getElementById('cliente-busca-input');
            const resultados = document.getElementById('cliente-busca-resultados');
            const idInput = document.getElementById('cliente-id-selecionado');
            const preview = document.getElementById('cliente-selecionado-preview');
            const btnConfirmar = document.getElementById('btn-confirmar-associar');

            if (!input) return;

            let debounce;
            input.addEventListener('input', function () {
                clearTimeout(debounce);
                const termo = this.value.trim();
                idInput.value = '';
                preview.style.display = 'none';
                btnConfirmar.style.display = 'none';

                if (termo.length < 2) {
                    resultados.style.display = 'none';
                    resultados.innerHTML = '';
                    return;
                }

                debounce = setTimeout(async () => {
                    try {
                        const resp = await fetch(`/Cliente/Buscar?termo=${encodeURIComponent(termo)}`);
                        const lista = await resp.json();

                        resultados.innerHTML = '';
                        if (lista.length === 0) {
                            resultados.innerHTML = '<div class="list-group-item list-group-item-action disabled small text-muted">Nenhum cliente encontrado</div>';
                            resultados.style.display = 'block';
                            return;
                        }

                        lista.forEach(c => {
                            const item = document.createElement('a');
                            item.href = '#';
                            item.className = 'list-group-item list-group-item-action py-2';
                            item.innerHTML = `
                                <div class="d-flex align-items-center gap-2">
                                    ${c.fotoPath
                                        ? `<img src="${c.fotoPath}" class="rounded-circle" style="width:28px;height:28px;object-fit:cover;">`
                                        : `<div class="rounded-circle bg-primary d-flex align-items-center justify-content-center" style="width:28px;height:28px;flex-shrink:0;"><i class="fas fa-user text-white" style="font-size:0.6rem;"></i></div>`}
                                    <div>
                                        <div class="fw-semibold small">${c.nome}</div>
                                        <div class="text-muted" style="font-size:0.75rem;">
                                            ${c.email ? c.email : ''}
                                            ${c.idadeCalculada ? ` · ${c.idadeCalculada} anos` : ''}
                                        </div>
                                    </div>
                                </div>`;
                            item.addEventListener('click', function (e) {
                                e.preventDefault();
                                input.value = c.nome;
                                idInput.value = c.id;
                                resultados.style.display = 'none';
                                preview.style.display = 'block';
                                preview.innerHTML = `<i class="fas fa-check-circle text-success me-1"></i>
                                    Selecionado: <strong>${c.nome}</strong>${c.email ? ` — ${c.email}` : ''}`;
                                btnConfirmar.style.display = 'inline-block';
                            });
                            resultados.appendChild(item);
                        });
                        resultados.style.display = 'block';
                    } catch { /* ignore */ }
                }, 300);
            });

            document.addEventListener('click', function (e) {
                if (!input.contains(e.target) && !resultados.contains(e.target)) {
                    resultados.style.display = 'none';
                }
            });
        })();

        // ── Quill — fábrica reutilizável para editores da aba Condições ──────
        function criarEditorCondicoes(editorId, btnId, statusId, actionUrl, placeholder, conteudoInicial) {
            const editorEl = document.getElementById(editorId);
            if (!editorEl || typeof Quill === 'undefined') return;

            const propostaId = '@(proposta?.Id)';
            const statusEl   = document.getElementById(statusId);
            const btnSalvar  = document.getElementById(btnId);

            const quill = new Quill('#' + editorId, {
                theme: 'snow',
                placeholder: placeholder,
                modules: {
                    toolbar: [
                        [{ header: [2, 3, false] }],
                        ['bold', 'italic', 'underline', 'strike'],
                        [{ color: [] }, { background: [] }],
                        [{ list: 'ordered' }, { list: 'bullet' }],
                        ['blockquote', 'link'],
                        [{ table: [] }],
                        ['image'],
                        ['clean']
                    ]
                }
            });

            if (conteudoInicial) {
                quill.clipboard.dangerouslyPasteHTML(0, conteudoInicial);
            }

            function setStatus(msg, cls) {
                if (!statusEl) return;
                statusEl.textContent = msg;
                statusEl.className = 'me-2 ' + (cls || 'text-white-50');
            }

            async function salvar() {
                const html = quill.root.innerHTML;
                const conteudo = html === '<p><br></p>' ? '' : html;
                setStatus('Salvando…', 'text-white-50');
                try {
                    const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';
                    const resp = await fetch(actionUrl, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                        body: new URLSearchParams({ id: propostaId, conteudo, __RequestVerificationToken: token })
                    });
                    const json = await resp.json();
                    setStatus(json.ok ? 'Salvo ✓' : 'Erro ao salvar', json.ok ? 'text-white-50' : 'text-warning');
                    if (json.ok) setTimeout(() => setStatus(''), 3000);
                } catch {
                    setStatus('Erro de rede', 'text-warning');
                }
            }

            let _debounce;
            quill.on('text-change', function () {
                setStatus('Não salvo', 'text-warning');
                clearTimeout(_debounce);
                _debounce = setTimeout(salvar, 2000);
            });

            if (btnSalvar) btnSalvar.addEventListener('click', function () {
                clearTimeout(_debounce);
                salvar();
            });
        }

        criarEditorCondicoes(
            'condicoes-editor', 'btn-salvar-condicoes', 'condicoes-status',
            '@Url.Action("SalvarCondicoesProposta","Proposta")',
            'Escreva aqui as condições gerais da proposta: cancelamento, documentação, inclusões, exclusões…',
            @Html.Raw(System.Text.Json.JsonSerializer.Serialize(proposta?.CondicoesPropostaHtml))
        );

        criarEditorCondicoes(
            'valores-editor', 'btn-salvar-valores', 'valores-status',
            '@Url.Action("SalvarValoresProposta","Proposta")',
            'Informe valores, formas de pagamento, parcelamento, observações financeiras…',
            @Html.Raw(System.Text.Json.JsonSerializer.Serialize(proposta?.ValoresPropostaHtml))
        );

        @{
            var novoDestinoId = TempData["NovoDestinoId"]?.ToString();
        }
        @if (!string.IsNullOrEmpty(novoDestinoId))
        {
            <text>
        // Auto-expand do destino recém-adicionado
        (function () {
            var collapseEl = document.getElementById('detalhes-@novoDestinoId');
            if (!collapseEl) return;
            var bsCollapse = bootstrap.Collapse.getOrCreateInstance(collapseEl, { toggle: false });
            bsCollapse.show();
            collapseEl.addEventListener('shown.bs.collapse', function () {
                collapseEl.closest('.list-group-item')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
            }, { once: true });
        })();
            </text>
        }
    </script>
}

<style>

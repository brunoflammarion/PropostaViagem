<!-- ============================================================ -->
<!-- MODALS                                                        -->
<!-- ============================================================ -->

<!-- Modal: Adicionar Voo -->
<div class="modal fade" id="modalAdicionarVoo" tabindex="-1" data-bs-backdrop="static">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="fas fa-plane me-2 text-white"></i>Adicionar Voo</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-controller="Voo" asp-action="Adicionar" method="post" id="formNovoVoo">
                @Html.AntiForgeryToken()
                <input type="hidden" name="propostaId" value="@(proposta?.Id)" />
                <div class="modal-body pb-2">

                    <!-- Alerta busca automática -->
                    <div id="novo-voo-alert" class="d-none mb-3"></div>

                    <!-- Linha 1: Data · Companhia · Nº Voo + [Buscar] -->
                    <div class="row g-3 mb-3">
                        <div class="col-sm-3">
                            <label class="form-label fw-semibold">Data do voo</label>
                            <input type="date" id="novo-data-voo" class="form-control"
                                   onchange="onNovoDataVooChange()" />
                        </div>
                        <div class="col-sm-3">
                            <label class="form-label fw-semibold">Companhia <span class="text-danger">*</span></label>
                            <input type="text" name="companhia" id="novo-companhia" class="form-control"
                                   list="airlines-datalist"
                                   required maxlength="100" placeholder="Selecione ou informe o código ICAO..." />
                            <div class="form-text text-muted" style="font-size:0.7rem">Para busca automática, selecione ou informe o ICAO (ex: AZU, GLO, TAM)</div>
                        </div>
                        <div class="col-sm-6">
                            <label class="form-label fw-semibold">Nº do Voo <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <input type="text" name="numeroVoo" id="novoVooNumero" class="form-control"
                                       required maxlength="20" placeholder="LA1234"
                                       style="text-transform:uppercase" />
                                <button type="button" class="btn btn-outline-info" id="btnBuscarModal"
                                        onclick="consultarVooModal()"
                                        title="Buscar dados do voo via AeroDataBox">
                                    <i class="fas fa-search me-1"></i>Buscar dados
                                </button>
                            </div>
                        </div>
                    </div>

                    <!-- Linha 2: Origem · Destino -->
                    <div class="row g-3 mb-3">
                        <div class="col-sm-6">
                            <label class="form-label fw-semibold">Origem <span class="text-danger">*</span></label>
                            <input type="text" name="origem" id="novo-origem" class="form-control"
                                   required maxlength="200" placeholder="São Paulo (GRU)" />
                        </div>
                        <div class="col-sm-6">
                            <label class="form-label fw-semibold">Destino <span class="text-danger">*</span></label>
                            <input type="text" name="destino" id="novo-destino" class="form-control"
                                   required maxlength="200" placeholder="Rio de Janeiro (GIG)" />
                        </div>
                    </div>

                    <!-- Linha 3: Saída · Chegada · Duração · Tipo · Classe -->
                    <div class="row g-3 mb-3">
                        <div class="col-sm-3">
                            <label class="form-label fw-semibold">Saída</label>
                            <input type="datetime-local" name="horarioSaida" id="novo-saida" class="form-control"
                                   onchange="onNovoSaidaChange()" />
                        </div>
                        <div class="col-sm-3">
                            <label class="form-label fw-semibold">Chegada</label>
                            <input type="datetime-local" name="horarioChegada" id="novo-chegada" class="form-control" />
                        </div>
                        <div class="col-sm-2">
                            <label class="form-label fw-semibold">Duração</label>
                            <input type="text" name="duracao" id="novo-duracao" class="form-control"
                                   maxlength="20" placeholder="2h30" />
                        </div>
                        <div class="col-sm-2">
                            <label class="form-label fw-semibold">Tipo</label>
                            <select name="tipoVoo" class="form-select" required>
                                <option value="1">✈️ Ida</option>
                                <option value="3">🔄 Interno</option>
                                <option value="2">🛬 Volta</option>
                            </select>
                        </div>
                        <div class="col-sm-2">
                            <label class="form-label fw-semibold">Classe</label>
                            <select name="classe" class="form-select">
                                <option value="">— Classe —</option>
                                <option value="Econômica">Econômica</option>
                                <option value="Econômica Premium">Econômica Premium</option>
                                <option value="Executiva">Executiva</option>
                                <option value="Primeira Classe">Primeira Classe</option>
                                <option value="Outra">Outra</option>
                            </select>
                        </div>
                    </div>

                    <!-- Bagagem (colapsável) -->
                    <div class="border-top pt-2">
                        <button type="button"
                                class="btn btn-link btn-sm text-muted px-0 py-1 text-decoration-none"
                                data-bs-toggle="collapse" data-bs-target="#novo-bagagem-collapse">
                            <i class="fas fa-suitcase-rolling me-1"></i>Bagagem permitida
                            <small class="text-muted ms-1">(opcional)</small>
                        </button>
                        <div class="collapse" id="novo-bagagem-collapse">
                            <div class="row g-2 pt-1">
                                <div class="col-12"><span class="small fw-semibold" style="color:#374151;font-size:.78rem;">Item pessoal</span></div>
                                <div class="col-sm-5">
                                    <input type="text" name="bagagemItemPessoalDescricao" class="form-control form-control-sm"
                                           maxlength="200" placeholder="Tipo / descrição (ex: bolsa, mochila)" />
                                </div>
                                <div class="col-sm-4">
                                    <input type="text" name="bagagemItemPessoalMedidas" class="form-control form-control-sm"
                                           maxlength="100" placeholder="Medidas (40×30×15 cm)" />

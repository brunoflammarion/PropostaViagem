        $(document).on('click', '.btn-gerar-desc-hosp', function () {
            const $container = getHospContainer(this);
            const nome = $container.data('hosp-nome-selecionado') || $container.find('.hosp-nome-input').val();
            const cidade = $container.data('cidade') || '';
            if (!nome) return;
            const $btn = $(this);
            $btn.prop('disabled', true);
            $container.find('.hosp-ia-loader').removeClass('d-none');
            $.post('/Hospedagem/GerarDescricaoHospedagem', { nome, cidade }, function (data) {
                if (typeof data === 'string') data = JSON.parse(data);
                if (data.descricao) {
                    const $editor = $container.find('.hosp-rich-desc');
                    if ($editor.length) $editor.text(data.descricao);
                }
                if (data.comodidades && Array.isArray(data.comodidades) && data.comodidades.length > 0) {
                    const comodidades = $container.data('comodidades') || [];
                    const novas = data.comodidades.filter(c => !comodidades.some(e => e.toLowerCase() === c.toLowerCase()));
                    const merged = [...comodidades, ...novas];
                    $container.data('comodidades', merged);
                    renderHospComodidadesInContainer($container);
                }
            }).fail(function () {
                showErrorAlert('Erro ao consultar IA. Tente novamente.');
            }).always(function () {
                $container.find('.hosp-ia-loader').addClass('d-none');
                $btn.prop('disabled', false);
            });
        });


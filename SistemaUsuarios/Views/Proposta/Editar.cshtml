            }

            btn.disabled = true;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i>Gerando...';
            if (alertEl) alertEl.className = 'd-none';

            try {
                const resp = await fetch('@Url.Action("GerarDescricao","Destino")', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8' },
                    body: new URLSearchParams({ nome })
                });
                const text = await resp.text();
                if (!resp.ok) throw new Error(text);
                const data = JSON.parse(text);

                if (descEl) descEl.value = data.descricao ?? '';
                const set = (id, val) => { const el = document.getElementById(id + destinoId); if (el && val) el.value = JSON.stringify(val, null, 2); };

                                        <input type="checkbox" name="faixaIsAproximada" value="true"
                                               id="add-faixa-chk" class="form-check-input">
                                        <label for="add-faixa-chk" class="form-check-label small text-muted">
                                            Data de nascimento não informada — usar faixa etária aproximada
                                        </label>
                                    </div>
                                    <select name="faixaEtaria" id="add-faixa-select"
                                            class="form-select form-select-sm mt-1" style="display:none;">
                                        <option value="">— Faixa etária —</option>
                                        <option value="1">Bebê (menos de 2 anos)</option>
                                        <option value="2">Criança (2 a 11 anos)</option>
                                        <option value="3">Adolescente (12 a 17 anos)</option>
                                        <option value="4">Adulto (18 anos ou mais)</option>
                                    </select>
                                </div>
                                <div class="col-md-4" id="add-modo-bebe-wrap" style="display:none;">
                                    <label class="form-label form-label-sm mb-0">Modo bebê</label>
                                    <select name="modoBebe" class="form-select form-select-sm">
                                        <option value="">— Selecionar —</option>
                                        <option value="1">No colo</option>
                                        <option value="2">Assento próprio</option>
                                    </select>
                                </div>
                                <div class="col-12">
                                    <label class="form-label form-label-sm mb-0">Observações</label>
                                    <input type="text" name="observacoes" class="form-control form-control-sm"
                                           maxlength="2000" placeholder="Opcional..." />
                                </div>
                            </div>
                            <div class="d-flex gap-2">
                                <button type="submit" class="btn btn-sm btn-info text-white">
                                    <i class="fas fa-plus me-1"></i>Adicionar
                                </button>
                                <button type="button" class="btn btn-sm btn-outline-secondary"
                                        data-bs-toggle="collapse"
                                        data-bs-target="#add-passageiro-form">
                                    Cancelar
                                </button>
                            </div>
                        </form>
                    </div>
                </div>

                <!-- Passageiros da viagem -->
                @foreach (var pax in proposta.PassageirosProposta.OrderBy(p => p.Ordem))
                {
                    var refDatePax = proposta.DataInicio ?? DateTime.Today;
                    var paxRelLabel = pax.Relacionamento.HasValue ? pax.Relacionamento switch {
                        SistemaUsuarios.Models.RelacionamentoPassageiro.Filho => "Filho",
                        SistemaUsuarios.Models.RelacionamentoPassageiro.Filha => "Filha",
                        SistemaUsuarios.Models.RelacionamentoPassageiro.Amigo => "Amigo",
                        SistemaUsuarios.Models.RelacionamentoPassageiro.Amiga => "Amiga",
                        SistemaUsuarios.Models.RelacionamentoPassageiro.Esposa => "Esposa",
                        SistemaUsuarios.Models.RelacionamentoPassageiro.Marido => "Marido",
                        SistemaUsuarios.Models.RelacionamentoPassageiro.Sogra => "Sogra",
                        SistemaUsuarios.Models.RelacionamentoPassageiro.Sogro => "Sogro",
                        SistemaUsuarios.Models.RelacionamentoPassageiro.Cunhado => "Cunhado",
                        SistemaUsuarios.Models.RelacionamentoPassageiro.Cunhada => "Cunhada",
                        SistemaUsuarios.Models.RelacionamentoPassageiro.Neto => "Neto",
                        SistemaUsuarios.Models.RelacionamentoPassageiro.Neta => "Neta",
                        SistemaUsuarios.Models.RelacionamentoPassageiro.Pai => "Pai",
                        SistemaUsuarios.Models.RelacionamentoPassageiro.Mae => "Mãe",
                        SistemaUsuarios.Models.RelacionamentoPassageiro.Irmao => "Irmão",
                        SistemaUsuarios.Models.RelacionamentoPassageiro.Irma => "Irmã",
                        _ => "Outro"
                    } : null;
                    var paxAgeOnTrip = pax.DataNascimento.HasValue
                        ? AgeService.GetAgeOnDate(pax.DataNascimento.Value, refDatePax)
                        : (int?)null;
                    var paxCatOnTrip = pax.DataNascimento.HasValue
                        ? AgeService.GetCategory(pax.DataNascimento.Value, refDatePax)
                        : (PassengerAgeCategory?)null;
                    var paxCatLabel = paxCatOnTrip.HasValue ? AgeService.GetCategoryLabel(paxCatOnTrip.Value) : null;
                    var paxFaixaLabel = (!pax.DataNascimento.HasValue && pax.FaixaIsAproximada && pax.FaixaEtaria.HasValue)
                        ? pax.FaixaEtaria switch {
                            SistemaUsuarios.Models.FaixaEtariaPassageiro.Bebe => "Bebê (aprox.)",
                            SistemaUsuarios.Models.FaixaEtariaPassageiro.Crianca => "Criança (aprox.)",
                            SistemaUsuarios.Models.FaixaEtariaPassageiro.Adolescente => "Adolescente (aprox.)",
                            _ => "Adulto (aprox.)"
                        } : null;
                    var _paxGenero = (int?)pax.Genero;
                    var _paxRel = (int?)pax.Relacionamento;
                    var _paxFaixa = (int?)pax.FaixaEtaria;
                    var _paxModo = (int?)pax.ModoBebe;
                    <div class="card mb-2 border-info" style="overflow:visible;">
                        <div class="card-header bg-light d-flex align-items-center gap-2 py-2">
                            <div class="rounded-circle bg-info d-flex align-items-center justify-content-center flex-shrink-0"
                                 style="width:32px;height:32px;">
                                <i class="fas fa-user text-white" style="font-size:0.7rem;"></i>
                            </div>
                            <div class="flex-grow-1">
                                <span class="fw-semibold">@pax.Nome</span>
                                @if (paxRelLabel != null)
                                {
                                    <span class="badge bg-info text-dark ms-2">@paxRelLabel</span>
                                }
                                @if (paxCatLabel != null)
                                {
                                    <span class="badge bg-secondary ms-1">@paxCatLabel</span>
                                }
                                else if (paxFaixaLabel != null)
                                {
                                    <span class="badge bg-secondary ms-1">@paxFaixaLabel</span>
                                }
                                @if (paxAgeOnTrip.HasValue)
                                {
                                    <span class="text-muted small ms-2">@paxAgeOnTrip anos na viagem</span>
                                }
                                @if (pax.DataNascimento.HasValue)
                                {
                                    <span class="text-muted small ms-1">(@pax.DataNascimento.Value.ToString("dd/MM/yyyy"))</span>
                                }
                                @if (pax.ModoBebe.HasValue)
                                {
                                    <span class="text-muted small ms-2">
                                        @(pax.ModoBebe == SistemaUsuarios.Models.ModoBebe.Colo ? "No colo" : "Assento próprio")
                                    </span>
                                }
                                @if (pax.Genero.HasValue)
                                {
                                    <span class="text-muted small ms-2">
                                        @(pax.Genero == SistemaUsuarios.Models.Genero.Masculino ? "Masc." :
                                          pax.Genero == SistemaUsuarios.Models.Genero.Feminino ? "Fem." : "Outro")
                                    </span>
                                }
                                @if (!string.IsNullOrEmpty(pax.Observacoes))
                                {
                                    <small class="text-muted ms-2 fst-italic">@pax.Observacoes</small>
                                }
                            </div>
                            <div class="btn-group btn-group-sm ms-auto">
                                <button type="button" class="btn btn-outline-secondary btn-sm"
                                        data-bs-toggle="collapse"

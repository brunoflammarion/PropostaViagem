                                                            onclick="abrirModalFoto('@destino.Id', '@destino.Nome')">
                                                        <i class="fas fa-plus"></i> Foto
                                                    </button>
                                                    <form asp-controller="Destino" asp-action="ExcluirDestino" method="post"
                                                          style="display:inline;"
                                                          onsubmit="return confirm('Excluir este destino e todas suas fotos?');">
                                                        <input type="hidden" name="id" value="@destino.Id" />
                                                        <button type="submit" class="btn btn-outline-danger"><i class="fas fa-trash"></i></button>
                                                    </form>
                                                </div>
                                            </div>
                                        </div>

                                        <!-- Detalhes expandidos -->
                                        <div class="collapse mt-3" id="detalhes-@destino.Id">
                                            <div class="border-top pt-3">

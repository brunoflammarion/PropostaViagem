                                                    </button>
                                                    <button class="btn btn-sm btn-outline-secondary" type="button"
                                                            onclick="gerarNovoCodigo('@Model.Id')" title="Gerar novo código" id="btnGerarCodigo">
                                                        <i class="fas fa-sync-alt"></i>
                                                    </button>
                                                </div>
                                                <div class="mt-1" style="font-size:.72rem;color:#888;">
                                                    <i class="fas fa-info-circle me-1"></i>Compartilhe com o cliente para liberação do acesso
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>

                    <div class="col-md-4">
                        <div class="card mb-4">
                            <div class="card-header bg-light">
                                <h6 class="mb-0"><i class="fas fa-info me-2"></i>Informações</h6>
                            </div>
                            <div class="card-body">
                                <div class="mb-2">
                                    <small class="text-muted">Criada em</small>
                                    <p class="mb-0">@(Model.DataCriacao?.ToString("dd/MM/yyyy HH:mm") ?? "N/A")</p>
                                </div>
                                @if (Model.DataModificacao.HasValue)
                                {
                                    <div class="mb-2">
                                        <small class="text-muted">Última modificação</small>
                                        <p class="mb-0">@Model.DataModificacao.Value.ToString("dd/MM/yyyy HH:mm")</p>
                                    </div>
                                }
                                <div class="mb-2">
                                    <small class="text-muted">Status</small>
                                    <p class="mb-0">
                                        <span class="badge bg-@Model.StatusPropostaCor" id="statusBadge">@Model.StatusPropostaTexto</span>
                                    </p>
                                </div>
                                <div class="mb-2">
                                    <small class="text-muted">Título</small>
                                    <p class="mb-0 fw-semibold" id="previewTituloTexto">@Model.Titulo</p>
                                </div>
                                @if (!string.IsNullOrEmpty(Model.NomeCriador))
                                {
                                    <div class="mb-2">
                                        <small class="text-muted">Criador</small>
                                        <p class="mb-0 small">
                                            <i class="fas fa-user-edit me-1 text-muted"></i>@Model.NomeCriador
                                        </p>
                                    </div>
                                }
                                @if (!string.IsNullOrEmpty(Model.NomeResponsavel))
                                {
                                    <div class="mb-0">
                                        <small class="text-muted">Responsável atual</small>
                                        <p class="mb-0 small fw-semibold">
                                            <i class="fas fa-user-tie me-1" style="color:var(--exec-accent)"></i>@Model.NomeResponsavel
                                        </p>
                                    </div>
                                }
                            </div>
                        </div>
                        <div class="card mb-3">
                            <div class="card-body">
                                <div class="d-grid gap-2">
                                    <button type="submit" class="btn btn-primary btn-lg" id="btnSalvar">
                                        <i class="fas fa-save me-2"></i>Salvar Alterações
                                    </button>
                                </div>
                            </div>
                        </div>

                        @* ── Painel de Transferência (apenas Master) ── *@
                        @if (ViewBag.IsMaster == true && ViewBag.MembrosEquipe != null)
                        {
                            var membros = ViewBag.MembrosEquipe as System.Collections.IEnumerable;
                            <div class="card border-0" style="border:1px solid var(--exec-border) !important">
                                <div class="card-header bg-white py-2 d-flex align-items-center gap-2">
                                    <i class="fas fa-exchange-alt" style="color:var(--exec-accent);font-size:.85rem"></i>
                                    <span class="fw-semibold" style="font-size:.8rem">Responsável pela proposta</span>
                                </div>
                                <div class="card-body py-3">
                                    <p class="small text-muted mb-3">
                                        Transfira esta proposta para outro membro da equipe.
                                        O criador original é preservado para histórico.
                                    </p>
                                    @*
                                        IMPORTANTE: não pode haver <form> aninhado dentro de formEditarProposta.
                                        Usamos o atributo HTML5 form="formTransferir" nos campos e no botão
                                        para associá-los ao form real definido FORA do form principal (logo abaixo).
                                    *@
                                    <input type="hidden" name="propostaId" value="@Model.Id"
                                           form="formTransferir" />
                                    <div class="mb-3">
                                        <label class="form-label small fw-medium">Novo responsável</label>
                                        <select name="novoResponsavelId" class="form-select form-select-sm"
                                                required form="formTransferir">
                                            @if (membros != null)
                                            {
                                                foreach (dynamic m in membros)
                                                {
                                                    bool isSelected = Model.UsuarioResponsavelId.HasValue
                                                        && Model.UsuarioResponsavelId.Value == (Guid)m.Id;
                                                    var label = (string)m.Nome;
                                                    if ((SistemaUsuarios.Models.TipoUsuario)m.TipoUsuario
                                                        == SistemaUsuarios.Models.TipoUsuario.Master)
                                                        label += " (você)";
                                                    if (isSelected)
                                                    {
                                                        <option value="@m.Id" selected="selected">@label</option>
                                                    }
                                                    else
                                                    {
                                                        <option value="@m.Id">@label</option>
                                                    }
                                                }
                                            }
                                        </select>
                                    </div>
                                    <button type="submit" class="btn btn-sm btn-outline-primary w-100"
                                            form="formTransferir">
                                        <i class="fas fa-exchange-alt me-1"></i>Transferir Responsável
                                    </button>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </form>

            @*
                Form de transferência de responsável.
                Deve ficar FORA do formEditarProposta para evitar aninhamento HTML inválido.
                Os campos e o botão acima referenciam este form via form="formTransferir".
            *@
            @if (ViewBag.IsMaster == true)
            {
                <form id="formTransferir"
                      method="post"
                      asp-action="TransferirResponsavel"
                      asp-controller="Proposta"
                      style="display:none">
                    @Html.AntiForgeryToken()
                </form>
            }
        </div>

        <!-- ============================================================ -->
        <!-- TAB 2: DESTINOS & HOSPEDAGENS                                 -->
        <!-- ============================================================ -->
        <div class="tab-pane fade @(activeTab == "destinos" ? "show active" : "")"
             id="pane-destinos" role="tabpanel">

            @if (proposta == null)
            {

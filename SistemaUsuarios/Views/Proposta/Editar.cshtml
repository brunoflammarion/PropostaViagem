                                                                        onclick="gerarDescricaoDestino('@destino.Id')">
                                                                    <i class="fas fa-magic me-1"></i>Gerar descrição com IA
                                                                </button>
                                                                <button type="submit" class="btn btn-sm btn-primary">
                                                                    <i class="fas fa-save me-1"></i>Salvar
                                                                </button>
                                                            </div>
                                                            <input type="hidden" name="AtracoesLLM" id="atracoes-dest-@destino.Id" value="@destino.AtracoesLLM" />
                                                            <input type="hidden" name="GastronomiaLLM" id="gastro-dest-@destino.Id" value="@destino.GastronomiaLLM" />
                                                            <input type="hidden" name="InformacoesPraticasLLM" id="infoprat-dest-@destino.Id" value="@destino.InformacoesPraticasLLM" />
                                                            <input type="hidden" name="MalaViagemLLM" id="mala-dest-@destino.Id" value="@destino.MalaViagemLLM" />
                                                            <input type="hidden" name="CuidadosLLM" id="cuidados-dest-@destino.Id" value="@destino.CuidadosLLM" />
                                                            <input type="hidden" name="PratosTipicosLLM" id="pratos-dest-@destino.Id" value="@destino.PratosTipicosLLM" />
                                                        </form>
                                                    </div>
                                                    <div class="col-md-6">
                                                        <h6><i class="fas fa-images me-1"></i>Fotos (@destino.Fotos.Count)</h6>
                                                        @if (destino.Fotos.Any())
                                                        {
                                                            <div class="img-upload-grid" id="fotos-@destino.Id">
                                                                @foreach (var foto in destino.Fotos.OrderBy(f => f.Ordem))
                                                                {
                                                                    <div class="img-thumb" data-foto-id="@foto.Id">

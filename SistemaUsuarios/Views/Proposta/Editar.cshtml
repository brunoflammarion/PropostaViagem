                                                                <button type="button" class="btn btn-outline-primary btn-sm"
                                                                        data-bs-toggle="collapse"
                                                                        data-bs-target="#hosp-edit-@hospedagem.Id">
                                                                    <i class="fas fa-edit me-1"></i>Editar
                                                                </button>
                                                                <form asp-controller="Hospedagem" asp-action="Excluir" method="post"
                                                                      style="display:inline;"
                                                                      onsubmit="return confirm('Excluir esta hospedagem e todas suas acomodações?');">
                                                                    <input type="hidden" name="id" value="@hospedagem.Id" />
                                                                    <button type="submit" class="btn btn-outline-danger btn-sm">
                                                                        <i class="fas fa-trash"></i>
                                                                    </button>
                                                                </form>
                                                            </div>
                                                        </div>

                                                        <div class="collapse" id="hosp-edit-@hospedagem.Id">
                                                            <div class="card-body pt-2 hosp-form-container"
                                                                 data-cidade="@(destino.Cidade ?? destino.Nome)">
                                                                <!-- Editar hospedagem — campos pré-preenchidos pelo servidor -->
                                                                @{
                                                                    var _ic = System.Globalization.CultureInfo.InvariantCulture;
                                                                    var _latStr = hospedagem.Latitude?.ToString("G17", _ic) ?? "";
                                                                    var _lngStr = hospedagem.Longitude?.ToString("G17", _ic) ?? "";
                                                                }
                                                                <form asp-controller="Hospedagem" asp-action="Editar" method="post" class="mb-3">
                                                                    @Html.AntiForgeryToken()
                                                                    <input type="hidden" name="id" value="@hospedagem.Id" />
                                                                    <input type="hidden" name="latitude" class="hosp-lat" value="@_latStr" />
                                                                    <input type="hidden" name="longitude" class="hosp-lng" value="@_lngStr" />
                                                                    <div class="row g-2 mb-2">
                                                                        <div class="col-md-8 position-relative">
                                                                            <label class="form-label form-label-sm mb-0">Nome *</label>
                                                                            <input type="text" name="nome"
                                                                                   class="form-control form-control-sm hosp-nome-input"
                                                                                   value="@hospedagem.Nome"
                                                                                   required autocomplete="off" />
                                                                            <div class="hosp-sugestoes-list list-group mt-1"
                                                                                 style="position:absolute;z-index:9999;width:100%;max-height:220px;overflow-y:auto;"></div>
                                                                        </div>
                                                                        <div class="col-md-4">
                                                                            <label class="form-label form-label-sm mb-0">Categoria</label>
                                                                            @{ var _catVal = (int)hospedagem.Categoria; }
                                                                            <select name="categoria" class="form-select form-select-sm">
                                                                                <option value="1" selected="@(_catVal == 1 ? "selected" : null)">Hotel</option>
                                                                                <option value="2" selected="@(_catVal == 2 ? "selected" : null)">Pousada</option>
                                                                                <option value="3" selected="@(_catVal == 3 ? "selected" : null)">Resort</option>
                                                                                <option value="4" selected="@(_catVal == 4 ? "selected" : null)">Hotel Fazenda</option>
                                                                                <option value="5" selected="@(_catVal == 5 ? "selected" : null)">Aluguel de Casa</option>
                                                                                <option value="6" selected="@(_catVal == 6 ? "selected" : null)">Camping</option>
                                                                                <option value="7" selected="@(_catVal == 7 ? "selected" : null)">Outros</option>
                                                                            </select>
                                                                        </div>
                                                                    </div>
                                                                    <div class="mb-2">
                                                                        <label class="form-label form-label-sm mb-0">Endereço</label>
                                                                        <div class="input-group input-group-sm">
                                                                            <input type="text" name="endereco"
                                                                                   class="form-control hosp-endereco-input"
                                                                                   value="@hospedagem.Endereco" />
                                                                            @if (hospedagem.Latitude.HasValue && hospedagem.Longitude.HasValue)
                                                                            {
                                                                                <span class="input-group-text hosp-coord-badge"
                                                                                      style="font-size:0.75rem;">
                                                                                    <i class="fas fa-map-pin me-1 text-success"></i>
                                                                                    <span class="hosp-coord-texto">@hospedagem.Latitude.Value.ToString("F6", _ic), @hospedagem.Longitude.Value.ToString("F6", _ic)</span>
                                                                                </span>
                                                                            }
                                                                            else
                                                                            {
                                                                                <span class="input-group-text hosp-coord-badge d-none"
                                                                                      style="font-size:0.75rem;">
                                                                                    <i class="fas fa-map-pin me-1 text-success"></i>
                                                                                    <span class="hosp-coord-texto"></span>
                                                                                </span>
                                                                            }
                                                                        </div>
                                                                    </div>
                                                                    @if (hospedagem.Latitude.HasValue && hospedagem.Longitude.HasValue)
                                                                    {
                                                                        <a href="https://www.google.com/maps?q=@hospedagem.Latitude?.ToString("F6", System.Globalization.CultureInfo.InvariantCulture),@hospedagem.Longitude?.ToString("F6", System.Globalization.CultureInfo.InvariantCulture)"
                                                                           target="_blank" rel="noopener noreferrer"
                                                                           class="small text-decoration-none d-inline-block mb-2"
                                                                           style="color:var(--bs-primary);">
                                                                            <i class="fas fa-map-marked-alt me-1"></i>Ver no mapa
                                                                        </a>
                                                                    }
                                                                    <div class="mb-2">
                                                                        <div class="d-flex justify-content-between align-items-center mb-1">
                                                                            <label class="form-label form-label-sm mb-0">Descrição</label>
                                                                            <div class="d-flex gap-1 align-items-center">
                                                                                <button type="button"
                                                                                        class="btn btn-outline-secondary btn-xs hosp-bold-btn"
                                                                                        data-editor="hosp-desc-@hospedagem.Id.ToString("N")"
                                                                                        title="Negrito (Ctrl+B)">
                                                                                    <b>B</b>
                                                                                </button>
                                                                                <button type="button"
                                                                                        class="btn btn-outline-primary btn-xs btn-gerar-desc-hosp">
                                                                                    <i class="fas fa-magic me-1"></i>IA
                                                                                </button>
                                                                            </div>
                                                                        </div>
                                                                        @{
                                                                            var _descHtml = string.IsNullOrEmpty(hospedagem.Descricao) ? "" :
                                                                                System.Text.RegularExpressions.Regex.Replace(
                                                                                    System.Net.WebUtility.HtmlEncode(hospedagem.Descricao),
                                                                                    @"&lt;(/?b|br\s*/?)&gt;",
                                                                                    m => "<" + m.Groups[1].Value + ">"
                                                                                ).Replace("\r", "").Replace("\n", "<br>");
                                                                        }
                                                                        <div id="hosp-desc-@hospedagem.Id.ToString("N")"
                                                                             class="form-control form-control-sm hosp-rich-desc"
                                                                             contenteditable="true"
                                                                             style="min-height:56px;max-height:160px;overflow-y:auto;"
                                                                             data-placeholder="Descreva o hotel...">@Html.Raw(_descHtml)</div>
                                                                        <input type="hidden" name="descricao" class="hosp-rich-desc-val" />
                                                                        <div class="hosp-ia-loader text-center py-1 d-none">
                                                                            <div class="spinner-border spinner-border-sm text-primary me-1"></div>
                                                                            <small class="text-muted">Consultando IA...</small>
                                                                        </div>
                                                                    </div>
                                                                    <div class="row g-2 mb-2">
                                                                        <div class="col-md-4">
                                                                            <label class="form-label form-label-sm mb-0">Tipo de Pensão</label>
                                                                            @{ var _pensaoVal = (int)hospedagem.TipoPensao; }
                                                                            <select name="tipoPensao" class="form-select form-select-sm">
                                                                                <option value="1" selected="@(_pensaoVal == 1 ? "selected" : null)">Sem Pensão</option>
                                                                                <option value="2" selected="@(_pensaoVal == 2 ? "selected" : null)">Café da Manhã</option>
                                                                                <option value="3" selected="@(_pensaoVal == 3 ? "selected" : null)">Meia Pensão</option>
                                                                                <option value="4" selected="@(_pensaoVal == 4 ? "selected" : null)">Pensão Completa</option>
                                                                                <option value="5" selected="@(_pensaoVal == 5 ? "selected" : null)">All Inclusive</option>
                                                                                <option value="6" selected="@(_pensaoVal == 6 ? "selected" : null)">Outros</option>
                                                                            </select>
                                                                        </div>
                                                                        <div class="col-md-4">
                                                                            <label class="form-label form-label-sm mb-0">Check-in</label>
                                                                            <input type="datetime-local" name="checkIn"
                                                                                   class="form-control form-control-sm"
                                                                                   value="@hospedagem.CheckIn?.ToString("yyyy-MM-ddTHH:mm")" />
                                                                        </div>
                                                                        <div class="col-md-4">
                                                                            <label class="form-label form-label-sm mb-0">Check-out</label>
                                                                            <input type="datetime-local" name="checkOut"
                                                                                   class="form-control form-control-sm"
                                                                                   value="@hospedagem.CheckOut?.ToString("yyyy-MM-ddTHH:mm")" />
                                                                        </div>
                                                                    </div>
                                                                    <div class="mb-2">
                                                                        <label class="form-label form-label-sm mb-0">Reserva</label>
                                                                        <textarea name="reserva"
                                                                                  class="form-control form-control-sm"
                                                                                  rows="1">@hospedagem.Reserva</textarea>
                                                                    </div>
                                                                    <button type="submit" class="btn btn-sm btn-primary">
                                                                        <i class="fas fa-save me-1"></i>Salvar
                                                                    </button>
                                                                </form>

                                                                <hr class="my-2" />

                                                                <!-- Comodidades -->
                                                                <div class="mb-3">
                                                                    <h6 class="text-muted mb-2">
                                                                        <i class="fas fa-concierge-bell me-1"></i>Comodidades
                                                                    </h6>
                                                                    @if (hospedagem.Comodidades.Any())
                                                                    {
                                                                        <div class="d-flex flex-wrap gap-1 mb-2">
                                                                            @foreach (var comodidade in hospedagem.Comodidades.OrderBy(c => c.Ordem))
                                                                            {
                                                                                <span class="badge bg-light text-dark border d-inline-flex align-items-center gap-1 py-1 px-2">
                                                                                    <i class="fas fa-check-circle text-success" style="font-size:0.7rem;"></i>
                                                                                    @comodidade.Nome
                                                                                    <form asp-controller="Hospedagem" asp-action="ExcluirComodidade"
                                                                                          method="post" style="display:inline;"
                                                                                          onsubmit="return confirm('Remover comodidade?');">
                                                                                        <input type="hidden" name="id" value="@comodidade.Id" />
                                                                                        <button type="submit"
                                                                                                class="btn p-0 ms-1 border-0 bg-transparent lh-1"
                                                                                                title="Remover">
                                                                                            <i class="fas fa-times text-muted" style="font-size:0.6rem;"></i>
                                                                                        </button>
                                                                                    </form>
                                                                                </span>
                                                                            }
                                                                        </div>
                                                                    }
                                                                    else
                                                                    {
                                                                        <p class="small text-muted mb-2">Nenhuma comodidade cadastrada.</p>
                                                                    }
                                                                    <form asp-controller="Hospedagem" asp-action="AdicionarComodidade"
                                                                          method="post" class="d-flex gap-1">
                                                                        <input type="hidden" name="hospedagemId" value="@hospedagem.Id" />
                                                                        <input type="text" name="nome" class="form-control form-control-sm"
                                                                               placeholder="Adicionar comodidade..." maxlength="200"
                                                                               style="max-width:220px;" />
                                                                        <button type="submit" class="btn btn-sm btn-outline-secondary flex-shrink-0">
                                                                            <i class="fas fa-plus me-1"></i>Adicionar
                                                                        </button>
                                                                    </form>
                                                                </div>

                                                                <hr class="my-2" />

                                                                <!-- Fotos do Hotel -->
                                                                <div class="mb-3">
                                                                    <h6 class="text-muted mb-2">
                                                                        <i class="fas fa-images me-1"></i>Fotos do Hotel
                                                                        @if (hospedagem.Fotos.Any())
                                                                        {
                                                                            <span class="badge bg-secondary ms-1">@hospedagem.Fotos.Count</span>
                                                                        }
                                                                    </h6>

                                                                    @if (hospedagem.Fotos.Any())
                                                                    {
                                                                        <div class="img-upload-grid"
                                                                             id="fotos-hotel-@hospedagem.Id"
                                                                             data-hospedagem-id="@hospedagem.Id">
                                                                            @foreach (var fotoH in hospedagem.Fotos.OrderBy(f => f.Ordem))
                                                                            {
                                                                                <div class="img-thumb"
                                                                                     data-foto-hosp-id="@fotoH.Id">
                                                                                    <div class="img-thumb-frame">
                                                                                        <img src="@fotoH.CaminhoFoto" alt="" />
                                                                                    </div>
                                                                                    @if (fotoH.Principal)
                                                                                    {
                                                                                        <span class="position-absolute top-0 start-0 badge bg-success"
                                                                                              style="font-size:0.5rem;padding:2px;">
                                                                                            <i class="fas fa-star"></i>
                                                                                        </span>
                                                                                    }
                                                                                    <span class="position-absolute bottom-0 start-0 badge bg-dark bg-opacity-75"
                                                                                          style="font-size:0.5rem;padding:1px 3px;">@fotoH.Ordem</span>
                                                                                    <form asp-controller="Hospedagem" asp-action="ExcluirFotoHospedagem"
                                                                                          method="post" style="display:inline;"
                                                                                          onsubmit="return confirm('Excluir foto do hotel?');">
                                                                                        <input type="hidden" name="id" value="@fotoH.Id" />
                                                                                        <button type="submit"
                                                                                                class="btn btn-danger btn-sm position-absolute top-0 end-0 p-0"
                                                                                                style="width:16px;height:16px;font-size:0.55rem;line-height:1;">
                                                                                            <i class="fas fa-times"></i>
                                                                                        </button>
                                                                                    </form>
                                                                                </div>
                                                                            }
                                                                        </div>
                                                                        <small class="text-muted d-block mb-2">
                                                                            <i class="fas fa-arrows-alt me-1"></i>Arraste para reordenar
                                                                        </small>
                                                                    }
                                                                    else
                                                                    {
                                                                        <p class="small text-muted mb-2">Nenhuma foto do hotel cadastrada.</p>
                                                                    }

                                                                    <form asp-controller="Hospedagem" asp-action="AdicionarFotoHospedagem"
                                                                          method="post" enctype="multipart/form-data">
                                                                        <input type="hidden" name="hospedagemId" value="@hospedagem.Id" />
                                                                        <label class="form-label form-label-sm text-muted small mb-1">
                                                                            <i class="fas fa-plus me-1"></i>Adicionar imagens
                                                                        </label>
                                                                        <input type="file" name="fotos" multiple
                                                                               accept="image/*"
                                                                               class="form-control form-control-sm"
                                                                               data-auto-upload />
                                                                        <p class="img-upload-hint">As imagens serão enviadas automaticamente. Depois, arraste para ordenar.</p>
                                                                    </form>
                                                                </div>

                                                                <hr class="my-2" />

                                                                <!-- Acomodações -->
                                                                <h6 class="text-muted mb-2">
                                                                    <i class="fas fa-bed me-1"></i>Acomodações
                                                                </h6>
                                                                @foreach (var acomodacao in hospedagem.Acomodacoes.OrderBy(a => a.Ordem))
                                                                {
                                                                    <div class="card mb-2 border-light">
                                                                        <div class="card-body p-2">
                                                                            <div class="d-flex justify-content-between align-items-start">
                                                                                <strong class="small">@acomodacao.Nome</strong>
                                                                                <div class="btn-group btn-group-sm">
                                                                                    <button type="button" class="btn btn-outline-secondary btn-sm"
                                                                                            data-bs-toggle="collapse"
                                                                                            data-bs-target="#acmd-@acomodacao.Id">
                                                                                        <i class="fas fa-edit me-1"></i>Editar
                                                                                    </button>
                                                                                    <button type="button" class="btn btn-outline-success btn-sm"
                                                                                            onclick="abrirModalFotoAcomodacao('@acomodacao.Id', '@acomodacao.Nome')">
                                                                                        <i class="fas fa-camera me-1"></i>Foto
                                                                                    </button>
                                                                                    <form asp-controller="Hospedagem" asp-action="ExcluirAcomodacao"
                                                                                          method="post" style="display:inline;"
                                                                                          onsubmit="return confirm('Excluir esta acomodação?');">
                                                                                        <input type="hidden" name="id" value="@acomodacao.Id" />
                                                                                        <button type="submit" class="btn btn-outline-danger btn-sm">
                                                                                            <i class="fas fa-trash"></i>
                                                                                        </button>
                                                                                    </form>
                                                                                </div>
                                                                            </div>
                                                                            @if (acomodacao.Fotos.Any())
                                                                            {
                                                                                <div class="d-flex flex-wrap gap-1 mt-2">
                                                                                    @foreach (var fotoAcmd in acomodacao.Fotos.OrderBy(f => f.Ordem))
                                                                                    {
                                                                                        <div class="position-relative" style="width:64px;height:48px;">
                                                                                            <img src="@fotoAcmd.CaminhoFoto" alt="@fotoAcmd.Descricao"
                                                                                                 class="rounded"
                                                                                                 style="width:64px;height:48px;object-fit:cover;" />
                                                                                            @if (fotoAcmd.Principal)
                                                                                            {
                                                                                                <span class="position-absolute top-0 start-0 badge bg-success"
                                                                                                      style="font-size:0.5rem;padding:2px;">
                                                                                                    <i class="fas fa-star"></i>
                                                                                                </span>
                                                                                            }
                                                                                            <form asp-controller="Hospedagem" asp-action="ExcluirFotoAcomodacao"
                                                                                                  method="post" style="display:inline;"
                                                                                                  onsubmit="return confirm('Excluir foto?');">
                                                                                                <input type="hidden" name="id" value="@fotoAcmd.Id" />
                                                                                                <button type="submit"
                                                                                                        class="btn btn-danger btn-sm position-absolute top-0 end-0 p-0"
                                                                                                        style="width:16px;height:16px;font-size:0.55rem;line-height:1;">
                                                                                                    <i class="fas fa-times"></i>
                                                                                                </button>
                                                                                            </form>
                                                                                        </div>
                                                                                    }
                                                                                </div>
                                                                            }
                                                                            <div class="collapse mt-2" id="acmd-@acomodacao.Id">
                                                                                <form asp-controller="Hospedagem" asp-action="EditarAcomodacao"
                                                                                      method="post" class="mb-2">
                                                                                    <input type="hidden" name="id" value="@acomodacao.Id" />
                                                                                    <div class="mb-1">
                                                                                        <input type="text" name="nome" class="form-control form-control-sm"
                                                                                               value="@acomodacao.Nome" required />
                                                                                    </div>
                                                                                    <div class="mb-1">
                                                                                        <textarea name="descricao" class="form-control form-control-sm"
                                                                                                  rows="2">@acomodacao.Descricao</textarea>
                                                                                    </div>
                                                                                    <button type="submit" class="btn btn-sm btn-primary">
                                                                                        <i class="fas fa-save me-1"></i>Salvar
                                                                                    </button>
                                                                                </form>

                                                                                <hr class="my-2" />

                                                                                <!-- Comodidades da Acomodação -->
                                                                                <div class="mb-1">
                                                                                    <p class="small fw-semibold text-muted mb-1">
                                                                                        <i class="fas fa-check-circle me-1"></i>Comodidades da Acomodação
                                                                                    </p>
                                                                                    @if (acomodacao.Comodidades.Any())
                                                                                    {
                                                                                        <div class="d-flex flex-wrap gap-1 mb-2">
                                                                                            @foreach (var comAcmd in acomodacao.Comodidades.OrderBy(c => c.Ordem))
                                                                                            {
                                                                                                <span class="badge bg-light text-dark border d-flex align-items-center gap-1 ps-2 pe-1 py-1">
                                                                                                    @comAcmd.Nome
                                                                                                    <form asp-controller="Hospedagem" asp-action="ExcluirComodidadeAcomodacao"
                                                                                                          method="post" class="d-inline m-0 p-0">
                                                                                                        <input type="hidden" name="id" value="@comAcmd.Id" />
                                                                                                        <button type="submit"
                                                                                                                class="btn btn-link p-0 text-danger"
                                                                                                                style="font-size:0.65rem;line-height:1;"
                                                                                                                title="Remover">
                                                                                                            <i class="fas fa-times"></i>
                                                                                                        </button>
                                                                                                    </form>
                                                                                                </span>
                                                                                            }
                                                                                        </div>
                                                                                    }
                                                                                    else
                                                                                    {
                                                                                        <p class="small text-muted mb-2">Nenhuma comodidade da acomodação.</p>
                                                                                    }
                                                                                    <form asp-controller="Hospedagem" asp-action="AdicionarComodidadeAcomodacao"
                                                                                          method="post" class="d-flex gap-1">
                                                                                        <input type="hidden" name="acomodacaoId" value="@acomodacao.Id" />
                                                                                        <input type="text" name="nome" class="form-control form-control-sm"
                                                                                               placeholder="Ex: Ar-condicionado, TV..." maxlength="200"
                                                                                               style="max-width:200px;" />
                                                                                        <button type="submit" class="btn btn-sm btn-outline-secondary flex-shrink-0">
                                                                                            <i class="fas fa-plus me-1"></i>Adicionar
                                                                                        </button>
                                                                                    </form>
                                                                                </div>
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                }

                                                                <!-- Adicionar acomodação -->
                                                                <div class="card border-light bg-light mt-2">
                                                                    <div class="card-body p-2">
                                                                        <p class="small text-muted mb-2 fw-semibold">
                                                                            <i class="fas fa-plus-circle me-1 text-success"></i>Nova Acomodação
                                                                        </p>
                                                                        <form asp-controller="Hospedagem" asp-action="AdicionarAcomodacao" method="post">
                                                                            <input type="hidden" name="hospedagemId" value="@hospedagem.Id" />
                                                                            <div class="row g-1 mb-1">
                                                                                <div class="col-sm-4">
                                                                                    <input type="text" name="nome" class="form-control form-control-sm"
                                                                                           placeholder="Nome (ex: Suíte...)" required />
                                                                                </div>
                                                                                <div class="col-sm-8">
                                                                                    <input type="text" name="descricao" class="form-control form-control-sm"
                                                                                           placeholder="Descrição..." />
                                                                                </div>
                                                                            </div>
                                                                            <button type="submit" class="btn btn-sm btn-outline-success">
                                                                                <i class="fas fa-plus me-1"></i>Adicionar
                                                                            </button>
                                                                        </form>
                                                                    </div>
                                                                </div>

                                                            </div>
                                                        </div>
                                                    </div>
                                                }
                                            </div>

                                        <!-- ══ EXPERIÊNCIAS ══════════════════════════════ -->
                                        <div class="border-top pt-3 mt-3">
                                            <div class="d-flex justify-content-between align-items-center mb-3">
                                                <h6 class="mb-0">
                                                    <i class="fas fa-star me-2 text-warning"></i>Experiências
                                                    <span class="badge bg-secondary ms-1">@destino.Experiencias.Count</span>
                                                </h6>
                                                <button type="button"
                                                        class="btn btn-sm btn-outline-warning"
                                                        data-bs-toggle="collapse"
                                                        data-bs-target="#add-exp-@destino.Id">
                                                    <i class="fas fa-plus me-1"></i>Adicionar Experiência
                                                </button>
                                            </div>

                                            <!-- Formulário inline para adicionar nova experiência -->
                                            <div class="collapse mb-3" id="add-exp-@destino.Id">
                                                <div class="card bg-light border-0 p-3">
                                                    <h6 class="small text-muted fw-semibold mb-2">Nova Experiência</h6>
                                                    <form asp-controller="Experiencia" asp-action="Adicionar" method="post" enctype="multipart/form-data">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="destinoId" value="@destino.Id" />
                                                        <div class="row g-2">
                                                            <div class="col-sm-4">
                                                                <label class="form-label form-label-sm mb-0">Título<span class="text-danger">*</span></label>
                                                                <input type="text" name="tipoPasseio"
                                                                       class="form-control form-control-sm"
                                                                       required maxlength="200"
                                                                       placeholder="City tour, Trilha, Mergulho..." />

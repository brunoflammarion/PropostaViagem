                                                                </form>

                                                                <hr class="my-3" />

                                                                <!-- Documentos -->
                                                                <h6 class="small text-muted text-uppercase mb-2">
                                                                    <i class="fas fa-paperclip me-1"></i>Documentos
                                                                    <span class="badge bg-secondary ms-1">@transp.Documentos.Count</span>
                                                                </h6>
                                                                @if (transp.Documentos.Any())
                                                                {
                                                                    <ul class="list-group list-group-flush mb-3">
                                                                        @foreach (var doc in transp.Documentos.OrderBy(d => d.DataCriacao))
                                                                        {
                                                                            <li class="list-group-item px-0 d-flex align-items-center gap-2">
                                                                                <i class="fas @(doc.TipoArquivo.StartsWith("image") ? "fa-image text-success" : doc.TipoArquivo == "application/pdf" ? "fa-file-pdf text-danger" : "fa-file-alt text-primary") fa-fw"></i>
                                                                                <a asp-controller="Transporte"
                                                                                   asp-action="BaixarDocumento"
                                                                                   asp-route-id="@doc.Id"
                                                                                   class="text-truncate small"
                                                                                   style="max-width:260px;"
                                                                                   title="@doc.NomeOriginal">
                                                                                    @doc.NomeOriginal
                                                                                </a>
                                                                                <span class="text-muted small">(@((doc.Tamanho / 1024.0).ToString("0.#")) KB)</span>
                                                                                <form asp-controller="Transporte"
                                                                                      asp-action="ExcluirDocumento"
                                                                                      method="post" class="ms-auto d-inline"
                                                                                      onsubmit="return confirm('Excluir documento?');">
                                                                                    @Html.AntiForgeryToken()
                                                                                    <input type="hidden" name="id" value="@doc.Id" />
                                                                                    <button type="submit" class="btn btn-xs btn-outline-danger">
                                                                                        <i class="fas fa-times"></i>
                                                                                    </button>
                                                                                </form>
                                                                            </li>
                                                                        }
                                                                    </ul>
                                                                }
                                                                <form asp-controller="Transporte" asp-action="AdicionarDocumento"
                                                                      method="post" enctype="multipart/form-data"
                                                                      class="d-flex align-items-end gap-2 flex-wrap">
                                                                    @Html.AntiForgeryToken()
                                                                    <input type="hidden" name="transporteId" value="@transp.Id" />
                                                                    <div style="flex:1; min-width:200px;">
                                                                        <label class="form-label form-label-sm mb-0 text-muted small">
                                                                            Adicionar documento (voucher, PDF, imagem...)
                                                                        </label>
                                                                        <input type="file" name="documento"
                                                                               class="form-control form-control-sm"
                                                                               required
                                                                               accept=".pdf,.jpg,.jpeg,.png,.gif,.webp,.doc,.docx,.xls,.xlsx" />
                                                                    </div>
                                                                    <div>
                                                                        <button type="submit" class="btn btn-sm btn-outline-primary">
                                                                            <i class="fas fa-upload me-1"></i>Upload
                                                                        </button>
                                                                    </div>
                                                                </form>

                                                            </div><!-- /card-body transp -->
                                                        </div><!-- /collapse transp -->
                                                    </div><!-- /card transp -->
                                                }
                                            }

                                        </div><!-- /transportes section -->

                                        @{
                                            var _dAccId = "acc-dei-" + destino.Id.ToString("N");
                                            var _dHasIns = !string.IsNullOrEmpty(destino.CuidadosLLM)
                                                || !string.IsNullOrEmpty(destino.GastronomiaLLM)
                                                || !string.IsNullOrEmpty(destino.PratosTipicosLLM)
                                                || !string.IsNullOrEmpty(destino.AtracoesLLM)
                                                || !string.IsNullOrEmpty(destino.InformacoesPraticasLLM)
                                                || !string.IsNullOrEmpty(destino.MalaViagemLLM);
                                        }
                                        @if (_dHasIns)
                                        {
                                            <div class="border-top pt-3 mt-3">
                                                <div class="dest-insights-panel">
                                                    <div class="panel-title">
                                                        <i class="fas fa-brain me-1"></i>Insights para o Agente
                                                    </div>
                                                    @Html.Raw(RenderTemasAccordion(destino, _dAccId))
                                                </div>
                                            </div>
                                        }
                                        </div><!-- /detalhes-collapse -->
                                    </div><!-- /border-top destino -->
                                }
                            </div>
                        </div>
                    </div>
                }
                else
                {
                    <div class="text-center py-5">
                        <i class="fas fa-map-marked-alt fa-4x text-muted mb-3"></i>
                        <h5 class="text-muted">Nenhum destino adicionado</h5>
                        <p class="text-muted">Use o formulário abaixo para adicionar o primeiro destino.</p>
                    </div>
                }

                

                <!-- Formulário Adicionar Destino -->
                <div class="card mb-4">
                    <div class="card-header">
                        <h5 class="mb-0"><i class="fas fa-plus me-2"></i>Adicionar Novo Destino</h5>
                    </div>
                    <div class="card-body">
                        <form asp-controller="Destino" asp-action="AdicionarDestino" method="post">
                            <input type="hidden" name="propostaId" value="@proposta.Id" />
                            <input type="hidden" name="latitude" id="latitude" />
                            <input type="hidden" name="longitude" id="longitude" />
                            <div class="row">
                                <div class="col-md-3 mb-3 position-relative">
                                    <label class="form-label">Nome do Destino *</label>
                                    <input type="text" name="nome" id="nomeDestino" class="form-control"
                                           placeholder="Ex: Paris, França" required autocomplete="off" />
                                    <div id="sugestoesDestino" class="list-group mt-1"
                                         style="position:absolute;z-index:9999;width:100%;"></div>
                                </div>
                                <div class="col-md-2 mb-3">
                                    <label class="form-label">País</label>
                                    <input type="text" name="pais" class="form-control" placeholder="França" id="campoPais" />
                                </div>
                                <div class="col-md-2 mb-3">
                                    <label class="form-label">Cidade</label>
                                    <input type="text" name="cidade" class="form-control" placeholder="Paris" id="campoCidade" />
                                </div>
                                <div class="col-md-2 mb-3">
                                    <label class="form-label">Chegada</label>
                                    <input type="date" name="dataChegada" class="form-control" />
                                </div>
                                <div class="col-md-2 mb-3">
                                    <label class="form-label">Saída</label>
                                    <input type="date" name="dataSaida" class="form-control" />
                                </div>
                                <div class="col-md-1 mb-3 d-flex align-items-end">
                                    <button type="submit" class="btn btn-success w-100">
                                        <i class="fas fa-plus"></i>
                                    </button>
                                </div>
                            </div>
                            <!-- Campo auxiliar para o LLM (oculto) -->
                            <div style="display:none;">
                                <input id="Nome" name="_nomeLLM" class="form-control" />
                            </div>
                            <button type="button" id="btnGerarDesc" class="btn btn-outline-primary btn-sm mb-2">
                                <i class="fas fa-magic me-1"></i>Gerar descrição com IA
                            </button>
                            <div id="editor-llm" class="mt-2 d-none">
                                <label class="form-label">Descrição</label>
                                <textarea id="Descricao" name="descricao" rows="4" class="form-control mb-2"></textarea>

                                <!-- Insights gerados pela IA — aparecem após geração -->
                                <div id="novo-dest-insights" class="mt-3 mb-3 d-none">
                                    <div class="dest-insights-panel">
                                        <div class="panel-title"><i class="fas fa-brain me-1"></i>Insights para o Agente</div>
                                        <div id="novo-dest-insights-body" class="accordion"></div>
                                    </div>
                                </div>

                                <input type="hidden" id="AtracoesLLM" name="AtracoesLLM" />
                                <input type="hidden" id="GastronomiaLLM" name="GastronomiaLLM" />
                                <input type="hidden" id="InformacoesPraticasLLM" name="InformacoesPraticasLLM" />
                                <input type="hidden" id="MalaViagemLLM" name="MalaViagemLLM" />
                                <input type="hidden" id="pratosTipicosLLM" name="pratosTipicosLLM" />
                                <input type="hidden" id="CuidadosLLM" name="CuidadosLLM" />
                            </div>
                        </form>
                    </div>
                </div>

<!-- ── Configuração de avaliação pelo cliente ──────────────────────── -->
                <form asp-action="Editar" asp-controller="Proposta" method="post"
                      enctype="multipart/form-data" id="formAvaliacaoConfig"
                      class="mb-4">
                    @Html.AntiForgeryToken()
                    @* Hidden fields para preservar todos os outros campos da proposta *@
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="Titulo" />
                    <input type="hidden" asp-for="NumeroPassageiros" />
                    <input type="hidden" asp-for="NumeroCriancas" />
                    <input type="hidden" asp-for="StatusProposta" />
                    <input type="hidden" asp-for="LinkPublicoAtivo" />
                    <input type="hidden" asp-for="FotoCapa" />
                    <input type="hidden" asp-for="LayoutId" />

                    <div class="card border-0 shadow-sm">
                        <div class="card-header bg-white d-flex align-items-center gap-2 py-2">
                            <i class="fas fa-star-half-alt text-warning"></i>
                            <span class="fw-semibold" style="font-size:.875rem;">Avaliação pelo cliente</span>
                            <span class="badge bg-light text-secondary border ms-1" style="font-size:.7rem;">Opcional</span>
                        </div>
                        <div class="card-body py-3">
                            <p class="small text-muted mb-3">
                                Quando ativado e houver <strong>mais de uma opção</strong> do mesmo tipo, o cliente verá uma seção de avaliação comparativa na proposta pública.
                            </p>
                            <div class="row g-3">
                                <div class="col-sm-4">
                                    <div class="form-check form-switch d-flex align-items-center gap-2 p-0">
                                        <input asp-for="SolicitarAvaliacaoHospedagem"
                                               class="form-check-input flex-shrink-0"
                                               style="width:2.2rem;height:1.1rem;margin:0;"
                                               id="toggleAvalHosp" role="switch" />
                                        <label class="form-check-label small" for="toggleAvalHosp">
                                            <i class="fas fa-hotel me-1 text-info"></i>
                                            Avaliar hospedagens
                                        </label>
                                    </div>
                                </div>
                                <div class="col-sm-4">
                                    <div class="form-check form-switch d-flex align-items-center gap-2 p-0">
                                        <input asp-for="SolicitarAvaliacaoAcomodacao"
                                               class="form-check-input flex-shrink-0"
                                               style="width:2.2rem;height:1.1rem;margin:0;"
                                               id="toggleAvalAcom" role="switch" />
                                        <label class="form-check-label small" for="toggleAvalAcom">
                                            <i class="fas fa-bed me-1 text-primary"></i>
                                            Avaliar acomodações
                                        </label>
                                    </div>
                                </div>
                                <div class="col-sm-4">
                                    <div class="form-check form-switch d-flex align-items-center gap-2 p-0">
                                        <input asp-for="SolicitarAvaliacaoExperiencia"
                                               class="form-check-input flex-shrink-0"
                                               style="width:2.2rem;height:1.1rem;margin:0;"
                                               id="toggleAvalExp" role="switch" />
                                        <label class="form-check-label small" for="toggleAvalExp">
                                            <i class="fas fa-star me-1 text-warning"></i>
                                            Avaliar experiências
                                        </label>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="card-footer bg-white border-top-0 pt-0 pb-3 d-flex justify-content-end">
                            <button type="submit" class="btn btn-sm btn-outline-primary">
                                <i class="fas fa-save me-1"></i>Salvar configuração
                            </button>
                        </div>
                    </div>
                </form>

            }
        </div>

        <!-- ============================================================ -->
        <!-- TAB 3: AÉREO                                                  -->
        <!-- ============================================================ -->
        <div class="tab-pane fade @(activeTab == "aereo" ? "show active" : "")"
             id="pane-aereo" role="tabpanel">

            @if (proposta == null)
            {
                <div class="alert alert-warning">Não foi possível carregar os dados da proposta.</div>
            }
            else
            {
                <!-- Cabeçalho -->
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <div>
                        <h5 class="mb-0"><i class="fas fa-plane me-2 text-primary"></i>Voos</h5>
                        <small class="text-muted">Adicione, edite e gerencie os voos da proposta</small>
                    </div>
                    <button type="button" class="btn btn-primary btn-sm"
                            data-bs-toggle="modal" data-bs-target="#modalAdicionarVoo">
                        <i class="fas fa-plus me-1"></i>Adicionar Voo
                    </button>
                </div>

                @if (!proposta.Voos.Any())
                {
                    <div class="card border-dashed text-center py-5 text-muted">
                        <div>
                            <i class="fas fa-plane fa-3x mb-3 opacity-25"></i>
                            <p class="mb-0">Nenhum voo adicionado.</p>
                            <p>Clique em <strong>Adicionar Voo</strong> para começar.</p>
                        </div>
                    </div>
                }
                else
                {
                    <!-- Lista de voos como accordion -->
                    <div class="accordion" id="accordionVoos">
                        @foreach (var voo in proposta.Voos)
                        {
                            var vooSafeId = voo.Id.ToString().Replace("-", "");
                            <div class="card mb-2 border" id="voo-card-@vooSafeId">
                                <!-- Cabeçalho do voo -->
                                <div class="card-header d-flex align-items-center gap-2 py-2 bg-white">
                                    @if (voo.TipoVoo == SistemaUsuarios.Models.TipoVoo.Ida)
                                    {
                                        <span class="badge bg-primary px-2 py-1" style="min-width:58px">
                                            <i class="fas fa-plane-departure me-1"></i>Ida
                                        </span>
                                    }
                                    else if (voo.TipoVoo == SistemaUsuarios.Models.TipoVoo.Interno)
                                    {
                                        <span class="badge bg-warning text-dark px-2 py-1" style="min-width:58px">
                                            <i class="fas fa-route me-1"></i>Interno
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success px-2 py-1" style="min-width:58px">
                                            <i class="fas fa-plane-arrival me-1"></i>Volta
                                        </span>
                                    }
                                    <strong class="me-1">@voo.NumeroVoo</strong>
                                    <span class="text-muted small">@voo.Companhia</span>
                                    <span class="text-muted small ms-1">
                                        @voo.Origem <i class="fas fa-arrow-right mx-1"></i> @voo.Destino
                                    </span>
                                    @if (voo.HorarioSaida.HasValue)
                                    {
                                        <span class="text-muted small ms-1">
                                            | @voo.HorarioSaida.Value.ToString("dd/MM HH:mm")
                                        </span>
                                    }
                                    <span class="badge bg-light text-dark border ms-1">
                                        <i class="fas fa-users me-1"></i>@voo.Passageiros.Count pax
                                    </span>
                                    <div class="ms-auto d-flex gap-1">
                                        <button class="btn btn-outline-primary btn-sm" type="button"
                                                data-bs-toggle="collapse"
                                                data-bs-target="#collapse-voo-@vooSafeId">
                                            <i class="fas fa-edit me-1"></i>Editar
                                        </button>
                                        <form asp-controller="Voo" asp-action="Excluir" method="post" class="d-inline"
                                              onsubmit="return confirm('Excluir voo @voo.NumeroVoo? Esta ação não pode ser desfeita.');">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@voo.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger" title="Excluir voo">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </div>

                                <!-- Corpo expansível -->
                                <div class="collapse" id="collapse-voo-@vooSafeId">
                                    <div class="card-body">

                                        <!-- ── FORMULÁRIO DE EDIÇÃO DO VOO ── -->
                                        <form asp-controller="Voo" asp-action="Editar" method="post"
                                              id="form-voo-@vooSafeId" class="mb-3">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@voo.Id" />
                                            @{
                                                var classesValidas = new[] { "Econômica", "Econômica Premium", "Executiva", "Primeira Classe", "Outra" };
                                                var classeAtual = classesValidas.Contains(voo.Classe) ? voo.Classe : (string.IsNullOrEmpty(voo.Classe) ? "" : "Outra");
                                                var temBagagem = !string.IsNullOrEmpty(voo.BagagemItemPessoalDescricao)
                                                    || !string.IsNullOrEmpty(voo.BagagemItemPessoalMedidas)
                                                    || voo.BagagemMaoPeso.HasValue || !string.IsNullOrEmpty(voo.BagagemMaoMedidas)
                                                    || voo.BagagemDespachadaPeso.HasValue || !string.IsNullOrEmpty(voo.BagagemDespachadaMedidas);
                                            }

                                            <!-- Alerta busca automática -->
                                            <div id="voo-alert-@vooSafeId" class="d-none mb-2"></div>

                                            <!-- Linha 1: Data · Companhia · Nº do Voo + [Buscar] -->
                                            <div class="row g-2 mb-2">
                                                <div class="col-sm-2">
                                                    <label class="form-label small fw-semibold mb-1">Data do voo</label>
                                                    <input type="date" id="data-voo-@vooSafeId"
                                                           class="form-control form-control-sm"
                                                           value="@(voo.HorarioSaida.HasValue ? voo.HorarioSaida.Value.ToString("yyyy-MM-dd") : "")"
                                                           onchange="onDataVooChange('@vooSafeId')" />
                                                </div>
                                                <div class="col-sm-3">
                                                    <label class="form-label small fw-semibold mb-1">Companhia <span class="text-danger">*</span></label>
                                                    <input type="text" name="companhia" id="companhia-@vooSafeId"
                                                           class="form-control form-control-sm"
                                                           list="airlines-datalist"
                                                           value="@voo.Companhia" required maxlength="100"
                                                           placeholder="Selecione ou informe o código ICAO..." />
                                                    <div class="form-text text-muted" style="font-size:0.7rem">Para busca automática, selecione ou informe o ICAO (ex: AZU, GLO, TAM)</div>
                                                </div>
                                                <div class="col-sm-7">
                                                    <label class="form-label small fw-semibold mb-1">Nº do Voo <span class="text-danger">*</span></label>
                                                    <div class="input-group input-group-sm">
                                                        <input type="text" name="numeroVoo" id="numero-voo-@vooSafeId"
                                                               class="form-control form-control-sm"
                                                               value="@voo.NumeroVoo" required maxlength="20"
                                                               placeholder="1234" style="text-transform:uppercase" />
                                                        <button type="button" class="btn btn-outline-info"
                                                                id="btn-buscar-@vooSafeId"
                                                                onclick="consultarVooCard('@vooSafeId')"
                                                                title="Buscar dados do voo via AeroDataBox">
                                                            <i class="fas fa-search me-1"></i>Buscar dados
                                                        </button>
                                                    </div>
                                                </div>
                                            </div>

                                            <!-- Linha 2: Origem · Destino -->
                                            <div class="row g-2 mb-2">
                                                <div class="col-sm-6">
                                                    <label class="form-label small fw-semibold mb-1">Origem <span class="text-danger">*</span></label>
                                                    <input type="text" name="origem" id="origem-@vooSafeId"
                                                           class="form-control form-control-sm"
                                                           value="@voo.Origem" required maxlength="200"
                                                           placeholder="São Paulo (GRU)" />
                                                </div>
                                                <div class="col-sm-6">
                                                    <label class="form-label small fw-semibold mb-1">Destino <span class="text-danger">*</span></label>
                                                    <input type="text" name="destino" id="destino-@vooSafeId"
                                                           class="form-control form-control-sm"
                                                           value="@voo.Destino" required maxlength="200"
                                                           placeholder="Rio de Janeiro (GIG)" />
                                                </div>
                                            </div>

                                            <!-- Linha 3: Saída · Chegada · Duração · Tipo · Classe -->
                                            <div class="row g-2 mb-3">
                                                <div class="col-sm-3">
                                                    <label class="form-label small fw-semibold mb-1">Saída</label>
                                                    <input type="datetime-local" name="horarioSaida"
                                                           id="saida-@vooSafeId" class="form-control form-control-sm"
                                                           value="@(voo.HorarioSaida.HasValue ? voo.HorarioSaida.Value.ToString("yyyy-MM-ddTHH:mm") : "")"
                                                           onchange="onHorarioSaidaChange('@vooSafeId')" />
                                                </div>
                                                <div class="col-sm-3">
                                                    <label class="form-label small fw-semibold mb-1">Chegada</label>
                                                    <input type="datetime-local" name="horarioChegada"
                                                           id="chegada-@vooSafeId" class="form-control form-control-sm"
                                                           value="@(voo.HorarioChegada.HasValue ? voo.HorarioChegada.Value.ToString("yyyy-MM-ddTHH:mm") : "")" />
                                                </div>
                                                <div class="col-sm-2">
                                                    <label class="form-label small fw-semibold mb-1">Duração</label>
                                                    <input type="text" name="duracao" id="duracao-@vooSafeId"
                                                           class="form-control form-control-sm"
                                                           value="@voo.Duracao" maxlength="20" placeholder="2h30" />
                                                </div>
                                                <div class="col-sm-2">
                                                    <label class="form-label small fw-semibold mb-1">Tipo</label>
                                                    @{ var tVoo = voo.TipoVoo; }
                                                    <select name="tipoVoo" class="form-select form-select-sm">
                                                        @if (tVoo == SistemaUsuarios.Models.TipoVoo.Ida)     { <option value="1" selected="selected">✈️ Ida</option> }
                                                        else                                                 { <option value="1">✈️ Ida</option> }
                                                        @if (tVoo == SistemaUsuarios.Models.TipoVoo.Interno) { <option value="3" selected="selected">🔄 Interno</option> }
                                                        else                                                 { <option value="3">🔄 Interno</option> }
                                                        @if (tVoo == SistemaUsuarios.Models.TipoVoo.Volta)   { <option value="2" selected="selected">🛬 Volta</option> }
                                                        else                                                 { <option value="2">🛬 Volta</option> }
                                                    </select>
                                                </div>
                                                <div class="col-sm-2">
                                                    <label class="form-label small fw-semibold mb-1">Classe</label>
                                                    <select name="classe" class="form-select form-select-sm">
                                                        <option value="">— Classe —</option>
                                                        @foreach (var op in classesValidas)
                                                        {
                                                            if (classeAtual == op) { <option value="@op" selected="selected">@op</option> }
                                                            else                   { <option value="@op">@op</option> }
                                                        }
                                                    </select>
                                                </div>
                                            </div>

                                            <!-- Salvar + toggle bagagem -->
                                            <div class="d-flex align-items-center gap-3 mb-2">
                                                <button type="submit" class="btn btn-sm btn-primary">
                                                    <i class="fas fa-save me-1"></i>Salvar voo
                                                </button>
                                                <button type="button"
                                                        class="btn btn-sm btn-link text-muted px-0 py-0 text-decoration-none"
                                                        data-bs-toggle="collapse"
                                                        data-bs-target="#bagagem-voo-@vooSafeId"
                                                        aria-expanded="@(temBagagem ? "true" : "false")">
                                                    <i class="fas fa-suitcase-rolling me-1"></i>Bagagem
                                                    @if (temBagagem)
                                                    {
                                                        <span class="badge bg-secondary ms-1" style="font-size:.62rem;">preenchida</span>
                                                    }
                                                </button>
                                            </div>

                                            <!-- Bagagem Permitida (colapsável) -->
                                            <div class="collapse @(temBagagem ? "show" : "")" id="bagagem-voo-@vooSafeId">
                                                <div class="rounded border p-2 mb-1" style="background:#f8fafc;">
                                                    <p class="small fw-semibold text-muted text-uppercase mb-2" style="letter-spacing:.04em;font-size:.72rem;">
                                                        <i class="fas fa-suitcase-rolling me-1"></i>Bagagem Permitida
                                                    </p>
                                                    <div class="row g-2">
                                                        <div class="col-12"><span class="small fw-semibold" style="color:#374151;font-size:.78rem;">Item pessoal</span></div>
                                                        <div class="col-sm-5">
                                                            <input type="text" name="bagagemItemPessoalDescricao"
                                                                   class="form-control form-control-sm"
                                                                   value="@voo.BagagemItemPessoalDescricao" maxlength="200"
                                                                   placeholder="Tipo / descrição (ex: bolsa, mochila)" />
                                                        </div>
                                                        <div class="col-sm-4">
                                                            <input type="text" name="bagagemItemPessoalMedidas"
                                                                   class="form-control form-control-sm"
                                                                   value="@voo.BagagemItemPessoalMedidas" maxlength="100"
                                                                   placeholder="Medidas (40×30×15 cm)" />
                                                        </div>
                                                        <div class="col-12 mt-1"><span class="small fw-semibold" style="color:#374151;font-size:.78rem;">Bagagem de mão</span></div>
                                                        <div class="col-sm-2">
                                                            <input type="number" name="bagagemMaoPeso"
                                                                   class="form-control form-control-sm"
                                                                   value="@(voo.BagagemMaoPeso.HasValue ? voo.BagagemMaoPeso.Value.ToString("0", System.Globalization.CultureInfo.InvariantCulture) : "")"
                                                                   min="0" max="999" step="1" placeholder="kg" />
                                                        </div>
                                                        <div class="col-sm-4">
                                                            <input type="text" name="bagagemMaoMedidas"
                                                                   class="form-control form-control-sm"
                                                                   value="@voo.BagagemMaoMedidas" maxlength="100"
                                                                   placeholder="Medidas (55×35×25 cm)" />
                                                        </div>
                                                        <div class="col-12 mt-1"><span class="small fw-semibold" style="color:#374151;font-size:.78rem;">Bagagem despachada</span></div>
                                                        <div class="col-sm-2">
                                                            <input type="number" name="bagagemDespachadaPeso"
                                                                   class="form-control form-control-sm"
                                                                   value="@(voo.BagagemDespachadaPeso.HasValue ? voo.BagagemDespachadaPeso.Value.ToString("0", System.Globalization.CultureInfo.InvariantCulture) : "")"
                                                                   min="0" max="999" step="1" placeholder="kg" />
                                                        </div>
                                                        <div class="col-sm-4">
                                                            <input type="text" name="bagagemDespachadaMedidas"
                                                                   class="form-control form-control-sm"
                                                                   value="@voo.BagagemDespachadaMedidas" maxlength="100"
                                                                   placeholder="Medidas (158 cm soma total)" />
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                            <!-- /Bagagem -->
                                        </form>

                                        <hr />

                                        <!-- Passageiros -->
                                        <h6 class="text-muted text-uppercase small mb-3">
                                            <i class="fas fa-users me-1"></i>Passageiros
                                            <span class="badge bg-secondary ms-1">@voo.Passageiros.Count</span>
                                        </h6>

                                        @if (voo.Passageiros.Any())
                                        {
                                            <div class="table-responsive mb-3">
                                                <table class="table table-sm table-hover align-middle mb-0">
                                                    <thead class="table-light">
                                                        <tr>
                                                            <th>Nome</th>
                                                            <th style="width:90px">Assento</th>
                                                            <th style="width:130px">Bagagens</th>
                                                            <th style="width:80px"></th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        @foreach (var pax in voo.Passageiros)
                                                        {
                                                            var paxSafeId = pax.Id.ToString().Replace("-", "");
                                                            <!-- Linha de exibição -->
                                                            <tr id="pax-row-@paxSafeId" class="pax-display-row">
                                                                <td>@pax.Nome</td>
                                                                <td>
                                                                    @if (!string.IsNullOrEmpty(pax.Assento))
                                                                    {
                                                                        <span class="badge bg-light text-dark border">@pax.Assento</span>
                                                                    }
                                                                    else
                                                                    {
                                                                        <span class="text-muted small">—</span>
                                                                    }
                                                                </td>
                                                                <td>
                                                                    @for (int b = 0; b < pax.BagagensDespachadas; b++)
                                                                    {
                                                                        <i class="fas fa-suitcase text-muted me-1"></i>
                                                                    }
                                                                    @if (pax.BagagensDespachadas == 0)
                                                                    {
                                                                        <span class="text-muted small">Sem despacho</span>
                                                                    }
                                                                </td>
                                                                <td class="text-end">
                                                                    <button type="button"
                                                                            class="btn btn-xs btn-outline-secondary me-1"
                                                                            onclick="toggleEditPax('@paxSafeId')"
                                                                            title="Editar passageiro">
                                                                        <i class="fas fa-pencil-alt"></i>
                                                                    </button>
                                                                    <form asp-controller="Voo" asp-action="ExcluirPassageiro"
                                                                          method="post" class="d-inline"
                                                                          onsubmit="return confirm('Remover @Html.Raw(pax.Nome.Replace("'","\\'")??"") do voo?');">
                                                                        @Html.AntiForgeryToken()
                                                                        <input type="hidden" name="id" value="@pax.Id" />
                                                                        <button type="submit" class="btn btn-xs btn-outline-danger" title="Remover">
                                                                            <i class="fas fa-times"></i>
                                                                        </button>
                                                                    </form>
                                                                </td>
                                                            </tr>
                                                            <!-- Linha de edição inline (oculta por padrão) -->
                                                            <tr id="pax-edit-@paxSafeId" class="pax-edit-row d-none bg-light">
                                                                <td colspan="4">
                                                                    <form asp-controller="Voo" asp-action="EditarPassageiro"
                                                                          method="post" class="d-flex align-items-end gap-2 flex-wrap py-1">
                                                                        @Html.AntiForgeryToken()
                                                                        <input type="hidden" name="id" value="@pax.Id" />
                                                                        <div style="flex:2; min-width:150px;">
                                                                            <label class="form-label form-label-sm mb-0">Nome</label>
                                                                            <input type="text" name="nome" class="form-control form-control-sm"
                                                                                   value="@pax.Nome" required maxlength="200" />
                                                                        </div>
                                                                        <div style="flex:0 0 90px;">
                                                                            <label class="form-label form-label-sm mb-0">Assento</label>
                                                                            <input type="text" name="assento" class="form-control form-control-sm"
                                                                                   value="@pax.Assento" maxlength="10" placeholder="23A" />
                                                                        </div>
                                                                        <div style="flex:0 0 100px;">
                                                                            <label class="form-label form-label-sm mb-0">Bagagens</label>
                                                                            <input type="number" name="bagagensDespachadas"
                                                                                   class="form-control form-control-sm"
                                                                                   value="@pax.BagagensDespachadas" min="0" max="10" />
                                                                        </div>
                                                                        <div>
                                                                            <button type="submit" class="btn btn-sm btn-primary">
                                                                                <i class="fas fa-save"></i>
                                                                            </button>
                                                                            <button type="button" class="btn btn-sm btn-outline-secondary"
                                                                                    onclick="toggleEditPax('@paxSafeId')">
                                                                                Cancelar
                                                                            </button>
                                                                        </div>
                                                                    </form>
                                                                </td>
                                                            </tr>
                                                        }
                                                    </tbody>
                                                </table>
                                            </div>
                                        }

                                        <!-- Formulário inline para adicionar passageiro -->
                                        <div class="card bg-light border-0 p-3">
                                            <h6 class="small text-muted fw-semibold mb-2">
                                                <i class="fas fa-user-plus me-1"></i>Adicionar Passageiro
                                            </h6>
                                            <form asp-controller="Voo" asp-action="AdicionarPassageiro" method="post">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="vooId" value="@voo.Id" />
                                                <div class="d-flex align-items-end gap-2 flex-wrap">
                                                    <div style="flex:2; min-width:150px;">
                                                        <label class="form-label form-label-sm mb-0">Nome <span class="text-danger">*</span></label>
                                                        <input type="text" name="nome" class="form-control form-control-sm"
                                                               required maxlength="200" placeholder="Nome completo" />
                                                    </div>
                                                    <div style="flex:0 0 90px;">
                                                        <label class="form-label form-label-sm mb-0">Assento</label>
                                                        <input type="text" name="assento" class="form-control form-control-sm"
                                                               maxlength="10" placeholder="23A" />
                                                    </div>
                                                    <div style="flex:0 0 100px;">
                                                        <label class="form-label form-label-sm mb-0">Bagagens</label>
                                                        <input type="number" name="bagagensDespachadas"
                                                               class="form-control form-control-sm" value="0" min="0" max="10" />
                                                    </div>
                                                    <div>
                                                        <button type="submit" class="btn btn-sm btn-success">
                                                            <i class="fas fa-plus me-1"></i>Adicionar
                                                        </button>
                                                    </div>
                                                </div>
                                            </form>
                                        </div>

                                        <hr class="my-2" />

                                        <!-- ── OBSERVAÇÃO + ANEXOS (colapsável) ──── -->
                                        @{
                                            var temExtras = !string.IsNullOrEmpty(voo.Observacao) || voo.Anexos.Any();
                                        }
                                        <button type="button"
                                                class="btn btn-link btn-sm text-muted px-0 py-0 mb-2 text-decoration-none"
                                                data-bs-toggle="collapse"
                                                data-bs-target="#extras-voo-@vooSafeId"
                                                aria-expanded="@(temExtras ? "true" : "false")">
                                            <i class="fas fa-sticky-note me-1"></i>Observação &amp; Anexos
                                            @if (temExtras)
                                            {
                                                <span class="badge bg-secondary ms-1" style="font-size:.62rem;">
                                                    @(voo.Anexos.Count + (!string.IsNullOrEmpty(voo.Observacao) ? 1 : 0))
                                                </span>
                                            }
                                        </button>
                                        <div class="collapse @(temExtras ? "show" : "")" id="extras-voo-@vooSafeId">

                                        <!-- ── OBSERVAÇÃO ─────────────────────────── -->
                                        <h6 class="text-muted text-uppercase small mb-3">
                                            <i class="fas fa-sticky-note me-1"></i>Observação do Voo
                                        </h6>
                                        <form asp-controller="Voo" asp-action="SalvarObservacao"
                                              method="post" enctype="multipart/form-data" class="mb-3">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="vooId" value="@voo.Id" />
                                            <div class="mb-2">
                                                <textarea name="observacao" class="form-control form-control-sm"
                                                          rows="3" maxlength="4000"
                                                          placeholder="Observações sobre o voo (informações relevantes, instruções, etc.)">@voo.Observacao</textarea>
                                            </div>
                                            @if (!string.IsNullOrEmpty(voo.ObservacaoImagemPath))
                                            {
                                                <div class="mb-2 d-flex align-items-center gap-2">
                                                    <img src="@voo.ObservacaoImagemPath" alt="Imagem da observação"
                                                         class="rounded border" style="max-height:120px; max-width:220px; object-fit:cover;" />
                                                    <form asp-controller="Voo" asp-action="ExcluirObservacaoImagem"
                                                          method="post" class="d-inline">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="vooId" value="@voo.Id" />
                                                        <button type="submit" class="btn btn-xs btn-outline-danger"
                                                                onclick="return confirm('Remover imagem da observação?')"
                                                                title="Remover imagem">
                                                            <i class="fas fa-times me-1"></i>Remover imagem
                                                        </button>
                                                    </form>
                                                </div>
                                            }
                                            else
                                            {
                                                <div class="mb-2">
                                                    <label class="form-label form-label-sm mb-1 text-muted small">
                                                        Imagem (opcional)
                                                    </label>
                                                    <input type="file" name="imagem" class="form-control form-control-sm"
                                                           accept="image/*" />
                                                </div>
                                            }
                                            <button type="submit" class="btn btn-sm btn-outline-secondary">
                                                <i class="fas fa-save me-1"></i>Salvar Observação
                                            </button>
                                        </form>

                                        <hr />

                                        <!-- ── ANEXOS ─────────────────────────────── -->
                                        <h6 class="text-muted text-uppercase small mb-3">
                                            <i class="fas fa-paperclip me-1"></i>Anexos
                                            <span class="badge bg-secondary ms-1">@voo.Anexos.Count</span>
                                        </h6>

                                        @if (voo.Anexos.Any())
                                        {
                                            <ul class="list-group list-group-flush mb-3">
                                                @foreach (var anexo in voo.Anexos)
                                                {
                                                    <li class="list-group-item px-0 d-flex align-items-center gap-2">
                                                        <i class="fas @(anexo.TipoArquivo.StartsWith("image") ? "fa-image text-success" : "fa-file-alt text-primary") fa-fw"></i>
                                                        <a asp-controller="Voo" asp-action="BaixarAnexo"
                                                           asp-route-id="@anexo.Id"
                                                           class="text-truncate small" style="max-width:300px;"
                                                           title="@anexo.NomeOriginal">
                                                            @anexo.NomeOriginal
                                                        </a>
                                                        <span class="text-muted small ms-1">
                                                            (@((anexo.Tamanho / 1024.0).ToString("0.#")) KB)
                                                        </span>
                                                        <form asp-controller="Voo" asp-action="ExcluirAnexo"
                                                              method="post" class="ms-auto d-inline"
                                                              onsubmit="return confirm('Excluir anexo?');">
                                                            @Html.AntiForgeryToken()
                                                            <input type="hidden" name="id" value="@anexo.Id" />
                                                            <button type="submit" class="btn btn-xs btn-outline-danger">
                                                                <i class="fas fa-times"></i>
                                                            </button>
                                                        </form>
                                                    </li>
                                                }
                                            </ul>
                                        }

                                        <form asp-controller="Voo" asp-action="AdicionarAnexo"
                                              method="post" enctype="multipart/form-data"
                                              class="d-flex align-items-end gap-2 flex-wrap">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="vooId" value="@voo.Id" />
                                            <div style="flex:1; min-width:200px;">
                                                <label class="form-label form-label-sm mb-0 text-muted small">
                                                    Adicionar anexo (voucher, PDF, imagem...)
                                                </label>
                                                <input type="file" name="arquivo" class="form-control form-control-sm"
                                                       required accept=".pdf,.jpg,.jpeg,.png,.gif,.webp,.doc,.docx,.xls,.xlsx" />
                                            </div>
                                            <div>
                                                <button type="submit" class="btn btn-sm btn-outline-primary">
                                                    <i class="fas fa-upload me-1"></i>Upload
                                                </button>
                                            </div>
                                        </form>

                                        </div><!-- /extras-voo collapse -->

                                    </div><!-- /card-body -->
                                </div><!-- /collapse -->
                            </div><!-- /card voo -->
                        }
                    </div><!-- /accordion -->
                }
            }
        </div><!-- /pane-aereo -->

        <!-- ============================================================ -->
        <!-- TAB 4: PASSAGEIROS                                            -->
        <!-- ============================================================ -->
        <div class="tab-pane fade @(activeTab == "passageiros" ? "show active" : "")"
             id="pane-passageiros" role="tabpanel">

            @if (proposta == null)
            {
                <div class="alert alert-warning">Proposta não carregada.</div>
            }
            else
            {
                var cliente = proposta.Cliente;

                <!-- ── SEÇÃO: CLIENTE PRINCIPAL ───────────────────────────────── -->
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="mb-0">
                        <i class="fas fa-user-circle me-2 text-primary"></i>Responsável pela proposta
                        <span class="badge bg-secondary fw-normal ms-2" style="font-size:.65em;vertical-align:middle;">Opcional</span>
                    </h5>
                    @if (cliente == null)
                    {
                        <div class="d-flex gap-2">
                            <button type="button" class="btn btn-sm btn-outline-primary"
                                    data-bs-toggle="collapse" data-bs-target="#buscar-cliente-form">
                                <i class="fas fa-search me-1"></i>Buscar cliente
                            </button>
                            <button type="button" class="btn btn-sm btn-primary"
                                    data-bs-toggle="collapse" data-bs-target="#novo-cliente-form">
                                <i class="fas fa-plus me-1"></i>Novo cliente
                            </button>
                        </div>
                    }
                </div>

                @if (cliente == null)
                {
                    <!-- Buscar cliente existente -->
                    <div class="collapse mb-3" id="buscar-cliente-form">
                        <div class="bg-light rounded p-3" style="border:1px solid #dee2e6;">
                            <h6 class="small text-muted fw-semibold mb-2">
                                <i class="fas fa-search me-1"></i>Buscar cliente existente
                            </h6>
                            <div class="position-relative mb-2">
                                <input type="text" id="cliente-busca-input"
                                       class="form-control form-control-sm"
                                       placeholder="Digite nome, email ou CPF..."
                                       autocomplete="off" />
                                <div id="cliente-busca-resultados"
                                     class="list-group mt-1"
                                     style="position:absolute;z-index:9999;width:100%;max-height:220px;overflow-y:auto;display:none;"></div>
                            </div>
                            <form id="form-associar-cliente" asp-controller="Cliente" asp-action="Associar" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="propostaId" value="@proposta.Id" />
                                <input type="hidden" name="clienteId" id="cliente-id-selecionado" />
                                <div id="cliente-selecionado-preview" class="alert alert-info py-2 small mb-2" style="display:none;"></div>
                                <div class="d-flex gap-2">
                                    <button type="submit" id="btn-confirmar-associar"
                                            class="btn btn-sm btn-primary" style="display:none;">
                                        <i class="fas fa-link me-1"></i>Associar cliente selecionado
                                    </button>
                                    <button type="button" class="btn btn-sm btn-outline-secondary"
                                            data-bs-toggle="collapse" data-bs-target="#buscar-cliente-form">
                                        Cancelar
                                    </button>
                                </div>
                            </form>
                        </div>
                    </div>

                    <!-- Cadastrar novo cliente -->
                    <div class="collapse mb-4" id="novo-cliente-form">
                        <div class="bg-light rounded p-3" style="border:1px solid #dee2e6;">
                            <h6 class="small text-muted fw-semibold mb-3">
                                <i class="fas fa-user-plus me-1"></i>Cadastrar novo cliente
                            </h6>
                            <form asp-controller="Cliente" asp-action="CriarEAssociar"
                                  method="post" enctype="multipart/form-data">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="propostaId" value="@proposta.Id" />
                                <div class="row g-2 mb-2">
                                    <div class="col-md-4">
                                        <label class="form-label form-label-sm mb-0">Nome <span class="text-danger">*</span></label>
                                        <input type="text" name="nome" class="form-control form-control-sm"
                                               required maxlength="200" placeholder="Nome completo..." />
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label form-label-sm mb-0">Email</label>
                                        <input type="email" name="email" class="form-control form-control-sm"
                                               maxlength="200" />
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label form-label-sm mb-0">Telefone</label>
                                        <input type="text" name="telefone" class="form-control form-control-sm"
                                               maxlength="30" />
                                    </div>
                                    <div class="col-md-3">
                                        <label class="form-label form-label-sm mb-0">Data de Nascimento</label>

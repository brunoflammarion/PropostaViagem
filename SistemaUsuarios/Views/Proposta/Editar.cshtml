        // ============================================================
        // COLLAPSE STATE — preserva destinos abertos via sessionStorage
        // ============================================================
        function configurarCollapseState() {
            var STORAGE_KEY = 'agenttools.propostaEditar.destinos.@Model.Id';

            function getOpenIds() {
                try { return JSON.parse(sessionStorage.getItem(STORAGE_KEY) || '[]'); }
                catch (e) { return []; }
            }

            function saveOpenIds(ids) {
                sessionStorage.setItem(STORAGE_KEY, JSON.stringify(ids));
            }

            function setChevron(collapseId, open) {
                var btn = document.querySelector('[data-bs-target="#' + collapseId + '"] i');
                if (!btn) return;
                btn.classList.remove('fa-chevron-down', 'fa-chevron-up');
                btn.classList.add(open ? 'fa-chevron-up' : 'fa-chevron-down');
            }

            // Registra eventos em todos os collapses de destino
            document.querySelectorAll('[id^="detalhes-"]').forEach(function (el) {
                var destinoId = el.id.replace('detalhes-', '');

                el.addEventListener('show.bs.collapse', function () {
                    var ids = getOpenIds();
                    if (ids.indexOf(destinoId) === -1) ids.push(destinoId);
                    saveOpenIds(ids);
                    setChevron(el.id, true);
                    // Auto-gera descrição se nome preenchido mas descrição ainda vazia
                    var nomeEl = document.getElementById('nome-dest-' + destinoId);
                    var descEl = document.getElementById('desc-dest-' + destinoId);
                    if (nomeEl && nomeEl.value.trim() && descEl && !descEl.value.trim()) {
                        setTimeout(function () { gerarDescricaoDestino(destinoId); }, 400);
                    }
                });

                el.addEventListener('hide.bs.collapse', function () {
                    saveOpenIds(getOpenIds().filter(function (id) { return id !== destinoId; }));
                    setChevron(el.id, false);
                });
            });

            // Reabre destinos que estavam abertos antes do reload
            getOpenIds().forEach(function (destinoId) {
                var el = document.getElementById('detalhes-' + destinoId);
                if (!el) return;
                var bsCollapse = new bootstrap.Collapse(el, { toggle: false });
                bsCollapse.show();
            });
        }

        function configurarSortables() {
            const destinosContainer = document.getElementById('destinos-container');
            if (destinosContainer) {
                Sortable.create(destinosContainer, {
                    handle: '.drag-handle',
                    animation: 150,
                    onEnd: function () {
                        const destinosIds = Array.from(destinosContainer.children).map(item =>
                            item.getAttribute('data-destino-id')
                        );
                        fetch('/Destino/ReordenarDestinos', {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/json',
                                'RequestVerificationToken': getRequestVerificationToken()
                            },
                            body: JSON.stringify({ propostaId: '@proposta?.Id', destinosIds })
                        }).then(r => {
                            if (r.ok) showSuccessAlert('Ordem atualizada!');
                            else showErrorAlert('Erro ao reordenar destinos');

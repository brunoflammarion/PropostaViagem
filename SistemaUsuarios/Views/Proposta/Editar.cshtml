                                                    </div>
                                                }
                                            </div>
                                            <div class="col">
                                                <div class="row">
                                                    <div class="col-md-3">
                                                        <h6 class="mb-1">@destino.Nome</h6>
                                                        <small class="text-muted">
                                                            @if (!string.IsNullOrEmpty(destino.Cidade) || !string.IsNullOrEmpty(destino.Pais))
                                                            {
                                                                <i class="fas fa-globe me-1"></i>
                                                                @destino.Cidade@((!string.IsNullOrEmpty(destino.Cidade) && !string.IsNullOrEmpty(destino.Pais)) ? ", " : "")@destino.Pais
                                                            }
                                                        </small>
                                                    </div>
                                                    <div class="col-md-3">
                                                        @if (destino.DataChegada.HasValue || destino.DataSaida.HasValue)
                                                        {
                                                            <small class="text-muted">
                                                                <i class="fas fa-calendar me-1"></i>
                                                                @destino.DataChegada?.ToString("dd/MM") — @destino.DataSaida?.ToString("dd/MM")
                                                            </small>
                                                        }
                                                    </div>
                                                    <div class="col-md-2">
                                                        <small class="text-muted"><i class="fas fa-images me-1"></i>@destino.Fotos.Count foto(s)</small>
                                                    </div>
                                                    <div class="col-md-4">
                                                        @if (!string.IsNullOrEmpty(destino.Descricao))
                                                        {
                                                            <small class="text-muted">
                                                                @(destino.Descricao.Length > 80 ? destino.Descricao.Substring(0, 80) + "..." : destino.Descricao)
                                                            </small>
                                                        }
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="col-auto">
                                                <div class="btn-group btn-group-sm">
                                                    <button type="button" class="btn btn-outline-primary"
                                                            data-bs-toggle="collapse" data-bs-target="#detalhes-@destino.Id">
                                                        <i class="fas fa-chevron-down"></i>
                                                    </button>

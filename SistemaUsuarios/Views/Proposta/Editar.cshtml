                                                                        <i class="fas fa-arrows-alt me-1"></i>Arraste para reordenar
                                                                    </small>
                                                                }
                                                                <form asp-controller="Transporte" asp-action="AdicionarImagem"
                                                                      method="post" enctype="multipart/form-data"
                                                                      class="mb-3">
                                                                    @Html.AntiForgeryToken()
                                                                    <input type="hidden" name="transporteId" value="@transp.Id" />
                                                                    <label class="form-label form-label-sm text-muted small mb-1">
                                                                        <i class="fas fa-plus me-1"></i>Adicionar imagens
                                                                    </label>
                                                                    <input type="file" name="imagens"
                                                                           class="form-control form-control-sm"
                                                                           accept="image/*" multiple
                                                                           data-auto-upload />

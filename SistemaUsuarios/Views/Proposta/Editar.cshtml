        // IA — Gerar descrição para destino existente (cards editáveis)
        async function gerarDescricaoDestino(destinoId) {
            const nomeEl  = document.getElementById('nome-dest-'   + destinoId);
            const descEl  = document.getElementById('desc-dest-'   + destinoId);
            const alertEl = document.getElementById('desc-alert-'  + destinoId);

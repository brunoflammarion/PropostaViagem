            }
        }

        // ============================================================
        // SORTABLE
        // ============================================================
        // ============================================================
        // AUTO UPLOAD — submete o form automaticamente ao selecionar imagens
        // ============================================================
        function configurarAutoUpload() {
            document.querySelectorAll('[data-auto-upload]').forEach(function(input) {
                input.addEventListener('change', function() {
                    if (!this.files || this.files.length === 0) return;
                    var form = this.closest('form');
                    if (!form) return;
                    // Indicador visual — não usar disabled pois inputs disabled são excluídos da submissão (HTML spec)
                    this.style.pointerEvents = 'none';
                    this.style.opacity = '0.5';
                    var spinner = form.querySelector('.upload-spinner');
                    if (spinner) spinner.style.display = 'inline-block';
                    form.submit();
                });
            });
        }

        // ── Preview de fotos no formulário "Nova Hospedagem" ─────────────────
        function configurarPreviewFotosNovaHospedagem() {
            document.querySelectorAll('.new-hosp-fotos-input').forEach(function (input) {
                var dropzone = input.closest('label.new-hosp-dropzone');
                var preview  = dropzone ? dropzone.nextElementSibling : null;
                if (!preview) return;

                var fileMap = []; // [{file, url}]
                var MAX_MB  = 10 * 1024 * 1024;

                function addFiles(list) {
                    var erros = [];
                    Array.from(list).forEach(function (f) {
                        if (!f.type.startsWith('image/')) { erros.push(f.name + ': não é imagem'); return; }
                        if (f.size > MAX_MB)              { erros.push(f.name + ': maior que 10 MB'); return; }
                        if (fileMap.some(function (x) { return x.file.name === f.name && x.file.size === f.size; })) return;
                        fileMap.push({ file: f, url: URL.createObjectURL(f) });
                    });
                    if (erros.length) alert('Arquivo(s) ignorado(s):\n' + erros.join('\n'));
                    rebuild();
                }

                function rebuild() {
                    preview.innerHTML = '';
                    var dt = new DataTransfer();

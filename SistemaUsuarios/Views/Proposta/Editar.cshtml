                                        <div class="col-md-2">
                                            <label class="form-label form-label-sm mb-0">Gênero</label>
                                            <select name="genero" class="form-select form-select-sm">
                                                <option value="">—</option>
                                                <option value="1" selected="@(_paxGenero == 1 ? "selected" : null)">Masculino</option>
                                                <option value="2" selected="@(_paxGenero == 2 ? "selected" : null)">Feminino</option>
                                                <option value="3" selected="@(_paxGenero == 3 ? "selected" : null)">Outro</option>
                                            </select>
                                        </div>
                                        <div class="col-md-3">
                                            <label class="form-label form-label-sm mb-0">Relacionamento</label>
                                            <select name="relacionamento" class="form-select form-select-sm">
                                                <option value="">— Selecionar —</option>
                                                <option value="1" selected="@(_paxRel == 1 ? "selected" : null)">Filho</option>
                                                <option value="2" selected="@(_paxRel == 2 ? "selected" : null)">Filha</option>
                                                <option value="3" selected="@(_paxRel == 3 ? "selected" : null)">Amigo</option>
                                                <option value="4" selected="@(_paxRel == 4 ? "selected" : null)">Amiga</option>
                                                <option value="5" selected="@(_paxRel == 5 ? "selected" : null)">Esposa</option>
                                                <option value="6" selected="@(_paxRel == 6 ? "selected" : null)">Marido</option>
                                                <option value="7" selected="@(_paxRel == 7 ? "selected" : null)">Sogra</option>
                                                <option value="8" selected="@(_paxRel == 8 ? "selected" : null)">Sogro</option>
                                                <option value="9" selected="@(_paxRel == 9 ? "selected" : null)">Cunhado</option>
                                                <option value="10" selected="@(_paxRel == 10 ? "selected" : null)">Cunhada</option>
                                                <option value="11" selected="@(_paxRel == 11 ? "selected" : null)">Neto</option>
                                                <option value="12" selected="@(_paxRel == 12 ? "selected" : null)">Neta</option>
                                                <option value="13" selected="@(_paxRel == 13 ? "selected" : null)">Pai</option>
                                                <option value="14" selected="@(_paxRel == 14 ? "selected" : null)">Mãe</option>
                                                <option value="15" selected="@(_paxRel == 15 ? "selected" : null)">Irmão</option>
                                                <option value="16" selected="@(_paxRel == 16 ? "selected" : null)">Irmã</option>
                                                <option value="99" selected="@(_paxRel == 99 ? "selected" : null)">Outro</option>
                                            </select>
                                        </div>
                                        <div class="col-12">
                                            <div class="form-check mb-1">
                                                <input type="checkbox" name="faixaIsAproximada" value="true"
                                                       id="edit-faixa-chk-@pax.Id" class="form-check-input edit-faixa-chk"
                                                       @(pax.FaixaIsAproximada ? "checked" : "")>
                                                <label for="edit-faixa-chk-@pax.Id" class="form-check-label small text-muted">
                                                    Data de nascimento não informada — usar faixa etária aproximada
                                                </label>
                                            </div>
                                            <select name="faixaEtaria" id="edit-faixa-select-@pax.Id"
                                                    class="form-select form-select-sm mt-1 edit-faixa-select"
                                                    style="@(pax.FaixaIsAproximada ? "" : "display:none;")">
                                                <option value="">— Faixa etária —</option>
                                                <option value="1" selected="@(_paxFaixa == 1 ? "selected" : null)">Bebê (menos de 2 anos)</option>
                                                <option value="2" selected="@(_paxFaixa == 2 ? "selected" : null)">Criança (2 a 11 anos)</option>
                                                <option value="3" selected="@(_paxFaixa == 3 ? "selected" : null)">Adolescente (12 a 17 anos)</option>
                                                <option value="4" selected="@(_paxFaixa == 4 ? "selected" : null)">Adulto (18 anos ou mais)</option>
                                            </select>
                                        </div>
                                        <div class="col-md-4 edit-modo-bebe-wrap-@pax.Id"
                                             style="@(pax.ModoBebe.HasValue || (_paxFaixa == 1 && pax.FaixaIsAproximada) ? "" : "display:none;")">
                                            <label class="form-label form-label-sm mb-0">Modo bebê</label>
                                            <select name="modoBebe" class="form-select form-select-sm">
                                                <option value="">— Selecionar —</option>
                                                <option value="1" selected="@(_paxModo == 1 ? "selected" : null)">No colo</option>
                                                <option value="2" selected="@(_paxModo == 2 ? "selected" : null)">Assento próprio</option>
                                            </select>
                                        </div>
                                        <div class="col-12">
                                            <label class="form-label form-label-sm mb-0">Observações</label>
                                            <input type="text" name="observacoes" class="form-control form-control-sm"
                                                   value="@pax.Observacoes" maxlength="2000" />
                                        </div>
                                    </div>
                                    <button type="submit" class="btn btn-sm btn-primary">
                                        <i class="fas fa-save me-1"></i>Salvar
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div><!-- /card pax -->
                }

                @if (!proposta.PassageirosProposta.Any())
                {
                    <div class="text-center py-3 text-muted">
                        <small>Nenhum passageiro cadastrado. Use "Adicionar Passageiro" para incluir os viajantes.</small>
                    </div>
                }
            }
        </div><!-- /pane-passageiros -->

        <!-- ============================================================ -->
        <!-- TAB 5: SEGURO                                                 -->
        <!-- ============================================================ -->
        <div class="tab-pane fade @(activeTab == "seguro" ? "show active" : "")"
             id="pane-seguro" role="tabpanel">

            @if (proposta == null)
            {
                <div class="alert alert-warning">Proposta não carregada.</div>
            }
            else
            {
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="mb-0">
                        <i class="fas fa-shield-alt me-2 text-success"></i>Seguros
                        <span class="badge bg-secondary ms-1">@proposta.Seguros.Count</span>
                    </h5>
                    <button type="button" class="btn btn-sm btn-outline-success"
                            data-bs-toggle="collapse"
                            data-bs-target="#add-seguro-form">
                        <i class="fas fa-plus me-1"></i>Adicionar Seguro
                    </button>
                </div>

                <!-- Formulário inline para adicionar novo seguro -->
                <div class="collapse mb-4" id="add-seguro-form">
                    <div class="bg-light rounded p-3" style="border:1px solid #dee2e6;">
                        <h6 class="small text-muted fw-semibold mb-2">Novo Seguro</h6>
                        <form asp-controller="Seguro" asp-action="Adicionar" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="propostaId" value="@proposta.Id" />
                            <div class="row g-2 mb-2">
                                <div class="col-md-7">
                                    <label class="form-label form-label-sm mb-0">Título <span class="text-danger">*</span></label>
                                    <input type="text" name="titulo"
                                           class="form-control form-control-sm"
                                           required maxlength="200"
                                           placeholder="Ex: Seguro Viagem Internacional..." />
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label form-label-sm mb-0">Valor (R$)</label>
                                    <input type="number" name="valor"
                                           class="form-control form-control-sm"
                                           step="0.01" min="0"
                                           placeholder="350,00" />
                                </div>
                            </div>
                            <div class="mb-2">
                                <label class="form-label form-label-sm mb-0">Descrição</label>
                                <textarea name="descricao"
                                          class="form-control form-control-sm"
                                          rows="2" maxlength="4000"
                                          placeholder="Cobertura, franquia, contato da seguradora..."></textarea>
                            </div>
                            <div class="d-flex gap-2">
                                <button type="submit" class="btn btn-sm btn-success">
                                    <i class="fas fa-plus me-1"></i>Adicionar
                                </button>
                                <button type="button" class="btn btn-sm btn-outline-secondary"
                                        data-bs-toggle="collapse"
                                        data-bs-target="#add-seguro-form">
                                    Cancelar
                                </button>
                            </div>
                        </form>
                    </div>
                </div>

                @if (!proposta.Seguros.Any())
                {
                    <div class="text-center py-5 text-muted">
                        <i class="fas fa-shield-alt fa-3x mb-3 opacity-25"></i>
                        <p class="mb-0">Nenhum seguro cadastrado para esta proposta.</p>
                        <small>Clique em "Adicionar Seguro" para começar.</small>
                    </div>
                }
                else
                {
                    @foreach (var seguro in proposta.Seguros.OrderBy(s => s.Ordem))
                    {
                        <div class="card mb-3 border-success" style="overflow:visible;">
                            <div class="card-header bg-light d-flex justify-content-between align-items-center py-2">
                                <div class="d-flex align-items-center gap-2 flex-wrap">
                                    <i class="fas fa-shield-alt text-success"></i>
                                    <span class="fw-semibold">@seguro.Titulo</span>
                                    @if (seguro.Valor.HasValue)
                                    {
                                        <span class="badge bg-success">R$ @seguro.Valor.Value.ToString("N2")</span>
                                    }
                                    @if (seguro.Imagens.Any())
                                    {
                                        <span class="badge bg-light text-dark border">
                                            <i class="fas fa-images me-1"></i>@seguro.Imagens.Count img
                                        </span>
                                    }
                                    @if (seguro.Documentos.Any())
                                    {
                                        <span class="badge bg-light text-dark border">
                                            <i class="fas fa-file me-1"></i>@seguro.Documentos.Count doc
                                        </span>
                                    }
                                </div>
                                <div class="btn-group btn-group-sm ms-auto">
                                    <button type="button" class="btn btn-outline-primary btn-sm"
                                            data-bs-toggle="collapse"
                                            data-bs-target="#seguro-body-@seguro.Id">
                                        <i class="fas fa-edit me-1"></i>Editar
                                    </button>
                                    <form asp-controller="Seguro" asp-action="Excluir" method="post"
                                          style="display:inline;"
                                          onsubmit="return confirm('Excluir este seguro e todos seus arquivos?');">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@seguro.Id" />
                                        <button type="submit" class="btn btn-outline-danger btn-sm">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </div>

                            <div class="collapse" id="seguro-body-@seguro.Id">
                                <div class="card-body">

                                    <!-- Editar dados do seguro -->
                                    <form asp-controller="Seguro" asp-action="Editar" method="post" class="mb-4">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@seguro.Id" />
                                        <h6 class="text-muted text-uppercase small mb-2">
                                            <i class="fas fa-edit me-1"></i>Dados do Seguro
                                        </h6>
                                        <div class="row g-2 mb-2">
                                            <div class="col-md-7">
                                                <label class="form-label form-label-sm mb-0">Título <span class="text-danger">*</span></label>
                                                <input type="text" name="titulo"
                                                       class="form-control form-control-sm"
                                                       value="@seguro.Titulo"
                                                       required maxlength="200" />
                                            </div>
                                            <div class="col-md-3">
                                                <label class="form-label form-label-sm mb-0">Valor (R$)</label>
                                                <input type="number" name="valor"
                                                       class="form-control form-control-sm"
                                                       value="@seguro.Valor"
                                                       step="0.01" min="0" />
                                            </div>
                                        </div>
                                        <div class="mb-2">
                                            <label class="form-label form-label-sm mb-0">Descrição</label>
                                            <textarea name="descricao"
                                                      class="form-control form-control-sm"
                                                      rows="3" maxlength="4000">@seguro.Descricao</textarea>
                                        </div>
                                        <button type="submit" class="btn btn-sm btn-primary">
                                            <i class="fas fa-save me-1"></i>Salvar
                                        </button>
                                    </form>

                                    <hr class="my-3" />

                                    <!-- Imagens -->
                                    <div class="mb-3">
                                        <h6 class="text-muted mb-2">
                                            <i class="fas fa-images me-1"></i>Imagens
                                            <span class="badge bg-secondary ms-1">@seguro.Imagens.Count</span>
                                        </h6>
                                        @if (seguro.Imagens.Any())
                                        {
                                            <div class="d-flex flex-wrap gap-2 mb-2">
                                                @foreach (var img in seguro.Imagens.OrderBy(i => i.Ordem))
                                                {
                                                    <div class="position-relative" style="width:100px;height:75px;">
                                                        <img src="@img.CaminhoImagem"
                                                             alt="@img.Descricao"
                                                             class="rounded"
                                                             style="width:100px;height:75px;object-fit:cover;" />
                                                        @if (!string.IsNullOrEmpty(img.Descricao))
                                                        {
                                                            <div class="position-absolute bottom-0 start-0 end-0 text-center"
                                                                 style="background:rgba(0,0,0,.5);border-radius:0 0 4px 4px;">
                                                                <small class="text-white" style="font-size:0.6rem;">@img.Descricao</small>
                                                            </div>
                                                        }
                                                        <form asp-controller="Seguro" asp-action="ExcluirImagem"
                                                              method="post" style="display:inline;"
                                                              onsubmit="return confirm('Excluir imagem?');">
                                                            @Html.AntiForgeryToken()
                                                            <input type="hidden" name="id" value="@img.Id" />
                                                            <button type="submit"
                                                                    class="btn btn-danger position-absolute top-0 end-0 p-0"
                                                                    style="width:18px;height:18px;font-size:0.6rem;line-height:1;border-radius:50%;">
                                                                <i class="fas fa-times"></i>
                                                            </button>
                                                        </form>
                                                    </div>
                                                }
                                            </div>
                                        }
                                        else
                                        {
                                            <p class="small text-muted mb-2">Nenhuma imagem.</p>
                                        }
                                        <form asp-controller="Seguro" asp-action="AdicionarImagem"
                                              method="post" enctype="multipart/form-data"
                                              class="d-flex gap-2 align-items-end">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="seguroId" value="@seguro.Id" />
                                            <div style="flex:1;min-width:140px;">
                                                <label class="form-label form-label-sm mb-0 text-muted small">Adicionar imagem</label>
                                                <input type="file" name="imagem"
                                                       class="form-control form-control-sm"
                                                       accept="image/*" required />
                                            </div>
                                            <div style="min-width:120px;">
                                                <label class="form-label form-label-sm mb-0 text-muted small">Legenda</label>
                                                <input type="text" name="descricao"
                                                       class="form-control form-control-sm"
                                                       placeholder="Opcional" maxlength="200" />
                                            </div>
                                            <button type="submit" class="btn btn-sm btn-outline-success flex-shrink-0">
                                                <i class="fas fa-upload me-1"></i>Upload
                                            </button>
                                        </form>
                                    </div>

                                    <hr class="my-3" />

                                    <!-- Documentos -->
                                    <div>
                                        <h6 class="text-muted mb-2">
                                            <i class="fas fa-file me-1"></i>Documentos
                                            <span class="badge bg-secondary ms-1">@seguro.Documentos.Count</span>
                                        </h6>
                                        @if (seguro.Documentos.Any())
                                        {
                                            <div class="list-group list-group-flush mb-2">
                                                @foreach (var doc in seguro.Documentos.OrderBy(d => d.DataCriacao))
                                                {
                                                    <div class="list-group-item px-0 py-1 d-flex align-items-center gap-2">
                                                        <i class="fas fa-file-alt text-muted flex-shrink-0"></i>
                                                        <span class="small flex-grow-1 text-truncate" title="@doc.NomeOriginal">
                                                            @doc.NomeOriginal
                                                        </span>
                                                        <small class="text-muted flex-shrink-0">
                                                            @((doc.Tamanho / 1024.0).ToString("N0")) KB
                                                        </small>
                                                        <a href="/Seguro/BaixarDocumento/@doc.Id"
                                                           class="btn btn-xs btn-outline-primary flex-shrink-0"
                                                           title="Download">
                                                            <i class="fas fa-download"></i>
                                                        </a>
                                                        <form asp-controller="Seguro" asp-action="ExcluirDocumento"
                                                              method="post" style="display:inline;"
                                                              onsubmit="return confirm('Excluir documento?');">
                                                            @Html.AntiForgeryToken()
                                                            <input type="hidden" name="id" value="@doc.Id" />
                                                            <button type="submit" class="btn btn-xs btn-outline-danger">
                                                                <i class="fas fa-trash"></i>
                                                            </button>
                                                        </form>
                                                    </div>
                                                }
                                            </div>
                                        }
                                        else
                                        {
                                            <p class="small text-muted mb-2">Nenhum documento.</p>
                                        }
                                        <form asp-controller="Seguro" asp-action="AdicionarDocumento"
                                              method="post" enctype="multipart/form-data"
                                              class="d-flex gap-2 align-items-end">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="seguroId" value="@seguro.Id" />
                                            <div style="flex:1;min-width:200px;">
                                                <label class="form-label form-label-sm mb-0 text-muted small">
                                                    Adicionar documento (PDF, imagem, Word...)
                                                </label>
                                                <input type="file" name="documento"
                                                       class="form-control form-control-sm"
                                                       required
                                                       accept=".pdf,.jpg,.jpeg,.png,.gif,.webp,.doc,.docx,.xls,.xlsx" />
                                            </div>
                                            <button type="submit" class="btn btn-sm btn-outline-primary flex-shrink-0">
                                                <i class="fas fa-upload me-1"></i>Upload
                                            </button>
                                        </form>
                                    </div>

                                </div><!-- /card-body -->
                            </div><!-- /collapse -->
                        </div><!-- /card -->
                    }
                }
            }
        </div><!-- /pane-seguro -->

        <!-- ============================================================ -->
        <!-- TAB 6: CONDIÇÕES DA PROPOSTA                                  -->
        <!-- ============================================================ -->
        <div class="tab-pane fade @(activeTab == "condicoes" ? "show active" : "")"
             id="pane-condicoes" role="tabpanel">

            <style>
            #condicoes-save-bar, #valores-save-bar { height: 32px; display: flex; align-items: center; }
            </style>

            @if (proposta != null)
            {
                <div class="row">
                    <div class="col-12 mb-4">
                        <div class="card border-0 shadow-sm overflow-hidden">
                            <div class="card-header border-0 py-3 d-flex justify-content-between align-items-center"
                                 style="background:linear-gradient(135deg,#1a1a2e 0%,#0f3460 100%);">
                                <h5 class="mb-0 text-white">
                                    <i class="fas fa-file-contract me-2"></i>Condições da Proposta
                                </h5>
                                <div id="condicoes-save-bar" class="gap-2">
                                    <small id="condicoes-status" class="text-white-50 me-2"></small>
                                    <button type="button" id="btn-salvar-condicoes" class="btn btn-light btn-sm px-3">
                                        <i class="fas fa-save me-1"></i>Salvar
                                    </button>
                                </div>
                            </div>
                            <div id="condicoes-editor"></div>
                            <div class="card-footer border-0 bg-light py-2 px-3">
                                <small class="text-muted">
                                    <i class="fas fa-eye me-1 text-primary"></i>
                                    Quando preenchido, aparece na proposta pública com as condições gerais da viagem.
                                </small>
                            </div>
                        </div>
                    </div>
                    <div class="col-12">
                        <div class="card border-0 shadow-sm overflow-hidden">
                            <div class="card-header border-0 py-3 d-flex justify-content-between align-items-center"
                                 style="background:linear-gradient(135deg,#1a1a2e 0%,#0f3460 100%);">
                                <h5 class="mb-0 text-white">
                                    <i class="fas fa-dollar-sign me-2"></i>Valores da Proposta
                                </h5>
                                <div id="valores-save-bar" class="gap-2">
                                    <small id="valores-status" class="text-white-50 me-2"></small>
                                    <button type="button" id="btn-salvar-valores" class="btn btn-light btn-sm px-3">
                                        <i class="fas fa-save me-1"></i>Salvar
                                    </button>
                                </div>
                            </div>
                            <div id="valores-editor"></div>
                            <div class="card-footer border-0 bg-light py-2 px-3">
                                <small class="text-muted">
                                    <i class="fas fa-eye me-1 text-primary"></i>
                                    Quando preenchido, aparece na proposta pública com os valores, formas de pagamento e observações.
                                </small>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div><!-- /pane-condicoes -->

        <!-- ============================================================ -->
        <!-- TAB 7: REVISÃO                                                -->
        <!-- ============================================================ -->
        <div class="tab-pane fade @(activeTab == "revisao" ? "show active" : "")"
             id="pane-revisao" role="tabpanel">

            <style>
            /* ── Revisão tab ────────────────────────────────────────────── */
            .rev-section-label {
                font-size: .62rem; font-weight: 700; text-transform: uppercase;
                letter-spacing: .1em; color: #6c757d;
                border-bottom: 1px solid #f0f0f0; padding-bottom: 8px; margin-bottom: 14px;
            }
            .rev-stat-chip {
                display: inline-flex; align-items: center; gap: 5px;
                background: #f8f9fa; border: 1px solid #e9ecef; border-radius: 50px;
                padding: 4px 12px; font-size: .8rem; color: #495057; white-space: nowrap;
            }
            .rev-dest-card {
                background: #f8f9fa; border-radius: 10px; padding: 12px 14px;
                border-left: 3px solid #0dcaf0; margin-bottom: 8px;
            }
            .rev-voo-card {
                background: #f8f9fa; border-radius: 10px; padding: 12px 14px;
                border-left: 3px solid #0d6efd; margin-bottom: 8px;
            }
            .rev-seguro-card {
                background: #f8f9fa; border-radius: 10px; padding: 12px 14px;
                border-left: 3px solid #198754; margin-bottom: 8px;
            }
            .rev-insight-label {
                font-size: .65rem; font-weight: 700; text-transform: uppercase;
                letter-spacing: .07em; color: #6c757d;
            }
            .rev-insight-value { font-size: .88rem; color: #212529; line-height: 1.5; }
            .rev-gancho {
                font-size: .83rem; background: #fffbeb; border-left: 3px solid #f59e0b;
                padding: 6px 10px; border-radius: 0 6px 6px 0; margin-top: 6px; color: #7c5200;
            }
            .rev-arr-item {
                border: 1px solid #e9ecef; border-radius: 8px; padding: 12px 14px;
                margin-bottom: 8px; background: #fff;
            }
            .accordion-button:not(.collapsed) { background: #f8f9fa; color: #212529; box-shadow: none; }
            .accordion-button:focus { box-shadow: none; }
            .accordion-button { font-size: .88rem; }
            /* Painel de insights por destino */
            .dest-insights-panel {
                background: #f8f9ff;
                border: 1px solid rgba(10,17,40,.08);
                border-radius: 8px;
                padding: 12px 14px;
            }
            .dest-insights-panel .panel-title {
                font-size: .72rem; font-weight: 700; text-transform: uppercase;
                letter-spacing: .05em; color: #0A1128; opacity: .55; margin-bottom: 10px;
            }
            /* Quill editor — Resumo da Proposta */
            .ql-toolbar.ql-snow {
                border-radius: 0; border: none; border-bottom: 1px solid #dee2e6;
                background: #f8f9fa; padding: 8px 12px;
            }
            .ql-container.ql-snow {
                border: none; font-family: -apple-system, BlinkMacSystemFont, 'Inter', sans-serif;
                font-size: .93rem;
            }
            .ql-editor { min-height: 220px; padding: 16px 20px; line-height: 1.7; color: #2d3748; }
            .ql-editor.ql-blank::before { color: #adb5bd; font-style: normal; }
            .ql-snow .ql-picker { color: #495057; }
            .ql-snow .ql-stroke { stroke: #495057; }
            .ql-snow .ql-fill { fill: #495057; }
            </style>

            @if (proposta != null)
            {
                bool temInsights = proposta.Destinos.Any(d =>
                    !string.IsNullOrEmpty(d.CuidadosLLM) ||
                    !string.IsNullOrEmpty(d.GastronomiaLLM) ||
                    !string.IsNullOrEmpty(d.AtracoesLLM) ||
                    !string.IsNullOrEmpty(d.InformacoesPraticasLLM) ||
                    !string.IsNullOrEmpty(d.MalaViagemLLM) ||
                    !string.IsNullOrEmpty(d.PratosTipicosLLM));

                <div class="row g-4">

                    <!-- ════════════════════════════════════════════════════ -->
                    <!--   COLUNA ESQUERDA — RESUMO DA VIAGEM                -->
                    <!-- ════════════════════════════════════════════════════ -->
                    <div class="@(temInsights ? "col-lg-6" : "col-lg-8 offset-lg-2")">

                        <div class="card border-0 shadow-sm mb-3">
                            <div class="card-header border-0 py-3"
                                 style="background:linear-gradient(135deg,#1a1a2e 0%,#0f3460 100%);">
                                <h5 class="mb-0 text-white">
                                    <i class="fas fa-route me-2"></i>Resumo da Viagem
                                </h5>
                            </div>
                            <div class="card-body p-4">

                                <!-- Dados básicos da proposta -->
                                <div class="mb-4">
                                    <div class="rev-section-label">
                                        <i class="fas fa-suitcase-rolling me-1"></i>Proposta
                                    </div>
                                    <h4 class="fw-bold mb-3">@proposta.Titulo</h4>
                                    <div class="d-flex flex-wrap gap-2">
                                        @if (proposta.DataInicio.HasValue && proposta.DataFim.HasValue)
                                        {
                                            var totalDias = (proposta.DataFim.Value - proposta.DataInicio.Value).Days + 1;
                                            <span class="rev-stat-chip">
                                                <i class="fas fa-calendar-alt text-primary"></i>
                                                @proposta.DataInicio.Value.ToString("dd/MM/yyyy") → @proposta.DataFim.Value.ToString("dd/MM/yyyy")
                                                <span class="badge bg-primary ms-1">@totalDias dias</span>
                                            </span>
                                        }
                                        <span class="rev-stat-chip">
                                            <i class="fas fa-users text-info"></i>
                                            @proposta.NumeroPassageiros adulto(s)@(proposta.NumeroCriancas > 0 ? $" + {proposta.NumeroCriancas} criança(s)" : "")
                                        </span>
                                        <span class="rev-stat-chip">
                                            <i class="fas fa-map-pin text-danger"></i>
                                            @proposta.Destinos.Count destino(s)
                                        </span>
                                        @if (proposta.Voos.Any())
                                        {
                                            <span class="rev-stat-chip">
                                                <i class="fas fa-plane text-primary"></i>
                                                @proposta.Voos.Count voo(s)
                                            </span>
                                        }
                                        @if (proposta.Seguros.Any())
                                        {
                                            <span class="rev-stat-chip">
                                                <i class="fas fa-shield-alt text-success"></i>
                                                @proposta.Seguros.Count seguro(s)
                                            </span>
                                        }
                                    </div>
                                    @if (!string.IsNullOrEmpty(proposta.ObservacoesGerais))
                                    {
                                        <div class="alert alert-light border-start border-3 border-secondary py-2 px-3 mb-0 mt-3 small">
                                            <i class="fas fa-comment-dots me-1 text-muted"></i>
                                            @proposta.ObservacoesGerais
                                        </div>
                                    }
                                </div>

                                <!-- Cliente -->
                                @if (proposta.Cliente != null)
                                {
                                    <div class="mb-4">
                                        <div class="rev-section-label">
                                            <i class="fas fa-user me-1"></i>Cliente
                                        </div>
                                        <div class="d-flex align-items-center gap-3">
                                            <div class="rounded-circle d-flex align-items-center justify-content-center text-white fw-bold flex-shrink-0"
                                                 style="width:40px;height:40px;font-size:.95rem;background:linear-gradient(135deg,#667eea,#764ba2);">
                                                @(string.Join("", proposta.Cliente.Nome.Split(' ', StringSplitOptions.RemoveEmptyEntries).Take(2).Select(p => char.ToUpper(p[0]))))
                                            </div>
                                            <div>
                                                <div class="fw-semibold">@proposta.Cliente.Nome</div>
                                                <div class="small text-muted">
                                                    @if (!string.IsNullOrEmpty(proposta.Cliente.Email))
                                                    {
                                                        <span class="me-3"><i class="fas fa-envelope me-1"></i>@proposta.Cliente.Email</span>
                                                    }
                                                    @if (!string.IsNullOrEmpty(proposta.Cliente.Telefone))
                                                    {
                                                        <span><i class="fas fa-phone me-1"></i>@proposta.Cliente.Telefone</span>
                                                    }
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                }

                                <!-- Passageiros -->
                                @if (proposta.PassageirosProposta.Any())
                                {
                                    <div class="mb-4">
                                        <div class="rev-section-label">
                                            <i class="fas fa-users me-1"></i>Passageiros
                                            <span class="badge bg-secondary ms-1">@proposta.PassageirosProposta.Count</span>
                                        </div>
                                        <div class="d-flex flex-wrap gap-2">
                                            @foreach (var pax in proposta.PassageirosProposta.OrderBy(p => p.Ordem))
                                            {
                                                <span class="rev-stat-chip">
                                                    <i class="fas fa-user-circle text-muted"></i>
                                                    @pax.Nome
                                                    @if (pax.IdadeCalculada.HasValue)
                                                    {
                                                        <span class="text-muted" style="font-size:.74rem;">(@pax.IdadeCalculada a)</span>
                                                    }
                                                    @if (pax.Relacionamento.HasValue)
                                                    {
                                                        <span class="badge bg-light text-dark border" style="font-size:.68rem;">@pax.Relacionamento</span>
                                                    }
                                                </span>
                                            }
                                        </div>
                                    </div>
                                }

                                <!-- Itinerário por destino -->
                                @if (proposta.Destinos.Any())
                                {
                                    <div class="mb-4">
                                        <div class="rev-section-label">
                                            <i class="fas fa-map-marked-alt me-1"></i>Itinerário
                                        </div>
                                        @foreach (var d in proposta.Destinos.OrderBy(d => d.Ordem))
                                        {
                                            <div class="rev-dest-card d-flex gap-3 align-items-start">
                                                @if (d.Fotos.Any())
                                                {
                                                    var fp2 = d.Fotos.FirstOrDefault(f => f.Principal) ?? d.Fotos.OrderBy(f => f.Ordem).First();
                                                    <img src="@fp2.CaminhoFoto" class="rounded flex-shrink-0"
                                                         style="width:54px;height:42px;object-fit:cover;" />
                                                }
                                                else
                                                {
                                                    <div class="rounded d-flex align-items-center justify-content-center text-muted flex-shrink-0"
                                                         style="width:54px;height:42px;background:#e9ecef;">
                                                        <i class="fas fa-map-pin" style="font-size:.9rem;"></i>
                                                    </div>
                                                }
                                                <div class="flex-grow-1">
                                                    <div class="fw-semibold">@d.Nome</div>
                                                    @if (!string.IsNullOrEmpty(d.Cidade) || !string.IsNullOrEmpty(d.Pais))
                                                    {
                                                        <div class="small text-muted">
                                                            @d.Cidade@(!string.IsNullOrEmpty(d.Cidade) && !string.IsNullOrEmpty(d.Pais) ? ", " : "")@d.Pais
                                                        </div>
                                                    }
                                                    @if (d.DataChegada.HasValue || d.DataSaida.HasValue)
                                                    {
                                                        <div class="small text-muted">
                                                            <i class="fas fa-calendar-check me-1"></i>
                                                            @(d.DataChegada?.ToString("dd/MM") ?? "—") → @(d.DataSaida?.ToString("dd/MM") ?? "—")
                                                        </div>
                                                    }
                                                    <div class="d-flex flex-wrap gap-1 mt-1">
                                                        @if (d.Hospedagens.Any())
                                                        {
                                                            <span class="rev-stat-chip" style="font-size:.73rem;padding:2px 8px;">
                                                                <i class="fas fa-hotel text-info"></i>@d.Hospedagens.Count hosp.
                                                            </span>
                                                        }
                                                        @if (d.Experiencias.Any())
                                                        {
                                                            <span class="rev-stat-chip" style="font-size:.73rem;padding:2px 8px;">
                                                                <i class="fas fa-star text-warning"></i>@d.Experiencias.Count exp.
                                                            </span>
                                                        }
                                                        @if (d.Transportes.Any())
                                                        {
                                                            <span class="rev-stat-chip" style="font-size:.73rem;padding:2px 8px;">
                                                                <i class="fas fa-car text-primary"></i>@d.Transportes.Count transp.
                                                            </span>
                                                        }
                                                    </div>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                }

                                <!-- Voos -->
                                @if (proposta.Voos.Any())
                                {
                                    <div class="mb-4">
                                        <div class="rev-section-label">
                                            <i class="fas fa-plane me-1"></i>Aéreo
                                            <span class="badge bg-secondary ms-1">@proposta.Voos.Count</span>
                                        </div>
                                        @foreach (var voo in proposta.Voos.OrderBy(v => v.Ordem))
                                        {
                                            <div class="rev-voo-card">
                                                <div class="d-flex align-items-center gap-2 flex-wrap mb-1">
                                                    @if (voo.TipoVoo == SistemaUsuarios.Models.TipoVoo.Ida)
                                                    {
                                                        <span class="badge bg-primary">Ida</span>
                                                    }
                                                    else if (voo.TipoVoo == SistemaUsuarios.Models.TipoVoo.Interno)
                                                    {
                                                        <span class="badge bg-warning text-dark">Interno</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge bg-success">Volta</span>
                                                    }
                                                    <strong class="small">@voo.Companhia · @voo.NumeroVoo</strong>
                                                    @if (!string.IsNullOrEmpty(voo.Classe))
                                                    {
                                                        <span class="badge bg-light text-dark border" style="font-size:.73rem;">@voo.Classe</span>
                                                    }
                                                </div>
                                                <div class="d-flex align-items-center gap-2">
                                                    <span class="fw-semibold small">@voo.Origem</span>
                                                    <i class="fas fa-long-arrow-alt-right text-muted"></i>
                                                    <span class="fw-semibold small">@voo.Destino</span>
                                                </div>
                                                @if (voo.HorarioSaida.HasValue)
                                                {
                                                    <div class="small text-muted mt-1">
                                                        <i class="fas fa-clock me-1"></i>
                                                        @voo.HorarioSaida.Value.ToString("dd/MM HH:mm")
                                                        @if (voo.HorarioChegada.HasValue)
                                                        {
                                                            <text> → @voo.HorarioChegada.Value.ToString("dd/MM HH:mm")</text>
                                                        }
                                                        @if (!string.IsNullOrEmpty(voo.Duracao))
                                                        {
                                                            <text> (@voo.Duracao)</text>
                                                        }
                                                    </div>
                                                }
                                            </div>
                                        }
                                    </div>
                                }

                                <!-- Seguros -->
                                @if (proposta.Seguros.Any())
                                {
                                    <div class="mb-2">
                                        <div class="rev-section-label">
                                            <i class="fas fa-shield-alt me-1"></i>Seguros
                                            <span class="badge bg-secondary ms-1">@proposta.Seguros.Count</span>
                                        </div>
                                        @foreach (var seg in proposta.Seguros.OrderBy(s => s.Ordem))
                                        {
                                            <div class="rev-seguro-card">
                                                <div class="d-flex justify-content-between align-items-start gap-2">
                                                    <span class="fw-semibold small">@seg.Titulo</span>
                                                    @if (seg.Valor.HasValue)
                                                    {
                                                        <span class="badge bg-success flex-shrink-0">R$ @seg.Valor.Value.ToString("N2")</span>
                                                    }
                                                </div>
                                                @if (!string.IsNullOrEmpty(seg.Descricao))
                                                {
                                                    <div class="small text-muted mt-1">@seg.Descricao</div>
                                                }
                                            </div>
                                        }
                                    </div>
                                }

                            </div>
                        </div>

                        <!-- Ações -->
                        <div class="d-flex gap-2 flex-wrap mb-4">
                            @if (proposta.LinkPublicoAtivo)
                            {
                                <a href="/Proposta/Publico/@proposta.Id" target="_blank" class="btn btn-success">
                                    <i class="fas fa-external-link-alt me-1"></i>Abrir Link Público
                                </a>
                            }
                            <a href="/Proposta/Detalhes/@proposta.Id" class="btn btn-outline-info">
                                <i class="fas fa-eye me-1"></i>Pré-visualizar
                            </a>
                            <button type="button" class="btn btn-outline-primary"
                                    onclick="document.getElementById('tab-destinos').click()">
                                <i class="fas fa-map-marked-alt me-1"></i>Editar Destinos
                            </button>
                        </div>

                    </div><!-- /col resumo -->

                    <!-- ════════════════════════════════════════════════════ -->
                    <!--   COLUNA DIREITA — INSIGHTS DO DESTINO              -->
                    <!-- ════════════════════════════════════════════════════ -->
                    @if (temInsights)
                    {
                        var destinosComInsight = proposta.Destinos
                            .OrderBy(d => d.Ordem)
                            .Where(d =>
                                !string.IsNullOrEmpty(d.CuidadosLLM) ||
                                !string.IsNullOrEmpty(d.GastronomiaLLM) ||
                                !string.IsNullOrEmpty(d.AtracoesLLM) ||
                                !string.IsNullOrEmpty(d.InformacoesPraticasLLM) ||
                                !string.IsNullOrEmpty(d.MalaViagemLLM) ||
                                !string.IsNullOrEmpty(d.PratosTipicosLLM))
                            .ToList();
                        bool multiDestino = destinosComInsight.Count > 1;

                        <div class="col-lg-6">

                            <!-- Header do painel -->
                            <div class="d-flex align-items-center gap-2 mb-3 px-1">
                                <div class="rounded-circle d-flex align-items-center justify-content-center text-white flex-shrink-0"
                                     style="width:32px;height:32px;background:linear-gradient(135deg,#134e1a,#1a6b2f);">
                                    <i class="fas fa-lightbulb" style="font-size:.75rem;"></i>
                                </div>
                                <div>
                                    <div class="fw-semibold" style="font-size:.9rem;">Insights para o Agente</div>
                                    <div class="text-muted" style="font-size:.73rem;">Dados processados — uso interno</div>
                                </div>
                            </div>

                            @if (multiDestino)
                            {
                                <!-- ── MÚLTIPLOS DESTINOS: accordion externo por destino ── -->
                                <div class="accordion" id="acc-destinos-outer">
                                    @foreach (var d in destinosComInsight)
                                    {
                                        var outerItemId  = "dest-outer-" + d.Id.ToString("N");
                                        var innerAccId   = "acc-inner-"  + d.Id.ToString("N");
                                        int temaCount =
                                            (string.IsNullOrEmpty(d.CuidadosLLM)          ? 0 : 1) +
                                            (string.IsNullOrEmpty(d.GastronomiaLLM) && string.IsNullOrEmpty(d.PratosTipicosLLM) ? 0 : 1) +
                                            (string.IsNullOrEmpty(d.AtracoesLLM)           ? 0 : 1) +
                                            (string.IsNullOrEmpty(d.InformacoesPraticasLLM)? 0 : 1) +
                                            (string.IsNullOrEmpty(d.MalaViagemLLM)         ? 0 : 1);

                                        <div class="accordion-item border-0 shadow-sm rounded-3 mb-3 overflow-hidden">
                                            <!-- Cabeçalho do destino -->
                                            <h2 class="accordion-header">
                                                <button class="accordion-button collapsed py-3 px-4 fw-semibold"
                                                        type="button"
                                                        data-bs-toggle="collapse"
                                                        data-bs-target="#@outerItemId"
                                                        style="background:#f8f9fa;font-size:.92rem;">
                                                    <span class="me-2" style="font-size:1rem;">📍</span>
                                                    <span class="flex-grow-1">@d.Nome
                                                        @if (!string.IsNullOrEmpty(d.Cidade) || !string.IsNullOrEmpty(d.Pais))
                                                        {
                                                            <span class="text-muted fw-normal" style="font-size:.8rem;">
                                                                — @(d.Cidade)@(!string.IsNullOrEmpty(d.Cidade) && !string.IsNullOrEmpty(d.Pais) ? ", " : "")@(d.Pais)
                                                            </span>
                                                        }
                                                    </span>
                                                    <span class="badge bg-secondary ms-2" style="font-size:.68rem;font-weight:500;">@temaCount tema(s)</span>
                                                </button>
                                            </h2>
                                            <!-- Corpo: accordion interno de temas -->
                                            <div id="@outerItemId" class="accordion-collapse collapse">
                                                <div class="accordion-body p-3" style="background:#fdfdfd;">
                                                    @Html.Raw(RenderTemasAccordion(d, innerAccId))
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                            else
                            {
                                <!-- ── DESTINO ÚNICO: accordion de temas direto ── -->
                                var d0     = destinosComInsight[0];
                                var accId0 = "acc-" + d0.Id.ToString("N");
                                <div class="card border-0 shadow-sm rounded-3 overflow-hidden">
                                    <div class="card-body p-3">
                                        @Html.Raw(RenderTemasAccordion(d0, accId0))
                                    </div>
                                </div>
                            }

                        </div><!-- /col insights -->
                    }

                </div><!-- /row -->


            }
        </div>

    </div><!-- /tab-content -->
</div><!-- /container-fluid -->


                                                                        <option value="3">Resort</option>
                                                                        <option value="4">Hotel Fazenda</option>
                                                                        <option value="5">Aluguel de Casa</option>
                                                                        <option value="6">Camping</option>
                                                                        <option value="7">Outros</option>
                                                                    </select>
                                                                </div>
                                                            </div>

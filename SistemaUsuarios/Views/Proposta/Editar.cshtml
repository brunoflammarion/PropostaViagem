                                                                                    @arq.NomeOriginal
                                                                                </a>
                                                                                <span class="text-muted small">(@((arq.Tamanho / 1024.0).ToString("0.#")) KB)</span>
                                                                                <form asp-controller="Experiencia"
                                                                                      asp-action="ExcluirArquivo"
                                                                                      method="post" class="ms-auto d-inline"
                                                                                      onsubmit="return confirm('Excluir arquivo?');">
                                                                                    @Html.AntiForgeryToken()
                                                                                    <input type="hidden" name="id" value="@arq.Id" />
                                                                                    <button type="submit" class="btn btn-xs btn-outline-danger">
                                                                                        <i class="fas fa-times"></i>
                                                                                    </button>
                                                                                </form>
                                                                            </li>
                                                                        }
                                                                    </ul>
                                                                }
                                                                <form asp-controller="Experiencia" asp-action="AdicionarArquivo"
                                                                      method="post" enctype="multipart/form-data"
                                                                      class="d-flex align-items-end gap-2 flex-wrap">

    .btn-xs { padding: 0.15rem 0.4rem; font-size: 0.75rem; line-height: 1.2; }

    /* Card dashed para estado vazio */
    .border-dashed { border: 2px dashed #dee2e6 !important; }

    .drag-handle { cursor: move; }

    .list-group-item:hover { background-color: #f8f9fa; }

    .sortable-ghost { opacity: 0.4; }
    .sortable-chosen { background-color: #e3f2fd !important; }
    .sortable-drag { opacity: 0.8; }

    /* Mini rich editor — Descrição da Hospedagem */
    .hosp-rich-desc {
        font-size: .8125rem;
        line-height: 1.5;
        cursor: text;
        white-space: pre-wrap;
        word-break: break-word;
    }
    .hosp-rich-desc:empty::before {
        content: attr(data-placeholder);
        color: #9ca3af;
        pointer-events: none;
    }
    .hosp-rich-desc:focus { outline: none; box-shadow: 0 0 0 .2rem rgba(13,110,253,.15); border-color: #86b7fe; }

    .img-thumbnail {
        border: 1px solid #dee2e6;
        border-radius: 0.375rem;
        transition: transform 0.2s ease-in-out;
        cursor: pointer;
    }
    .img-thumbnail:hover { transform: scale(1.05); }

    .card {
        border: none;
        box-shadow: 0 0.125rem 0.25rem rgba(0,0,0,0.075);
        border-radius: 8px;
    }
    .card-header { background-color: #f8f9fa; border-bottom: 1px solid #e9ecef; }
    .card-header.bg-primary { background-color: #007bff !important; border-color: #007bff; }

    .current-photo-container {
        display: flex;
        align-items: center;
        gap: 1rem;
        padding: 0.75rem;
        background: #f8f9fa;
        border-radius: 8px;
        border: 1px solid #e9ecef;

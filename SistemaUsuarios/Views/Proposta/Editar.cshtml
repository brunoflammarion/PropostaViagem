                                    <input type="hidden" name="id" value="@pax.Id" />
                                    <button type="submit" class="btn btn-outline-danger btn-sm">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </div>
                        <div class="collapse" id="pax-edit-@pax.Id">
                            <div class="card-body">
                                <form asp-controller="PassageiroProposta" asp-action="Editar" method="post">
                                    @Html.AntiForgeryToken()

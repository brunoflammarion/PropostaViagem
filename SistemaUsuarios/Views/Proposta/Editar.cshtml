                                                                        <button type="submit" class="btn btn-sm btn-outline-primary">
                                                                            <i class="fas fa-upload me-1"></i>Upload
                                                                        </button>
                                                                    </div>
                                                                </form>

                                                            </div><!-- /card-body exp -->
                                                        </div><!-- /collapse exp -->
                                                    </div><!-- /card exp -->
                                                }
                                            }

                                        </div><!-- /experiências section -->


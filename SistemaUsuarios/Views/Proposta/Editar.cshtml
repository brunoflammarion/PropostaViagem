            $container.find('.btn-gerar-desc-hosp').prop('disabled', false);
            $.get('/Hospedagem/BuscarDetalhesHotel', { placeId }, function (dados) {
                if (dados.endereco) $container.find('.hosp-endereco-input').val(dados.endereco);
                if (dados.latitude && dados.longitude) {

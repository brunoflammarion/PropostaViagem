                                                                </h6>
                                                                @if (exp.Arquivos.Any())
                                                                {
                                                                    <ul class="list-group list-group-flush mb-3">
                                                                        @foreach (var arq in exp.Arquivos.OrderBy(a => a.DataCriacao))
                                                                        {
                                                                            <li class="list-group-item px-0 d-flex align-items-center gap-2">
                                                                                <i class="fas @(arq.TipoArquivo.StartsWith("image") ? "fa-image text-success" : arq.TipoArquivo == "application/pdf" ? "fa-file-pdf text-danger" : "fa-file-alt text-primary") fa-fw"></i>
                                                                                <a asp-controller="Experiencia"
                                                                                   asp-action="BaixarArquivo"
                                                                                   asp-route-id="@arq.Id"

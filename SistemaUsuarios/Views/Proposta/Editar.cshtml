                                                                        data-bs-toggle="collapse"
                                                                        data-bs-target="#add-hosp-@destino.Id">
                                                                    Cancelar
                                                                </button>
                                                            </div>
                                                        </form>
                                                    </div>
                                                </div>

                                                @foreach (var hospedagem in destino.Hospedagens.OrderBy(h => h.Ordem))
                                                {
                                                    <div class="card mb-3 border-info" style="overflow:visible;">
                                                        <div class="card-header bg-light d-flex justify-content-between align-items-center py-2">

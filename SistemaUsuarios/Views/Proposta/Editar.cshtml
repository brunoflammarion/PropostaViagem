                                                                        <div class="col-sm-3">
                                                                            <label class="form-label form-label-sm mb-0">Valor (R$)</label>
                                                                            <input type="number" name="valor"
                                                                                   class="form-control form-control-sm"
                                                                                   value="@exp.Valor" step="0.01" min="0" />
                                                                        </div>
                                                                        <div class="col-sm-5">
                                                                            <label class="form-label form-label-sm mb-0">URL de Vídeo</label>
                                                                            <input type="url" name="videoUrl"
                                                                                   class="form-control form-control-sm"
                                                                                   value="@exp.VideoUrl"

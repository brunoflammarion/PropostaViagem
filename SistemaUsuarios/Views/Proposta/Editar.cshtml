                <!-- ── SEÇÃO: PASSAGEIROS ─────────────────────────────────────── -->
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="mb-0">
                        <i class="fas fa-users me-2 text-info"></i>Passageiros da Viagem

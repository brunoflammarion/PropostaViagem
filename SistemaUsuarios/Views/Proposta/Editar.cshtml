                                                         style="border:1px solid #dee2e6;"
                                                         data-cidade="@(destino.Cidade ?? destino.Nome)">
                                                        <h6 class="small text-muted fw-semibold mb-2">Nova Hospedagem</h6>
                                                        <form asp-controller="Hospedagem" asp-action="Adicionar" method="post" enctype="multipart/form-data">
                                                            @Html.AntiForgeryToken()
                                                            <input type="hidden" name="destinoId" value="@destino.Id" />

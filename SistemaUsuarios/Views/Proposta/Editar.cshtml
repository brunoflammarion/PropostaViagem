@* ── AI Copilot Panel (proposta ID passado como model) ── *@
@await Html.PartialAsync("_CopilotPanel", (Guid?)Model.Id)

@section Scripts {
    <script src="~/js/copilot.js" asp-append-version="true"></script>
    <link href="https://cdn.quilljs.com/1.3.7/quill.snow.css" rel="stylesheet" />
    <script src="https://cdn.quilljs.com/1.3.7/quill.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sortablejs@latest/Sortable.min.js"></script>

    <script>

    
        // ============================================================
        // INSTÂNCIAS DE MODAL — criadas uma única vez
        // ============================================================
        let modalUploadFoto, modalFotoAcomodacao, modalAdicionarVoo;

        // ─── Passageiros — FaixaEtaria / ModoBebe ────────────────────────────────

        (function () {
            // Formulário de ADICIONAR passageiro
            var addFaixaChk    = document.getElementById('add-faixa-chk');
            var addFaixaSelect = document.getElementById('add-faixa-select');
            var addModoBebe    = document.getElementById('add-modo-bebe-wrap');

            function updateAddBebe() {
                if (!addFaixaSelect || !addModoBebe) return;
                addModoBebe.style.display = (addFaixaSelect.value === '1') ? '' : 'none';
            }

            if (addFaixaChk) {
                addFaixaChk.addEventListener('change', function () {
                    addFaixaSelect.style.display = this.checked ? '' : 'none';
                    if (!this.checked) { addFaixaSelect.value = ''; addModoBebe.style.display = 'none'; }
                    updateAddBebe();
                });
            }
            if (addFaixaSelect) {
                addFaixaSelect.addEventListener('change', updateAddBebe);
            }

            // Formulários de EDITAR passageiro (um por passageiro na página)
            document.querySelectorAll('.edit-faixa-chk').forEach(function (chk) {
                var id         = chk.id.replace('edit-faixa-chk-', '');
                var sel        = document.getElementById('edit-faixa-select-' + id);
                var modoWrap   = document.querySelector('.edit-modo-bebe-wrap-' + id);

                function updateEditBebe() {
                    if (!sel || !modoWrap) return;
                    modoWrap.style.display = (sel.value === '1') ? '' : 'none';
                }

                chk.addEventListener('change', function () {
                    if (sel) sel.style.display = this.checked ? '' : 'none';
                    if (!this.checked && sel) { sel.value = ''; }
                    if (modoWrap && !this.checked) modoWrap.style.display = 'none';
                    updateEditBebe();
                });
                if (sel) sel.addEventListener('change', updateEditBebe);
            });
        }());

        // Aéreo — toggle inline de edição de passageiro
        function toggleEditPax(safeId) {
            const displayRow = document.getElementById('pax-row-' + safeId);
            const editRow    = document.getElementById('pax-edit-' + safeId);
            if (!displayRow || !editRow) return;
            displayRow.classList.toggle('d-none');
            editRow.classList.toggle('d-none');
        }

        // ─── Companhia → ICAO ─────────────────────────────────────────────────────

        const AIRLINES_MAP = {
            // Brasil
            'Azul — AD / AZU'                  : { iata: 'AD', icao: 'AZU' },
            'GOL — G3 / GLO'                   : { iata: 'G3', icao: 'GLO' },
            'LATAM Brasil — JJ / TAM'          : { iata: 'JJ', icao: 'TAM' },
            'Voepass — 2Z / VPA'               : { iata: '2Z', icao: 'VPA' },
            // América Latina
            'LATAM Airlines — LA / LAN'        : { iata: 'LA', icao: 'LAN' },
            'Avianca — AV / AVA'               : { iata: 'AV', icao: 'AVA' },
            'Copa Airlines — CM / CMP'         : { iata: 'CM', icao: 'CMP' },
            'Aerolíneas Argentinas — AR / ARG' : { iata: 'AR', icao: 'ARG' },
            'Aeromexico — AM / AMX'            : { iata: 'AM', icao: 'AMX' },
            'JetSMART — JA / JAT'              : { iata: 'JA', icao: 'JAT' },
            'Sky Airline — H2 / SKU'           : { iata: 'H2', icao: 'SKU' },
            'Wingo — P5 / WNG'                 : { iata: 'P5', icao: 'WNG' },
            // América do Norte
            'American Airlines — AA / AAL'     : { iata: 'AA', icao: 'AAL' },
            'Delta Air Lines — DL / DAL'       : { iata: 'DL', icao: 'DAL' },
            'United Airlines — UA / UAL'       : { iata: 'UA', icao: 'UAL' },
            'Air Canada — AC / ACA'            : { iata: 'AC', icao: 'ACA' },
            'Southwest — WN / SWA'             : { iata: 'WN', icao: 'SWA' },
            'JetBlue — B6 / JBU'               : { iata: 'B6', icao: 'JBU' },
            'Spirit Airlines — NK / NKS'       : { iata: 'NK', icao: 'NKS' },
            // Europa
            'Air France — AF / AFR'            : { iata: 'AF', icao: 'AFR' },
            'Lufthansa — LH / DLH'             : { iata: 'LH', icao: 'DLH' },
            'British Airways — BA / BAW'       : { iata: 'BA', icao: 'BAW' },
            'KLM — KL / KLM'                   : { iata: 'KL', icao: 'KLM' },
            'Iberia — IB / IBE'                : { iata: 'IB', icao: 'IBE' },
            'ITA Airways — AZ / ITY'           : { iata: 'AZ', icao: 'ITY' },
            'Swiss — LX / SWR'                 : { iata: 'LX', icao: 'SWR' },
            'TAP Air Portugal — TP / TAP'      : { iata: 'TP', icao: 'TAP' },
            'Turkish Airlines — TK / THY'      : { iata: 'TK', icao: 'THY' },
            'Ryanair — FR / RYR'               : { iata: 'FR', icao: 'RYR' },
            'easyJet — U2 / EZY'               : { iata: 'U2', icao: 'EZY' },
            'Aeroflot — SU / AFL'              : { iata: 'SU', icao: 'AFL' },
            'Finnair — AY / FIN'               : { iata: 'AY', icao: 'FIN' },
            'SAS — SK / SAS'                   : { iata: 'SK', icao: 'SAS' },
            // Oriente Médio / Ásia / África
            'Emirates — EK / UAE'              : { iata: 'EK', icao: 'UAE' },
            'Qatar Airways — QR / QTR'         : { iata: 'QR', icao: 'QTR' },
            'Etihad Airways — EY / ETD'        : { iata: 'EY', icao: 'ETD' },
            'Air Arabia — G9 / ABY'            : { iata: 'G9', icao: 'ABY' },
            'flydubai — FZ / FDB'              : { iata: 'FZ', icao: 'FDB' },
            'Singapore Airlines — SQ / SIA'    : { iata: 'SQ', icao: 'SIA' },
            'Ethiopian Airlines — ET / ETH'    : { iata: 'ET', icao: 'ETH' },
            'El Al — LY / ELY'                 : { iata: 'LY', icao: 'ELY' },
        };

        function resolverIcao(valor) {
            if (!valor) return '';
            const v = valor.trim();
            if (AIRLINES_MAP[v]) return AIRLINES_MAP[v].icao;
            // Extrai "/ XYZ" do final da string (ex: "Azul — AD / AZU" → "AZU")
            const m = v.match(/\/\s*([A-Z]{2,3})\s*$/);
            if (m) return m[1];
            // 2–3 letras maiúsculas isoladas → ICAO/IATA digitado diretamente
            if (/^[A-Z]{2,3}$/.test(v)) return v;
            return v;
        }

        function buildCodigoVoo(companhia, numeroVoo) {
            const num = (numeroVoo || '').trim().toUpperCase();
            if (!num) return '';
            // Número já inclui prefixo de letras (AFL1482 ou LA1234) → usar direto
            if (/^[A-Z]{2,3}\d/.test(num)) return num;
            // Apenas dígitos → prefixar com ICAO resolvido
            const icao = resolverIcao(companhia);
            if (icao && /^[A-Z]{2,3}$/.test(icao)) return icao + num;
            return num;
        }

        // ─── Busca automática de dados do voo via AeroDataBox ────────────────────

        async function _consultarVoo(codigoVoo, dataVoo, fillFn, btn, alertEl) {
            if (!codigoVoo || !dataVoo) {
                mostrarAlertaVoo(alertEl, 'warning', 'Informe a data, a companhia e o número do voo antes de buscar.');
                return;
            }

            btn.disabled = true;
            const originalHtml = btn.innerHTML;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i>Buscando...';
            if (alertEl) alertEl.className = 'd-none';

            try {
                // dataVoo vem do <input type="date"> → já em yyyy-MM-dd sem ambiguidade de timezone
                const url  = '/Voo/ConsultarVoo?codigoVoo=' + encodeURIComponent(codigoVoo)
                           + '&dataVoo=' + encodeURIComponent(dataVoo);
                const res  = await fetch(url);
                const json = await res.json();

                if (!res.ok) {
                    mostrarAlertaVoo(alertEl, 'warning', json.erro || 'Voo não encontrado. Preencha os campos manualmente.');
                    return;
                }

                // Garantia extra: não sobrescrever a data pesquisada
                const dataRetornada = json.horarioSaida ? json.horarioSaida.substring(0, 10) : null;
                if (dataRetornada && dataRetornada !== dataVoo) {
                    mostrarAlertaVoo(alertEl, 'warning',
                        'Encontramos informações para esse número de voo, mas não para a data selecionada. Verifique os dados informados.');
                    return;
                }

                fillFn(json, dataVoo);
                const statusLabel = json.status && !['Departed','Landed'].includes(json.status)
                    ? ` · Status: ${json.status}`
                    : json.status ? ' · Status: Programado' : '';
                mostrarAlertaVoo(alertEl, 'success', `Dados preenchidos automaticamente.${statusLabel} Verifique e salve.`);

            } catch (e) {
                mostrarAlertaVoo(alertEl, 'warning', 'Erro de conexão. Preencha os campos manualmente.');
            } finally {
                btn.disabled = false;
                btn.innerHTML = originalHtml;
            }
        }

        // Busca no card de edição de voo existente
        function consultarVooCard(safeId) {
            const companhia = document.getElementById('companhia-'  + safeId)?.value?.trim();
            const numero    = document.getElementById('numero-voo-' + safeId)?.value?.trim();
            const dataVoo   = document.getElementById('data-voo-'   + safeId)?.value?.trim();
            const btn       = document.getElementById('btn-buscar-' + safeId);
            const alrt      = document.getElementById('voo-alert-'  + safeId);

            if (!companhia || !numero || !dataVoo) {
                mostrarAlertaVoo(alrt, 'warning', 'Informe a data, a companhia e o número do voo antes de buscar.');
                return;
            }

            const codigo = buildCodigoVoo(companhia, numero);

            _consultarVoo(codigo, dataVoo, function (d, dataOriginal) {
                preencherCampoVoo('companhia-' + safeId, d.companhia);
                preencherCampoVoo('origem-'    + safeId, d.origem);
                preencherCampoVoo('destino-'   + safeId, d.destino);
                preencherCampoVoo('duracao-'   + safeId, d.duracao);
                preencherCampoVoo('saida-'     + safeId, d.horarioSaida);
                preencherCampoVoo('chegada-'   + safeId, d.horarioChegada);
                // Preservar a data pesquisada pelo usuário — nunca sobrescrever
                const dataEl = document.getElementById('data-voo-' + safeId);
                if (dataEl) dataEl.value = dataOriginal;
            }, btn, alrt);
        }

        // Busca no modal "Adicionar Voo"
        function consultarVooModal() {
            const companhia = document.getElementById('novo-companhia')?.value?.trim();
            const numero    = document.getElementById('novoVooNumero')?.value?.trim();
            const dataVoo   = document.getElementById('novo-data-voo')?.value?.trim();
            const btn       = document.getElementById('btnBuscarModal');
            const alrt      = document.getElementById('novo-voo-alert');

            if (!companhia || !numero || !dataVoo) {
                mostrarAlertaVoo(alrt, 'warning', 'Informe a data, a companhia e o número do voo antes de buscar.');
                return;
            }

            const codigo = buildCodigoVoo(companhia, numero);

            _consultarVoo(codigo, dataVoo, function (d, dataOriginal) {
                preencherCampoVoo('novo-companhia', d.companhia);
                preencherCampoVoo('novo-origem',    d.origem);
                preencherCampoVoo('novo-destino',   d.destino);
                preencherCampoVoo('novo-duracao',   d.duracao);
                preencherCampoVoo('novo-saida',     d.horarioSaida);
                preencherCampoVoo('novo-chegada',   d.horarioChegada);
                // Preservar a data pesquisada pelo usuário — nunca sobrescrever
                const dataEl = document.getElementById('novo-data-voo');
                if (dataEl) dataEl.value = dataOriginal;
            }, btn, alrt);
        }

        // ── Sincronização Data ↔ Horário de Saída ────────────────────────────────

        // Quando o campo "Data do voo" muda → atualiza a data no datetime-local de saída
        function onDataVooChange(safeId) {
            const data   = document.getElementById('data-voo-' + safeId)?.value;
            const saidaEl = document.getElementById('saida-' + safeId);
            if (!saidaEl || !data) return;
            const horaAtual = saidaEl.value ? saidaEl.value.substring(11) : '00:00';
            saidaEl.value = data + 'T' + horaAtual;
        }

        // Quando o datetime-local de saída muda → sincroniza o campo de data
        function onHorarioSaidaChange(safeId) {
            const saida  = document.getElementById('saida-' + safeId)?.value;
            const dataEl = document.getElementById('data-voo-' + safeId);
            if (!dataEl || !saida) return;
            dataEl.value = saida.substring(0, 10);
        }

        // Versão para o modal de novo voo
        function onNovoDataVooChange() {
            const data   = document.getElementById('novo-data-voo')?.value;
            const saidaEl = document.getElementById('novo-saida');
            if (!saidaEl || !data) return;
            const horaAtual = saidaEl.value ? saidaEl.value.substring(11) : '00:00';
            saidaEl.value = data + 'T' + horaAtual;
        }

        function onNovoSaidaChange() {
            const saida  = document.getElementById('novo-saida')?.value;
            const dataEl = document.getElementById('novo-data-voo');
            if (!dataEl || !saida) return;
            dataEl.value = saida.substring(0, 10);
        }

        // Preenche um campo pelo id; ignora se valor for vazio/null
        function preencherCampoVoo(id, valor) {
            if (!valor) return;
            const el = document.getElementById(id);
            if (el) el.value = valor;
        }

        function mostrarAlertaVoo(el, tipo, mensagem) {
            if (!el) return;
            el.className = `alert alert-${tipo} py-1 px-2 small mb-2`;
            el.textContent = mensagem;
        }

        document.addEventListener('DOMContentLoaded', function () {
            modalUploadFoto     = new bootstrap.Modal(document.getElementById('modalUploadFoto'),     { backdrop: 'static', keyboard: false });
            modalFotoAcomodacao = new bootstrap.Modal(document.getElementById('modalFotoAcomodacao'), { backdrop: 'static' });
            modalAdicionarVoo   = new bootstrap.Modal(document.getElementById('modalAdicionarVoo'),   { backdrop: 'static' });

            // Limpeza de backdrop ao fechar qualquer modal
            ['modalUploadFoto', 'modalFotoAcomodacao', 'modalAdicionarVoo'].forEach(function (id) {
                document.getElementById(id).addEventListener('hidden.bs.modal', function () {
                    document.querySelectorAll('.modal-backdrop').forEach(function (el) { el.remove(); });
                    document.body.classList.remove('modal-open');
                    document.body.style.removeProperty('overflow');
                    document.body.style.removeProperty('padding-right');
                });
            });

            configurarEventListeners();
            configurarSortables();
            configurarValidacaoFormularios();
            configurarHospRichEditors();
            configurarAutoUpload();
            configurarPreviewFotosNovaHospedagem();
            configurarPreviewFotosNovaExp();
            configurarPreviewFotosNovaTransp();
            configurarCollapseState();

            // Auto-busca AeroDataBox: quando card de voo abre com número preenchido
            document.querySelectorAll('[id^="collapse-voo-"]').forEach(function (collapseEl) {
                collapseEl.addEventListener('show.bs.collapse', function () {
                    const safeId = collapseEl.id.replace('collapse-voo-', '');
                    const numero = document.getElementById('numero-voo-' + safeId)?.value?.trim();
                    if (numero) {
                        setTimeout(function () { consultarVooCard(safeId); }, 400);
                    }
                });
            });

            // Auto-IA hospedagem: desativado — IA só é gerada quando o usuário clicar explicitamente no botão
            // (disparar automaticamente causava chamadas à OpenAI em toda abertura de card)

            // Preview em tempo real do título (Tab 1)
            const tituloInput = document.getElementById('Titulo');
            if (tituloInput) {
                tituloInput.addEventListener('input', function () {
                    const el = document.getElementById('previewTituloTexto');
                    if (el) el.textContent = this.value || 'Digite um título...';
                });
            }

            // Validação de datas (Tab 1)
            const dataInicio = document.getElementById('DataInicio');
            const dataFim    = document.getElementById('DataFim');
            if (dataInicio && dataFim) {
                function validarDatas() {
                    if (dataInicio.value && dataFim.value && new Date(dataInicio.value) > new Date(dataFim.value)) {
                        showErrorAlert('Data de fim deve ser posterior à data de início');
                        dataFim.value = '';
                    }
                }
                dataInicio.addEventListener('change', validarDatas);
                dataFim.addEventListener('change', validarDatas);
            }

            // Preview foto de capa (Tab 1)
            const fotoCapa = document.getElementById('fotoCapa');
            if (fotoCapa) {
                fotoCapa.addEventListener('change', function () {
                    const file = this.files[0];
                    if (file) {
                        if (file.size > 5 * 1024 * 1024) {
                            showErrorAlert('Arquivo muito grande. Máximo 5MB.');
                            this.value = '';
                            document.getElementById('previewNovaFoto').style.display = 'none';
                            return;
                        }
                        const reader = new FileReader();
                        reader.onload = function (e) {
                            document.getElementById('imagemPreviewNova').src = e.target.result;
                            document.getElementById('previewNovaFoto').style.display = 'block';
                        };
                        reader.readAsDataURL(file);
                    } else {
                        document.getElementById('previewNovaFoto').style.display = 'none';
                    }
                });
            }

            // Botão salvar — animação
            const formEditar = document.getElementById('formEditarProposta');
            if (formEditar) {
                formEditar.addEventListener('submit', function (e) {
                    const btn = document.activeElement;

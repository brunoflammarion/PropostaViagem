@model SistemaUsuarios.Models.ViewModels.PropostaViewModel
@using System.Text.RegularExpressions
@using System.Text.Json
@using SistemaUsuarios.Services
@inject IPassengerAgeService AgeService
@{
    var proposta = ViewBag.Proposta as SistemaUsuarios.Models.Proposta;
    ViewData["Title"] = $"Editar - {Model.Titulo}";
    var activeTab = (ViewBag.ActiveTab as string) ?? "dados";
}
@functions {
    /// <summary>Converts a YouTube/Vimeo watch URL to its embed URL for use in iframes.</summary>
    static string ConvertToEmbedUrl(string? url)
    {
        if (string.IsNullOrWhiteSpace(url)) return string.Empty;

        // YouTube: https://www.youtube.com/watch?v=ID or https://youtu.be/ID
        var ytMatch = Regex.Match(url,
            @"(?:youtube\.com/watch\?v=|youtu\.be/)([A-Za-z0-9_\-]{11})");
        if (ytMatch.Success)
            return $"https://www.youtube.com/embed/{ytMatch.Groups[1].Value}";

        // Vimeo: https://vimeo.com/ID
        var vimeoMatch = Regex.Match(url, @"vimeo\.com/(\d+)");
        if (vimeoMatch.Success)
            return $"https://player.vimeo.com/video/{vimeoMatch.Groups[1].Value}";

        return url; // fallback: use URL as-is
    }

    // ── Helpers para renderização dos blocos LLM na aba Revisão ──────────

    /// <summary>Renderiza um bloco de dados LLM (JSON) como HTML legível para o agente.</summary>
    static string RenderLlmBlock(string? json)
    {
        if (string.IsNullOrWhiteSpace(json)) return "";

        JsonDocument? doc = null;
        try { doc = JsonDocument.Parse(json); }
        catch { }

        if (doc == null)
            return $"<p class=\"small text-muted fst-italic\">{System.Net.WebUtility.HtmlEncode(json)}</p>";

        var sb = new System.Text.StringBuilder();
        var root = doc.RootElement;

        if (root.ValueKind == JsonValueKind.Array)
        {
            foreach (var item in root.EnumerateArray())
            {
                sb.Append("<div class=\"rev-arr-item\">");
                if (item.ValueKind == JsonValueKind.Object)
                    AppendObjectProps(sb, item);
                else
                    sb.Append($"<span class=\"rev-insight-value\">{System.Net.WebUtility.HtmlEncode(GetJsonString(item))}</span>");
                sb.Append("</div>");
            }
        }
        else if (root.ValueKind == JsonValueKind.Object)
        {
            AppendObjectProps(sb, root);
        }
        else
        {
            sb.Append($"<p class=\"rev-insight-value\">{System.Net.WebUtility.HtmlEncode(GetJsonString(root))}</p>");
        }

        doc.Dispose();
        return sb.ToString();
    }

    static void AppendObjectProps(System.Text.StringBuilder sb, JsonElement obj)
    {
        foreach (var prop in obj.EnumerateObject())
        {
            var val = GetJsonString(prop.Value);
            if (string.IsNullOrWhiteSpace(val)) continue;
            var enc = System.Net.WebUtility.HtmlEncode(val);
            var label = System.Net.WebUtility.HtmlEncode(LlmLabel(prop.Name));
            var nomeLower = prop.Name.ToLowerInvariant();

            if (nomeLower.Contains("gancho"))
                sb.Append($"<div class=\"rev-gancho\"><i class=\"fas fa-bolt text-warning me-1\"></i>{enc}</div>");
            else if (nomeLower.Contains("referencia") || nomeLower.Contains("referência"))
                sb.Append($"<div class=\"mb-1\"><span class=\"rev-insight-label\">Referência</span> <span class=\"text-muted small fst-italic\">{enc}</span></div>");
            else
                sb.Append($"<div class=\"mb-2\"><div class=\"rev-insight-label\">{label}</div><div class=\"rev-insight-value\">{enc}</div></div>");
        }
    }

    static string GetJsonString(JsonElement el)
    {
        return el.ValueKind switch
        {
            JsonValueKind.String => el.GetString() ?? "",
            JsonValueKind.Number => el.ToString(),
            JsonValueKind.True   => "Sim",
            JsonValueKind.False  => "Não",
            JsonValueKind.Array  => string.Join(", ",
                el.EnumerateArray().Select(e => GetJsonString(e)).Where(s => !string.IsNullOrEmpty(s))),
            _ => ""
        };
    }

    /// <summary>Converte camelCase/PascalCase para label legível: "ganchoComercial" → "Gancho Comercial"</summary>
    static string LlmLabel(string key)
    {
        if (string.IsNullOrEmpty(key)) return key;
        var s = Regex.Replace(key, "([A-Z])", " $1").Trim();
        return char.ToUpper(s[0]) + s[1..];
    }

    /// <summary>
    /// Renderiza o accordion de temas (cuidados, gastronomia, atrações, info prática, mala)
    /// para um destino. Retorna HTML pronto para uso com @Html.Raw().
    /// </summary>
    static string RenderTemasAccordion(SistemaUsuarios.Models.Destino d, string accId)
    {
        var sb = new System.Text.StringBuilder();
        sb.Append($"<div class=\"accordion\" id=\"{System.Net.WebUtility.HtmlEncode(accId)}\">");

        // ① Cuidados & Atenção
        if (!string.IsNullOrEmpty(d.CuidadosLLM))
        {
            var id = "cuidados-" + d.Id.ToString("N");
            sb.Append(AccordionItem(accId, id,
                "fas fa-exclamation-triangle text-danger", "Cuidados &amp; Atenção",
                "border-danger", RenderLlmBlock(d.CuidadosLLM)));
        }

        // ② Gastronomia & Pratos Típicos
        if (!string.IsNullOrEmpty(d.GastronomiaLLM) || !string.IsNullOrEmpty(d.PratosTipicosLLM))
        {
            var id      = "gastro-" + d.Id.ToString("N");
            var gastroHtml = new System.Text.StringBuilder();
            if (!string.IsNullOrEmpty(d.GastronomiaLLM))
                gastroHtml.Append(RenderLlmBlock(d.GastronomiaLLM));
            if (!string.IsNullOrEmpty(d.PratosTipicosLLM))
            {
                if (!string.IsNullOrEmpty(d.GastronomiaLLM))
                    gastroHtml.Append("<hr class=\"my-2\" />");
                gastroHtml.Append("<div class=\"rev-insight-label mb-2\">Pratos Típicos</div>");
                gastroHtml.Append(RenderLlmBlock(d.PratosTipicosLLM));
            }
            sb.Append(AccordionItem(accId, id,
                "fas fa-utensils text-warning", "Gastronomia &amp; Pratos",
                "border-warning", gastroHtml.ToString()));
        }

        // ③ Atrações & Pontos de Interesse
        if (!string.IsNullOrEmpty(d.AtracoesLLM))
        {
            var id = "atracoes-" + d.Id.ToString("N");
            sb.Append(AccordionItem(accId, id,
                "fas fa-map-marked-alt text-info", "Atrações &amp; Pontos de Interesse",
                "border-info", RenderLlmBlock(d.AtracoesLLM)));
        }

        // ④ Informações Práticas
        if (!string.IsNullOrEmpty(d.InformacoesPraticasLLM))
        {
            var id = "infoprat-" + d.Id.ToString("N");
            sb.Append(AccordionItem(accId, id,
                "fas fa-info-circle text-primary", "Informações Práticas",
                "border-primary", RenderLlmBlock(d.InformacoesPraticasLLM)));
        }

        // ⑤ Mala de Viagem
        if (!string.IsNullOrEmpty(d.MalaViagemLLM))
        {
            var id = "mala-" + d.Id.ToString("N");
            sb.Append(AccordionItem(accId, id,
                "fas fa-suitcase text-secondary", "Mala de Viagem",
                "border-secondary", RenderLlmBlock(d.MalaViagemLLM)));
        }

        sb.Append("</div>");
        return sb.ToString();
    }

    static string AccordionItem(string parentId, string itemId,
        string iconCls, string label, string borderCls, string bodyHtml)
    {
        return "<div class=\"accordion-item " + borderCls + " border-opacity-25 rounded-3 mb-2 overflow-hidden\">"
             + "<h2 class=\"accordion-header\">"
             + "<button class=\"accordion-button collapsed py-2 px-3\" type=\"button\""
             + " data-bs-toggle=\"collapse\" data-bs-target=\"#" + itemId + "\""
             + " data-bs-parent=\"#" + parentId + "\">"
             + "<i class=\"" + iconCls + " me-2\" style=\"font-size:.85rem;\"></i>"
             + "<span class=\"small fw-semibold\">" + label + "</span>"
             + "</button></h2>"
             + "<div id=\"" + itemId + "\" class=\"accordion-collapse collapse\">"
             + "<div class=\"accordion-body py-2 px-3\">" + bodyHtml + "</div>"
             + "</div></div>";
    }
}

<div class="container-fluid" id="proposta-edit-page">
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/Proposta">Propostas</a></li>
            <li class="breadcrumb-item active">@Model.Titulo</li>
        </ol>
    </nav>

    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h3 class="mb-0"><i class="fas fa-edit me-2 text-primary"></i>@Model.Titulo</h3>
            <small class="text-muted">Edite os dados, destinos e hospedagens da proposta</small>
        </div>
        <div class="btn-group">
            <a href="/Proposta/Detalhes/@Model.Id" class="btn btn-sm btn-outline-info">
                <i class="fas fa-eye me-1"></i>Visualizar
            </a>
            @if (Model.LinkPublicoAtivo)
            {
                <a href="/Proposta/Publico/@Model.Id" target="_blank" class="btn btn-sm btn-outline-success">
                    <i class="fas fa-external-link-alt me-1"></i>Público
                </a>
            }
            <a href="/Proposta" class="btn btn-sm btn-outline-secondary">
                <i class="fas fa-arrow-left me-1"></i>Propostas
            </a>
        </div>
    </div>

    <!-- Tabs de navegação -->
    <ul class="nav nav-pills mb-4" id="editarTabs" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link @(activeTab == "dados" ? "active" : "")"
                    id="tab-dados" data-bs-toggle="pill" data-bs-target="#pane-dados"
                    type="button" role="tab">
                <i class="fas fa-file-alt me-1"></i>Dados
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link @(activeTab == "passageiros" ? "active" : "")"
                    id="tab-passageiros" data-bs-toggle="pill" data-bs-target="#pane-passageiros"
                    type="button" role="tab">
                <i class="fas fa-users me-1"></i>Passageiros
                @if (proposta?.PassageirosProposta.Any() == true)
                {
                    <span class="badge bg-secondary ms-1">@proposta.PassageirosProposta.Count</span>
                }
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link @(activeTab == "aereo" ? "active" : "")"
                    id="tab-aereo" data-bs-toggle="pill" data-bs-target="#pane-aereo"
                    type="button" role="tab">
                <i class="fas fa-plane me-1"></i>Aéreo
                @if (proposta != null && proposta.Voos.Any())
                {
                    <span class="badge bg-secondary ms-1">@proposta.Voos.Count</span>
                }
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link @(activeTab == "destinos" ? "active" : "")"
                    id="tab-destinos" data-bs-toggle="pill" data-bs-target="#pane-destinos"
                    type="button" role="tab">
                <i class="fas fa-map-marked-alt me-1"></i>Destinos &amp; Hospedagens
                @if (proposta != null)
                {
                    <span class="badge bg-secondary ms-1">@proposta.Destinos.Count</span>
                }
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link @(activeTab == "seguro" ? "active" : "")"
                    id="tab-seguro" data-bs-toggle="pill" data-bs-target="#pane-seguro"
                    type="button" role="tab">
                <i class="fas fa-shield-alt me-1"></i>Seguro
                @if (proposta != null && proposta.Seguros.Any())
                {
                    <span class="badge bg-secondary ms-1">@proposta.Seguros.Count</span>
                }
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link @(activeTab == "condicoes" ? "active" : "")"
                    id="tab-condicoes" data-bs-toggle="pill" data-bs-target="#pane-condicoes"
                    type="button" role="tab">
                <i class="fas fa-file-contract me-1"></i>Condições da Proposta
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link @(activeTab == "revisao" ? "active" : "")"
                    id="tab-revisao" data-bs-toggle="pill" data-bs-target="#pane-revisao"
                    type="button" role="tab">
                <i class="fas fa-check-double me-1"></i>Revisão
            </button>
        </li>
    </ul>

    <div class="tab-content" id="editarTabsContent">

        <!-- ============================================================ -->
        <!-- TAB 1: DADOS DA PROPOSTA                                      -->
        <!-- ============================================================ -->
        <div class="tab-pane fade @(activeTab == "dados" ? "show active" : "")"
             id="pane-dados" role="tabpanel">

            <form asp-action="Editar" method="post" enctype="multipart/form-data" id="formEditarProposta">
                <input asp-for="Id" type="hidden" />
                <input asp-for="UsuarioId" type="hidden" />
                <input asp-for="DataCriacao" type="hidden" />
                <input asp-for="DataModificacao" type="hidden" />

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row">
                    <div class="col-md-8">
                        <div class="card mb-4">
                            <div class="card-header bg-primary text-white">
                                <h5 class="mb-0"><i class="fas fa-info-circle me-2"></i>Informações da Viagem</h5>
                            </div>
                            <div class="card-body">
                                <div class="mb-3">
                                    <label asp-for="Titulo" class="form-label fw-bold">
                                        <span class="text-danger">*</span> @Html.DisplayNameFor(m => m.Titulo)
                                    </label>
                                    <input asp-for="Titulo" class="form-control form-control-lg"
                                           placeholder="Ex: Viagem dos Sonhos - Europa 2024" maxlength="500" required />
                                    <span asp-validation-for="Titulo" class="text-danger"></span>
                                </div>
                                <div class="row">
                                    <div class="col-md-6 mb-3">
                                        <label asp-for="DataInicio" class="form-label fw-bold">
                                            <i class="fas fa-calendar-alt me-1"></i>Data de Início
                                        </label>
                                        <input asp-for="DataInicio" class="form-control" type="date" />
                                        <span asp-validation-for="DataInicio" class="text-danger"></span>
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <label asp-for="DataFim" class="form-label fw-bold">
                                            <i class="fas fa-calendar-check me-1"></i>Data de Fim
                                        </label>
                                        <input asp-for="DataFim" class="form-control" type="date" />
                                        <span asp-validation-for="DataFim" class="text-danger"></span>
                                    </div>
                                </div>
                                @* Passageiros e Crianças gerenciados na aba Passageiros (fonte única) *@
                                <input asp-for="NumeroPassageiros" type="hidden" />
                                <input asp-for="NumeroCriancas" type="hidden" />

                                <div class="mb-3">
                                    <label class="form-label fw-bold"><i class="fas fa-camera me-1"></i>Foto de Capa</label>
                                    @if (!string.IsNullOrEmpty(Model.FotoCapa))
                                    {
                                        <div class="mb-2">
                                            <div class="current-photo-container">
                                                <img src="@Model.FotoCapa" alt="Foto atual" class="img-thumbnail current-photo" />
                                                <button type="button" class="btn btn-sm btn-outline-danger" onclick="removerFotoAtual()">
                                                    <i class="fas fa-trash me-1"></i>Remover
                                                </button>
                                            </div>
                                        </div>
                                    }
                                    <input asp-for="FotoCapaUpload" class="form-control" type="file" accept="image/*" id="fotoCapa" />
                                    <div class="form-text">JPG, PNG, GIF (máx: 5MB)</div>
                                    <div id="previewNovaFoto" class="mt-2" style="display: none;">
                                        <img id="imagemPreviewNova" class="img-thumbnail" style="max-height: 150px;" />
                                        <button type="button" class="btn btn-sm btn-outline-danger mt-1" onclick="cancelarNovaFoto()">
                                            <i class="fas fa-times me-1"></i>Cancelar
                                        </button>
                                    </div>
                                    <input asp-for="FotoCapa" type="hidden" id="fotoCapaAtual" />
                                </div>

                                <div class="mb-3">
                                    <label asp-for="ObservacoesGerais" class="form-label fw-bold">
                                        <i class="fas fa-sticky-note me-1"></i>Observações Gerais
                                    </label>
                                    <textarea asp-for="ObservacoesGerais" class="form-control" rows="4"
                                              placeholder="Descreva detalhes importantes sobre a viagem..."></textarea>
                                </div>
                            </div>
                        </div>

                        <div class="card mb-4">
                            <div class="card-header">
                                <h5 class="mb-0"><i class="fas fa-cog me-2"></i>Status e Configurações</h5>
                            </div>
                            <div class="card-body">
                                <div class="row">
                                    <div class="col-md-6 mb-3">
                                        <label asp-for="StatusProposta" class="form-label fw-bold">Status</label>
                                        <select asp-for="StatusProposta" class="form-control">
                                            <option value="1">Rascunho</option>
                                            <option value="2">Enviada</option>
                                            <option value="3">Aprovada</option>
                                            <option value="4">Rejeitada</option>
                                            <option value="5">Cancelada</option>
                                        </select>
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <label asp-for="LayoutId" class="form-label fw-bold">Layout</label>
                                        <select asp-for="LayoutId" class="form-control">
                                            <option value="">Layout Padrão</option>
                                            @if (ViewBag.Layouts != null)
                                            {
                                                @foreach (var layout in (List<SistemaUsuarios.Models.Layout>)ViewBag.Layouts)
                                                {
                                                    <option value="@layout.Id">@layout.Nome</option>
                                                }
                                            }
                                        </select>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-6 mb-3">
                                        <div class="form-check form-switch">
                                            <input asp-for="LinkPublicoAtivo" class="form-check-input" />
                                            <label asp-for="LinkPublicoAtivo" class="form-check-label fw-bold">
                                                <i class="fas fa-link me-1"></i>Link Público Ativo
                                            </label>
                                        </div>
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <label asp-for="DataExpiracaoLink" class="form-label fw-bold">Data de Expiração</label>
                                        <input asp-for="DataExpiracaoLink" class="form-control" type="datetime-local" />
                                    </div>
                                </div>
                                @if (Model.LinkPublicoAtivo)
                                {
                                    var codigoAtual = proposta?.CodigoAcesso;
                                    <div class="rounded-3 border p-3 mb-0" style="background:#f8f9ff;">
                                        <div class="row g-2 align-items-end">
                                            <!-- Link público -->
                                            <div class="col-md-7">
                                                <label class="form-label small fw-semibold text-muted mb-1">
                                                    <i class="fas fa-link me-1"></i>Link da proposta
                                                </label>
                                                <div class="input-group">
                                                    <input type="text" class="form-control form-control-sm"
                                                           id="linkPublico"
                                                           value="@(Context.Request.Scheme)://@(Context.Request.Host)/Proposta/Publico/@Model.Id"
                                                           readonly />
                                                    <button class="btn btn-sm btn-outline-primary" type="button"
                                                            onclick="copiarLinkPublico()" title="Copiar link" id="btnCopiarLink">
                                                        <i class="fas fa-copy"></i>
                                                    </button>
                                                    
                                                </div>
                                            </div>
                                            <!-- Código de acesso -->
                                            <div class="col-md-5">
                                                <label class="form-label small fw-semibold text-muted mb-1">
                                                    <i class="fas fa-key me-1"></i>Código de acesso
                                                </label>
                                                <div class="input-group">
                                                    <input type="text" class="form-control form-control-sm fw-bold text-center"
                                                           id="codigoAcesso"
                                                           value="@(codigoAtual ?? "—")"
                                                           readonly
                                                           style="letter-spacing:.18em;font-size:.95rem;" />
                                                    <button class="btn btn-sm btn-outline-success" type="button"
                                                            onclick="copiarCodigo()" title="Copiar código" id="btnCopiarCodigo"
                                                            @(codigoAtual == null ? "disabled" : "")>

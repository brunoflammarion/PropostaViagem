        }

        // ── Preview de Insights no bloco Adicionar Novo Destino ──────────
        function renderInsightsPreviewNovoDest(data) {
            const body = document.getElementById('novo-dest-insights-body');
            const panel = document.getElementById('novo-dest-insights');
            if (!body || !panel) return;
            body.innerHTML = '';

            const sections = [
                { key: 'cuidados',           icon: 'fa-exclamation-triangle text-danger',   label: 'Cuidados &amp; Atenção',            border: 'border-danger'   },
                { key: 'gastronomia',         icon: 'fa-utensils text-warning',              label: 'Gastronomia &amp; Pratos',          border: 'border-warning'  },
                { key: 'atracoes',            icon: 'fa-map-marked-alt text-info',           label: 'Atrações &amp; Pontos de Interesse', border: 'border-info'     },
                { key: 'informacoesPraticas', icon: 'fa-info-circle text-primary',           label: 'Informações Práticas',              border: 'border-primary'  },
                { key: 'malaViagem',          icon: 'fa-suitcase text-secondary',            label: 'Mala de Viagem',                    border: 'border-secondary'},
            ];

            let hasAny = false;
            sections.forEach(function(s, idx) {
                const val = data[s.key];
                if (!val || (Array.isArray(val) && val.length === 0) || (typeof val === 'object' && !Array.isArray(val) && Object.keys(val).length === 0)) return;
                const itemId = 'ndins-' + s.key;
                const bodyHtml = insRenderVal(val);
                if (!bodyHtml.trim()) return;
                body.insertAdjacentHTML('beforeend',
                    '<div class="accordion-item ' + s.border + ' border-opacity-25 rounded-3 mb-2 overflow-hidden">'
                    + '<h2 class="accordion-header">'
                    + '<button class="accordion-button' + (idx === 0 ? '' : ' collapsed') + ' py-2 px-3" type="button"'
                    + ' data-bs-toggle="collapse" data-bs-target="#' + itemId + '">'
                    + '<i class="fas ' + s.icon + ' me-2" style="font-size:.85rem;"></i>'
                    + '<span class="small fw-semibold">' + s.label + '</span>'
                    + '</button></h2>'
                    + '<div id="' + itemId + '" class="accordion-collapse collapse' + (idx === 0 ? ' show' : '') + '">'
                    + '<div class="accordion-body py-2 px-3">' + bodyHtml + '</div>'
                    + '</div></div>'
                );
                hasAny = true;
            });

            panel.classList.toggle('d-none', !hasAny);
        }

        function insRenderVal(val) {
            if (Array.isArray(val)) {
                return val.map(function(item) {
                    if (item && typeof item === 'object')
                        return '<div class="rev-arr-item">' + insRenderObj(item) + '</div>';
                    return '<div class="rev-arr-item"><span class="rev-insight-value">' + insEsc(String(item)) + '</span></div>';
                }).join('');
            }
            if (val && typeof val === 'object') return insRenderObj(val);
            return '<p class="rev-insight-value">' + insEsc(String(val)) + '</p>';
        }

        function insRenderObj(obj) {
            return Object.entries(obj)
                .filter(function([, v]) { return v !== null && v !== undefined && v !== ''; })
                .map(function([k, v]) {
                    const enc = insEsc(Array.isArray(v) ? v.join(', ') : String(v));
                    const label = insEsc(k.replace(/([A-Z])/g, ' $1').trim().replace(/^./, function(c) { return c.toUpperCase(); }));
                    if (k.toLowerCase().includes('gancho'))
                        return '<div class="rev-gancho"><i class="fas fa-bolt text-warning me-1"></i>' + enc + '</div>';
                    return '<div class="mb-2"><div class="rev-insight-label">' + label + '</div><div class="rev-insight-value">' + enc + '</div></div>';
                }).join('');
        }

        function insEsc(s) {
            return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
        }

        // ============================================================

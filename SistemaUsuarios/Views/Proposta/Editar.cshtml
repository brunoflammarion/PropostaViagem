        function renderHospComodidadesInContainer(container) {
            const $container = $(container);
            const comodidades = $container.data('comodidades') || [];
            const badges = comodidades.map((c, i) =>
                `<span class="badge bg-light text-dark border d-inline-flex align-items-center gap-1 py-1 px-2">

<!-- ═══ HOSPEDAGEM ═══ -->
@if (famTemHospedagem)
{
<section class="fam-section" id="sec-hospedagem">
    <div class="fam-container">
        <h2 class="fam-section-h2"><i class="fas fa-bed" style="color:var(--c-accent);"></i>Hospedagem</h2>
        <p class="fam-section-sub">Acomodações selecionadas para o conforto de todos.</p>
        <div class="fam-section-divider"></div>

        @foreach (var dest in famDestOrd)
        {
            var _destCor3 = famDestCores.GetValueOrDefault(dest.Id, famPaleta[0]);
            foreach (var hosp in dest.Hospedagens.OrderBy(h => h.CheckIn ?? DateTime.MaxValue))
            {
                var _hospFotos = hosp.Fotos.OrderBy(f => f.Ordem).ToList();
                var _noites = (hosp.CheckIn.HasValue && hosp.CheckOut.HasValue)
                    ? (int)(hosp.CheckOut.Value.Date - hosp.CheckIn.Value.Date).TotalDays
                    : 0;
                <div class="fam-hotel-card">
                    @if (_hospFotos.Any())
                    {
                        var _cid     = "hospCar_" + hosp.Id.ToString("N");
                var _hospGid = "gal-h-" + hosp.Id.ToString("N");
                        <div class="fam-hotel-gallery">
                            @if (_hospFotos.Count == 1)
                            {
                                <img src="@_hospFotos[0].CaminhoFoto" alt="@hosp.Nome"
                                     data-gallery-group="@_hospGid"
                                     data-gallery-src="@_hospFotos[0].CaminhoFoto"
                                     data-gallery-caption="@hosp.Nome"
                                     style="cursor:zoom-in;" />
                            }
                            else
                            {
                                <div id="@_cid" class="carousel slide" data-bs-ride="false">
                                    <div class="carousel-inner">
                                        @for (int _fi2 = 0; _fi2 < _hospFotos.Count; _fi2++)
                                        {
                                            <div class="carousel-item @(_fi2==0?"active":"")">
                                                <img src="@_hospFotos[_fi2].CaminhoFoto" alt="@hosp.Nome"
                                                     data-gallery-group="@_hospGid"
                                                     data-gallery-src="@_hospFotos[_fi2].CaminhoFoto"
                                                     data-gallery-caption="@hosp.Nome"
                                                     style="cursor:zoom-in;" />
                                            </div>
                                        }
                                    </div>
                                    <button class="carousel-control-prev" type="button" data-bs-target="#@_cid" data-bs-slide="prev">
                                        <span class="carousel-control-prev-icon"></span>
                                    </button>
                                    <button class="carousel-control-next" type="button" data-bs-target="#@_cid" data-bs-slide="next">
                                        <span class="carousel-control-next-icon"></span>
                                    </button>
                                </div>
                            }
                        </div>
                    }
                    <div class="fam-hotel-body">
                        <span class="fam-hotel-dest-tag" style="color:@_destCor3;">@dest.Nome</span>
                        <div class="fam-hotel-name">@hosp.Nome</div>
                        @if (!string.IsNullOrEmpty(hosp.Endereco))
                        {
                            <div class="fam-hotel-address"><i class="fas fa-map-marker-alt" style="color:var(--c-accent);"></i>@hosp.Endereco</div>
                        }
                        <div class="fam-hotel-meta">
                            <span class="fam-hotel-chip"><i class="fas fa-star"></i>@hosp.Categoria.ToString()</span>
                            @if (_noites > 0) { <span class="fam-hotel-chip"><i class="fas fa-moon"></i>@_noites @(_noites == 1 ? "noite" : "noites")</span> }
                            @if (hosp.TipoPensao != TipoPensao.SemPensao) { <span class="fam-hotel-chip"><i class="fas fa-utensils"></i>@hosp.TipoPensao.ToString()</span> }
                        </div>
                        @if (hosp.CheckIn.HasValue || hosp.CheckOut.HasValue)
                        {
                            <div class="fam-hotel-dates">
                                @if (hosp.CheckIn.HasValue)
                                {
                                    <span><i class="fas fa-sign-in-alt" style="color:var(--c-accent);"></i>
                                        Check-in: <strong>@hosp.CheckIn.Value.ToString("dd 'de' MMM 'de' yyyy", famPtBR) @hosp.CheckIn.Value.ToString("HH:mm")</strong>
                                    </span>
                                }
                                @if (hosp.CheckOut.HasValue)
                                {
                                    <span><i class="fas fa-sign-out-alt" style="color:var(--c-accent);"></i>
                                        Check-out: <strong>@hosp.CheckOut.Value.ToString("dd 'de' MMM 'de' yyyy", famPtBR) @hosp.CheckOut.Value.ToString("HH:mm")</strong>
                                    </span>
                                }
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(hosp.Descricao))
                        {
                            <div class="fam-hotel-desc">@hosp.Descricao</div>
                        }
                        @if (hosp.Acomodacoes.Any())
                        {
                            <div class="fam-acmd-grid">
                                @foreach (var acmd in hosp.Acomodacoes.OrderBy(a => a.Ordem))
                                {
                                    var _acFoto = acmd.Fotos.OrderBy(f => f.Ordem).FirstOrDefault();
                                    <div class="fam-acmd-card">
                                        @if (_acFoto != null)
                                        {
                                            <img src="@_acFoto.CaminhoFoto" alt="@acmd.Nome"
                                                 onclick="openLightbox('@_acFoto.CaminhoFoto','@acmd.Nome')" style="cursor:zoom-in;" />
                                        }
                                        <div class="fam-acmd-body">
                                            <div class="fam-acmd-name">@acmd.Nome</div>
                                            @if (!string.IsNullOrEmpty(acmd.Descricao))
                                            {
                                                <div class="fam-acmd-sub">@(acmd.Descricao.Length > 90 ? acmd.Descricao.Substring(0,90) + "…" : acmd.Descricao)</div>
                                            }
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
            }
        }
    </div>
</section>
}

<!-- ═══ EXPERIÊNCIAS ═══ -->
@if (famTemExperiencias)
{
<section class="fam-section" id="sec-experiencias">
    <div class="fam-container">
        <h2 class="fam-section-h2"><i class="fas fa-hiking" style="color:var(--c-accent);"></i>Experiências</h2>
        <p class="fam-section-sub">Experiências e passeios preparados para criar memórias únicas.</p>
        <div class="fam-section-divider"></div>

        <div class="fam-exp-list">
            @foreach (var dest in famDestOrd)
            {
                var _destCor4 = famDestCores.GetValueOrDefault(dest.Id, famPaleta[0]);
                @foreach (var exp in dest.Experiencias.OrderBy(e => e.Ordem))
                {
                    var _expImgs  = exp.Imagens.OrderBy(i => i.Ordem).ToList();
                    var _expImg   = _expImgs.FirstOrDefault();
                    bool _hasVid  = !string.IsNullOrEmpty(exp.VideoUrl);
                    bool _hasMedia = _expImg != null || _hasVid;
                    var _expGid   = "gal-e-" + exp.Id.ToString("N");
                    <div class="fam-exp-card">
                        @if (_hasMedia)
                        {
                            <div class="fam-exp-card-media">
                                @if (_hasVid)
                                {
                                    <iframe src="@EmbedUrl(exp.VideoUrl)" allowfullscreen title="@exp.TipoPasseio"></iframe>
                                }
                                else if (_expImg != null)
                                {
                                    <img src="@_expImg.CaminhoImagem" alt="@exp.TipoPasseio"
                                         data-gallery-group="@_expGid"
                                         data-gallery-src="@_expImg.CaminhoImagem"
                                         data-gallery-caption="@exp.TipoPasseio"
                                         style="cursor:zoom-in;" />
                                }
                            </div>
                        }
                        <div class="fam-exp-card-body">
                            <div class="fam-exp-card-tag" style="color:@_destCor4;">
                                <i class="fas fa-map-marker-alt"></i>@dest.Nome
                            </div>
                            <div class="fam-exp-card-title">@exp.TipoPasseio</div>
                            @if (!string.IsNullOrEmpty(exp.Descricao))
                            {
                                <div class="fam-exp-card-desc">@exp.Descricao</div>
                            }
                            <div class="fam-exp-card-meta">
                                @if (exp.DataInicio.HasValue)
                                {
                                    <span class="fam-exp-chip"><i class="fas fa-calendar"></i>@exp.DataInicio.Value.ToString("dd/MM/yyyy", famPtBR)@(exp.DataInicio.Value.Hour != 0 ? " " + exp.DataInicio.Value.ToString("HH:mm") : "")</span>
                                }
                                @if (exp.Valor.HasValue && exp.Valor.Value > 0)
                                {
                                    <span class="fam-exp-chip"><i class="fas fa-tag"></i>R$ @exp.Valor.Value.ToString("N2")</span>
                                }
                            </div>
                            @if (_expImgs.Count > 1)
                            {
                                var _expCarId = "expCar_" + exp.Id.ToString("N");
                                <div id="@_expCarId" class="carousel slide mt-3" data-bs-ride="false" style="border-radius:10px;overflow:hidden;">
                                    <div class="carousel-inner">
                                        @for (int _ei = 0; _ei < _expImgs.Count; _ei++)
                                        {
                                            <div class="carousel-item @(_ei==0?"active":"")">
                                                <img src="@_expImgs[_ei].CaminhoImagem" alt="@exp.TipoPasseio"
                                                     data-gallery-group="@_expGid"
                                                     data-gallery-src="@_expImgs[_ei].CaminhoImagem"
                                                     data-gallery-caption="@exp.TipoPasseio"
                                                     style="width:100%;height:160px;object-fit:cover;cursor:zoom-in;" />
                                            </div>
                                        }
                                    </div>
                                    <button class="carousel-control-prev" type="button" data-bs-target="#@_expCarId" data-bs-slide="prev">
                                        <span class="carousel-control-prev-icon"></span>
                                    </button>
                                    <button class="carousel-control-next" type="button" data-bs-target="#@_expCarId" data-bs-slide="next">
                                        <span class="carousel-control-next-icon"></span>
                                    </button>
                                </div>
                            }
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</section>
}


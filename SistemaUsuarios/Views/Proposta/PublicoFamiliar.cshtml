<!-- ═══ VOOS ═══ -->
@if (temVoos)
{
    var gruposVooFam = new[] {
        new { Titulo = "Voos de Ida",    Cor = "#3B82F6", Icone = "fas fa-plane",          Voos = Model.Voos.Where(v => v.TipoVoo == TipoVoo.Ida).OrderBy(v => v.Ordem).ToList() },
        new { Titulo = "Voos Internos",  Cor = "#8B5CF6", Icone = "fas fa-plane-departure", Voos = Model.Voos.Where(v => v.TipoVoo == TipoVoo.Interno).OrderBy(v => v.Ordem).ToList() },
        new { Titulo = "Voos de Volta",  Cor = "#10B981", Icone = "fas fa-plane-arrival",   Voos = Model.Voos.Where(v => v.TipoVoo == TipoVoo.Volta).OrderBy(v => v.Ordem).ToList() },
    };
<section class="fam-section" id="sec-voos">
    <div class="fam-container">
        <h2 class="fam-section-h2"><i class="fas fa-plane-departure" style="color:var(--c-accent);"></i>Os voos da família</h2>
        <div class="fam-section-divider"></div>
        @foreach (var _gv in gruposVooFam)
        {
            if (!_gv.Voos.Any()) { continue; }
            <div class="fam-voo-group-title" style="color:@_gv.Cor;">
                <i class="@_gv.Icone"></i>@_gv.Titulo
            </div>
            <div class="row g-3 mb-4">
                @foreach (var _v in _gv.Voos)
                {
                    var _vPartida = _v.HorarioSaida?.ToString("dd/MM/yyyy") ?? "—";
                    var _vChegada = _v.HorarioChegada?.ToString("dd/MM/yyyy") ?? "—";
                    var _vHoraP   = _v.HorarioSaida?.ToString(@"HH\:mm") ?? "";
                    var _vHoraC   = _v.HorarioChegada?.ToString(@"HH\:mm") ?? "";
                    <div class="col-md-6">
                        <div class="fam-flight-card">
                            <div class="fam-flight-header">
                                <div class="fam-flight-route">
                                    <div>
                                        <div class="fam-flight-iata">@(_v.Origem ?? "—")</div>
                                        <div class="fam-flight-sub">@_vPartida @_vHoraP</div>
                                    </div>
                                    <div class="fam-flight-arrow"><i class="fas fa-long-arrow-alt-right fa-lg"></i></div>
                                    <div class="text-end">
                                        <div class="fam-flight-iata">@(_v.Destino ?? "—")</div>
                                        <div class="fam-flight-sub">@_vChegada @_vHoraC</div>
                                    </div>
                                </div>
                            </div>
                            <div class="fam-flight-body">
                                <div class="fam-flight-meta">
                                    @if (!string.IsNullOrEmpty(_v.Companhia))
                                    {
                                        <div class="fam-flight-meta-item"><small>Companhia</small><span>@_v.Companhia @(!string.IsNullOrEmpty(_v.NumeroVoo) ? "· " + _v.NumeroVoo : "")</span></div>
                                    }
                                    @if (!string.IsNullOrEmpty(_v.Classe))
                                    {
                                        <div class="fam-flight-meta-item"><small>Classe</small><span>@_v.Classe</span></div>
                                    }
                                    @if (!string.IsNullOrEmpty(_v.Duracao))
                                    {
                                        <div class="fam-flight-meta-item"><small>Duração</small><span>@_v.Duracao</span></div>
                                    }
                                    @{
                                        bool _vTemBag = _v.BagagemItemPessoalDescricao != null || _v.BagagemMaoPeso.HasValue || _v.BagagemDespachadaPeso.HasValue;
                                    }
                                    @if (_vTemBag)
                                    {
                                        <div class="fam-flight-meta-item">
                                            <small>Bagagem</small>
                                            <span>
                                                @if (_v.BagagemItemPessoalDescricao != null) { <text>Item pessoal · </text> }
                                                @if (_v.BagagemMaoPeso.HasValue) { <text>Mão @(_v.BagagemMaoPeso.Value.ToString("0"))kg · </text> }
                                                @if (_v.BagagemDespachadaPeso.HasValue) { <text>Desp. @(_v.BagagemDespachadaPeso.Value.ToString("0"))kg</text> }
                                            </span>
                                        </div>
                                    }
                                </div>
                                @if (_v.Passageiros.Any())
                                {
                                    <div style="margin-top:8px;font-size:.78rem;color:var(--c-text-mid);">
                                        <i class="fas fa-user me-1" style="color:var(--c-accent);"></i>@string.Join(", ", _v.Passageiros.Select(p => p.Nome))
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</section>
}


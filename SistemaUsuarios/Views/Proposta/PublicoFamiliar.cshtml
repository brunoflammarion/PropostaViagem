<section class="fam-section aval-section" id="sec-avaliacao">
    <div class="fam-container">
        <h2 class="fam-section-h2"><i class="fas fa-star" style="color:var(--c-warm);"></i>O que a família achou?</h2>
        <p class="fam-section-sub">Sua avaliação nos ajuda a personalizar ainda mais a viagem.</p>
        <div class="fam-section-divider"></div>

        @if (mostrarAvalHospedagem)
        {
            <p class="aval-group-title"><i class="fas fa-hotel me-1"></i>Hospedagens</p>
            <div class="row g-3 mb-4">
                @foreach (var _ah in todasHospedagens)
                {
                    var _ahId = _ah.Id.ToString();
                    <div class="col-sm-6 col-lg-4">
                        <div class="aval-card">
                            <div class="aval-card-name">@_ah.Nome</div>
                            @if (!string.IsNullOrEmpty(_ah.Endereco))
                            {
                                <div class="aval-card-sub"><i class="fas fa-map-marker-alt me-1"></i>@_ah.Endereco</div>
                            }
                            <div class="aval-card-sub">@_ah.Categoria.ToString()</div>
                            <div class="star-rating" data-tipo="Hospedagem" data-id="@_ahId">
                                @for (int s = 5; s >= 1; s--) {
                                    <input type="radio" name="aval-hosp-@_ahId" id="aval-hosp-@(_ahId)-@s" value="@s" />
                                    <label for="aval-hosp-@(_ahId)-@s" title="@s estrelas"></label>
                                }
                            </div>
                            <button class="aval-fav-btn" data-fav="@_ahId"><i class="fas fa-heart"></i><span>Favorito</span></button>
                            <textarea class="aval-comment" data-comment="@_ahId" rows="2" placeholder="Comentário opcional..."></textarea>
                        </div>
                    </div>
                }
            </div>
        }

        @if (mostrarAvalAcomodacao)
        {
            <p class="aval-group-title @(mostrarAvalHospedagem ? "mt-4" : "")"><i class="fas fa-bed me-1"></i>Acomodações</p>
            <div class="row g-3 mb-4">
                @foreach (var _ac in todasAcomodacoes)
                {
                    var _acId   = _ac.Id.ToString();
                    var _acFoto = _ac.Fotos.OrderBy(f => f.Ordem).FirstOrDefault();
                    <div class="col-sm-6 col-lg-4">
                        <div class="aval-card">
                            @if (_acFoto != null) {
                                <img src="@_acFoto.CaminhoFoto" alt="@_ac.Nome" class="aval-card-img"
                                     onclick="openLightbox('@_acFoto.CaminhoFoto','@_ac.Nome')" style="cursor:zoom-in;" />
                            }
                            <div class="aval-card-name">@_ac.Nome</div>
                            @if (!string.IsNullOrEmpty(_ac.Descricao)) {
                                <div class="aval-card-sub">@(_ac.Descricao.Length > 80 ? _ac.Descricao.Substring(0,80) + "…" : _ac.Descricao)</div>
                            }
                            <div class="star-rating" data-tipo="Acomodacao" data-id="@_acId">
                                @for (int s = 5; s >= 1; s--) {
                                    <input type="radio" name="aval-acmd-@_acId" id="aval-acmd-@(_acId)-@s" value="@s" />
                                    <label for="aval-acmd-@(_acId)-@s" title="@s estrelas"></label>
                                }
                            </div>
                            <button class="aval-fav-btn" data-fav="@_acId"><i class="fas fa-heart"></i><span>Favorito</span></button>
                            <textarea class="aval-comment" data-comment="@_acId" rows="2" placeholder="Comentário opcional..."></textarea>
                        </div>
                    </div>
                }
            </div>
        }

        @if (mostrarAvalExperiencia)
        {
            <p class="aval-group-title @(mostrarAvalHospedagem || mostrarAvalAcomodacao ? "mt-4" : "")"><i class="fas fa-hiking me-1"></i>Experiências</p>
            <div class="row g-3 mb-4">
                @foreach (var _ae in todasExperiencias)
                {
                    var _aeId  = _ae.Id.ToString();
                    var _aeImg = _ae.Imagens.OrderBy(i => i.Ordem).FirstOrDefault();
                    <div class="col-sm-6 col-lg-4">
                        <div class="aval-card">
                            @if (_aeImg != null) {
                                <img src="@_aeImg.CaminhoImagem" alt="@_ae.TipoPasseio" class="aval-card-img"
                                     onclick="openLightbox('@_aeImg.CaminhoImagem','@_ae.TipoPasseio')" style="cursor:zoom-in;" />
                            }
                            <div class="aval-card-name">@_ae.TipoPasseio</div>
                            @if (!string.IsNullOrEmpty(_ae.Descricao)) {
                                <div class="aval-card-sub">@(_ae.Descricao.Length > 80 ? _ae.Descricao.Substring(0,80) + "…" : _ae.Descricao)</div>
                            }
                            <div class="star-rating" data-tipo="Experiencia" data-id="@_aeId">
                                @for (int s = 5; s >= 1; s--) {
                                    <input type="radio" name="aval-exp-@_aeId" id="aval-exp-@(_aeId)-@s" value="@s" />
                                    <label for="aval-exp-@(_aeId)-@s" title="@s estrelas"></label>
                                }
                            </div>
                            <button class="aval-fav-btn" data-fav="@_aeId"><i class="fas fa-heart"></i><span>Favorito</span></button>
                            <textarea class="aval-comment" data-comment="@_aeId" rows="2" placeholder="Comentário opcional..."></textarea>
                        </div>
                    </div>
                }
            </div>
        }

        <div class="aval-submit-wrap">
            <div class="aval-submitted-msg" id="avalSubmittedMsg">
                <i class="fas fa-check-circle me-2"></i>Avaliação enviada! Obrigado pelo feedback da família.
            </div>
            <button class="btn-aval-submit" id="btnEnviarAvaliacao" onclick="enviarAvaliacao('@Model.Id')">
                <i class="fas fa-paper-plane"></i>Enviar Avaliação
            </button>
        </div>
    </div>
</section>
}

<!-- ═══ CTA ═══ -->
<section class="fam-cta" id="sec-cta">
    <div class="fam-cta-emoji">✈️🌍</div>
    <h2>Adorou? Vamos confirmar!</h2>
    <p>Fale com a gente agora e transforme essa proposta na viagem mais incrível da família!</p>
    <div class="fam-cta-btns">
        @if (!string.IsNullOrEmpty(waPhone))
        {
            <a href="https://wa.me/55@waPhone?text=@Uri.EscapeDataString(waMsgRaw)"
               class="btn-wa" data-track="whatsapp" target="_blank">
                <i class="fab fa-whatsapp fa-lg"></i>Conversar no WhatsApp
            </a>
        }
        @if (!string.IsNullOrEmpty(Model.Usuario.Email))
        {
            <a href="mailto:@Model.Usuario.Email?subject=Proposta: @Model.Titulo"
               class="btn-email" data-track="email">
                <i class="fas fa-envelope"></i>Enviar E-mail
            </a>
        }
    </div>
    <div class="fam-agent-card">
        <div class="fam-agent-avatar">
            @if (!string.IsNullOrEmpty(Model.Usuario.FotoPath))
            {
                <img src="@Model.Usuario.FotoPath" alt="@Model.Usuario.Nome"
                     style="width:100%;height:100%;object-fit:cover;border-radius:50%;" />
            }
            else { <i class="fas fa-user-tie"></i> }
        </div>
        <div class="fam-agent-name">@Model.Usuario.Nome</div>
        <div class="fam-agent-agency">
            @(string.IsNullOrEmpty(Model.Usuario.NomeAgencia) ? "Consultor de Viagens" : Model.Usuario.NomeAgencia)
        </div>
        <div class="fam-agent-contact">
            @if (!string.IsNullOrEmpty(Model.Usuario.Email))
            {
                <span><i class="fas fa-envelope"></i>@Model.Usuario.Email</span>
            }
            @if (!string.IsNullOrEmpty(Model.Usuario.Telefone))
            {
                <span><i class="fas fa-phone"></i>@Model.Usuario.Telefone</span>
            }
        </div>
    </div>
</section>

<!-- FOOTER -->
<footer>
    <div>
        @{
            var _fStatus = Model.StatusProposta == StatusProposta.Aprovada ? "Aprovada" :
                           Model.StatusProposta == StatusProposta.Enviada  ? "Enviada"  :
                           Model.StatusProposta == StatusProposta.Rejeitada ? "Rejeitada" : "Em elaboração";
            var _fDataAtual = Model.DataModificacao ?? Model.DataCriacao;
            var _fAtualizada = Model.DataModificacao.HasValue;
        }
        Proposta <strong style="color:rgba(255,255,255,.8);">@Model.Titulo</strong> · Status: @_fStatus
        &nbsp;·&nbsp; <span id="viewCount"></span>
    </div>
    <div style="font-size:.78rem;color:rgba(255,255,255,.55);margin-top:6px;display:flex;align-items:center;justify-content:center;gap:5px;">
        <i class="fas fa-clock" style="font-size:.72rem;"></i>
        @(_fAtualizada ? "Esta proposta foi atualizada em" : "Proposta criada em")
        @_fDataAtual.ToString("dd/MM/yyyy 'às' HH:mm")
        @if (Model.DataExpiracaoLink.HasValue)
        {
            <text> · válida até @Model.DataExpiracaoLink.Value.ToString("dd/MM/yyyy")</text>
        }
    </div>
    <div class="fam-share-btns">
        <button class="fam-share-btn" onclick="compartilharWhatsApp()"><i class="fab fa-whatsapp"></i>Compartilhar</button>
        <button class="fam-share-btn" onclick="copiarLink()"><i class="fas fa-copy"></i>Copiar link</button>
    </div>
</footer>

<!-- lightbox → _LayoutPublico.cshtml -->

@section Scripts {
<script>
/* ── scroll bar ── */
window.addEventListener('scroll', () => {
    const docH = document.documentElement.scrollHeight - window.innerHeight;
    document.getElementById('scrollBar').style.width = (docH > 0 ? Math.min((window.scrollY/docH)*100,100) : 0) + '%';
});

/* ── nav active ── */
const _famNavLinks = document.querySelectorAll('.fam-nav-links a');
const _famSections = [];
_famNavLinks.forEach(a => {
    a.addEventListener('click', e => {
        e.preventDefault();
        document.querySelector(a.getAttribute('href'))?.scrollIntoView({ behavior:'smooth' });
    });
    const href = a.getAttribute('href');
    if (href && href.startsWith('#')) {
        const el = document.querySelector(href);
        if (el) _famSections.push({ el, a });
    }
});
const _famObs = new IntersectionObserver(entries => {
    entries.forEach(entry => {
        const f = _famSections.find(s => s.el === entry.target);
        if (f) f.a.classList.toggle('active', entry.isIntersecting);
    });
}, { threshold: .25 });
_famSections.forEach(s => _famObs.observe(s.el));

/* lightbox → _LayoutPublico.cshtml */

/* ── share ── */
function compartilharWhatsApp() {
    const url = window.location.href;
    window.open('https://wa.me/?text=' + encodeURIComponent('Confira esta proposta de viagem: @Model.Titulo — ' + url), '_blank');
}
function copiarLink() {
    navigator.clipboard.writeText(window.location.href)
        .then(() => showNotif('Link copiado!', 'success'))
        .catch(() => showNotif('Erro ao copiar.', 'danger'));
}
function showNotif(msg, type) {
    const el = document.createElement('div');
    el.className = 'alert alert-' + type + ' position-fixed';
    el.style.cssText = 'top:20px;right:20px;z-index:99999;min-width:260px;';
    el.innerHTML = msg + ' <button type="button" class="btn-close float-end" onclick="this.parentElement.remove()"></button>';
    document.body.appendChild(el);
    setTimeout(() => el.remove(), 4000);
}

/* ── Avaliação ── */
@{
    var _famAvalDict = ViewBag.AvaliacoesPorItem as Dictionary<string, SistemaUsuarios.Models.AvaliacaoCliente>
                      ?? new Dictionary<string, SistemaUsuarios.Models.AvaliacaoCliente>();
    var _famAvalSer  = _famAvalDict.ToDictionary(
        kvp => kvp.Key,
        kvp => new { nota = kvp.Value.Nota, favorito = kvp.Value.Favorito, comentario = kvp.Value.Comentario ?? "" });
    var _famAvalJson = System.Text.Json.JsonSerializer.Serialize(_famAvalSer);
}
var __avals = @Html.Raw(_famAvalJson);

(function () {
    document.querySelectorAll('.aval-fav-btn').forEach(function (btn) {
        btn.addEventListener('click', function () { this.classList.toggle('active'); });
    });

    window.enviarAvaliacao = function (propostaId) {
        var btn = document.getElementById('btnEnviarAvaliacao');
        var tipoMap = { Hospedagem: 1, Acomodacao: 2, Experiencia: 3 };
        var itens = [];
        document.querySelectorAll('.star-rating').forEach(function (el) {
            var tipo   = el.dataset.tipo;
            var itemId = el.dataset.id;
            var checked = el.querySelector('input:checked');
            if (!checked) return;
            var nota     = parseInt(checked.value, 10);
            var favBtn   = document.querySelector('.aval-fav-btn[data-fav="' + itemId + '"]');
            var favorito = favBtn ? favBtn.classList.contains('active') : false;
            var commentEl = document.querySelector('.aval-comment[data-comment="' + itemId + '"]');
            var comentario = commentEl ? commentEl.value.trim() : '';
            itens.push({ tipoItem: tipoMap[tipo], itemId: itemId, nota: nota, comentario: comentario || null, favorito: favorito });
        });
        if (itens.length === 0) { showNotif('Avalie pelo menos uma opção antes de enviar.', 'warning'); return; }
        btn.disabled = true;
        btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Enviando...';
        fetch('/Avaliacao/Salvar', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ propostaId: propostaId, itens: itens })
        }).then(function (r) { return r.json(); })
          .then(function (data) {
            if (data.ok) {
                btn.style.display = 'none';
                var msg = document.getElementById('avalSubmittedMsg');
                if (msg) msg.style.display = 'block';
            } else {
                showNotif(data.erro || 'Erro ao enviar avaliação.', 'danger');
                btn.disabled = false;
                btn.innerHTML = '<i class="fas fa-paper-plane"></i>Enviar Avaliação';
            }
        }).catch(function () {
            showNotif('Erro de conexão. Tente novamente.', 'danger');
            btn.disabled = false;
            btn.innerHTML = '<i class="fas fa-paper-plane"></i>Enviar Avaliação';
        });
    };

    var tipoMap = { Hospedagem: 1, Acomodacao: 2, Experiencia: 3 };
    if (__avals && Object.keys(__avals).length) {
        document.querySelectorAll('.star-rating').forEach(function (el) {
            var tipo   = el.dataset.tipo;
            var itemId = el.dataset.id;
            var key    = tipoMap[tipo] + '_' + itemId;
            var a      = __avals[key];
            if (!a) return;
            var radio = el.querySelector('input[value="' + a.nota + '"]');
            if (radio) radio.checked = true;
            if (a.favorito) {
                var favBtn = document.querySelector('.aval-fav-btn[data-fav="' + itemId + '"]');
                if (favBtn) favBtn.classList.add('active');
            }
            if (a.comentario) {
                var commentEl = document.querySelector('.aval-comment[data-comment="' + itemId + '"]');
                if (commentEl) commentEl.value = a.comentario;
            }
        });
    }
})();

/* ── Analytics ── */
class PropostaAnalytics {
    constructor(propostaId) {
        this.propostaId = propostaId;
        this.sessionToken = 'sess_' + Date.now() + '_' + Math.random().toString(36).substr(2,9);
        this.startTime = new Date();
        this.maxScroll = 0; this.clicks = 0;
        this.interactions = { whatsapp: false, email: false };
        this.init();
    }
    init() { this.trackPageLoad(); this.setupScrollTracking(); this.setupClickTracking(); this.setupBeforeUnload(); this.sendHeartbeat(); }
    async trackPageLoad() {
        const data = await this.collectDeviceData();
        try { await fetch('/api/proposta/analytics/start', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({ propostaId: this.propostaId, sessionToken: this.sessionToken, ...data }) }); } catch {}
    }
    async collectDeviceData() {
        const data = {
            dataHoraInicio: new Date().toISOString(),
            tipoDispositivo: window.innerWidth <= 768 ? 'Mobile' : window.innerWidth <= 1024 ? 'Tablet' : 'Desktop',
            navegador: navigator.userAgent.includes('Chrome') ? 'Chrome' : navigator.userAgent.includes('Firefox') ? 'Firefox' : navigator.userAgent.includes('Safari') ? 'Safari' : 'Other',
            sistemaOperacional: navigator.userAgent.includes('Windows') ? 'Windows' : navigator.userAgent.includes('Mac') ? 'macOS' : navigator.userAgent.includes('Android') ? 'Android' : (navigator.userAgent.includes('iPhone') || navigator.userAgent.includes('iPad')) ? 'iOS' : 'Linux',
            resolucaoTela: screen.width + 'x' + screen.height,
            idiomaNavegador: navigator.language || 'pt-BR',
            urlReferenciador: document.referrer,
            tipoReferenciador: document.referrer.includes('whatsapp') ? 'WhatsApp' : document.referrer.includes('google') ? 'Google' : document.referrer ? 'Website' : 'Direto',
            userAgent: navigator.userAgent,
            deviceFingerprint: 'fp_' + Math.abs([navigator.userAgent, navigator.language, screen.width, screen.height].join('|').split('').reduce((h,c) => ((h<<5)-h)+c.charCodeAt(0)|0, 0)).toString(36)
        };
        try {
            const pos = await new Promise((res,rej) => navigator.geolocation ? navigator.geolocation.getCurrentPosition(p => res(p.coords), rej, {timeout:5000}) : rej());
            data.latitude = pos.latitude; data.longitude = pos.longitude;
        } catch {}
        return data;
    }
    setupScrollTracking() {
        window.addEventListener('scroll', () => {
            const pct = Math.round((window.scrollY / (document.documentElement.scrollHeight - window.innerHeight)) * 100);
            if (pct > this.maxScroll) this.maxScroll = Math.min(pct, 100);
        }, { passive: true });
    }
    setupClickTracking() {
        document.querySelectorAll('[data-track="whatsapp"]').forEach(el => el.addEventListener('click', () => { this.interactions.whatsapp = true; this.clicks++; this.sendInteraction('whatsapp_click'); }));
        document.querySelectorAll('[data-track="email"]').forEach(el => el.addEventListener('click', () => { this.interactions.email = true; this.clicks++; this.sendInteraction('email_click'); }));
        document.addEventListener('click', () => this.clicks++);
    }
    setupBeforeUnload() {
        window.addEventListener('beforeunload', () => this.sendFinalData());
        document.addEventListener('visibilitychange', () => { if (document.visibilityState === 'hidden') this.sendFinalData(); });
    }
    sendHeartbeat() { setInterval(() => this.sendUpdateData(), 30000); }
    async sendInteraction(type) {
        try { await fetch('/api/proposta/analytics/interaction', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({ sessionToken: this.sessionToken, interactionType: type, timestamp: new Date().toISOString() }) }); } catch {}
    }
    async sendUpdateData() {
        const t = Math.round((new Date() - this.startTime) / 1000);
        try { await fetch('/api/proposta/analytics/update', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({ sessionToken: this.sessionToken, tempoVisualizacaoSegundos: t, scrollMaximoPercentual: this.maxScroll, numeroCliques: this.clicks, clicouWhatsApp: this.interactions.whatsapp, clicouEmail: this.interactions.email }) }); } catch {}
    }
    sendFinalData() {
        const data = { sessionToken: this.sessionToken, dataHoraFim: new Date().toISOString(), tempoVisualizacaoSegundos: Math.round((new Date()-this.startTime)/1000), scrollMaximoPercentual: this.maxScroll, numeroCliques: this.clicks, clicouWhatsApp: this.interactions.whatsapp, clicouEmail: this.interactions.email };
        if (navigator.sendBeacon) navigator.sendBeacon('/api/proposta/analytics/finish', JSON.stringify(data));
        else fetch('/api/proposta/analytics/finish', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify(data), keepalive:true }).catch(()=>{});
    }
}

var isPreviewMode = @(isPreview ? "true" : "false");
document.addEventListener('DOMContentLoaded', () => {
    if (!isPreviewMode) window.analytics = new PropostaAnalytics('@Model.Id');
    document.getElementById('viewCount').textContent = '';
    if (isPreviewMode) document.body.classList.add('has-preview-bar');
});

@if (isPreview)
{
<text>
(function () {
    var _layoutOrig = '@(Model.LayoutId?.ToString() ?? "")';
    var sel = document.getElementById('layoutSelector');
    var btnSalvar = document.getElementById('btnSalvarLayout');
    if (sel && btnSalvar) {
        sel.addEventListener('change', function () {
            btnSalvar.style.display = sel.value !== _layoutOrig ? 'inline-flex' : 'none';
        });
        btnSalvar.addEventListener('click', function () {
            btnSalvar.disabled = true;
            btnSalvar.innerHTML = '<i class="fas fa-spinner fa-spin"></i><span class="pb-label"> Salvando…</span>';
            fetch('/api/proposta/@Model.Id/layout', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({ layoutId: sel.value ? parseInt(sel.value) : null }) })
            .then(function (r) { return r.json(); })
            .then(function (d) {
                if (d.success) { _layoutOrig = sel.value; btnSalvar.style.display='none'; btnSalvar.disabled=false; btnSalvar.innerHTML='<i class="fas fa-save"></i><span class="pb-label"> Salvar layout</span>'; window.location.reload(); }
                else { alert('Erro ao salvar layout.'); btnSalvar.disabled=false; btnSalvar.innerHTML='<i class="fas fa-save"></i><span class="pb-label"> Salvar layout</span>'; }
            }).catch(function () { alert('Erro de conexão.'); btnSalvar.disabled=false; btnSalvar.innerHTML='<i class="fas fa-save"></i><span class="pb-label"> Salvar layout</span>'; });
        });
    }
    var btnCopiar = document.getElementById('btnCopiarLink');
    if (btnCopiar) {
        btnCopiar.addEventListener('click', function () {
            var url = '@linkPublico';
            if (!url) return;
            navigator.clipboard.writeText(url)
                .then(function () { var orig = btnCopiar.innerHTML; btnCopiar.innerHTML = '<i class="fas fa-check"></i><span class="pb-label"> Copiado!</span>'; setTimeout(function () { btnCopiar.innerHTML = orig; }, 2000); })
                .catch(function () { prompt('Copie o link manualmente:', url); });
        });
    }
})();
</text>
}

@if (_famTemMapa)
{
<text>
/* ── Mapa de hospedagens ── */
var famHoteis = [
    @for (int _mi2 = 0; _mi2 < _famMapHoteis.Count; _mi2++)
    {
        var _mh2 = _famMapHoteis[_mi2];
        string _mhPer = "";
        if (_mh2.CheckIn.HasValue && _mh2.CheckOut.HasValue)
            _mhPer = _mh2.CheckIn.Value.ToString("dd/MM", famPtBR) + " a " + _mh2.CheckOut.Value.ToString("dd/MM/yy", famPtBR);
        <text>{ lat: @_mh2.Latitude!.Value.ToString("G17", _famIc), lng: @_mh2.Longitude!.Value.ToString("G17", _famIc), nome: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(_mh2.Nome)), dest: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(_mh2.DestNome)), cor: "@_mh2.Cor", idx: @(_mi2 + 1), periodo: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(_mhPer)) },</text>
    }
];

window.initFamHotelMap = function () {
    var mapEl = document.getElementById('famHotelMap');
    if (!mapEl || !famHoteis.length) return;

    var map = new google.maps.Map(mapEl, {
        center:            { lat: famHoteis[0].lat, lng: famHoteis[0].lng },
        zoom:              14,
        mapTypeControl:    false,
        streetViewControl: false,
        fullscreenControl: true,
        zoomControl:       true,
        gestureHandling:   'cooperative',
        styles: [{ featureType: 'poi', elementType: 'labels', stylers: [{ visibility: 'off' }] }]
    });

    var bounds = new google.maps.LatLngBounds();

    famHoteis.forEach(function (h) {
        var pos = { lat: h.lat, lng: h.lng };
        bounds.extend(pos);

        var marker = new google.maps.Marker({
            position: pos,
            map:      map,
            title:    h.nome,
            label:    { text: String(h.idx), color: '#fff', fontWeight: '800', fontSize: '11px' },
            icon: {
                path:          google.maps.SymbolPath.CIRCLE,
                scale:         16,
                fillColor:     h.cor,
                fillOpacity:   1,
                strokeColor:   '#ffffff',
                strokeWeight:  2.5
            }
        });

        var infoContent = '<div style="font-family:sans-serif;padding:6px 2px;min-width:160px;">' +
            '<div style="font-weight:700;font-size:.88rem;color:#1e293b;">' + h.nome + '</div>' +
            '<div style="font-size:.74rem;color:' + h.cor + ';font-weight:600;margin-top:3px;">' + h.dest + '</div>' +
            (h.periodo ? '<div style="font-size:.72rem;color:#64748b;margin-top:3px;">' + h.periodo + '</div>' : '') +
            '</div>';

        var info = new google.maps.InfoWindow({ content: infoContent });
        marker.addListener('click', function () { info.open(map, marker); });
    });

    if (famHoteis.length > 1) {
        map.fitBounds(bounds);
        google.maps.event.addListenerOnce(map, 'bounds_changed', function () {
            if (map.getZoom() > 15) map.setZoom(15);
        });
    }
};
</text>
}
</script>
@if (_famTemMapa)
{
    <text><script async defer src="https://maps.googleapis.com/maps/api/js?key=@_famApiKey&callback=initFamHotelMap&language=pt-BR&region=BR&loading=async"></script></text>
}
}

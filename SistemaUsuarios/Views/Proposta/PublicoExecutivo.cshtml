</aside>

<!-- MAIN CONTENT -->
<main class="exec-main">

<!-- ── RESUMO EXECUTIVO ── -->
<section class="exec-section" id="exec-resumo">
    <div class="exec-section-header" data-target="body-resumo">
        <h2 class="exec-section-h2"><i class="fas fa-chart-bar"></i>Resumo</h2>
        <button class="exec-section-toggle"><i class="fas fa-chevron-down"></i></button>
    </div>
    <div class="exec-section-body" id="body-resumo">
        <div class="exec-brief-grid">
            @if (Model.DataInicio.HasValue && Model.DataFim.HasValue)
            {
                var _dias3 = (Model.DataFim.Value - Model.DataInicio.Value).Days + 1;
                var _noites3 = (int)(Model.DataFim.Value.Date - Model.DataInicio.Value.Date).TotalDays;
                <div class="exec-brief-item">
                    <span class="exec-brief-label">Período</span>
                    <span class="exec-brief-val">@Model.DataInicio.Value.ToString("dd/MM") – @Model.DataFim.Value.ToString("dd/MM/yy")</span>
                    <span class="exec-brief-sub">@_dias3 dias · @_noites3 noites</span>
                </div>
            }
            @{
                var _paxNomEx = Model.PassageirosProposta?.Count ?? 0;
                var _temCliEx = Model.Cliente != null;
                var _paxEx = (_paxNomEx > 0 || _temCliEx)
                    ? (_temCliEx ? 1 : 0) + _paxNomEx
                    : Model.NumeroPassageiros + Model.NumeroCriancas;
                var _crEx = (_paxNomEx > 0 || _temCliEx) ? 0 : Model.NumeroCriancas;
            }
            <div class="exec-brief-item">
                <span class="exec-brief-label">Passageiros</span>
                <span class="exec-brief-val">@_paxEx pax</span>
                @if (_crEx > 0)
                {
                    <span class="exec-brief-sub">@_crEx crianças</span>
                }
            </div>
            @if (execDestOrd.Any())
            {
                <div class="exec-brief-item">
                    <span class="exec-brief-label">Destinos</span>
                    <span class="exec-brief-val">@execDestOrd.Count @(execDestOrd.Count == 1 ? "destino" : "destinos")</span>
                    <span class="exec-brief-sub">@string.Join(", ", execDestOrd.Select(d => d.Nome).Take(3))@(execDestOrd.Count > 3 ? "…" : "")</span>
                </div>
            }
            @if (temVoos)
            {
                <div class="exec-brief-item">
                    <span class="exec-brief-label">Voos</span>
                    <span class="exec-brief-val">@Model.Voos.Count voo@(Model.Voos.Count != 1 ? "s" : "")</span>
                </div>
            }
            @if (execTemHospedagem)
            {
                <div class="exec-brief-item">
                    <span class="exec-brief-label">Hospedagem</span>
                    <span class="exec-brief-val">@todasHospedagens.Count hotel@(todasHospedagens.Count != 1 ? "is" : "")</span>
                </div>
            }
            @{
                var _execDataAtual  = Model.DataModificacao ?? Model.DataCriacao;
                var _execAtualizada = Model.DataModificacao.HasValue;
            }
            <div class="exec-brief-item">
                <span class="exec-brief-label">Status</span>
                <span class="exec-brief-val">@_execStatus.Item1</span>
                <span class="exec-brief-sub">
                    @(_execAtualizada ? "Atualizada em" : "Criada em")
                    @_execDataAtual.ToString("dd/MM/yyyy 'às' HH:mm")
                </span>
            </div>
        </div>
        @if (!string.IsNullOrEmpty(Model.ObservacoesGerais))
        {
            <div style="margin-top:16px;padding:14px 16px;background:var(--c-bg-alt);border-radius:10px;font-size:.84rem;color:var(--c-text-mid);">
                @Model.ObservacoesGerais
            </div>
        }
    </div>
</section>

<!-- ── DESTINOS E PERÍODOS ── -->
@if (execDestOrd.Any())
{
    var execDestPaleta = new[] { "#1E3A5F","#2A7B9B","#2e9c57","#9b3d9b","#c44b4b","#00828c","#c27c10","#3B4E9B" };
<section class="exec-section" id="exec-destinos">
    <div class="exec-section-header" data-target="body-destinos">
        <h2 class="exec-section-h2"><i class="fas fa-map-marked-alt"></i>Destinos e períodos</h2>
        <button class="exec-section-toggle"><i class="fas fa-chevron-down"></i></button>
    </div>
    <div class="exec-section-body" id="body-destinos">
        <div style="overflow-x:auto;">
            <table class="exec-dest-table">
                <thead>
                    <tr>
                        <th>Destino</th>
                        <th>Período</th>
                        <th>Hospedagem prevista</th>
                        <th>Serviços sugeridos</th>
                    </tr>
                </thead>
                <tbody>
                @for (int _di2 = 0; _di2 < execDestOrd.Count; _di2++)
                {
                    var _d2 = execDestOrd[_di2];
                    var _dc2 = execDestPaleta[_di2 % execDestPaleta.Length];

                    DateTime? _dIni2 = _d2.DataChegada;
                    DateTime? _dFim2 = _d2.DataSaida;
                    if (!_dIni2.HasValue && _d2.Hospedagens.Any(h => h.CheckIn.HasValue))
                        _dIni2 = _d2.Hospedagens.Where(h => h.CheckIn.HasValue).Min(h => h.CheckIn);
                    if (!_dFim2.HasValue && _d2.Hospedagens.Any(h => h.CheckOut.HasValue))
                        _dFim2 = _d2.Hospedagens.Where(h => h.CheckOut.HasValue).Max(h => h.CheckOut);

                    int? _dNoites2 = (_dIni2.HasValue && _dFim2.HasValue)
                        ? (int?)(_dFim2.Value.Date - _dIni2.Value.Date).TotalDays : null;

                    var _dHosp2 = _d2.Hospedagens.OrderBy(h => h.CheckIn ?? DateTime.MaxValue).ToList();
                    int _nHosp = _dHosp2.Count;
                    int _nExp  = _d2.Experiencias.Count;

                    <tr>
                        <td>
                            <span class="exec-dest-dot" style="background:@_dc2;"></span>
                            <span class="exec-dest-name">@_d2.Nome</span>
                            @{
                                var _locParts2 = new[]{ _d2.Cidade, _d2.Pais }.Where(s => !string.IsNullOrEmpty(s));
                                var _locStr2 = string.Join(", ", _locParts2);
                            }
                            @if (!string.IsNullOrEmpty(_locStr2))
                            {
                                <div class="exec-dest-loc">@_locStr2</div>
                            }
                        </td>
                        <td>
                            @if (_dIni2.HasValue || _dFim2.HasValue)
                            {
                                <span class="exec-dest-period">
                                    @if (_dIni2.HasValue) { <text>@_dIni2.Value.ToString("dd/MM", execPtBR)</text> }
                                    @if (_dIni2.HasValue && _dFim2.HasValue) { <text>–</text> }
                                    @if (_dFim2.HasValue) { <text>@_dFim2.Value.ToString("dd/MM/yy", execPtBR)</text> }
                                </span>
                                @if (_dNoites2.HasValue && _dNoites2 > 0)
                                {
                                    <span class="exec-dest-noites">@_dNoites2 @(_dNoites2 == 1 ? "noite" : "noites")</span>
                                }
                            }
                            else
                            {
                                <span style="color:#94a3b8;font-size:.78rem;">—</span>
                            }
                        </td>
                        <td>
                            @if (_dHosp2.Any())
                            {
                                foreach (var _h2 in _dHosp2)
                                {
                                    <div style="font-size:.82rem;font-weight:600;color:var(--c-text);">@_h2.Nome</div>
                                }
                            }
                            else
                            {
                                <span style="color:#94a3b8;font-size:.78rem;">A definir</span>
                            }
                        </td>
                        <td class="exec-dest-services">
                            @if (_nHosp > 0) { <span><i class="fas fa-bed"></i>@_nHosp @(_nHosp == 1 ? "hospedagem" : "hospedagens")</span> }
                            @if (_nExp > 0)  { <span><i class="fas fa-star"></i>@_nExp @(_nExp == 1 ? "experiência" : "experiências")</span> }
                            @if (_d2.Transportes.Any()) { <span><i class="fas fa-car"></i>Transporte</span> }
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</section>
}

<!-- ── PASSAGEIROS ── -->
@if (temPassageiros)
{
<section class="exec-section" id="exec-passageiros">
    <div class="exec-section-header" data-target="body-passageiros">
        <h2 class="exec-section-h2"><i class="fas fa-users"></i>Passageiros</h2>
        <button class="exec-section-toggle"><i class="fas fa-chevron-down"></i></button>
    </div>
    <div class="exec-section-body" id="body-passageiros">
        <div class="exec-pax-list">
            @foreach (var pax in Model.PassageirosProposta.OrderBy(p => p.Ordem))
            {
                var _ini4 = pax.Nome.Length > 0 ? pax.Nome.Substring(0,1).ToUpper() : "?";
                <div class="exec-pax-row">
                    <div class="exec-pax-init">@_ini4</div>
                    <span class="exec-pax-name">@pax.Nome</span>
                    <span class="exec-pax-sub">
                        @if (pax.DataNascimento.HasValue)
                        {
                            var _age2 = (DateTime.Today - pax.DataNascimento.Value).Days / 365;
                            <text>@_age2 anos</text>
                        }
                    </span>
                </div>
            }
        </div>
    </div>
</section>
}

<!-- ── VOOS ── -->
@if (temVoos)
{
<section class="exec-section" id="exec-voos">
    <div class="exec-section-header" data-target="body-voos">
        <h2 class="exec-section-h2"><i class="fas fa-plane"></i>Voos</h2>
        <button class="exec-section-toggle"><i class="fas fa-chevron-down"></i></button>
    </div>
    <div class="exec-section-body" id="body-voos">
        @foreach (var _gv in gruposVooExec)
        {
            if (!_gv.Voos.Any()) { continue; }
            <div style="font-size:.72rem;font-weight:700;letter-spacing:.07em;text-transform:uppercase;color:@_gv.Cor;margin:12px 0 6px;">
                <i class="@_gv.Icone me-1"></i>@_gv.Titulo
            </div>
            <div class="exec-compact-list mb-3">
                @foreach (var _v in _gv.Voos)
                {
                    var _vPartida = _v.HorarioSaida?.ToString("dd/MM/yyyy") ?? "—";
                    var _vChegada = _v.HorarioChegada?.ToString("dd/MM/yyyy") ?? "—";
                    var _vHoraP   = _v.HorarioSaida?.ToString(@"HH\:mm") ?? "";
                    var _vHoraC   = _v.HorarioChegada?.ToString(@"HH\:mm") ?? "";
                    bool _vBag    = _v.BagagemItemPessoalDescricao != null || _v.BagagemMaoPeso.HasValue || _v.BagagemDespachadaPeso.HasValue;
                    <div class="exec-compact-row">
                        <div>
                            <div class="exec-route">
                                <span>@(_v.Origem ?? "—")</span>
                                <span class="exec-route-sep"><i class="fas fa-arrow-right" style="font-size:.7rem;"></i></span>
                                <span>@(_v.Destino ?? "—")</span>
                            </div>
                            <div class="exec-flight-meta mt-2">

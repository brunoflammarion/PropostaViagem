<!-- lightbox → _LayoutPublico.cshtml -->

@section Scripts {
<script>
/* lightbox → _LayoutPublico.cshtml */

/* ── share ── */
function compartilharWhatsApp() {
    window.open('https://wa.me/?text=' + encodeURIComponent('Confira esta proposta: @Model.Titulo — ' + window.location.href), '_blank');
}
function copiarLink() {
    navigator.clipboard.writeText(window.location.href)
        .then(() => showNotif('Link copiado!', 'success'))
        .catch(() => showNotif('Erro ao copiar.', 'danger'));
}
function showNotif(msg, type) {
    const el = document.createElement('div');
    el.className = 'alert alert-' + type + ' position-fixed';
    el.style.cssText = 'top:20px;right:20px;z-index:99999;min-width:260px;';
    el.innerHTML = msg + ' <button type="button" class="btn-close float-end" onclick="this.parentElement.remove()"></button>';
    document.body.appendChild(el);
    setTimeout(() => el.remove(), 4000);
}

/* ── sidebar active via IntersectionObserver ── */
(function () {
    var sbLinks = {
        'exec-resumo':       'sb-resumo',
        'exec-destinos':     'sb-destinos',
        'exec-passageiros':  'sb-passageiros',
        'exec-voos':         'sb-voos',
        'exec-hospedagem':   'sb-hospedagem',
        'exec-experiencias': 'sb-experiencias',
        'exec-transportes':  'sb-transportes',
        'exec-seguro':       'sb-seguro',
        'exec-obs':          'sb-obs',
        'exec-valores':      'sb-valores',
        'exec-condicoes':    'sb-condicoes',
        'exec-avaliacao':    'sb-avaliacao',
        'exec-cta':          'sb-cta',
    };
    var sbObs = new IntersectionObserver(function (entries) {
        entries.forEach(function (entry) {
            var sbId = sbLinks[entry.target.id];
            if (sbId) {
                var el = document.getElementById(sbId);
                if (el) el.classList.toggle('active', entry.isIntersecting);
            }
        });
    }, { threshold: .25 });
    Object.keys(sbLinks).forEach(function (id) {
        var el = document.getElementById(id);
        if (el) sbObs.observe(el);
    });

    // Smooth scroll on sidebar link clicks
    document.querySelectorAll('.exec-nav-link').forEach(function (a) {
        a.addEventListener('click', function (e) {
            e.preventDefault();
            var target = document.querySelector(a.getAttribute('href'));
            if (target) target.scrollIntoView({ behavior: 'smooth' });
        });
    });
})();

/* ── mobile accordion ── */
(function () {
    if (window.innerWidth >= 900) return;
    document.querySelectorAll('.exec-section-header').forEach(function (header, idx) {
        var targetId = header.getAttribute('data-target');
        var body = targetId ? document.getElementById(targetId) : null;
        if (!body) return;
        if (idx > 0) {
            body.classList.add('collapsed');
            var chevron = header.querySelector('.fa-chevron-down');
            if (chevron) { chevron.style.transform = 'rotate(-90deg)'; chevron.style.transition = 'transform .2s'; }
        }
        header.addEventListener('click', function () {
            var isCollapsed = body.classList.contains('collapsed');
            body.classList.toggle('collapsed', !isCollapsed);
            var chevron = header.querySelector('.fa-chevron-down');
            if (chevron) chevron.style.transform = isCollapsed ? '' : 'rotate(-90deg)';
        });
    });
})();

/* ── Avaliação ── */
@{
    var _exAvalDict = ViewBag.AvaliacoesPorItem as Dictionary<string, SistemaUsuarios.Models.AvaliacaoCliente>
                     ?? new Dictionary<string, SistemaUsuarios.Models.AvaliacaoCliente>();
    var _exAvalSer  = _exAvalDict.ToDictionary(
        kvp => kvp.Key,
        kvp => new { nota = kvp.Value.Nota, favorito = kvp.Value.Favorito, comentario = kvp.Value.Comentario ?? "" });
    var _exAvalJson = System.Text.Json.JsonSerializer.Serialize(_exAvalSer);
}
var __avals = @Html.Raw(_exAvalJson);

(function () {
    document.querySelectorAll('.aval-fav-btn').forEach(function (btn) {
        btn.addEventListener('click', function () { this.classList.toggle('active'); });
    });

    window.enviarAvaliacao = function (propostaId) {
        var btn = document.getElementById('btnEnviarAvaliacao');
        var tipoMap = { Hospedagem: 1, Acomodacao: 2, Experiencia: 3 };
        var itens = [];
        document.querySelectorAll('.star-rating').forEach(function (el) {
            var tipo   = el.dataset.tipo;
            var itemId = el.dataset.id;
            var checked = el.querySelector('input:checked');
            if (!checked) return;
            var nota     = parseInt(checked.value, 10);
            var favBtn   = document.querySelector('.aval-fav-btn[data-fav="' + itemId + '"]');
            var favorito = favBtn ? favBtn.classList.contains('active') : false;
            itens.push({ tipoItem: tipoMap[tipo], itemId: itemId, nota: nota, comentario: null, favorito: favorito });
        });
        if (itens.length === 0) { showNotif('Avalie pelo menos uma opção antes de enviar.', 'warning'); return; }
        btn.disabled = true;
        btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Enviando...';
        fetch('/Avaliacao/Salvar', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ propostaId: propostaId, itens: itens })
        }).then(function (r) { return r.json(); })
          .then(function (data) {
            if (data.ok) {
                btn.style.display = 'none';
                var msg = document.getElementById('avalSubmittedMsg');
                if (msg) msg.style.display = 'block';
            } else {
                showNotif(data.erro || 'Erro ao enviar.', 'danger');
                btn.disabled = false;
                btn.innerHTML = '<i class="fas fa-paper-plane"></i>Enviar Preferências';
            }
        }).catch(function () {
            showNotif('Erro de conexão.', 'danger');
            btn.disabled = false;
            btn.innerHTML = '<i class="fas fa-paper-plane"></i>Enviar Preferências';
        });
    };

    var tipoMap = { Hospedagem: 1, Acomodacao: 2, Experiencia: 3 };
    if (__avals && Object.keys(__avals).length) {
        document.querySelectorAll('.star-rating').forEach(function (el) {
            var tipo   = el.dataset.tipo;
            var itemId = el.dataset.id;
            var key    = tipoMap[tipo] + '_' + itemId;
            var a      = __avals[key];
            if (!a) return;
            var radio = el.querySelector('input[value="' + a.nota + '"]');
            if (radio) radio.checked = true;
            if (a.favorito) {
                var favBtn = document.querySelector('.aval-fav-btn[data-fav="' + itemId + '"]');
                if (favBtn) favBtn.classList.add('active');
            }
        });
    }
})();

/* ── Analytics ── */
class PropostaAnalytics {
    constructor(propostaId) {
        this.propostaId = propostaId;
        this.sessionToken = 'sess_' + Date.now() + '_' + Math.random().toString(36).substr(2,9);
        this.startTime = new Date();
        this.maxScroll = 0; this.clicks = 0;
        this.interactions = { whatsapp: false, email: false };
        this.init();
    }
    init() { this.trackPageLoad(); this.setupScrollTracking(); this.setupClickTracking(); this.setupBeforeUnload(); this.sendHeartbeat(); }
    async trackPageLoad() {
        const data = await this.collectDeviceData();
        try { await fetch('/api/proposta/analytics/start', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({ propostaId: this.propostaId, sessionToken: this.sessionToken, ...data }) }); } catch {}
    }
    async collectDeviceData() {
        const data = {
            dataHoraInicio: new Date().toISOString(),
            tipoDispositivo: window.innerWidth <= 768 ? 'Mobile' : window.innerWidth <= 1024 ? 'Tablet' : 'Desktop',
            navegador: navigator.userAgent.includes('Chrome') ? 'Chrome' : navigator.userAgent.includes('Firefox') ? 'Firefox' : navigator.userAgent.includes('Safari') ? 'Safari' : 'Other',
            sistemaOperacional: navigator.userAgent.includes('Windows') ? 'Windows' : navigator.userAgent.includes('Mac') ? 'macOS' : navigator.userAgent.includes('Android') ? 'Android' : (navigator.userAgent.includes('iPhone') || navigator.userAgent.includes('iPad')) ? 'iOS' : 'Linux',
            resolucaoTela: screen.width + 'x' + screen.height,
            idiomaNavegador: navigator.language || 'pt-BR',
            urlReferenciador: document.referrer,
            tipoReferenciador: document.referrer.includes('whatsapp') ? 'WhatsApp' : document.referrer.includes('google') ? 'Google' : document.referrer ? 'Website' : 'Direto',
            userAgent: navigator.userAgent,
            deviceFingerprint: 'fp_' + Math.abs([navigator.userAgent, navigator.language, screen.width, screen.height].join('|').split('').reduce((h,c) => ((h<<5)-h)+c.charCodeAt(0)|0, 0)).toString(36)
        };
        try {
            const pos = await new Promise((res,rej) => navigator.geolocation ? navigator.geolocation.getCurrentPosition(p => res(p.coords), rej, {timeout:5000}) : rej());
            data.latitude = pos.latitude; data.longitude = pos.longitude;
        } catch {}
        return data;
    }
    setupScrollTracking() {
        window.addEventListener('scroll', () => {
            const pct = Math.round((window.scrollY / (document.documentElement.scrollHeight - window.innerHeight)) * 100);
            if (pct > this.maxScroll) this.maxScroll = Math.min(pct, 100);
        }, { passive: true });
    }
    setupClickTracking() {
        document.querySelectorAll('[data-track="whatsapp"]').forEach(el => el.addEventListener('click', () => { this.interactions.whatsapp = true; this.clicks++; this.sendInteraction('whatsapp_click'); }));
        document.querySelectorAll('[data-track="email"]').forEach(el => el.addEventListener('click', () => { this.interactions.email = true; this.clicks++; this.sendInteraction('email_click'); }));
        document.addEventListener('click', () => this.clicks++);
    }
    setupBeforeUnload() {
        window.addEventListener('beforeunload', () => this.sendFinalData());
        document.addEventListener('visibilitychange', () => { if (document.visibilityState === 'hidden') this.sendFinalData(); });
    }
    sendHeartbeat() { setInterval(() => this.sendUpdateData(), 30000); }
    async sendInteraction(type) {
        try { await fetch('/api/proposta/analytics/interaction', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({ sessionToken: this.sessionToken, interactionType: type, timestamp: new Date().toISOString() }) }); } catch {}
    }
    async sendUpdateData() {
        const t = Math.round((new Date() - this.startTime) / 1000);
        try { await fetch('/api/proposta/analytics/update', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({ sessionToken: this.sessionToken, tempoVisualizacaoSegundos: t, scrollMaximoPercentual: this.maxScroll, numeroCliques: this.clicks, clicouWhatsApp: this.interactions.whatsapp, clicouEmail: this.interactions.email }) }); } catch {}
    }
    sendFinalData() {
        const data = { sessionToken: this.sessionToken, dataHoraFim: new Date().toISOString(), tempoVisualizacaoSegundos: Math.round((new Date()-this.startTime)/1000), scrollMaximoPercentual: this.maxScroll, numeroCliques: this.clicks, clicouWhatsApp: this.interactions.whatsapp, clicouEmail: this.interactions.email };
        if (navigator.sendBeacon) navigator.sendBeacon('/api/proposta/analytics/finish', JSON.stringify(data));
        else fetch('/api/proposta/analytics/finish', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify(data), keepalive:true }).catch(()=>{});
    }
}

var isPreviewMode = @(isPreview ? "true" : "false");
document.addEventListener('DOMContentLoaded', () => {
    if (!isPreviewMode) window.analytics = new PropostaAnalytics('@Model.Id');
    document.getElementById('viewCount').textContent = '';
    if (isPreviewMode) document.body.classList.add('has-preview-bar');
});


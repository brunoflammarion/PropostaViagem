@{
    Layout = "_LayoutPublico";
    ViewData["Title"] = Model.Titulo;
}
@model SistemaUsuarios.Models.Proposta
@using SistemaUsuarios.Models
@using System.Text.RegularExpressions
@functions {
    static string EmbedUrl(string? url) {
        if (string.IsNullOrWhiteSpace(url)) return "";
        var yt = Regex.Match(url, @"(?:youtube\.com/watch\?v=|youtu\.be/)([A-Za-z0-9_\-]{11})");
        if (yt.Success) return $"https://www.youtube.com/embed/{yt.Groups[1].Value}";
        var vimeo = Regex.Match(url, @"vimeo\.com/(\d+)");
        if (vimeo.Success) return $"https://player.vimeo.com/video/{vimeo.Groups[1].Value}";
        return url;
    }
    static string LightenPub(string hex, int amt) {
        if (string.IsNullOrEmpty(hex) || !hex.StartsWith("#") || hex.Length != 7) return hex;
        try {
            int r = Math.Clamp(Convert.ToInt32(hex.Substring(1,2),16)+amt,0,255);
            int g = Math.Clamp(Convert.ToInt32(hex.Substring(3,2),16)+amt,0,255);
            int b = Math.Clamp(Convert.ToInt32(hex.Substring(5,2),16)+amt,0,255);
            return $"#{r:X2}{g:X2}{b:X2}";
        } catch { return hex; }
    }

    static string ContrastText(string hex) {
        if (string.IsNullOrEmpty(hex) || !hex.StartsWith("#") || hex.Length != 7) return "#ffffff";
        try {
            int r = Convert.ToInt32(hex.Substring(1, 2), 16);
            int g = Convert.ToInt32(hex.Substring(3, 2), 16);
            int b = Convert.ToInt32(hex.Substring(5, 2), 16);
            return (0.299 * r + 0.587 * g + 0.114 * b) / 255.0 > 0.5 ? "#1a1a2e" : "#ffffff";
        } catch { return "#ffffff"; }
    }

    static string TintColor(string hex, double factor = 0.87) {
        if (string.IsNullOrEmpty(hex) || !hex.StartsWith("#") || hex.Length != 7) return "#f8f9fa";
        try {
            int r = Convert.ToInt32(hex.Substring(1,2),16);
            int g = Convert.ToInt32(hex.Substring(3,2),16);
            int b = Convert.ToInt32(hex.Substring(5,2),16);
            return $"#{(int)(r+(255-r)*factor):X2}{(int)(g+(255-g)*factor):X2}{(int)(b+(255-b)*factor):X2}";
        } catch { return "#f8f9fa"; }
    }
}
@{
    var layoutNome = (Model.Layout?.Nome ?? "Executivo").ToLower();
    var waPhone  = Model.Usuario.Telefone?.Replace("(","").Replace(")","").Replace("-","").Replace(" ","") ?? "";
    var waMsgRaw = $"Olá! Vi a proposta \"{Model.Titulo}\" e tenho interesse!";

    bool temPassageiros = Model.PassageirosProposta.Any();
    bool temVoos        = Model.Voos.Any();
    bool temSeguros     = Model.Seguros.Any();
    bool temResumo      = !string.IsNullOrWhiteSpace(Model.ResumoProposta);
    bool temCondicoes   = !string.IsNullOrWhiteSpace(Model.CondicoesPropostaHtml);
    bool temValores     = !string.IsNullOrWhiteSpace(Model.ValoresPropostaHtml);

    var todasHospedagens  = Model.Destinos.SelectMany(d => d.Hospedagens).ToList();
    var todasAcomodacoes  = Model.Destinos.SelectMany(d => d.Hospedagens).SelectMany(h => h.Acomodacoes).ToList();
    var todasExperiencias = Model.Destinos.SelectMany(d => d.Experiencias).ToList();

    bool mostrarAvalHospedagem  = Model.SolicitarAvaliacaoHospedagem  && todasHospedagens.Count  > 1;
    bool mostrarAvalAcomodacao  = Model.SolicitarAvaliacaoAcomodacao  && todasAcomodacoes.Count  > 1;
    bool mostrarAvalExperiencia = Model.SolicitarAvaliacaoExperiencia && todasExperiencias.Count > 1;
    bool temAvaliacao = mostrarAvalHospedagem || mostrarAvalAcomodacao || mostrarAvalExperiencia;

    var uCorP = Model.Usuario.CorPrimaria;
    var uCorD = Model.Usuario.CorDestaque;
    bool uTemCores  = !string.IsNullOrEmpty(uCorP) && !string.IsNullOrEmpty(uCorD);
    var uCorPLight  = uTemCores ? LightenPub(uCorP!, 22)  : "";
    var uCorDAlt    = uTemCores ? LightenPub(uCorD!, -15) : "";
    // CorSecundaria → accent2 (ícones, labels, botões secundários); fallback = primary clareada
    var uCorS       = !string.IsNullOrEmpty(Model.Usuario.CorSecundaria) ? Model.Usuario.CorSecundaria : (uTemCores ? uCorPLight! : "");
    var uCorAcc2    = uTemCores ? (string.IsNullOrEmpty(uCorS) ? uCorPLight! : uCorS) : "";
    var uCorAcc2Txt = uTemCores && !string.IsNullOrEmpty(uCorAcc2) ? ContrastText(uCorAcc2) : "#ffffff";
    var uCorDTxt    = uTemCores ? ContrastText(uCorD!) : "#ffffff";
    var uCorSTint   = uTemCores && !string.IsNullOrEmpty(uCorS) ? TintColor(uCorS, 0.72) : "";

    bool isPreview     = (bool)(ViewBag.IsPreview ?? false);
    string linkPublico = isPreview ? (string)(ViewBag.LinkPublico ?? "") : "";
    var layoutsPreview = isPreview
        ? (ViewBag.Layouts as IEnumerable<SistemaUsuarios.Models.Layout>
           ?? Enumerable.Empty<SistemaUsuarios.Models.Layout>())
        : Enumerable.Empty<SistemaUsuarios.Models.Layout>();

    var execDestOrd = Model.Destinos.OrderBy(d => d.Ordem).ToList();
    bool execTemHospedagem   = execDestOrd.Any(d => d.Hospedagens.Any());
    bool execTemExperiencias = execDestOrd.Any(d => d.Experiencias.Any());
    bool execTemTransporte   = execDestOrd.Any(d => d.Transportes.Any());

    var execPtBR = new System.Globalization.CultureInfo("pt-BR");

    var gruposVooExec = new[] {
        new { Titulo = "Ida",     Icone = "fas fa-plane",          Cor = "#3B82F6", Voos = Model.Voos.Where(v => v.TipoVoo == TipoVoo.Ida).OrderBy(v => v.Ordem).ToList() },
        new { Titulo = "Internos",Icone = "fas fa-plane-departure", Cor = "#8B5CF6", Voos = Model.Voos.Where(v => v.TipoVoo == TipoVoo.Interno).OrderBy(v => v.Ordem).ToList() },
        new { Titulo = "Volta",   Icone = "fas fa-plane-arrival",   Cor = "#10B981", Voos = Model.Voos.Where(v => v.TipoVoo == TipoVoo.Volta).OrderBy(v => v.Ordem).ToList() },
    };
}

@section Styles {
<style>
/* ═══ TOKENS ═══════════════════════════════════════════════ */
:root {
    --c-accent:   #1E3A5F;
    --c-accent2:  #2A7B9B;
    --c-warm:     #F59E0B;
    --c-bg:       #F8FAFC;
    --c-bg-card:  #FFFFFF;
    --c-bg-alt:   #F1F5F9;
    --c-text:     #0F172A;
    --c-text-mid: #475569;
    --c-line:     #E2E8F0;
    --c-shadow:   0 1px 4px rgba(0,0,0,.1);
    --exec-sb-w:  220px;
    --ff-body:    'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    --ff-mono:    'SF Mono', 'Fira Code', 'Consolas', monospace;
}
@if (uTemCores)
{
    <text>
:root {
    --c-accent:  @uCorP;
    --c-accent2: @uCorAcc2;
    --c-warm:    @uCorD;
    --c-bg-alt:  @(string.IsNullOrEmpty(uCorSTint) ? "#F1F5F9" : uCorSTint);
}
/* Secundária: ícones, labels, sidebar nav, badges, pax buttons */
.exec-pax-init { color: @uCorAcc2Txt; }
/* Destaque: CTAs de contato (botões principais de ação) */
.exec-sb-cta,
.exec-btn-email,
.btn-aval-submit { background: @uCorD; color: @uCorDTxt; }
    </text>
}
* { box-sizing: border-box; margin: 0; padding: 0; }
body { font-family: var(--ff-body); background: var(--c-bg); color: var(--c-text); font-size: .92rem; line-height: 1.6; }

/* ── PREVIEW BAR ── */
.preview-bar {
    position: fixed; top: 0; left: 0; right: 0; z-index: 9999;
    background: #1A2B3C; color: #fff;
    padding: .55rem 1rem; display: flex; align-items: center; gap: .75rem; flex-wrap: wrap;
    font-size: .82rem; box-shadow: 0 2px 12px rgba(0,0,0,.3);
}
.preview-bar-left  { display: flex; align-items: center; gap: .6rem; flex: 1; }
.preview-bar-right { display: flex; align-items: center; gap: .45rem; flex-wrap: wrap; margin-left: auto; }
.preview-badge {
    background: #F59E0B; color: #1A2B3C; font-size: .7rem; font-weight: 700;
    padding: .18rem .55rem; border-radius: 50px; letter-spacing: .05em;
}
.preview-bar select {
    background: rgba(255,255,255,.1); border: 1px solid rgba(255,255,255,.25);
    color: #fff; border-radius: 6px; padding: .28rem .55rem; font-size: .78rem; cursor: pointer;
}
.preview-bar select option { background: #1A2B3C; }
.btn-pb {
    display: inline-flex; align-items: center; gap: .3rem;
    padding: .3rem .75rem; border-radius: 6px; font-size: .77rem; font-weight: 600;
    text-decoration: none; border: none; cursor: pointer; transition: opacity .2s;
}
.btn-pb:hover { opacity: .82; }
.btn-pb-outline { background: transparent; border: 1.5px solid rgba(255,255,255,.35) !important; color: #fff !important; }
.btn-pb-blue    { background: #005197; color: #fff !important; }
.btn-pb-teal    { background: #2ec4b6; color: #fff !important; }
body.has-preview-bar { padding-top: 46px; }
@@media (max-width: 600px) { .btn-pb .pb-label { display: none; } }

/* ── COMPACT HEADER ── */
.exec-header {
    height: 58px; background: var(--c-bg-card); border-bottom: 1px solid var(--c-line);
    display: flex; align-items: center; padding: 0 24px; gap: 16px;
    position: sticky; top: 0; z-index: 800;
}
.exec-header-brand {
    font-weight: 800; font-size: .9rem; color: var(--c-accent);
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 320px;
}
.exec-header-badge {
    font-size: .68rem; font-weight: 700; letter-spacing: .07em; text-transform: uppercase;
    background: var(--c-bg-alt); color: var(--c-text-mid);
    padding: 3px 10px; border-radius: 50px; white-space: nowrap;
}
.exec-header-status {
    font-size: .72rem; font-weight: 700; padding: 3px 10px; border-radius: 50px;
    background: #dcfce7; color: #15803d;
}
.exec-header-status.status-rascunho { background: #fef9c3; color: #854d0e; }
.exec-header-status.status-enviada  { background: #dbeafe; color: #1d4ed8; }
.exec-header-meta {
    margin-left: auto; display: flex; align-items: center; gap: 10px;
    font-size: .78rem; color: var(--c-text-mid);
}
.exec-header-meta i { color: var(--c-accent2); }

/* ── TWO-COLUMN LAYOUT ── */
.exec-layout {
    max-width: 1140px; margin: 0 auto; padding: 0;
    display: grid; grid-template-columns: var(--exec-sb-w) 1fr;
    min-height: calc(100vh - 58px);
}
@@media (max-width: 900px) {
    .exec-layout { grid-template-columns: 1fr; }
    .exec-sidebar { display: none; }
}

/* ── SIDEBAR ── */
.exec-sidebar {
    position: sticky; top: 58px; height: calc(100vh - 58px); overflow-y: auto;
    border-right: 1px solid var(--c-line); background: var(--c-bg-card);
    padding: 20px 0; display: flex; flex-direction: column;
    scrollbar-width: thin; scrollbar-color: var(--c-line) transparent;
}
.exec-sidebar::-webkit-scrollbar { width: 4px; }
.exec-sidebar::-webkit-scrollbar-thumb { background: var(--c-line); }
.exec-sb-label {
    font-size: .65rem; font-weight: 700; letter-spacing: .1em; text-transform: uppercase;
    color: var(--c-text-mid); padding: 12px 18px 4px; opacity: .6;
}
.exec-nav-link {
    display: flex; align-items: center; gap: 8px;
    padding: 7px 18px; font-size: .82rem; font-weight: 500;
    color: var(--c-text-mid); text-decoration: none;
    border-left: 2px solid transparent; transition: all .12s;
}
.exec-nav-link:hover { background: var(--c-bg-alt); color: var(--c-text); }
.exec-nav-link.active {
    color: var(--c-accent2); border-left-color: var(--c-accent2);
    background: var(--c-bg-alt); font-weight: 700;
}
.exec-nav-link i { width: 14px; text-align: center; font-size: .8rem; color: var(--c-accent2); opacity: .7; }
.exec-nav-link.active i { opacity: 1; }
.exec-sb-agent {
    margin-top: auto; padding: 16px 18px;
    border-top: 1px solid var(--c-line); font-size: .78rem; color: var(--c-text-mid);
}
.exec-sb-agent-name { font-weight: 700; color: var(--c-text); font-size: .84rem; margin-bottom: 2px; }
.exec-sb-agent-agency { margin-bottom: 8px; }
.exec-sb-cta {
    display: flex; align-items: center; gap: 6px;
    background: var(--c-accent2); color: #fff; border-radius: 8px;
    padding: 8px 14px; font-size: .79rem; font-weight: 700; text-decoration: none;
    justify-content: center; transition: opacity .2s;
}
.exec-sb-cta:hover { opacity: .85; }

/* ── MAIN CONTENT ── */
.exec-main { padding: 0 32px 64px; }
@@media (max-width: 900px) { .exec-main { padding: 0 16px 48px; } }

/* ── SECTIONS ── */
.exec-section { padding: 32px 0; border-bottom: 1px solid var(--c-line); }
.exec-section:last-child { border-bottom: none; }
.exec-section-header {
    display: flex; align-items: center; justify-content: space-between; gap: 10px;
    margin-bottom: 20px; cursor: default;
}
.exec-section-h2 {
    font-size: 1rem; font-weight: 700; color: var(--c-text);
    display: flex; align-items: center; gap: 8px; text-transform: uppercase;
    letter-spacing: .06em;
}
.exec-section-h2 i { color: var(--c-accent2); font-size: .88rem; }
.exec-section-toggle {
    display: none; background: none; border: none; cursor: pointer;
    color: var(--c-text-mid); font-size: .9rem; padding: 4px;
}
@@media (max-width: 900px) {
    .exec-section-toggle { display: block; }
    .exec-section-header { cursor: pointer; }
    .exec-section-body.collapsed { display: none; }
}

/* ── EXECUTIVE SUMMARY GRID ── */
.exec-brief-grid {
    display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 12px;
}
.exec-brief-item {
    background: var(--c-bg-alt); border-radius: 10px; padding: 14px 16px;
    display: flex; flex-direction: column; gap: 4px;
}
.exec-brief-label {
    font-size: .66rem; font-weight: 700; letter-spacing: .08em; text-transform: uppercase;
    color: var(--c-text-mid);
}
.exec-brief-val {
    font-size: .95rem; font-weight: 700; color: var(--c-text);
    font-variant-numeric: tabular-nums;
}
.exec-brief-sub { font-size: .72rem; color: var(--c-text-mid); }

/* ── DESTINOS E PERÍODOS (tabela compacta) ── */
.exec-dest-table { width: 100%; border-collapse: collapse; font-size: .83rem; }
.exec-dest-table th {
    text-align: left; padding: 6px 10px; font-size: .67rem; font-weight: 700;
    letter-spacing: .07em; text-transform: uppercase; color: var(--c-text-mid);
    border-bottom: 1px solid var(--c-line); background: var(--c-bg-alt);
}
.exec-dest-table td {
    padding: 10px 10px; border-bottom: 1px solid var(--c-line); vertical-align: top;
}
.exec-dest-table tr:last-child td { border-bottom: none; }
.exec-dest-table tr:hover td { background: var(--c-bg-alt); }
.exec-dest-dot {
    width: 8px; height: 8px; border-radius: 2px; display: inline-block; margin-right: 7px;
    vertical-align: middle; flex-shrink: 0;
}
.exec-dest-name { font-weight: 700; color: var(--c-text); }
.exec-dest-loc  { font-size: .74rem; color: var(--c-text-mid); margin-top: 2px; }
.exec-dest-period {
    font-weight: 600; font-variant-numeric: tabular-nums;
    white-space: nowrap; color: var(--c-accent);
}
.exec-dest-noites {
    display: block; font-size: .72rem; color: var(--c-text-mid); margin-top: 2px;
}
.exec-dest-services { font-size: .8rem; color: var(--c-text-mid); }
.exec-dest-services span { display: inline-block; margin-right: 10px; white-space: nowrap; }
.exec-dest-services i { color: var(--c-accent2); margin-right: 3px; font-size: .75rem; }
@@media (max-width: 600px) {
    .exec-dest-table { font-size: .78rem; }
    .exec-dest-table th, .exec-dest-table td { padding: 7px 7px; }
    .exec-dest-period { font-size: .78rem; }
}

/* ── COMPACT LISTS ── */
.exec-compact-list { display: flex; flex-direction: column; gap: 0; }
.exec-compact-row {
    display: grid; grid-template-columns: 1fr; gap: 8px;
    padding: 14px 0; border-bottom: 1px solid var(--c-line);
}
.exec-compact-row:last-child { border-bottom: none; }
.exec-route {
    display: flex; align-items: center; gap: 6px; font-size: .9rem; font-weight: 700;
}
.exec-route-sep { color: var(--c-accent2); }
.exec-flight-meta {
    display: flex; flex-wrap: wrap; gap: 6px 18px; margin-top: 6px;
}
.exec-flight-meta-item { display: flex; flex-direction: column; gap: 0; }
.exec-flight-meta-item small { font-size: .65rem; text-transform: uppercase; letter-spacing: .05em; color: var(--c-text-mid); }
.exec-flight-meta-item span  { font-size: .82rem; font-weight: 600; }

/* ── COMPACT HOTEL ── */
.exec-hotel-row {
    display: grid; grid-template-columns: 80px 1fr; gap: 14px;
    padding: 14px 0; border-bottom: 1px solid var(--c-line); align-items: start;
}
.exec-hotel-row:last-child { border-bottom: none; }
.exec-hotel-thumb {
    width: 80px; height: 60px; object-fit: cover; border-radius: 8px;
    background: var(--c-bg-alt); overflow: hidden;
}
.exec-hotel-thumb img { width: 100%; height: 100%; object-fit: cover; border-radius: 8px; }
.exec-hotel-name  { font-weight: 700; font-size: .9rem; margin-bottom: 4px; }
.exec-hotel-meta  { font-size: .77rem; color: var(--c-text-mid); display: flex; flex-wrap: wrap; gap: 4px 12px; }
.exec-hotel-meta span { display: flex; align-items: center; gap: 4px; }
.exec-hotel-meta i { color: var(--c-accent2); }
.exec-hotel-dest  {
    display: inline-block; font-size: .68rem; font-weight: 700; letter-spacing: .05em;
    text-transform: uppercase; color: var(--c-accent2);
    background: var(--c-bg-alt); border-radius: 50px; padding: 2px 8px; margin-bottom: 4px;
}

/* ── COMPACT EXP ── */
.exec-exp-row {
    display: grid; grid-template-columns: 72px 1fr; gap: 12px;
    padding: 12px 0; border-bottom: 1px solid var(--c-line); align-items: start;
}
.exec-exp-row:last-child { border-bottom: none; }
.exec-exp-thumb { width: 72px; height: 54px; object-fit: cover; border-radius: 7px; background: var(--c-bg-alt); overflow: hidden; }
.exec-exp-thumb img { width: 100%; height: 100%; object-fit: cover; border-radius: 7px; cursor: zoom-in; }
.exec-exp-name { font-weight: 700; font-size: .88rem; margin-bottom: 3px; }
.exec-exp-sub  { font-size: .76rem; color: var(--c-text-mid); }

/* ── AVALIAÇÃO EXECUTIVA ── */
.aval-exec-row {
    display: flex; align-items: center; gap: 12px; flex-wrap: wrap;
    padding: 10px 0; border-bottom: 1px solid var(--c-line);
}
.aval-exec-row:last-child { border-bottom: none; }
.aval-exec-name { font-weight: 600; font-size: .88rem; }
.aval-exec-sub  { font-size: .75rem; color: var(--c-text-mid); }
.aval-exec-row .star-rating { margin: 0; }
.aval-exec-row .aval-fav-btn { margin: 0; }
.star-rating {
    display: flex; flex-direction: row-reverse; gap: 2px;
}
.star-rating input { display: none; }
.star-rating label {
    font-size: 1.1rem; color: #d1d5db; cursor: pointer; transition: color .1s;
}
.star-rating label::before { content: '★'; }
.star-rating input:checked ~ label,
.star-rating label:hover,
.star-rating label:hover ~ label { color: var(--c-warm); }
.aval-fav-btn {
    display: inline-flex; align-items: center; gap: 4px;
    background: transparent; border: 1px solid var(--c-line);
    border-radius: 50px; padding: 3px 10px; font-size: .73rem; font-weight: 600;
    color: var(--c-text-mid); cursor: pointer; transition: all .15s;
}
.aval-fav-btn:hover { border-color: #e11d48; color: #e11d48; }
.aval-fav-btn.active { background: #fee2e2; border-color: #e11d48; color: #e11d48; }
.aval-submit-wrap { margin-top: 24px; display: flex; flex-direction: column; align-items: flex-start; gap: 10px; }
.btn-aval-submit {
    display: inline-flex; align-items: center; gap: 7px;
    background: var(--c-accent2); color: #fff; border: none; border-radius: 8px;
    padding: 10px 24px; font-size: .86rem; font-weight: 700; cursor: pointer; transition: opacity .2s;
}
.btn-aval-submit:hover { opacity: .88; }
.aval-submitted-msg {
    display: none; color: #16a34a; font-weight: 600; font-size: .84rem;
    background: #dcfce7; border-radius: 8px; padding: 8px 16px;
}
.aval-group-title {
    font-size: .72rem; font-weight: 700; letter-spacing: .08em; text-transform: uppercase;
    color: var(--c-accent2); margin-bottom: 10px;
}

/* ── RICHTEXT ── */
.exec-richtext { font-size: .88rem; line-height: 1.7; color: var(--c-text-mid); }
.exec-richtext h1, .exec-richtext h2, .exec-richtext h3 { color: var(--c-text); margin: 12px 0 6px; font-size: 1rem; }
.exec-richtext ul, .exec-richtext ol { padding-left: 1.4em; }
.exec-richtext table { width: 100%; border-collapse: collapse; font-variant-numeric: tabular-nums; }
.exec-richtext td, .exec-richtext th { padding: 7px 10px; border: 1px solid var(--c-line); font-size: .84rem; }
.exec-richtext th { background: var(--c-bg-alt); font-weight: 700; }
.exec-richtext tr:hover td { background: var(--c-bg-alt); }

/* ── SEGURO ── */
.exec-seguro-row {
    display: flex; gap: 12px; align-items: flex-start;
    padding: 12px 0; border-bottom: 1px solid var(--c-line);
}
.exec-seguro-row:last-child { border-bottom: none; }
.exec-seguro-icon {
    width: 36px; height: 36px; border-radius: 50%;
    background: var(--c-bg-alt); border: 1.5px solid var(--c-accent2);
    display: flex; align-items: center; justify-content: center;
    font-size: .8rem; color: var(--c-accent2); flex-shrink: 0;
}
.exec-seguro-name { font-weight: 700; font-size: .88rem; }
.exec-seguro-sub  { font-size: .77rem; color: var(--c-text-mid); }

/* ── PASSAGEIROS ── */
.exec-pax-list { display: flex; flex-direction: column; gap: 0; }
.exec-pax-row {
    display: flex; align-items: center; gap: 10px;
    padding: 10px 0; border-bottom: 1px solid var(--c-line);
    font-size: .86rem;
}
.exec-pax-row:last-child { border-bottom: none; }
.exec-pax-init {
    width: 30px; height: 30px; border-radius: 50%;
    background: var(--c-accent2); color: #fff;
    display: flex; align-items: center; justify-content: center;
    font-size: .75rem; font-weight: 800; flex-shrink: 0;
}
.exec-pax-name { font-weight: 600; }
.exec-pax-sub  { font-size: .75rem; color: var(--c-text-mid); margin-left: auto; }

/* ── TRANSPORTE ── */
.exec-transp-row {
    display: flex; gap: 10px; align-items: flex-start;
    padding: 10px 0; border-bottom: 1px solid var(--c-line);
}
.exec-transp-row:last-child { border-bottom: none; }
.exec-transp-icon {
    width: 30px; height: 30px; border-radius: 50%;
    background: var(--c-bg-alt); border: 1px solid var(--c-line);
    display: flex; align-items: center; justify-content: center;
    font-size: .75rem; color: var(--c-accent2); flex-shrink: 0;
}
.exec-transp-name { font-weight: 700; font-size: .86rem; }
.exec-transp-sub  { font-size: .77rem; color: var(--c-text-mid); }

/* ── CTA ── */
.exec-cta-section { padding: 32px 0; }
.exec-next-step {
    background: var(--c-bg-alt); border-radius: 12px; padding: 24px;
    border-left: 4px solid var(--c-accent2);
}
.exec-next-step h3 {
    font-size: .9rem; font-weight: 700; text-transform: uppercase; letter-spacing: .06em;
    color: var(--c-accent2); margin-bottom: 10px;
}
.exec-next-step p { font-size: .88rem; color: var(--c-text-mid); margin-bottom: 16px; }
.exec-cta-btns { display: flex; flex-wrap: wrap; gap: 8px; }
.exec-btn-wa {
    display: inline-flex; align-items: center; gap: 7px;
    background: #16a34a; color: #fff; border-radius: 8px;
    padding: 10px 20px; font-size: .84rem; font-weight: 700;
    text-decoration: none; transition: opacity .2s;
}
.exec-btn-wa:hover { opacity: .88; }
.exec-btn-email {
    display: inline-flex; align-items: center; gap: 7px;
    background: var(--c-accent2); color: #fff; border-radius: 8px;
    padding: 10px 20px; font-size: .84rem; font-weight: 700;
    text-decoration: none; transition: opacity .2s;
}
.exec-btn-email:hover { opacity: .88; }
.exec-agent-strip {
    margin-top: 20px; padding-top: 16px; border-top: 1px solid var(--c-line);
    display: flex; align-items: center; gap: 14px; flex-wrap: wrap;
}
.exec-agent-avatar {
    width: 44px; height: 44px; border-radius: 50%;
    background: var(--c-bg-alt); border: 1.5px solid var(--c-line);
    display: flex; align-items: center; justify-content: center;
    font-size: 1rem; color: var(--c-text-mid); overflow: hidden; flex-shrink: 0;
}
.exec-agent-info { font-size: .82rem; color: var(--c-text-mid); }
.exec-agent-info strong { color: var(--c-text); font-size: .88rem; display: block; margin-bottom: 2px; }
.exec-agent-contact { display: flex; flex-wrap: wrap; gap: 6px 14px; font-size: .78rem; color: var(--c-text-mid); }
.exec-agent-contact span { display: flex; align-items: center; gap: 4px; }
.exec-agent-contact i { color: var(--c-accent2); }

/* ── FOOTER ── */
footer {
    background: var(--c-bg-card); border-top: 1px solid var(--c-line);
    padding: 16px 24px; font-size: .77rem; color: var(--c-text-mid);
    display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 8px;
}
.exec-share-btn {
    display: inline-flex; align-items: center; gap: 5px;
    background: var(--c-bg-alt); border: 1px solid var(--c-line);
    color: var(--c-text-mid); border-radius: 7px; padding: 5px 12px;
    font-size: .74rem; font-weight: 600; cursor: pointer; text-decoration: none; transition: opacity .2s;
}
.exec-share-btn:hover { opacity: .75; }

/* lightbox → _LayoutPublico.cshtml */

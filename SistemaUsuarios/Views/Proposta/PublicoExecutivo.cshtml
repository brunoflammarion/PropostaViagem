<!-- COMPACT HEADER -->
@{
    var _execStatus = Model.StatusProposta switch {
        StatusProposta.Aprovada  => ("Aprovada",  ""),
        StatusProposta.Enviada   => ("Enviada",   " status-enviada"),
        StatusProposta.Rejeitada => ("Rejeitada", " status-rascunho"),
        _                        => ("Rascunho",  " status-rascunho"),
    };
}
<header class="exec-header">
    <span class="exec-header-brand">@Model.Titulo</span>
    <span class="exec-header-badge">Executivo</span>
    <span class="exec-header-status@(_execStatus.Item2)">@_execStatus.Item1</span>
    <div class="exec-header-meta">
        @if (Model.DataInicio.HasValue && Model.DataFim.HasValue)
        {
            var _dias2 = (Model.DataFim.Value - Model.DataInicio.Value).Days + 1;
            <span><i class="fas fa-calendar-alt"></i>@Model.DataInicio.Value.ToString("dd/MM") – @Model.DataFim.Value.ToString("dd/MM/yy") · @_dias2 @(_dias2 == 1 ? "dia" : "dias")</span>
        }
        @{
            var _paxNom2 = Model.PassageirosProposta?.Count ?? 0;
            var _temCli2 = Model.Cliente != null;
            var _totalPax2 = (_paxNom2 > 0 || _temCli2)
                ? (_temCli2 ? 1 : 0) + _paxNom2
                : Model.NumeroPassageiros + Model.NumeroCriancas;
        }
        <span><i class="fas fa-users"></i>@_totalPax2 pax</span>
    </div>
</header>

<div class="exec-layout">


@model SistemaUsuarios.Models.ViewModels.PropostaFiltroViewModel
@using SistemaUsuarios.Models
@{
    ViewData["Title"] = "Propostas de Viagem";
    ViewData["IsMaster"] = Model.IsMaster;

    // Mapa status → (label, cssClass, colorHex)
    var statusMeta = new Dictionary<StatusProposta,(string Label, string Css, string Color)>
    {
        [StatusProposta.Rascunho]  = ("Rascunho",  "status-rascunho",  "#6c757d"),
        [StatusProposta.Enviada]   = ("Enviada",   "status-enviada",   "#e0a800"),
        [StatusProposta.Aprovada]  = ("Aprovada",  "status-aprovada",  "#28a745"),
        [StatusProposta.Rejeitada] = ("Rejeitada", "status-rejeitada", "#dc3545"),
        [StatusProposta.Cancelada] = ("Cancelada", "status-cancelada", "#495057"),
    };

    // Ordem das colunas kanban
    var kanbanColunas = new[]
    {
        StatusProposta.Rascunho,
        StatusProposta.Enviada,
        StatusProposta.Aprovada,
        StatusProposta.Rejeitada,
        StatusProposta.Cancelada,
    };
}

<!-- ═══════════════════════════════════════════════════════
     HEADER
═══════════════════════════════════════════════════════ -->
<div class="executive-header">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
        <div>
            <h2 class="exec-title"><i class="fas fa-chart-line me-2"></i>Propostas de Viagem</h2>
            <span class="exec-subtitle">@Model.TotalPropostas proposta(s) &bull; @Model.TotalAprovadas aprovada(s)</span>
        </div>

        <div class="d-flex align-items-center gap-2">
            <!-- Seletor de visualização -->
            <div class="view-toggle" id="viewToggle" role="group" aria-label="Visualização">
                <button class="view-btn" id="btn-lista" onclick="setView('lista')" title="Visualização em lista">
                    <i class="fas fa-list"></i><span>Lista</span>
                </button>
                <button class="view-btn" id="btn-kanban" onclick="setView('kanban')" title="Visualização em kanban">
                    <i class="fas fa-columns"></i><span>Kanban</span>
                </button>
            </div>

            <a href="/Proposta/Criar" class="btn btn-primary exec-btn-create">
                <i class="fas fa-plus me-1"></i>Nova Proposta
            </a>
            <button id="btnCriarComIA" class="btn btn-outline-primary exec-btn-create" onclick="abrirCriarComIA()">
                <i class="fas fa-magic me-1"></i>Criar com IA
            </button>
        </div>
    </div>
</div>

<!-- ── Overlay "Criar com IA" ─────────────────────────────────────────── -->
<div id="criarIAOverlay" style="display:none;position:fixed;inset:0;z-index:2000;background:rgba(0,0,0,.55);align-items:center;justify-content:center;">
    <div style="background:#fff;border-radius:14px;padding:28px 32px;max-width:480px;width:90%;box-shadow:0 16px 56px rgba(0,0,0,.25);">
        <div id="criarIA-step-pick">
            <h5 style="margin:0 0 6px;font-weight:700;">Criar proposta com IA</h5>
            <p style="font-size:.87rem;color:#6c757d;margin:0 0 20px;">Envie um voucher, PDF, imagem ou e-mail de reserva. A IA extrai os dados e monta a proposta para você.</p>
            <div id="criarIA-dropzone" onclick="document.getElementById('criarIAFileInput').click()"
                 style="border:2px dashed #b6d4fe;border-radius:10px;padding:32px;text-align:center;cursor:pointer;background:#f0f7ff;transition:background .15s;"
                 ondragover="event.preventDefault();this.style.background='#dbeafe'"
                 ondragleave="this.style.background='#f0f7ff'"
                 ondrop="criarIADrop(event)">
                <i class="fas fa-cloud-upload-alt" style="font-size:2rem;color:#6ea8fe;margin-bottom:8px;"></i>
                <div style="font-weight:600;color:#084298;">Arraste arquivos aqui</div>
                <div style="font-size:.78rem;color:#6c757d;margin-top:4px;">ou clique para selecionar · PDF, imagens, DOCX, TXT</div>
            </div>
            <input type="file" id="criarIAFileInput" hidden multiple accept=".pdf,.jpg,.jpeg,.png,.gif,.webp,.docx,.txt,.eml,.html"
                   onchange="criarIAFilesSelected(this.files)">
            <div id="criarIAFileList" style="margin-top:12px;display:flex;flex-wrap:wrap;gap:6px;"></div>
            <div style="display:flex;gap:8px;margin-top:20px;justify-content:flex-end;">
                <button class="btn btn-outline-secondary" onclick="fecharCriarComIA()">Cancelar</button>
                <button id="btnIAAnalisar" class="btn btn-primary" onclick="iniciarCriarComIA()" disabled>
                    <i class="fas fa-magic me-1"></i>Criar proposta
                </button>
            </div>
        </div>
        <div id="criarIA-step-loading" style="display:none;text-align:center;padding:16px 0;">
            <div class="spinner-border text-primary" style="width:2.5rem;height:2.5rem;"></div>
            <p id="criarIA-loading-msg" style="margin:14px 0 0;font-weight:500;color:#084298;">Criando proposta…</p>
            <p style="font-size:.8rem;color:#6c757d;margin:4px 0 0;">Aguarde, isso pode levar alguns segundos</p>
        </div>
    </div>
</div>

<script>
(function () {
    var selectedFiles = [];

    window.abrirCriarComIA = function () {
        selectedFiles = [];
        document.getElementById('criarIAFileList').innerHTML = '';
        document.getElementById('btnIAAnalisar').disabled = true;
        document.getElementById('criarIA-step-pick').style.display = '';
        document.getElementById('criarIA-step-loading').style.display = 'none';
        var ov = document.getElementById('criarIAOverlay');
        ov.style.display = 'flex';
    };

    window.fecharCriarComIA = function () {
        document.getElementById('criarIAOverlay').style.display = 'none';
    };

    window.criarIADrop = function (e) {
        e.preventDefault();
        document.getElementById('criarIA-dropzone').style.background = '#f0f7ff';
        criarIAFilesSelected(e.dataTransfer.files);
    };

    window.criarIAFilesSelected = function (files) {
        Array.from(files).forEach(function (f) {
            if (!selectedFiles.find(function (x) { return x.name === f.name && x.size === f.size; }))
                selectedFiles.push(f);
        });
        renderIAFileList();
    };

    window.removeIAFile = function (idx) {
        selectedFiles.splice(idx, 1);
        renderIAFileList();
    };

    function renderIAFileList() {
        var list = document.getElementById('criarIAFileList');
        list.innerHTML = selectedFiles.map(function (f, i) {
            var ext = f.name.split('.').pop().toLowerCase();
            var icon = {pdf:'📄',jpg:'🖼',jpeg:'🖼',png:'🖼',gif:'🖼',webp:'🖼',docx:'📝',doc:'📝',txt:'📃',eml:'📧',html:'🌐'}[ext] || '📎';
            return '<span style="display:inline-flex;align-items:center;gap:4px;padding:3px 8px;background:rgba(0,81,151,.08);border-radius:20px;font-size:.72rem;color:#005197;font-weight:500;">'
                + icon + ' ' + escHTML(f.name)
                + '<button onclick="removeIAFile(' + i + ')" style="background:none;border:none;padding:0;cursor:pointer;color:inherit;font-size:.65rem;line-height:1;margin-left:2px;">✕</button>'
                + '</span>';
        }).join('');
        document.getElementById('btnIAAnalisar').disabled = selectedFiles.length === 0;
    }

    function escHTML(t) {
        var d = document.createElement('div');
        d.textContent = t;
        return d.innerHTML;
    }

    window.iniciarCriarComIA = async function () {
        if (!selectedFiles.length) return;

        document.getElementById('criarIA-step-pick').style.display = 'none';
        document.getElementById('criarIA-step-loading').style.display = '';
        document.getElementById('criarIA-loading-msg').textContent = 'Criando proposta rascunho…';

        try {
            // 1. Criar rascunho
            var res1 = await fetch('/Importacao/CriarRascunho', { method: 'POST' });
            if (!res1.ok) throw new Error('Erro ao criar proposta');
            var d1 = await res1.json();
            var propostaId = d1.propostaId;

            // 2. Analisar documentos
            document.getElementById('criarIA-loading-msg').textContent = 'Analisando documentos com IA…';
            var fd = new FormData();
            fd.append('propostaId', propostaId);
            selectedFiles.forEach(function (f) { fd.append('arquivos', f); });

            var res2 = await fetch('/AiCopilot/AnalisarArquivos', { method: 'POST', body: fd });
            if (!res2.ok) throw new Error('Erro na análise');
            var analise = await res2.json();

            // 3. Salvar preview no sessionStorage
            if (analise.preview) {
                sessionStorage.setItem('pendingImport_' + propostaId, JSON.stringify(analise));
            }

            // 4. Redirecionar para Editar com pendingImport=1
            window.location.href = '/Proposta/Editar/' + propostaId + '?pendingImport=1';

        } catch (err) {
            document.getElementById('criarIA-step-loading').style.display = 'none';
            document.getElementById('criarIA-step-pick').style.display = '';
            alert('Ocorreu um erro: ' + err.message + '. Tente novamente.');
        }
    };

    // Close overlay on backdrop click
    document.getElementById('criarIAOverlay').addEventListener('click', function (e) {
        if (e.target === this) fecharCriarComIA();
    });
})();
</script>

<!-- ═══════════════════════════════════════════════════════
     DASHBOARD (estatísticas)
═══════════════════════════════════════════════════════ -->
<div class="exec-dashboard">
    <div class="exec-stats-row">
        <div class="exec-stat-item primary">
            <div class="exec-stat-content">
                <span class="exec-stat-number">@Model.TotalPropostas</span>
                <span class="exec-stat-label">Total</span>
            </div>
            <i class="fas fa-file-alt exec-stat-icon"></i>
        </div>
        <div class="exec-stat-item secondary">
            <div class="exec-stat-content">
                <span class="exec-stat-number">@Model.TotalRascunhos</span>
                <span class="exec-stat-label">Rascunhos</span>
            </div>
            <i class="fas fa-edit exec-stat-icon"></i>
        </div>
        <div class="exec-stat-item warning">
            <div class="exec-stat-content">
                <span class="exec-stat-number">@Model.TotalEnviadas</span>
                <span class="exec-stat-label">Enviadas</span>
            </div>
            <i class="fas fa-paper-plane exec-stat-icon"></i>
        </div>
        <div class="exec-stat-item success">
            <div class="exec-stat-content">
                <span class="exec-stat-number">@Model.TotalAprovadas</span>
                <span class="exec-stat-label">Aprovadas</span>
            </div>
            <i class="fas fa-check-circle exec-stat-icon"></i>
        </div>
    </div>
</div>

<!-- ═══════════════════════════════════════════════════════
     FILTROS  (compartilhados pelas duas visões)
═══════════════════════════════════════════════════════ -->
<div class="exec-filters">
    <form method="get" asp-action="Index">
        <div class="filters-row">
            <div class="filter-compact">
                <input asp-for="TermoBusca" class="form-control exec-search"
                       placeholder="🔍 Buscar propostas..." />
            </div>
            <div class="filter-compact">
                <select asp-for="FiltroStatus" class="form-select exec-select">
                    <option value="">Todos os Status</option>
                    <option value="1">Rascunho</option>
                    <option value="2">Enviada</option>
                    <option value="3">Aprovada</option>
                    <option value="4">Rejeitada</option>
                    <option value="5">Cancelada</option>
                </select>
            </div>
            <div class="filter-compact">
                <input asp-for="DataInicioFiltro" class="form-control exec-date"
                       type="date" title="Data início" />
            </div>
            <div class="filter-compact">
                <input asp-for="DataFimFiltro" class="form-control exec-date"
                       type="date" title="Data fim" />
            </div>
            <div class="filter-actions">
                <button type="submit" class="btn btn-outline-primary exec-btn-filter" title="Filtrar">
                    <i class="fas fa-filter"></i>
                </button>
                <a href="/Proposta" class="btn btn-outline-secondary exec-btn-clear" title="Limpar filtros">
                    <i class="fas fa-times"></i>
                </a>
            </div>
        </div>
        @if (Model.TemFiltrosAplicados)
        {
            <div class="filter-active-hint mt-2">
                <i class="fas fa-filter me-1"></i>@Model.DescricaoFiltros
            </div>
        }
    </form>
</div>

@* ── VISÃO LISTA ─────────────────────────────────────────── *@
<div id="view-lista" style="@(Model.VisualizacaoAtual == "kanban" ? "display:none;" : "")">
    @if (Model.Propostas.Any())
    {
        <div class="exec-propostas-grid">
            @foreach (var proposta in Model.Propostas)
            {
                @await Html.PartialAsync("_PropostaCard", proposta)
            }
        </div>
    }
    else
    {
        <div class="exec-empty-state">
            <i class="fas fa-suitcase-rolling exec-empty-icon"></i>
            <h4>Nenhuma proposta encontrada</h4>
            <p class="exec-empty-text">
                @if (Model.TemFiltrosAplicados) { <text>Ajuste os filtros ou </text> }
                <a href="/Proposta/Criar" class="exec-empty-link">crie sua primeira proposta</a>
            </p>
        </div>
    }
</div>

@* ── VISÃO KANBAN ─────────────────────────────────────────── *@
<div id="view-kanban" style="@(Model.VisualizacaoAtual != "kanban" ? "display:none;" : "")">
    <div class="kanban-board">
        @foreach (var status in kanbanColunas)
        {
            var meta = statusMeta[status];
            var colPropostas = Model.Propostas.Where(p => p.StatusProposta == status).ToList();
            <div class="kanban-col" data-status="@((int)status)">
                <div class="kanban-col-header" style="--col-color:@meta.Color;">
                    <div class="d-flex align-items-center gap-2">
                        <span class="kanban-col-dot" style="background:@meta.Color;"></span>
                        <span class="kanban-col-title">@meta.Label</span>
                    </div>
                    <span class="kanban-col-count">@colPropostas.Count</span>
                </div>
                <div class="kanban-col-body" data-status="@((int)status)">
                    @if (colPropostas.Any())
                    {
                        @foreach (var proposta in colPropostas)
                        {
                            @await Html.PartialAsync("_PropostaCard", proposta)
                        }
                    }
                    else
                    {
                        <div class="kanban-empty-col">
                            <i class="fas fa-inbox"></i>
                            <span>Sem propostas</span>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</div>

@section Styles {
<style>
/* ════════════════════════════════════════
   TOKENS
════════════════════════════════════════ */
:root {
    /* Raios menores nesta tela — alinhados com o componente */
    --exec-radius:    8px;
    --exec-radius-lg: 12px;
}

/* ════════════════════════════════════════
   HEADER
════════════════════════════════════════ */
.executive-header {
    padding: 1.5rem 0;
    border-bottom: 1px solid var(--exec-border);
    margin-bottom: 1.5rem;
}
.exec-title {
    font-size: 1.75rem; font-weight: 700;
    color: var(--exec-primary); margin: 0;
}
.exec-subtitle { color: #6c757d; font-size: .875rem; font-weight: 500; }
.exec-btn-create {
    padding: .5rem 1.25rem; font-size: .875rem;
    font-weight: 600; border-radius: var(--exec-radius);
}

/* ════════════════════════════════════════
   SELETOR DE VISUALIZAÇÃO
════════════════════════════════════════ */
.view-toggle {
    display: flex; border: 1px solid var(--exec-border);
    border-radius: var(--exec-radius); overflow: hidden;
    background: white;
}
.view-btn {
    display: flex; align-items: center; gap: 6px;
    padding: 6px 14px; font-size: .8rem; font-weight: 600;
    border: none; background: transparent; color: #6c757d;
    cursor: pointer; transition: all .2s ease; white-space: nowrap;
}
.view-btn:hover { background: var(--exec-light); color: var(--exec-primary); }
.view-btn.active {
    background: var(--exec-primary); color: white;
}

/* ════════════════════════════════════════
   DASHBOARD
════════════════════════════════════════ */
.exec-dashboard { margin-bottom: 1.5rem; }
.exec-stats-row {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1rem;
}
.exec-stat-item {
    background: white; border: 1px solid var(--exec-border);
    border-radius: var(--exec-radius); padding: 1rem;
    display: flex; align-items: center; justify-content: space-between;
    transition: all .2s ease; position: relative; overflow: hidden;
}
.exec-stat-item::before {
    content: ''; position: absolute; top: 0; left: 0;
    width: 3px; height: 100%; background: var(--exec-primary);
}
.exec-stat-item.primary::before  { background: var(--exec-primary); }
.exec-stat-item.secondary::before{ background: var(--exec-dark); }
.exec-stat-item.warning::before  { background: var(--exec-warning); }
.exec-stat-item.success::before  { background: var(--exec-success); }
.exec-stat-item:hover { box-shadow: var(--exec-shadow-hover); transform: translateY(-1px); }
.exec-stat-content { display: flex; flex-direction: column; }
.exec-stat-number { font-size: 1.75rem; font-weight: 700; color: var(--exec-primary); line-height: 1; }
.exec-stat-label { font-size: .75rem; color: #6c757d; text-transform: uppercase; font-weight: 600; letter-spacing: .5px; }
.exec-stat-icon { font-size: 1.5rem; color: #dee2e6; }

/* ════════════════════════════════════════
   FILTROS
════════════════════════════════════════ */
.exec-filters { margin-bottom: 1.5rem; }
.filters-row {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr auto;
    gap: .75rem; align-items: end;
}
.filter-compact { position: relative; }
.exec-search, .exec-select, .exec-date {
    height: 38px; border: 1px solid var(--exec-border);
    border-radius: var(--exec-radius); font-size: .875rem;
    transition: border-color .2s ease;
}
.exec-search:focus, .exec-select:focus, .exec-date:focus {
    border-color: var(--exec-primary);
    box-shadow: 0 0 0 2px rgba(10,17,40,.1);
}
.filter-actions { display: flex; gap: .5rem; }
.exec-btn-filter, .exec-btn-clear {
    width: 38px; height: 38px; padding: 0;
    display: flex; align-items: center; justify-content: center;
    border-radius: var(--exec-radius);
}
.filter-active-hint {
    font-size: .75rem; color: var(--exec-primary);
    background: #eef3ff; border: 1px solid #c7d7f9;
    border-radius: var(--exec-radius); padding: 4px 10px;
    display: inline-block;
}

/* ════════════════════════════════════════
   CARD  (compartilhado lista + kanban)
════════════════════════════════════════ */
.exec-proposta-card {
    background: white; border: 1px solid var(--exec-border);
    border-radius: var(--exec-radius-lg); overflow: hidden;
    transition: all .2s ease; position: relative;
}
.exec-proposta-card:hover {
    box-shadow: var(--exec-shadow-hover); transform: translateY(-2px);
    border-color: var(--exec-primary);
}
/* Status badge */
.exec-status {
    position: absolute; top: .75rem; right: .75rem;
    padding: .25rem .75rem; border-radius: 12px;
    font-size: .6875rem; font-weight: 600;
    text-transform: uppercase; letter-spacing: .5px; z-index: 2;
}
.status-rascunho  { background: #f8f9fa; color: #6c757d; }
.status-enviada   { background: #fff3cd; color: #856404; }
.status-aprovada  { background: #d4edda; color: #155724; }
.status-rejeitada { background: #f8d7da; color: #721c24; }
.status-cancelada { background: #e2e3e5; color: #383d41; }
/* Imagem */
.exec-image-container { height: 120px; overflow: hidden; }
.exec-image { width: 100%; height: 100%; object-fit: cover; transition: transform .3s ease; }
.exec-proposta-card:hover .exec-image { transform: scale(1.05); }
.exec-image-placeholder {
    width: 100%; height: 100%;
    background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
    display: flex; align-items: center; justify-content: center;
    color: #adb5bd; font-size: 1.5rem;
}
/* Conteúdo */
.exec-content { padding: 1rem; }
.exec-title-card {
    font-size: 1rem; font-weight: 600; color: var(--exec-primary);
    margin: 0 0 .75rem 0; line-height: 1.3;
    height: 2.6rem; overflow: hidden;
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;
}
.exec-meta { display: flex; flex-wrap: wrap; gap: .75rem; margin-bottom: 1rem; }
.exec-meta-item {
    display: flex; align-items: center; gap: .375rem;
    color: #6c757d; font-size: .75rem; font-weight: 500;
}
.exec-meta-item i { color: var(--exec-primary); width: 12px; text-align: center; }
.exec-footer { display: flex; align-items: center; justify-content: space-between; }
.exec-badge {
    padding: .25rem .5rem; border-radius: 6px;
    font-size: .6875rem; font-weight: 500;
}
.exec-badge.active  { background: #d4edda; color: #155724; }
.exec-badge.inactive{ background: #f8d7da; color: #721c24; }
.exec-actions { display: flex; gap: .375rem; align-items: center; }
.exec-action-btn {
    width: 32px; height: 32px; border-radius: 8px;
    display: inline-flex; align-items: center; justify-content: center;
    border: 1px solid transparent; text-decoration: none;
    font-size: .78rem; transition: all .18s ease; cursor: pointer;
}

/* Visualizar — Azul Oceano */
.exec-action-btn.primary {
    background: #002B45 !important;
    color: #FFFFFF !important;
    border-color: #002B45 !important;
}
.exec-action-btn.primary i,
.exec-action-btn.primary .fas,
.exec-action-btn.primary .far,
.exec-action-btn.primary .fab {
    color: #FFFFFF !important;
}
.exec-action-btn.primary:hover {
    background: #1E4E8C !important;
    border-color: #1E4E8C !important;
    color: #FFFFFF !important;
    transform: translateY(-1px);
    box-shadow: 0 3px 10px rgba(0,43,69,.28);
    text-decoration: none;
}

/* Editar — outline discreto */
.exec-action-btn.secondary {
    background: #FFFFFF !important;
    color: #1E4E8C !important;
    border: 1px solid rgba(30, 78, 140, 0.28) !important;
}
.exec-action-btn.secondary i,
.exec-action-btn.secondary .fas,
.exec-action-btn.secondary .far,
.exec-action-btn.secondary .fab {
    color: #1E4E8C !important;
}
.exec-action-btn.secondary:hover {
    background: #E6F1FF !important;
    color: #002B45 !important;
    border-color: #5BA8FF !important;
    transform: translateY(-1px);
    box-shadow: 0 3px 8px rgba(0,43,69,.10);
    text-decoration: none;
}
.exec-action-btn.secondary:hover i,
.exec-action-btn.secondary:hover .fas,
.exec-action-btn.secondary:hover .far {
    color: #002B45 !important;
}

/* Analytics — Azul Principal */
.exec-action-btn.success {
    background: #1E4E8C !important;
    color: #FFFFFF !important;
    border-color: #1E4E8C !important;
}
.exec-action-btn.success i,
.exec-action-btn.success .fas,
.exec-action-btn.success .far,
.exec-action-btn.success .fab {
    color: #FFFFFF !important;
}
.exec-action-btn.success:hover {
    background: #002B45 !important;
    border-color: #002B45 !important;
    color: #FFFFFF !important;
    transform: translateY(-1px);
    box-shadow: 0 3px 10px rgba(0,43,69,.28);
    text-decoration: none;
}

/* Mais opções — outline neutro */
.exec-action-btn.outline {
    background: #FFFFFF !important;
    color: #68728B !important;
    border: 1px solid rgba(30, 78, 140, 0.22) !important;
}
.exec-action-btn.outline i,
.exec-action-btn.outline .fas,
.exec-action-btn.outline .far,
.exec-action-btn.outline .fab {
    color: #68728B !important;
}
.exec-action-btn.outline:hover {
    background: #E6F1FF !important;
    color: #002B45 !important;
    border-color: #5BA8FF !important;
    transform: translateY(-1px);
    box-shadow: 0 3px 8px rgba(0,43,69,.10);
    text-decoration: none;
}
.exec-action-btn.outline:hover i,
.exec-action-btn.outline:hover .fas,
.exec-action-btn.outline:hover .far {
    color: #002B45 !important;
}
.exec-dropdown {
    border: none; border-radius: var(--exec-radius);
    box-shadow: 0 4px 12px rgba(0,0,0,.15);
    padding: .5rem 0; min-width: 160px;
}
.exec-dropdown .dropdown-item { padding: .5rem 1rem; font-size: .875rem; transition: background-color .2s ease; }
.exec-dropdown .dropdown-item:hover { background: #f8f9fa; }
.exec-dropdown .dropdown-item.text-danger:hover { background: #f8d7da; color: #721c24; }

/* ════════════════════════════════════════
   VISÃO LISTA — grid
════════════════════════════════════════ */
.exec-propostas-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1rem;
}
/* Empty state */
.exec-empty-state {
    text-align: center; padding: 3rem 2rem;
    background: white; border: 1px solid var(--exec-border);
    border-radius: var(--exec-radius-lg);
}
.exec-empty-icon { font-size: 3rem; color: #adb5bd; margin-bottom: 1rem; }
.exec-empty-state h4 { color: var(--exec-primary); margin-bottom: .5rem; }
.exec-empty-text { color: #6c757d; margin: 0; }
.exec-empty-link { color: var(--exec-primary); text-decoration: none; font-weight: 600; }
.exec-empty-link:hover { text-decoration: underline; }

/* ════════════════════════════════════════
   VISÃO KANBAN
════════════════════════════════════════ */
.kanban-board {
    display: flex; gap: 14px;
    overflow-x: auto; align-items: flex-start;
    padding-bottom: 20px;
    /* Scroll suave em desktop e mobile */
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
}

.kanban-col {
    flex: 0 0 300px; width: 300px;
    background: #f5f6f8; border-radius: var(--exec-radius-lg);
    display: flex; flex-direction: column;
    scroll-snap-align: start;
    max-height: calc(100vh - 320px);
    min-height: 200px;
}

.kanban-col-header {
    padding: 12px 14px;
    background: white;
    border-radius: var(--exec-radius-lg) var(--exec-radius-lg) 0 0;
    border-bottom: 2px solid var(--col-color, #ccc);
    display: flex; align-items: center; justify-content: space-between;
    flex-shrink: 0;
}
.kanban-col-dot {
    width: 9px; height: 9px; border-radius: 50%; flex-shrink: 0;
}
.kanban-col-title { font-size: .875rem; font-weight: 700; color: var(--exec-primary); }
.kanban-col-count {
    font-size: .75rem; font-weight: 700;
    background: #e9ecef; color: #495057;
    border-radius: 10px; padding: 1px 8px; min-width: 22px; text-align: center;
}

.kanban-col-body {
    flex: 1; overflow-y: auto; padding: 10px 8px;
    display: flex; flex-direction: column; gap: 8px;
    /* SortableJS drop target needs min-height */
    min-height: 60px;
}

/* Card dentro do kanban: sem animação, cursor grab */
.kanban-col-body .exec-proposta-card {
    animation: none !important;
    cursor: grab;
    margin: 0;
    /* overflow: visible é obrigatório para o dropdown do Bootstrap escapar
       do container com overflow-y:auto; a imagem ainda fica recortada pelo
       seu próprio container (.exec-image-container já tem overflow:hidden) */
    overflow: visible !important;
}
.kanban-col-body .exec-proposta-card:active { cursor: grabbing; }

/* Imagem ainda precisa de clip — reaplica border-radius no container */
.kanban-col-body .exec-image-container {
    overflow: hidden;
    border-radius: var(--exec-radius-lg) var(--exec-radius-lg) 0 0;
}

/* Botões mais compactos para colunas de 300 px */
.kanban-col-body .exec-actions { gap: 5px; }
.kanban-col-body .exec-action-btn {
    width: 30px !important;
    height: 30px !important;
    font-size: .73rem;
    border-radius: 7px !important;
}

/* Ghost durante drag */
.kanban-ghost {
    opacity: .4;
    background: #e0e7ff !important;
    border: 2px dashed var(--exec-primary) !important;
}
/* Chosen (being dragged) */
.kanban-dragging {
    opacity: .9;
    box-shadow: 0 8px 24px rgba(0,0,0,.2) !important;
    transform: rotate(1.5deg) !important;
}

/* Drop zone highlight quando hover */
.kanban-col-body.sortable-over {
    background: #eef2ff;
    border-radius: 0 0 var(--exec-radius-lg) var(--exec-radius-lg);
}

.kanban-empty-col {
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    gap: 6px; padding: 24px 0; color: #adb5bd; font-size: .8rem;
    pointer-events: none;
}
.kanban-empty-col i { font-size: 1.25rem; }

/* Toast de status atualizado */
.kanban-status-toast {
    position: fixed; bottom: 28px; left: 50%; transform: translateX(-50%);
    background: var(--at-ocean, #0D2B45); color: white; padding: 10px 20px;
    border-radius: 50px; font-size: .85rem; font-weight: 600;
    box-shadow: 0 4px 16px rgba(0,0,0,.3);
    z-index: 9999; white-space: nowrap;
    animation: toastIn .25s ease-out;
}
@@keyframes toastIn {
    from { opacity: 0; transform: translateX(-50%) translateY(10px); }
    to   { opacity: 1; transform: translateX(-50%) translateY(0); }
}

/* ════════════════════════════════════════
   RESPONSIVO
════════════════════════════════════════ */
@@media (max-width: 768px) {
    .executive-header { padding: 1rem 0; }
    .executive-header > .d-flex { flex-direction: column; align-items: stretch !important; }
    .exec-stats-row { grid-template-columns: repeat(2, 1fr); gap: .75rem; }
    .exec-stat-number { font-size: 1.5rem; }
    .filters-row { grid-template-columns: 1fr; gap: .75rem; }
    .filter-actions { justify-content: center; }
    .exec-propostas-grid { grid-template-columns: 1fr; gap: .75rem; }
    .kanban-col { flex: 0 0 260px; width: 260px; max-height: unset; }
    .view-btn span { display: none; }
    .view-btn { padding: 6px 10px; }
}
@@media (max-width: 576px) {
    .exec-stats-row { grid-template-columns: 1fr; }
    .exec-title { font-size: 1.5rem; }
}

/* ════════════════════════════════════════
   ANIMAÇÕES (lista)
════════════════════════════════════════ */
.exec-propostas-grid .exec-proposta-card { animation: fadeInUp .4s ease-out both; }
.exec-propostas-grid .exec-proposta-card:nth-child(1) { animation-delay: .05s; }
.exec-propostas-grid .exec-proposta-card:nth-child(2) { animation-delay: .10s; }
.exec-propostas-grid .exec-proposta-card:nth-child(3) { animation-delay: .15s; }
.exec-propostas-grid .exec-proposta-card:nth-child(4) { animation-delay: .20s; }
.exec-propostas-grid .exec-proposta-card:nth-child(5) { animation-delay: .25s; }
.exec-propostas-grid .exec-proposta-card:nth-child(6) { animation-delay: .30s; }
@@keyframes fadeInUp {
    from { opacity: 0; transform: translateY(15px); }
    to   { opacity: 1; transform: translateY(0); }
}
</style>
}

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.2/Sortable.min.js"></script>
<script>
/* ────────────────────────────────────────────────
   MAPA: int → { label, cssClass }
──────────────────────────────────────────────── */
const STATUS_MAP = {
    1: { label: 'Rascunho',  css: 'status-rascunho'  },
    2: { label: 'Enviada',   css: 'status-enviada'   },
    3: { label: 'Aprovada',  css: 'status-aprovada'  },
    4: { label: 'Rejeitada', css: 'status-rejeitada' },
    5: { label: 'Cancelada', css: 'status-cancelada' },
};

/* ────────────────────────────────────────────────
   TOGGLE DE VISUALIZAÇÃO
──────────────────────────────────────────────── */
function setView(view) {
    const lista  = document.getElementById('view-lista');
    const kanban = document.getElementById('view-kanban');
    const btnL   = document.getElementById('btn-lista');
    const btnK   = document.getElementById('btn-kanban');

    if (view === 'kanban') {
        lista.style.display  = 'none';
        kanban.style.display = '';
        btnL.classList.remove('active');
        btnK.classList.add('active');
    } else {
        kanban.style.display = 'none';
        lista.style.display  = '';
        btnL.classList.add('active');
        btnK.classList.remove('active');
    }

    // Persiste sem bloquear o UI
    fetch('/Proposta/SalvarVisualizacao', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ visualizacao: view })
    }).catch(() => {}); // falha silenciosa — preferência será salva na próxima troca bem-sucedida
}

/* ────────────────────────────────────────────────
   KANBAN — DRAG & DROP (SortableJS)
──────────────────────────────────────────────── */
document.addEventListener('DOMContentLoaded', function () {

    // Activar botão correto ao carregar (servidor já definiu display, só marca o botão)
    const currentView = '@Model.VisualizacaoAtual';
    document.getElementById(currentView === 'kanban' ? 'btn-kanban' : 'btn-lista').classList.add('active');

    // Inicializar SortableJS em cada coluna
    document.querySelectorAll('.kanban-col-body').forEach(function (col) {
        Sortable.create(col, {
            group: 'proposals',
            animation: 180,
            ghostClass: 'kanban-ghost',
            dragClass: 'kanban-dragging',
            // Impede que cliques em botões/links/dropdowns iniciem um drag
            filter: '.exec-actions, .exec-action-btn, .dropdown, .dropdown-toggle, .dropdown-menu, .dropdown-item, button, a',
            preventOnFilter: true,
            // Highlight na drop-zone ao entrar
            onDragEnter: function (evt) { evt.to.classList.add('sortable-over'); },
            onDragLeave: function (evt) { evt.to.classList.remove('sortable-over'); },
            onEnd: function (evt) {
                evt.to.classList.remove('sortable-over');

                const card      = evt.item;
                const propostaId = card.dataset.id;
                const novoStatus = parseInt(evt.to.dataset.status, 10);
                const statusAnterior = parseInt(evt.from.dataset.status, 10);

                // Nada mudou (mesma coluna)
                if (novoStatus === statusAnterior && evt.oldIndex === evt.newIndex) return;

                // Atualiza badge visualmente de imediato (otimista)
                updateStatusBadge(card, novoStatus);

                // Remove empty-col hint se existia
                const emptyHint = evt.to.querySelector('.kanban-empty-col');
                if (emptyHint) emptyHint.remove();

                // Atualiza contagens das colunas
                updateColCount(evt.from);
                updateColCount(evt.to);

                // Persiste no servidor
                fetch('/api/proposta/' + propostaId + '/status', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ status: novoStatus })
                })
                .then(r => r.json())
                .then(data => {
                    if (data.success) {
                        showKanbanToast('Status: ' + STATUS_MAP[novoStatus].label, '✓');
                    } else {
                        revertDrag(card, evt.from, evt.oldIndex);
                    }
                })
                .catch(function () {
                    showKanbanToast('Erro de conexão — revertendo', '⚠');
                    revertDrag(card, evt.from, evt.oldIndex);
                });
            }
        });
    });

    // Re-inicializa dropdowns do kanban com strategy:'fixed' para escapar
    // de qualquer container com overflow:hidden ou overflow-y:auto.
    // Sem isso, o menu fica invisível recortado pela coluna.
    document.querySelectorAll('.kanban-col-body .dropdown-toggle').forEach(function (toggle) {
        const existing = bootstrap.Dropdown.getInstance(toggle);
        if (existing) existing.dispose();
        new bootstrap.Dropdown(toggle, {
            popperConfig: function (defaultConfig) {
                return Object.assign({}, defaultConfig, { strategy: 'fixed' });
            }
        });
    });
});

/* ────────────────────────────────────────────────
   HELPERS
──────────────────────────────────────────────── */
function updateStatusBadge(cardEl, statusInt) {
    const badge = cardEl.querySelector('.exec-status');
    if (!badge) return;
    const info = STATUS_MAP[statusInt];
    if (!info) return;
    badge.className = 'exec-status ' + info.css;
    badge.textContent = info.label;
    cardEl.dataset.status = statusInt;
}

function updateColCount(colBody) {
    const col = colBody.closest('.kanban-col');
    if (!col) return;
    const countEl = col.querySelector('.kanban-col-count');
    if (!countEl) return;
    const cards = colBody.querySelectorAll('.exec-proposta-card').length;
    countEl.textContent = cards;
}

function revertDrag(card, originalCol, originalIndex) {
    // Re-insere o card na posição original
    const children = originalCol.children;
    if (originalIndex >= children.length) {
        originalCol.appendChild(card);
    } else {
        originalCol.insertBefore(card, children[originalIndex]);
    }
    updateStatusBadge(card, parseInt(originalCol.dataset.status, 10));
    updateColCount(originalCol);
}

function showKanbanToast(msg, icon) {
    // Remove toast anterior se ainda existir
    document.querySelectorAll('.kanban-status-toast').forEach(t => t.remove());
    const toast = document.createElement('div');
    toast.className = 'kanban-status-toast';
    toast.textContent = (icon ? icon + ' ' : '') + msg;
    document.body.appendChild(toast);
    setTimeout(() => {
        toast.style.transition = 'opacity .3s';
        toast.style.opacity = '0';
        setTimeout(() => toast.remove(), 320);
    }, 2200);
}

/* ────────────────────────────────────────────────
   FUNÇÕES ORIGINAIS (copiar link, duplicar, notif)
──────────────────────────────────────────────── */
function copiarLink(link) {
    const linkCompleto = window.location.origin + link;
    navigator.clipboard.writeText(linkCompleto)
        .then(() => showNotification('Link copiado!', 'success'))
        .catch(() => showNotification('Erro ao copiar link.', 'error'));
}

function duplicarProposta(propostaId) {
    if (confirm('Deseja duplicar esta proposta?')) {
        fetch('/api/proposta/' + propostaId + '/duplicar', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' }
        })
        .then(r => r.json())
        .then(data => {
            if (data.success) {
                showNotification(data.message, 'success');
                if (data.redirect) setTimeout(() => window.location.href = data.redirect, 2000);
            } else {
                showNotification('Erro ao duplicar proposta', 'error');
            }
        })
        .catch(() => showNotification('Erro de conexão', 'error'));
    }
}

function showNotification(message, type) {
    const n = document.createElement('div');
    n.className = 'alert alert-' + (type === 'success' ? 'success' : 'danger') + ' position-fixed';
    n.style.cssText = 'top:20px;right:20px;z-index:9999;min-width:300px;';
    n.innerHTML = '<i class="fas fa-' + (type === 'success' ? 'check-circle' : 'exclamation-circle') + ' me-2"></i>' +
        message + '<button type="button" class="btn-close" onclick="this.parentElement.remove()"></button>';
    document.body.appendChild(n);
    setTimeout(() => { if (n.parentNode) n.remove(); }, 4000);
}
</script>
}

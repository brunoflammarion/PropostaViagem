<script>
AOS.init({ duration:700, easing:'ease-out-quad', once:true, offset:80 });

/* ══════════════════════════════════════════════════
   JOURNEY CALENDAR — renderização real de calendário
══════════════════════════════════════════════════ */
(function () {
    var calEl = document.getElementById('journeyCalendar');
    if (!calEl) return;

    @if (_jrnTemTimeline)
    {
        <text>
    var jS = new Date(@_jrnStart!.Value.Year, @(_jrnStart!.Value.Month - 1), @_jrnStart!.Value.Day);
    var jE = new Date(@_jrnEnd!.Value.Year,   @(_jrnEnd!.Value.Month   - 1), @_jrnEnd!.Value.Day);
    var dests = [
        @foreach (var _d in _jrnDestOrd)
        {
            var _cor = _jrnCores.TryGetValue(_d.Id, out var _jcvD) ? _jcvD : "#667eea";
            var _dc  = _d.DataChegada ?? _jrnStart!.Value;
            var _ds  = _d.DataSaida   ?? _jrnEnd!.Value;
            <text>{ n: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(_d.Nome)), c: "@_cor", s: new Date(@_dc.Year, @(_dc.Month-1), @_dc.Day), e: new Date(@_ds.Year, @(_ds.Month-1), @_ds.Day) },</text>
        }
    ];
        </text>
    }

    /* Subtítulo do card */
    var subEl = document.getElementById('jrnCalSubtitle');
    if (subEl) {
        var fmtLong = { day: 'numeric', month: 'long', year: 'numeric' };
        var totalDias = Math.round((jE - jS) / 86400000) + 1;
        subEl.textContent = jS.toLocaleDateString('pt-BR', fmtLong)
            + ' · ' + totalDias + (totalDias === 1 ? ' dia' : ' dias');
    }

    function colorFor(d) {
        var t = d.getTime();
        for (var i = 0; i < dests.length; i++) {
            if (t >= dests[i].s.getTime() && t <= dests[i].e.getTime()) return dests[i].c;
        }
        if (t >= jS.getTime() && t <= jE.getTime())
            return dests.length ? dests[0].c : '#667eea';
        return null;
    }

    var DOW   = ['D','S','T','Q','Q','S','S'];
    var MESES = ['Janeiro','Fevereiro','Março','Abril','Maio','Junho',
                 'Julho','Agosto','Setembro','Outubro','Novembro','Dezembro'];

    var cur  = new Date(jS.getFullYear(), jS.getMonth(), 1);
    var last = new Date(jE.getFullYear(), jE.getMonth(), 1);

    while (cur <= last) {
        var yr = cur.getFullYear(), mo = cur.getMonth();

        /* month block */
        var mDiv = document.createElement('div');
        mDiv.className = 'cal-month';

        /* header com ponto colorido */
        var hdr = document.createElement('div');
        hdr.className = 'cal-header';
        var dot = document.createElement('span');
        dot.className = 'cal-header-dot';
        var moTxt = document.createTextNode(MESES[mo] + ' ' + yr);
        hdr.appendChild(dot);
        hdr.appendChild(moTxt);
        mDiv.appendChild(hdr);

        /* dia da semana row */
        var dowRow = document.createElement('div');
        dowRow.className = 'cal-dow-row';
        DOW.forEach(function (x) {
            var c = document.createElement('div');
            c.className = 'cal-dow-cell';
            c.textContent = x;
            dowRow.appendChild(c);
        });
        mDiv.appendChild(dowRow);

        /* grade de dias */
        var grid = document.createElement('div');
        grid.className = 'cal-grid';

        /* células vazias antes do 1º dia */
        var fd = new Date(yr, mo, 1).getDay();
        for (var e = 0; e < fd; e++) {
            var em = document.createElement('div');
            em.className = 'cal-day';
            grid.appendChild(em);
        }

        /* dias do mês */
        var dim = new Date(yr, mo + 1, 0).getDate();
        for (var day = 1; day <= dim; day++) {
            var dd  = new Date(yr, mo, day);
            var el  = document.createElement('div');
            el.className = 'cal-day cur-month';
            el.textContent = day;

            var col = colorFor(dd);
            if (col) {
                el.classList.add('in-trip');
                el.classList.remove('cur-month');
                el.style.background = col;
                if (dd.getTime() === jS.getTime()) el.classList.add('trip-first');
                if (dd.getTime() === jE.getTime()) el.classList.add('trip-last');
            }
            grid.appendChild(el);
        }

        mDiv.appendChild(grid);
        calEl.appendChild(mDiv);
        cur = new Date(yr, mo + 1, 1);
    }

    /* Separador e legenda — só se houver destinos */
    var legEl = document.getElementById('journeyLegend');
    var sepEl = document.getElementById('jrnCalSep');
    if (legEl && dests.length > 0) {
        if (sepEl) sepEl.style.display = '';
        dests.forEach(function (d) {
            var item  = document.createElement('div'); item.className = 'jrn-leg-item';
            var dot2  = document.createElement('div'); dot2.className = 'jrn-leg-dot'; dot2.style.background = d.c;
            var name  = document.createElement('span'); name.className = 'jrn-leg-name'; name.textContent = d.n;
            var fmt   = { day: '2-digit', month: '2-digit' };
            var dStr  = d.s.toLocaleDateString('pt-BR', fmt) + ' – ' + d.e.toLocaleDateString('pt-BR', fmt);
            var dates = document.createElement('span'); dates.className = 'jrn-leg-dates'; dates.textContent = dStr;
            var nd    = Math.round((d.e - d.s) / 86400000) + 1;
            var daysS = document.createElement('span'); daysS.className = 'jrn-leg-days'; daysS.textContent = nd + ' d';
            item.appendChild(dot2); item.appendChild(name); item.appendChild(dates); item.appendChild(daysS);
            legEl.appendChild(item);
        });
    }
})();

/* ══════════════════════════════════════════════════
   GOOGLE MAPS — callback chamado pela API
══════════════════════════════════════════════════ */
@if (_jrnTemMapa)
{
    <text>
var jrnHoteis = [
    @foreach (var _h in _jrnHotels)
    {
        <text>{ lat: @_h.Latitude!.Value.ToString("G17", _jrnIc), lng: @_h.Longitude!.Value.ToString("G17", _jrnIc), nome: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(_h.NomeHotel)), dest: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(_h.NomeDest)), cor: "@_h.Cor" },</text>
    }
];

window.initJourneyMap = function () {
    var mapEl = document.getElementById('journeyMap');
    if (!mapEl || !jrnHoteis.length) return;

    var map = new google.maps.Map(mapEl, {
        center:             { lat: jrnHoteis[0].lat, lng: jrnHoteis[0].lng },
        zoom:               13,
        mapTypeControl:     false,
        streetViewControl:  false,
        fullscreenControl:  true,
        zoomControl:        true,
        gestureHandling:    'cooperative'
    });

    var bounds = new google.maps.LatLngBounds();

    jrnHoteis.forEach(function (h) {
        var pos = { lat: h.lat, lng: h.lng };
        bounds.extend(pos);

        var marker = new google.maps.Marker({
            position: pos,
            map:      map,
            title:    h.nome,
            icon: {
                path:          google.maps.SymbolPath.CIRCLE,
                scale:         11,
                fillColor:     h.cor,
                fillOpacity:   1,
                strokeColor:   '#ffffff',
                strokeWeight:  2.5
            }
        });

        var info = new google.maps.InfoWindow({
            content: '<div style="font-family:var(--ff-body,sans-serif);padding:8px 4px;min-width:160px;">' +
                     '<div style="font-weight:700;font-size:.87rem;color:#1e293b;">' + h.nome + '</div>' +
                     '<div style="font-size:.74rem;color:#64748b;margin-top:3px;">' + h.dest + '</div>' +
                     '</div>'
        });

        marker.addListener('click', function () { info.open(map, marker); });
    });

    if (jrnHoteis.length > 1) {
        map.fitBounds(bounds);
        var limiter = google.maps.event.addListenerOnce(map, 'bounds_changed', function () {
            if (map.getZoom() > 15) map.setZoom(15);
        });
    }
};
    </text>
}

/* ── scroll bar ── */
window.addEventListener('scroll', () => {
    const scrollTop = window.scrollY;
    const docH = document.documentElement.scrollHeight - window.innerHeight;
    const pct  = docH > 0 ? (scrollTop / docH) * 100 : 0;
    document.getElementById('scrollBar').style.width = Math.min(pct,100) + '%';
});

/* ── nav active link ── */
const navLinks = document.querySelectorAll('.prop-nav .nav-link');
const sections = [];
navLinks.forEach(a => {
    const href = a.getAttribute('href');
    if (href && href.startsWith('#')) {
        const el = document.querySelector(href);
        if (el) sections.push({ el, a });
    }
    a.addEventListener('click', e => {
        e.preventDefault();
        document.querySelector(a.getAttribute('href'))?.scrollIntoView({ behavior:'smooth' });
    });
});
const observer = new IntersectionObserver(entries => {
    entries.forEach(entry => {
        const found = sections.find(s => s.el === entry.target);
        if (found) found.a.classList.toggle('active', entry.isIntersecting);
    });
}, { threshold:.3 });
sections.forEach(s => observer.observe(s.el));

/* ── carrosseis: atualizar contador de slides ── */
document.querySelectorAll('.carousel').forEach(function (car) {
    car.addEventListener('slide.bs.carousel', function (e) {
        var counter = car.querySelector('.cur-slide');
        if (counter) counter.textContent = e.to + 1;
    });
});


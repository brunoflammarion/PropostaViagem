                                    <img src="@acmdFoto.CaminhoFoto" alt="@acmd.Nome" class="aval-card-img"
                                         onclick="openLightbox('@acmdFoto.CaminhoFoto','@acmd.Nome')" style="cursor:zoom-in;" />
                                }
                                <div class="aval-card-name">@acmd.Nome</div>
                                @if (!string.IsNullOrEmpty(acmd.Descricao))
                                {
                                    <div class="aval-card-sub">@acmd.Descricao.Substring(0, Math.Min(80, acmd.Descricao.Length))@(acmd.Descricao.Length > 80 ? "…" : "")</div>
                                }
                                <div class="star-rating" data-tipo="Acomodacao" data-id="@acmdId">
                                    @for (int s = 5; s >= 1; s--)
                                    {
                                        <input type="radio" name="aval-acmd-@acmdId" id="aval-acmd-@(acmdId)-@s" value="@s" />
                                        <label for="aval-acmd-@(acmdId)-@s" title="@s estrelas"></label>

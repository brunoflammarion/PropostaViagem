<!-- ═══════════════════════════════════════════
     AVALIAÇÃO DO CLIENTE (condicional)
═══════════════════════════════════════════ -->
@if (temAvaliacao)
{
<section class="prop-section aval-section" id="sec-avaliacao">
    <div class="container">
        <div class="section-head">
            <h2><i class="fas fa-star me-2" style="color:var(--c-accent);"></i>@(isFamiliar ? "O que acharam?" : "Avalie as Opções")</h2>
            <p>@(isExecutivo ? "Indique suas preferências para que possamos refinar a proposta." : "Sua avaliação nos ajuda a personalizar ainda mais a viagem.")</p>
            <div class="section-divider"></div>
        </div>

        @* ── Hospedagens ────────────────────────────────── *@
        @if (mostrarAvalHospedagem)
        {
            <p class="aval-group-title"><i class="fas fa-hotel me-1"></i>Hospedagens</p>

            @if (isExecutivo)
            {
                <div class="exec-compact-list mb-4">
                    @foreach (var hosp in todasHospedagens)
                    {
                        var hospId = hosp.Id.ToString();
                        <div class="aval-exec-row">
                            <div>
                                <div class="aval-exec-name">@hosp.Nome</div>
                                @if (!string.IsNullOrEmpty(hosp.Endereco))
                                {
                                    <div class="aval-exec-sub">@hosp.Endereco</div>
                                }
                            </div>
                            <div class="star-rating" data-tipo="Hospedagem" data-id="@hospId">
                                @for (int s = 5; s >= 1; s--)
                                {
                                    <input type="radio" name="aval-hosp-@hospId" id="aval-hosp-@(hospId)-@s" value="@s" />
                                    <label for="aval-hosp-@(hospId)-@s" title="@s estrelas"></label>
                                }
                            </div>
                            <button class="aval-fav-btn" data-fav="@hospId" title="Favorito">
                                <i class="fas fa-heart"></i>
                            </button>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="row g-3 mb-4">
                    @foreach (var hosp in todasHospedagens)
                    {
                        var hospId = hosp.Id.ToString();
                        <div class="col-sm-6 col-lg-4">
                            <div class="aval-card">
                                <div class="aval-card-name">@hosp.Nome</div>
                                @if (!string.IsNullOrEmpty(hosp.Endereco))
                                {
                                    <div class="aval-card-sub"><i class="fas fa-map-marker-alt me-1"></i>@hosp.Endereco</div>
                                }
                                <div class="aval-card-sub">@hosp.Categoria.ToString()</div>
                                <div class="star-rating" data-tipo="Hospedagem" data-id="@hospId">
                                    @for (int s = 5; s >= 1; s--)
                                    {
                                        <input type="radio" name="aval-hosp-@hospId" id="aval-hosp-@(hospId)-@s" value="@s" />
                                        <label for="aval-hosp-@(hospId)-@s" title="@s estrelas"></label>
                                    }
                                </div>
                                <button class="aval-fav-btn" data-fav="@hospId" title="Marcar como favorito">
                                    <i class="fas fa-heart"></i><span>Favorito</span>
                                </button>
                                <textarea class="aval-comment" data-comment="@hospId" rows="2"
                                          placeholder="Comentário opcional..."></textarea>
                            </div>
                        </div>
                    }
                </div>
            }
        }

        @* ── Acomodações ─────────────────────────────────── *@
        @if (mostrarAvalAcomodacao)
        {
            <p class="aval-group-title @(mostrarAvalHospedagem ? "mt-4" : "")"><i class="fas fa-bed me-1"></i>Acomodações</p>

            @if (isExecutivo)
            {
                <div class="exec-compact-list mb-4">
                    @foreach (var acmd in todasAcomodacoes)
                    {
                        var acmdId = acmd.Id.ToString();
                        <div class="aval-exec-row">
                            <div>
                                <div class="aval-exec-name">@acmd.Nome</div>
                                @if (!string.IsNullOrEmpty(acmd.Descricao))
                                {
                                    <div class="aval-exec-sub">@acmd.Descricao.Substring(0, Math.Min(80, acmd.Descricao.Length))@(acmd.Descricao.Length > 80 ? "…" : "")</div>
                                }
                            </div>
                            <div class="star-rating" data-tipo="Acomodacao" data-id="@acmdId">
                                @for (int s = 5; s >= 1; s--)
                                {
                                    <input type="radio" name="aval-acmd-@acmdId" id="aval-acmd-@(acmdId)-@s" value="@s" />
                                    <label for="aval-acmd-@(acmdId)-@s" title="@s estrelas"></label>
                                }
                            </div>
                            <button class="aval-fav-btn" data-fav="@acmdId" title="Favorito">
                                <i class="fas fa-heart"></i>
                            </button>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="row g-3 mb-4">
                    @foreach (var acmd in todasAcomodacoes)
                    {
                        var acmdId = acmd.Id.ToString();
                        var acmdFoto = acmd.Fotos.OrderBy(i => i.Ordem).FirstOrDefault();

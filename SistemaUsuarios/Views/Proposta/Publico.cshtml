                                          placeholder="Comentário opcional..."></textarea>
                            </div>
                        </div>
                    }
                </div>
            }
        }

        @* ── Experiências ─────────────────────────────────── *@
        @if (mostrarAvalExperiencia)
        {
            <p class="aval-group-title @(mostrarAvalHospedagem || mostrarAvalAcomodacao ? "mt-4" : "")"><i class="fas fa-hiking me-1"></i>Experiências</p>

            @if (isExecutivo)
            {
                <div class="exec-compact-list mb-4">
                    @foreach (var exp in todasExperiencias)
                    {
                        var expId = exp.Id.ToString();
                        <div class="aval-exec-row">
                            <div>
                                <div class="aval-exec-name">@exp.TipoPasseio</div>
                                @if (!string.IsNullOrEmpty(exp.Descricao))
                                {
                                    <div class="aval-exec-sub">@exp.Descricao.Substring(0, Math.Min(80, exp.Descricao.Length))@(exp.Descricao.Length > 80 ? "…" : "")</div>
                                }
                            </div>
                            <div class="star-rating" data-tipo="Experiencia" data-id="@expId">
                                @for (int s = 5; s >= 1; s--)
                                {
                                    <input type="radio" name="aval-exp-@expId" id="aval-exp-@(expId)-@s" value="@s" />
                                    <label for="aval-exp-@(expId)-@s" title="@s estrelas"></label>
                                }
                            </div>
                            <button class="aval-fav-btn" data-fav="@expId" title="Favorito">
                                <i class="fas fa-heart"></i>
                            </button>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="row g-3 mb-4">
                    @foreach (var exp in todasExperiencias)
                    {
                        var expId = exp.Id.ToString();
                        var expImgs = exp.Imagens.OrderBy(i => i.Ordem).ToList();
                        var expImg  = expImgs.FirstOrDefault();
                        <div class="col-sm-6 col-lg-4">
                            <div class="aval-card">
                                @if (expImg != null)
                                {
                                    <img src="@expImg.CaminhoImagem" alt="@exp.TipoPasseio" class="aval-card-img"
                                         onclick="openLightbox('@expImg.CaminhoImagem','@exp.TipoPasseio')" style="cursor:zoom-in;" />
                                }
                                <div class="aval-card-name">@exp.TipoPasseio</div>
                                @if (!string.IsNullOrEmpty(exp.Descricao))
                                {
                                    <div class="aval-card-sub">@exp.Descricao.Substring(0, Math.Min(80, exp.Descricao.Length))@(exp.Descricao.Length > 80 ? "…" : "")</div>
                                }
                                <div class="star-rating" data-tipo="Experiencia" data-id="@expId">
                                    @for (int s = 5; s >= 1; s--)
                                    {
                                        <input type="radio" name="aval-exp-@expId" id="aval-exp-@(expId)-@s" value="@s" />
                                        <label for="aval-exp-@(expId)-@s" title="@s estrelas"></label>
                                    }
                                </div>
                                <button class="aval-fav-btn" data-fav="@expId" title="Marcar como favorito">
                                    <i class="fas fa-heart"></i><span>Favorito</span>
                                </button>
                                <textarea class="aval-comment" data-comment="@expId" rows="2"
                                          placeholder="Comentário opcional..."></textarea>
                            </div>
                        </div>
                    }
                </div>
            }
        }

        @* ── Submit / confirmation ── *@
        <div class="aval-submit-wrap">
            <div class="aval-submitted-msg" id="avalSubmittedMsg">
                <i class="fas fa-check-circle me-2"></i>Avaliação enviada! Obrigado pelo seu feedback.
            </div>
            <button class="btn-aval-submit" id="btnEnviarAvaliacao" onclick="enviarAvaliacao('@Model.Id')">
                <i class="fas fa-paper-plane"></i>Enviar Avaliação
            </button>
        </div>
    </div>
</section>
}

<!-- ═══════════════════════════════════════════
     CTA / FECHAMENTO
═══════════════════════════════════════════ -->
<section class="cta-section" id="sec-cta">
    <div class="container">
        <div class="mb-4">
            @if (isExecutivo)

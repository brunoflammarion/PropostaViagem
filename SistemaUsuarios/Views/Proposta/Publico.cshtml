            btnSalvar.style.display = changed ? 'inline-flex' : 'none';
        });

        btnSalvar.addEventListener('click', function () {
            var btn = btnSalvar;
            btn.disabled = true;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i><span class="pb-label"> Salvando…</span>';
            fetch('/api/proposta/@Model.Id/layout', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ layoutId: sel.value ? parseInt(sel.value) : null })
            })
            .then(function (r) { return r.json(); })
            .then(function (d) {
                if (d.success) {
                    _layoutOrig = sel.value;
                    btn.style.display = 'none';
                    btn.disabled = false;
                    btn.innerHTML = '<i class="fas fa-save"></i><span class="pb-label"> Salvar layout</span>';
                    window.location.reload();
                } else {
                    alert('Erro ao salvar layout.');
                    btn.disabled = false;
                    btn.innerHTML = '<i class="fas fa-save"></i><span class="pb-label"> Salvar layout</span>';
                }
            })
            .catch(function () {
                alert('Erro de conexão.');
                btn.disabled = false;
                btn.innerHTML = '<i class="fas fa-save"></i><span class="pb-label"> Salvar layout</span>';
            });
        });
    }

    var btnCopiar = document.getElementById('btnCopiarLink');
    if (btnCopiar) {
        btnCopiar.addEventListener('click', function () {
            var url = '@linkPublico';
            if (!url) return;
            navigator.clipboard.writeText(url)
                .then(function () {
                    var orig = btnCopiar.innerHTML;
                    btnCopiar.innerHTML = '<i class="fas fa-check"></i><span class="pb-label"> Copiado!</span>';
                    setTimeout(function () { btnCopiar.innerHTML = orig; }, 2000);
                })
                .catch(function () { prompt('Copie o link manualmente:', url); });
        });
    }
})();
</text>
}
</script>
@if (_jrnTemMapa)
{
    <text><script async defer src="https://maps.googleapis.com/maps/api/js?key=@_apiKey&callback=initJourneyMap&language=pt-BR&region=BR&loading=async"></script></text>
}
}

@{
    Layout = "_LayoutPublico";
    ViewData["Title"] = Model.Titulo;
}
@model SistemaUsuarios.Models.Proposta
@using SistemaUsuarios.Models
@using System.Text.RegularExpressions
@functions {
    static string EmbedUrl(string? url) {
        if (string.IsNullOrWhiteSpace(url)) return "";
        var yt = Regex.Match(url, @"(?:youtube\.com/watch\?v=|youtu\.be/)([A-Za-z0-9_\-]{11})");
        if (yt.Success) return $"https://www.youtube.com/embed/{yt.Groups[1].Value}";
        var vimeo = Regex.Match(url, @"vimeo\.com/(\d+)");
        if (vimeo.Success) return $"https://player.vimeo.com/video/{vimeo.Groups[1].Value}";
        return url;
    }

    static string LightenPub(string hex, int amt)
    {
        if (string.IsNullOrEmpty(hex) || !hex.StartsWith("#") || hex.Length != 7) return hex;
        try
        {
            int r = Math.Clamp(Convert.ToInt32(hex.Substring(1, 2), 16) + amt, 0, 255);
            int g = Math.Clamp(Convert.ToInt32(hex.Substring(3, 2), 16) + amt, 0, 255);
            int b = Math.Clamp(Convert.ToInt32(hex.Substring(5, 2), 16) + amt, 0, 255);
            return $"#{r:X2}{g:X2}{b:X2}";
        }
        catch { return hex; }
    }

    // Retorna #ffffff ou #1a1a2e conforme a luminância relativa do fundo
    static string ContrastText(string hex)
    {
        if (string.IsNullOrEmpty(hex) || !hex.StartsWith("#") || hex.Length != 7) return "#ffffff";
        try
        {
            int r = Convert.ToInt32(hex.Substring(1, 2), 16);
            int g = Convert.ToInt32(hex.Substring(3, 2), 16);
            int b = Convert.ToInt32(hex.Substring(5, 2), 16);
            return (0.299 * r + 0.587 * g + 0.114 * b) / 255.0 > 0.5 ? "#1a1a2e" : "#ffffff";
        }
        catch { return "#ffffff"; }
    }

    // Mistura a cor com branco — factor 0=original, 1=branco puro (para fundos suaves)
    static string TintColor(string hex, double factor = 0.87)
    {
        if (string.IsNullOrEmpty(hex) || !hex.StartsWith("#") || hex.Length != 7) return "#f8f9fa";
        try
        {
            int r = Convert.ToInt32(hex.Substring(1, 2), 16);
            int g = Convert.ToInt32(hex.Substring(3, 2), 16);
            int b = Convert.ToInt32(hex.Substring(5, 2), 16);
            return $"#{(int)(r + (255-r)*factor):X2}{(int)(g + (255-g)*factor):X2}{(int)(b + (255-b)*factor):X2}";
        }
        catch { return "#f8f9fa"; }
    }
}
@{
    var layoutNome = (Model.Layout?.Nome ?? "Padrão").ToLower();
    bool isExecutivo = layoutNome.Contains("executivo");
    bool isFamiliar  = layoutNome.Contains("familiar");
    var themeClass   = isExecutivo ? "theme-executivo" : isFamiliar ? "theme-familiar" : "theme-padrao";

    var waPhone = Model.Usuario.Telefone?.Replace("(","").Replace(")","").Replace("-","").Replace(" ","") ?? "";
    var waMsgRaw = $"Olá! Vi a proposta \"{Model.Titulo}\" e tenho interesse!";

    bool temPassageiros = Model.PassageirosProposta.Any();
    bool temVoos        = Model.Voos.Any();
    bool temSeguros     = Model.Seguros.Any();
    bool temResumo      = !string.IsNullOrWhiteSpace(Model.ResumoProposta);
    bool temCondicoes   = !string.IsNullOrWhiteSpace(Model.CondicoesPropostaHtml);
    bool temValores     = !string.IsNullOrWhiteSpace(Model.ValoresPropostaHtml);
    // Jornada/calendário: existe quando há datas definidas (o mapa é bônus se houver coordenadas)
    bool temJornada     = Model.DataInicio.HasValue && Model.DataFim.HasValue;

    // ── Avaliação comparativa ─────────────────────────────────────────────────
    var todasHospedagens = Model.Destinos.SelectMany(d => d.Hospedagens).ToList();
    var todasAcomodacoes = Model.Destinos.SelectMany(d => d.Hospedagens).SelectMany(h => h.Acomodacoes).ToList();
    var todasExperiencias = Model.Destinos.SelectMany(d => d.Experiencias).ToList();

    bool mostrarAvalHospedagem  = Model.SolicitarAvaliacaoHospedagem  && todasHospedagens.Count  > 1;
    bool mostrarAvalAcomodacao  = Model.SolicitarAvaliacaoAcomodacao  && todasAcomodacoes.Count  > 1;
    bool mostrarAvalExperiencia = Model.SolicitarAvaliacaoExperiencia && todasExperiencias.Count > 1;
    bool temAvaliacao = mostrarAvalHospedagem || mostrarAvalAcomodacao || mostrarAvalExperiencia;

    // Tema personalizado do usuário/agente
    var uCorP = Model.Usuario.CorPrimaria;
    var uCorD = Model.Usuario.CorDestaque;
    bool uTemCores = !string.IsNullOrEmpty(uCorP) && !string.IsNullOrEmpty(uCorD);
    var uCorPLight = uTemCores ? LightenPub(uCorP!, 22)  : "";
    var uCorDAlt   = uTemCores ? LightenPub(uCorD!, -15) : "";
    var uCorS     = !string.IsNullOrEmpty(Model.Usuario.CorSecundaria) ? Model.Usuario.CorSecundaria : (uTemCores ? LightenPub(uCorP!, 50) : "");
    var uCorDTxt  = uTemCores ? ContrastText(uCorD!) : "#ffffff";
    var uCorPTxt  = uTemCores ? ContrastText(uCorP!) : "#ffffff";
    var uCorSTint = uTemCores && !string.IsNullOrEmpty(uCorS) ? TintColor(uCorS, 0.72) : "";
    var uCorSTxt  = uTemCores && !string.IsNullOrEmpty(uCorS) ? ContrastText(uCorS) : "#ffffff";

    // Modo preview do agente (não contabiliza visualização)
    bool isPreview      = (bool)(ViewBag.IsPreview ?? false);
    string linkPublico  = isPreview ? (string)(ViewBag.LinkPublico ?? "") : "";
    var layoutsPreview  = isPreview
        ? (ViewBag.Layouts as IEnumerable<SistemaUsuarios.Models.Layout>
           ?? Enumerable.Empty<SistemaUsuarios.Models.Layout>())
        : Enumerable.Empty<SistemaUsuarios.Models.Layout>();
}

@section Styles {
<style>
/* ═══════════════════════════════════════════════════════
   TOKENS GLOBAIS
═══════════════════════════════════════════════════════ */
:root {
    --ff-body:    'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    --ff-display: var(--ff-body);
    --radius-lg:  16px;
    --radius-md:  10px;
    --radius-sm:  6px;
    --shadow-sm:  0 2px 8px rgba(0,0,0,.08);
    --shadow-md:  0 8px 24px rgba(0,0,0,.12);
    --shadow-lg:  0 16px 48px rgba(0,0,0,.16);
    --transition: .25s ease;
}

/* ═══════════════════════════════════════════════════════
   TEMA PADRÃO  (roxo/azul vibrante)
═══════════════════════════════════════════════════════ */
.theme-padrao {
    --c-hero-from:   #3b2d8a;
    --c-hero-to:     #1a6eb5;
    --c-accent:      #667eea;
    --c-accent-alt:  #764ba2;
    --c-section-alt: #f5f7fb;
    --c-badge-bg:    #667eea;
    --c-badge-txt:   #fff;
    --c-h2:          #3b2d8a;
    --c-divider:     #667eea;
}

/* ═══════════════════════════════════════════════════════
   TEMA EXECUTIVO  (navy / ouro sóbrio)
═══════════════════════════════════════════════════════ */
.theme-executivo {
    --c-hero-from:   #0f1e35;
    --c-hero-to:     #1a3252;
    --c-accent:      #c9a84c;
    --c-accent-alt:  #a8823b;
    --c-section-alt: #f8f9fa;
    --c-badge-bg:    #1a3252;
    --c-badge-txt:   #c9a84c;
    --c-h2:          #0f1e35;
    --c-divider:     #c9a84c;
    --ff-display:    'Georgia', serif;
}

/* ═══════════════════════════════════════════════════════
   TEMA FAMILIAR  (coral / laranja acolhedor)
═══════════════════════════════════════════════════════ */
.theme-familiar {
    --c-hero-from:   #c0392b;
    --c-hero-to:     #e67e22;
    --c-accent:      #e74c3c;
    --c-accent-alt:  #f39c12;
    --c-section-alt: #fffaf5;
    --c-badge-bg:    #e74c3c;
    --c-badge-txt:   #fff;
    --c-h2:          #c0392b;
    --c-divider:     #e67e22;
    --radius-lg:     20px;
    --radius-md:     14px;
}

@if (uTemCores)
{
<text>
/* ═══════════════════════════════════════════════════════
   IDENTIDADE VISUAL DO AGENTE (override personalizado)
═══════════════════════════════════════════════════════ */
.@(themeClass) {
    --c-hero-from:   @uCorP;
    --c-hero-to:     @uCorPLight;
    --c-accent:      @uCorD;
    --c-accent-alt:  @uCorDAlt;
    --c-h2:          @uCorP;
    --c-divider:     @uCorD;
    --c-badge-bg:    @uCorD;
    --c-badge-txt:   @uCorDTxt;
    --c-section-alt: @(string.IsNullOrEmpty(uCorSTint) ? "#f5f7fb" : uCorSTint);
    --c-secondary:   @uCorS;
}
/* Primária: nav brand + headings | Secundária: numeração destinos + bordas chips | Destaque: badges + CTAs */
.@(themeClass) .prop-nav-brand { color: @uCorP; }
.@(themeClass) .destino-num { background: @uCorS; color: @uCorSTxt; }
.@(themeClass) .comod-chip { border-color: @uCorS; }
.@(themeClass) .highlight-chip { border-color: @uCorS; }
.@(themeClass) .btn-aval-submit { color: @uCorDTxt; }
</text>
}

/* ═══════════════════════════════════════════════════════
   BASE
═══════════════════════════════════════════════════════ */
* { box-sizing: border-box; }

body {
    font-family: var(--ff-body);
    color: #2d3748;
    line-height: 1.65;
    -webkit-font-smoothing: antialiased;
}

/* Progress bar */
.scroll-bar {
    position: fixed; top:0; left:0; width:0; height:3px;
    background: var(--c-accent); z-index:9999; transition:width .1s;
}

/* Scroll nav */
.prop-nav {
    position: sticky; top:0; z-index:800;
    background: rgba(255,255,255,.95);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid #edf2f7;
    padding: 10px 0;
}
.prop-nav .nav-pills .nav-link {
    color: #64748b; font-size:.82rem; padding:5px 14px;
    border-radius: 50px; transition:var(--transition);
}
.prop-nav .nav-pills .nav-link:hover,
.prop-nav .nav-pills .nav-link.active {
    background: var(--c-accent); color:#fff;
}
.prop-nav-brand { font-weight:700; color:var(--c-accent); font-size:.95rem; }

/* ── HERO ── */
.hero {
    position: relative; min-height: 480px;
    display: flex; align-items: flex-end;
    overflow: hidden;
}
.hero-bg {
    position:absolute; inset:0; z-index:0;
    background: linear-gradient(135deg, var(--c-hero-from) 0%, var(--c-hero-to) 100%);
    background-size: cover; background-position: center;
}
.hero-bg-img {
    position:absolute; inset:0; z-index:0;
    background-size:cover; background-position:center;
    transition: transform 8s ease;
}
.hero-bg-img:hover { transform: scale(1.05); }
.hero-overlay {
    position:absolute; inset:0; z-index:1;
    background: linear-gradient(to top, rgba(10,10,30,.85) 0%, rgba(10,10,30,.35) 60%, transparent 100%);
}
.hero-content { position:relative; z-index:2; width:100%; padding-bottom:56px; }

.theme-executivo .hero { min-height: 380px; }

.hero-pill {
    display:inline-flex; align-items:center; gap:6px;
    background:rgba(255,255,255,.15); border:1px solid rgba(255,255,255,.3);
    color:#fff; border-radius:50px; padding:4px 14px; font-size:.8rem;
    backdrop-filter:blur(6px); margin-bottom:14px;
}
.hero h1 {
    font-family: var(--ff-display);
    font-size: clamp(1.8rem, 4vw, 3.2rem);
    font-weight: 800; color:#fff; line-height:1.15;
    text-shadow: 0 2px 12px rgba(0,0,0,.4);
}
.theme-executivo .hero h1 { font-weight:600; letter-spacing:-.5px; }

.hero-sub { color:rgba(255,255,255,.85); font-size:1.05rem; max-width:560px; }

.hero-stat-strip {
    display:flex; flex-wrap:wrap; gap:10px; margin-top:28px;
}
.hero-stat {
    background:rgba(255,255,255,.12); border:1px solid rgba(255,255,255,.25);
    backdrop-filter:blur(6px); border-radius: var(--radius-md);
    padding: 12px 20px; text-align:center; color:#fff; min-width:120px;
}
.hero-stat strong { display:block; font-size:1.3rem; font-weight:700; }
.hero-stat small { font-size:.75rem; opacity:.85; }
.theme-executivo .hero-stat { border-color:rgba(201,168,76,.4); }
.theme-familiar .hero-stat { background:rgba(255,255,255,.18); }

/* ── SECTION ── */
.prop-section { padding: 72px 0; }
.prop-section.bg-alt { background: var(--c-section-alt); }
.section-head { margin-bottom: 48px; }
.section-head h2 {
    font-family: var(--ff-display);
    font-size: clamp(1.4rem, 3vw, 2rem);
    font-weight: 700; color: var(--c-h2);
    margin-bottom: 6px;
}
.section-head p { color:#64748b; margin:0; }
.section-divider {
    width:48px; height:3px; border-radius:2px;
    background: var(--c-divider); margin-top:10px;
}
.theme-executivo .section-divider { width:32px; height:2px; }
.theme-familiar  .section-divider { width:60px; height:4px; border-radius:4px; }

/* ── CARDS ── */
.p-card {
    background:#fff; border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md); overflow:hidden;
    transition: transform var(--transition), box-shadow var(--transition);
}
.p-card:hover { transform:translateY(-3px); box-shadow: var(--shadow-lg); }
.theme-executivo .p-card { border-radius: var(--radius-sm); box-shadow: 0 2px 12px rgba(0,0,0,.08); border:1px solid #e8ecf0; }
.theme-executivo .p-card:hover { transform:none; box-shadow: 0 4px 20px rgba(0,0,0,.12); }

.badge-theme {
    background: var(--c-badge-bg); color: var(--c-badge-txt);
    border-radius:50px; padding:3px 12px; font-size:.75rem; font-weight:600;
}
.theme-executivo .badge-theme { border-radius: var(--radius-sm); letter-spacing:.4px; }

/* ── PASSAGEIROS ── */
.pax-card {
    display:flex; align-items:center; gap:14px;
    padding:14px 18px; border-radius: var(--radius-md);
    background:#fff; border:1px solid #edf2f7; box-shadow: var(--shadow-sm);
    margin-bottom:10px;
}
.pax-avatar {
    width:48px; height:48px; border-radius:50%; object-fit:cover; flex-shrink:0;
    background:linear-gradient(135deg, var(--c-hero-from), var(--c-hero-to));
    display:flex; align-items:center; justify-content:center;
    color:#fff; font-size:1.1rem; font-weight:700;
}
.pax-avatar img { width:100%; height:100%; border-radius:50%; object-fit:cover; }
.theme-familiar .pax-card { border-radius: var(--radius-lg); }

/* ── VOOS ── */
.flight-card {
    background:#fff; border-radius: var(--radius-md);
    border: 1px solid #edf2f7; box-shadow: var(--shadow-sm);
    margin-bottom:16px; overflow:hidden;
}
.flight-header {
    background: linear-gradient(90deg, var(--c-hero-from), var(--c-hero-to));
    color:#fff; padding:14px 20px;
    display:flex; align-items:center; justify-content:space-between; gap:12px;
}
.theme-executivo .flight-header { background: var(--c-hero-from); }
.flight-route {
    display:flex; align-items:center; gap:16px; flex:1;
}
.flight-iata { font-size:1.6rem; font-weight:800; letter-spacing:-1px; }
.flight-arrow { color:rgba(255,255,255,.6); flex:1; text-align:center; font-size:.85rem; }
.flight-body { padding:16px 20px; }
.flight-detail { display:flex; gap:24px; flex-wrap:wrap; }
.flight-detail-item { display:flex; flex-direction:column; }
.flight-detail-item small { color:#94a3b8; font-size:.72rem; text-transform:uppercase; letter-spacing:.5px; }
.flight-detail-item span { font-weight:600; font-size:.9rem; }

/* ── DESTINOS ── */
.destino-wrap { margin-bottom: 56px; }
.destino-num {
    display:inline-flex; align-items:center; justify-content:center;
    width:36px; height:36px; border-radius:50%;
    background: var(--c-accent); color:#fff; font-weight:700; font-size:.9rem;
    flex-shrink:0;
}
.theme-executivo .destino-num { background:var(--c-h2); color: var(--c-accent); }
.theme-familiar  .destino-num { width:40px; height:40px; font-size:1rem; }

.destino-hero-img {
    width:100%; height:360px; object-fit:cover;
    border-radius: var(--radius-lg);
}
.theme-executivo .destino-hero-img { border-radius: var(--radius-sm); height:300px; }
.theme-familiar  .destino-hero-img { height:420px; border-radius: var(--radius-lg); }

.photo-grid {
    display:grid;
    grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    gap:10px; margin-top:14px;
}
.photo-grid-item {
    position:relative; border-radius: var(--radius-sm); overflow:hidden; cursor:zoom-in;
    aspect-ratio:4/3;
}
.photo-grid-item img {
    width:100%; height:100%; object-fit:cover;
    transition: transform .35s; display:block;
}
.photo-grid-item:hover img { transform:scale(1.06); }

/* ── HOSPEDAGEM ── */
.hotel-card { margin-bottom:24px; }
.hotel-img {
    width:100%; height:220px; object-fit:cover;
}
.theme-familiar .hotel-img { height:260px; }
.comod-chip {
    display:inline-flex; align-items:center; gap:5px;
    background: var(--c-section-alt); border:1px solid #e2e8f0;
    border-radius:50px; padding:3px 10px; font-size:.75rem; color:#475569;
    margin:3px;
}
.acomoda-row {
    display:grid; grid-template-columns:repeat(auto-fill, minmax(220px,1fr)); gap:14px;
    margin-top:14px;
}
.acomoda-card { border-radius: var(--radius-md); border:1px solid #edf2f7; overflow:hidden; background:#fff; }
.acomoda-img { width:100%; height:130px; object-fit:cover; }
.theme-familiar .acomoda-img { height:160px; }

/* ── EXPERIÊNCIAS ── */
.exp-card { margin-bottom:20px; }
.exp-img { width:100%; height:180px; object-fit:cover; border-radius: var(--radius-md) var(--radius-md) 0 0; }
.theme-familiar .exp-img { height:220px; }
.exp-valor {
    display:inline-flex; align-items:center; gap:5px;
    background:#ecfdf5; color:#059669; border-radius:50px;
    padding:3px 12px; font-size:.8rem; font-weight:600;
}

/* ── SUB-HEADINGS dentro de destino (Hospedagem, Experiências, etc.) ── */
.destino-sub-head {
    color: var(--c-h2);
    font-family: var(--ff-display);
    font-size: 1.05rem;
    font-weight: 700;
    margin-bottom: .75rem;
    display: flex;
    align-items: center;
    gap: .5rem;
}
.theme-executivo .destino-sub-head { font-size: .95rem; }

/* Separador entre destinos */
.destino-sep {
    border: none; border-top: 1px solid var(--c-divider);
    margin: 56px 0; opacity: .4;
}

/* ── CARROSSÉIS ── */
/* Botões de controle mais visíveis */
.carousel-control-prev,
.carousel-control-next {
    width: 36px;
    background: rgba(0,0,0,.42);
    border-radius: 4px;
    opacity: .9;
    transition: opacity .15s;
}
.carousel-control-prev:hover,
.carousel-control-next:hover { opacity: 1; }
.carousel-control-prev-icon,
.carousel-control-next-icon { width: 16px; height: 16px; }

/* Contador de slides */
.carousel-counter {
    position: absolute;
    bottom: 8px;
    right: 10px;
    background: rgba(0,0,0,.52);
    color: #fff;
    font-size: .72rem;
    font-weight: 600;
    padding: 2px 8px;
    border-radius: 50px;
    pointer-events: none;
    z-index: 10;
    letter-spacing: .03em;
}

/* Nos acomoda-card o carousel deve respeitar a altura da imagem */
.acomoda-card .carousel-item img { display: block; }

/* ── SEGUROS ── */
.seguro-card {
    padding:24px; border-radius: var(--radius-lg); background:#fff;
    border:1.5px solid #edf2f7; box-shadow: var(--shadow-md);
    transition: transform var(--transition), box-shadow var(--transition);
}
.seguro-card:hover { transform:translateY(-3px); box-shadow: var(--shadow-lg); }
.theme-executivo .seguro-card { border-radius: var(--radius-sm); box-shadow: 0 2px 12px rgba(0,0,0,.08); border:1px solid #e8ecf0; }
.theme-executivo .seguro-card:hover { transform:none; box-shadow: 0 4px 20px rgba(0,0,0,.12); }
.theme-familiar  .seguro-card { border-radius: var(--radius-lg); }
.seguro-icon { width:48px; height:48px; border-radius: var(--radius-sm); background: var(--c-accent); color:#fff; display:flex; align-items:center; justify-content:center; font-size:1.2rem; flex-shrink:0; }

/* ── RICH TEXT (Resumo / Condições / Valores) ── */
.resumo-proposta-body {
    font-size: 1.02rem; line-height: 1.8; color: #374151;
    background: #fff; border-radius: var(--radius-md);
    padding: 32px 36px; box-shadow: var(--shadow-sm);
    border: 1px solid #e5e7eb;
    overflow-x: hidden; /* previne scroll horizontal na seção */
}
@@media (max-width: 767px) {
    .resumo-proposta-body { padding: 22px 20px; font-size: .97rem; }
}
.resumo-proposta-body h1, .resumo-proposta-body h2, .resumo-proposta-body h3 {
    color: var(--c-h2); margin-bottom: .5em; margin-top: 1.2em; font-weight: 700;
}
.resumo-proposta-body h2 { font-size: 1.25rem; }
.resumo-proposta-body h3 { font-size: 1.05rem; }
.resumo-proposta-body ul, .resumo-proposta-body ol { padding-left: 1.5em; margin-bottom: 1em; }
.resumo-proposta-body li { margin-bottom: .4em; }
.resumo-proposta-body blockquote {
    border-left: 4px solid var(--c-accent); margin: 1em 0;
    padding: 10px 16px; background: var(--c-section-alt);
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0; color: #4b5563;
}
.resumo-proposta-body strong { color: var(--c-h2); }
.resumo-proposta-body a { color: var(--c-accent); text-decoration: underline; }
.resumo-proposta-body img { max-width: 100%; height: auto; border-radius: var(--radius-sm); margin: 8px 0; display: block; }
/* Tabelas responsivas dentro do rich text */
.resumo-proposta-body table {
    border-collapse: collapse; width: 100%; margin-bottom: 1.2em;
    font-size: .9rem; display: block; overflow-x: auto;
    -webkit-overflow-scrolling: touch;
}
.resumo-proposta-body table th,
.resumo-proposta-body table td {
    border: 1px solid #e5e7eb; padding: 9px 14px; text-align: left; white-space: nowrap;
}
.resumo-proposta-body table th {
    background: var(--c-section-alt); font-weight: 700; color: var(--c-h2);
}
.resumo-proposta-body table tr:nth-child(even) td { background: #fafafa; }

/* ── CTA ── */
.cta-section {
    background: linear-gradient(135deg, var(--c-hero-from) 0%, var(--c-hero-to) 100%);
    padding: 72px 0; text-align:center; color:#fff;
}
.theme-executivo .cta-section { background: var(--c-hero-from); }
.theme-familiar  .cta-section { border-radius: var(--radius-lg) var(--radius-lg) 0 0; margin:0 0; }

.btn-wa {
    background: #25d366; border:none; color:#fff; border-radius:50px;
    padding:14px 32px; font-weight:700; font-size:1rem;
    display:inline-flex; align-items:center; gap:8px; text-decoration:none;
    transition: transform var(--transition), box-shadow var(--transition);
    box-shadow: 0 6px 20px rgba(37,211,102,.45);
}
.btn-wa:hover { transform:translateY(-2px); box-shadow: 0 10px 28px rgba(37,211,102,.55); color:#fff; }

.btn-email {
    background: rgba(255,255,255,.15); border:2px solid rgba(255,255,255,.5);
    color:#fff; border-radius:50px; padding:13px 32px; font-weight:600;
    display:inline-flex; align-items:center; gap:8px; text-decoration:none;
    transition:var(--transition);
    backdrop-filter:blur(4px);
}
.btn-email:hover { background:rgba(255,255,255,.25); color:#fff; }

/* ── ACC — Variante Padrão (fundo gradiente escuro) ── */
.acc-padrao {
    max-width: 580px; margin: 0 auto;
    background: rgba(255,255,255,.09); border: 1px solid rgba(255,255,255,.14);
    border-radius: 20px; overflow: hidden; backdrop-filter: blur(12px);
    color: rgba(255,255,255,.92);
}
.acc-padrao .acc-brand {
    padding: 22px 32px 14px; text-align: center;
    background: rgba(255,255,255,.04);
    display: flex; flex-direction: column; align-items: center;
}
.acc-padrao .acc-logo { max-width: 200px; max-height: 76px; }
.acc-padrao .acc-agency { color: rgba(255,255,255,.6); }
.acc-padrao .acc-sep { background: rgba(255,255,255,.1); margin: 0 24px; }
.acc-padrao .acc-right {
    padding: 18px 32px 22px; gap: 14px; align-items: center;
}
.acc-padrao .acc-agent { width: 100%; justify-content: center; }
.acc-padrao .acc-avatar {
    background: rgba(255,255,255,.15); border: 2px solid rgba(255,255,255,.28);
    color: #fff; font-size: 1.25rem; width: 54px; height: 54px;
}
.acc-padrao .acc-agent-name { color: #fff; font-size: 1rem; }
.acc-padrao .acc-agent-sub  { color: rgba(255,255,255,.52); }
.acc-padrao .acc-contacts { justify-content: center; border-top: 1px solid rgba(255,255,255,.08); padding-top: 14px; width: 100%; }
.acc-padrao .acc-contact { color: rgba(255,255,255,.72); }
.acc-padrao .acc-contact i { color: var(--c-accent); font-size: .85rem; }

/* ── FOOTER ── */
footer { background:#0f172a; color:#94a3b8; padding:32px 0; font-size:.85rem; }
footer a { color:#94a3b8; }

/* lightbox → _LayoutPublico.cshtml */

/* ── STICKY CTA BTN mobile ── */
.floating-cta {
    position:fixed; bottom:24px; right:24px; z-index:700;
    display:none;
}
@@media (max-width:767px) { .floating-cta { display:block; } }

/* ── SCROLL BAR ── */
#scrollBar {
    position:fixed; top:0; left:0; height:3px; width:0;
    background: var(--c-accent); z-index:9999; transition:width .1s;
}

/* ── EXECUTIVO specifics ── */
.theme-executivo h2, .theme-executivo h3, .theme-executivo h4,
.theme-executivo h5, .theme-executivo h6 { font-family: var(--ff-display); }
.theme-executivo .prop-section { padding: 56px 0; }
.theme-executivo .comod-chip { border-radius: var(--radius-sm); }

/* ── FAMILIAR specifics ── */
.theme-familiar .p-card { border-radius: var(--radius-lg); }
.theme-familiar h2 { font-weight:800; }
.theme-familiar .section-head h2::before { content:'✦ '; color: var(--c-accent-alt); font-size:.7em; }

/* ── MISC ── */
.obs-box {
    background: var(--c-section-alt); border-left:4px solid var(--c-accent);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
    padding:20px 24px;
}
.pensao-badge { font-size:.72rem; text-transform:uppercase; letter-spacing:.5px; padding:2px 8px; }
.hosp-stars-pub { color:#C9982E; font-size:.8rem; letter-spacing:.05em; line-height:1; white-space:nowrap; }

/* ── MOBILE NAV: horizontal scrollable chip bar ── */
@@media (max-width:767px) {
    .prop-nav-brand { display:none !important; }
    .prop-nav .nav-pills {
        display:flex !important;
        overflow-x:auto;
        -webkit-overflow-scrolling:touch;
        gap:6px !important;
        padding:0 2px 2px;
        scrollbar-width:none;
        flex-wrap:nowrap !important;
    }
    .prop-nav .nav-pills::-webkit-scrollbar { display:none; }
    .prop-nav .nav-pills .nav-link {
        font-size:.78rem;
        padding:5px 14px;
        white-space:nowrap;
        border:1px solid #e2e8f0;
    }
    .prop-nav .nav-pills .nav-link.active,
    .prop-nav .nav-pills .nav-link:hover {
        border-color:var(--c-accent);
    }
    .prop-nav { padding:8px 0; }
    /* section padding reduced on mobile */
    .prop-section { padding:44px 0; }
    .section-head { margin-bottom:28px; }
    .hero { min-height:380px; }
    .destino-hero-img { height:240px; }
    .photo-grid { grid-template-columns: repeat(2,1fr); }
    /* better touch targets */
    .btn-wa, .btn-email { padding:14px 24px; font-size:.95rem; }
    .floating-cta .btn-wa { padding:14px 22px; }
    /* hero stat strip: scroll horizontally */
    .hero-stat-strip { flex-wrap:nowrap; overflow-x:auto; padding-bottom:4px; }
    .hero-stat { min-width:100px; flex-shrink:0; }
}

/* analytics debug */
.analytics-debug {
    position:fixed; bottom:10px; left:10px;
    background:rgba(0,0,0,.8); color:#fff; padding:10px;
    border-radius:5px; font-size:12px; display:none; max-width:250px; z-index:8000;
}

/* ── BAGAGEM PERMITIDA (dentro do flight-card) ── */
.bagagem-section {
    margin-top: 12px; padding-top: 12px;
    border-top: 1px dashed #e2e8f0;
}
.bagagem-section-title {
    font-size: .69rem; text-transform: uppercase; letter-spacing: .6px;
    color: #94a3b8; font-weight: 600; margin-bottom: 7px;
}
.bagagem-items { display: flex; flex-wrap: wrap; gap: 7px; }
.bagagem-item {
    display: inline-flex; align-items: center; gap: 5px;
    background: var(--c-section-alt); border: 1px solid #e2e8f0;
    border-radius: 50px; padding: 4px 10px;
    font-size: .78rem; color: #475569;
}
.bagagem-item i { color: var(--c-accent); font-size: .7rem; }

/* ── TRANSPORTE ── */
.transporte-card {
    background: #fff; border-radius: var(--radius-lg);
    border: 1.5px solid #edf2f7; box-shadow: var(--shadow-md);
    overflow: hidden; margin-bottom: 16px;
    transition: transform var(--transition), box-shadow var(--transition);
}
.transporte-card:hover { transform:translateY(-3px); box-shadow: var(--shadow-lg); }
.theme-executivo .transporte-card { border-radius: var(--radius-sm); box-shadow: 0 2px 12px rgba(0,0,0,.08); border:1px solid #e8ecf0; }
.theme-executivo .transporte-card:hover { transform:none; box-shadow: 0 4px 20px rgba(0,0,0,.12); }
.theme-familiar  .transporte-card { border-radius: var(--radius-lg); }
.transporte-header {
    background: linear-gradient(90deg, var(--c-hero-from), var(--c-hero-to));
    color: #fff; padding: 11px 18px;
    display: flex; align-items: center; gap: 10px;
}
.theme-executivo .transporte-header { background: var(--c-hero-from); }
.transporte-body { padding: 14px 18px; }
.transporte-img { width: 100%; height: 180px; object-fit: cover; }
.theme-familiar .transporte-img { height: 220px; }

/* ── EXECUTIVO: compact tables ── */
.exec-compact-list { border: 1px solid #e8ecf0; border-radius: var(--radius-sm); overflow: hidden; }
.exec-compact-row {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    padding: 14px 20px;
    border-bottom: 1px solid #f1f5f9;
    gap: 16px;
}
.exec-compact-row:last-child { border-bottom: none; }
.exec-compact-row:nth-child(even) { background: #fafbfc; }
.exec-route {
    display: flex; align-items: center; gap: 8px;
    font-size: 1.05rem; font-weight: 700; letter-spacing: -0.5px;
    color: #1e293b;
}
.exec-route-sep { color: #94a3b8; font-weight: 300; font-size: 1rem; }
.exec-flight-meta { display: flex; flex-wrap: wrap; gap: 16px; margin-top: 4px; }
.exec-flight-meta-item { display: flex; flex-direction: column; }
.exec-flight-meta-item small { color: #94a3b8; font-size: .68rem; text-transform: uppercase; letter-spacing: .4px; }
.exec-flight-meta-item span { font-weight: 600; font-size: .85rem; color: #334155; }
.exec-flight-badge {
    flex-shrink: 0; padding: 4px 12px; border-radius: var(--radius-sm);
    background: var(--c-hero-from); color: var(--c-accent);
    font-size: .72rem; font-weight: 600; letter-spacing: .4px;
    text-transform: uppercase; align-self: flex-start;
}
.voo-bloco-titulo {
    display: flex; align-items: center;
    font-size: 1rem; font-weight: 700; letter-spacing: .02em;
    margin-bottom: 12px; padding-bottom: 8px;
    border-bottom: 2px solid currentColor;
    opacity: .85;
}
.exec-pax-row {
    display: flex; align-items: center; gap: 10px;
    padding: 10px 20px; border-bottom: 1px solid #f1f5f9;
}
.exec-pax-row:last-child { border-bottom: none; }
.exec-pax-initials {
    width: 34px; height: 34px; border-radius: 50%; flex-shrink: 0;
    background: var(--c-hero-from); color: var(--c-accent);
    display: flex; align-items: center; justify-content: center;
    font-size: .85rem; font-weight: 700;
}

/* ── FAMILIAR: enlarged avatars, warm grid ── */
.fam-pax-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
    gap: 16px;
}
.fam-pax-item {
    text-align: center; padding: 22px 12px;
    background: #fff; border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
}
.fam-pax-avatar {
    width: 68px; height: 68px; border-radius: 50%;
    background: linear-gradient(135deg, var(--c-hero-from), var(--c-hero-to));
    color: #fff; font-size: 1.5rem; font-weight: 700;
    display: flex; align-items: center; justify-content: center;
    margin: 0 auto 10px; overflow: hidden;
}
.fam-pax-avatar img { width: 100%; height: 100%; object-fit: cover; border-radius: 50%; }
.fam-pax-name { font-weight: 700; font-size: .9rem; }
.fam-pax-role { font-size: .72rem; color: #94a3b8; margin-top: 3px; }

/* Familiar: full-bleed destination image */
.fam-destino-fullbleed {
    position: relative; border-radius: var(--radius-lg); overflow: hidden;
    height: 460px; margin-bottom: 28px; cursor: zoom-in;
}
.fam-destino-fullbleed img {
    width: 100%; height: 100%; object-fit: cover; display: block;
    transition: transform 6s ease;
}
.fam-destino-fullbleed:hover img { transform: scale(1.04); }
.fam-destino-caption {
    position: absolute; bottom: 0; left: 0; right: 0;
    background: linear-gradient(to top, rgba(0,0,0,.65) 0%, transparent 100%);
    padding: 40px 24px 20px;
    color: #fff;
}
.fam-destino-caption h3 { font-size: 1.6rem; font-weight: 800; margin: 0; text-shadow: 0 2px 8px rgba(0,0,0,.4); }
.fam-destino-caption small { opacity: .85; }
@@media (max-width: 768px) { .fam-destino-fullbleed { height: 280px; } }

/* ── AVALIAÇÃO DO CLIENTE ── */
.aval-section { background: var(--c-section-alt); }

.aval-group-title {
    font-size: .72rem; text-transform: uppercase; letter-spacing: .7px;
    color: #94a3b8; font-weight: 600; margin-bottom: 16px; margin-top: 0;
}

.aval-card {
    background: #fff; border-radius: var(--radius-md);
    border: 1px solid #e9edf3; box-shadow: var(--shadow-sm);
    padding: 18px 20px; transition: box-shadow var(--transition);
    display: flex; flex-direction: column; height: 100%;
}
.aval-card:hover { box-shadow: var(--shadow-md); }
.theme-executivo .aval-card { border-radius: var(--radius-sm); }
.theme-familiar  .aval-card { border-radius: var(--radius-lg); }

.aval-card-img {
    width: 100%; height: 120px; object-fit: cover;
    border-radius: var(--radius-sm); margin-bottom: 12px;
}
.theme-familiar .aval-card-img { height: 150px; border-radius: var(--radius-md); }

.aval-card-name {
    font-weight: 700; font-size: .95rem; color: #1e293b;
    margin-bottom: 4px; line-height: 1.3;
}
.aval-card-sub {
    font-size: .78rem; color: #94a3b8; margin-bottom: 12px;
}

/* Star rating — 5 stars, RTL trick */
.star-rating {
    display: inline-flex; flex-direction: row-reverse;
    gap: 3px; margin-bottom: 10px;
}
.star-rating input { display: none; }
.star-rating label {
    font-size: 1.45rem; color: #d1d5db; cursor: pointer;
    transition: color .15s; line-height: 1;
}
.star-rating label::before { content: '★'; }

/* Fill stars from right (RTL reverse) */
.star-rating input:checked ~ label,
.star-rating label:hover,
.star-rating label:hover ~ label { color: #f59e0b; }

/* Favorito toggle */
.aval-fav-btn {
    background: none; border: 1px solid #e2e8f0;
    border-radius: 50px; padding: 4px 12px;
    font-size: .78rem; color: #94a3b8; cursor: pointer;
    display: inline-flex; align-items: center; gap: 5px;
    transition: all .2s; margin-bottom: 10px;
}
.aval-fav-btn.active { background: #fff1f2; border-color: #fda4af; color: #e11d48; }
.aval-fav-btn i { font-size: .75rem; }

/* Comment textarea */
.aval-comment {
    width: 100%; border: 1px solid #e2e8f0; border-radius: var(--radius-sm);
    padding: 8px 12px; font-size: .8rem; resize: none; line-height: 1.5;
    color: #374151; font-family: var(--ff-body); transition: border-color .2s;
    margin-top: auto;
}
.aval-comment:focus { outline: none; border-color: var(--c-accent); }

/* Submit button */
.aval-submit-wrap { text-align: center; margin-top: 36px; }
.btn-aval-submit {
    background: var(--c-accent); color: #fff; border: none;
    border-radius: 50px; padding: 13px 40px; font-weight: 700;
    font-size: 1rem; cursor: pointer; display: inline-flex; align-items: center; gap: 8px;
    transition: transform var(--transition), box-shadow var(--transition), opacity var(--transition);
    box-shadow: 0 4px 16px rgba(0,0,0,.18);
}
.btn-aval-submit:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(0,0,0,.22); }
.btn-aval-submit:disabled { opacity: .55; cursor: not-allowed; transform: none; }

.aval-submitted-msg {
    display: none; padding: 16px 24px;
    background: #f0fdf4; border: 1px solid #86efac;
    border-radius: var(--radius-md); color: #166534;
    font-weight: 600; font-size: .95rem; text-align: center;
}

/* Exec: compact evaluation table */
.aval-exec-row {
    display: grid; grid-template-columns: 1fr auto auto;
    align-items: center; gap: 16px;
    padding: 12px 20px; border-bottom: 1px solid #f1f5f9;
}
.aval-exec-row:last-child { border-bottom: none; }
.aval-exec-row:nth-child(even) { background: #fafbfc; }
.aval-exec-name { font-weight: 600; font-size: .88rem; color: #1e293b; }
.aval-exec-sub  { font-size: .72rem; color: #94a3b8; }

/* ══════════════════════════════════════════════════
   JOURNEY BLOCK — calendário real + Google Maps
══════════════════════════════════════════════════ */
.journey-block { padding: 56px 0; }

/* Summary strip */
.jrn-summary {
    display: flex; flex-wrap: wrap; gap: 12px; margin-bottom: 32px; align-items: center;
}
.jrn-sum-card {
    display: flex; align-items: center; gap: 10px;
    background: #fff; border: 1.5px solid var(--c-accent);
    border-radius: var(--radius-md); padding: 10px 18px;
    box-shadow: var(--shadow-sm);
}
.jrn-sum-card.primary { background: var(--c-accent); border-color: var(--c-accent); }
.jrn-sum-card.primary .jrn-sum-icon,
.jrn-sum-card.primary .jrn-sum-label,
.jrn-sum-card.primary .jrn-sum-val { color: #fff; }
.jrn-sum-icon { color: var(--c-accent); font-size: .9rem; flex-shrink: 0; }
.jrn-sum-label { font-size: .67rem; font-weight: 600; color: #94a3b8; text-transform: uppercase; letter-spacing: .4px; display: block; }
.jrn-sum-val { font-size: .9rem; font-weight: 800; color: var(--c-h2); display: block; line-height: 1.1; }
.jrn-sum-sep { color: #cbd5e1; font-size: 1.2rem; font-weight: 300; }
.theme-executivo .jrn-sum-card.primary .jrn-sum-val { color: var(--c-h2); }

/* Journey grid — duas colunas fixas quando ambos existem */
.journey-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
    align-items: stretch;
}
@@media (max-width: 900px) {
    .journey-grid { grid-template-columns: 1fr; gap: 24px; }
    #journeyMap { height: 280px !important; }
}

/* ── CALENDÁRIO — card lateral esquerdo ── */
.jrn-cal-card {
    background: #fff;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md);
    padding: 28px 24px 20px;
    display: flex;
    flex-direction: column;
    min-height: 420px;
}
.theme-executivo .jrn-cal-card {
    border-radius: var(--radius-sm);
    border: 1px solid #e8ecf0;
    box-shadow: 0 2px 12px rgba(0,0,0,.08);
}
.theme-familiar .jrn-cal-card { border-radius: 20px; }

/* Cabeçalho interno do card */
.jrn-cal-title {
    font-size: .72rem; font-weight: 700; color: var(--c-accent);
    text-transform: uppercase; letter-spacing: .6px; margin-bottom: 4px;
}
.jrn-cal-subtitle {
    font-size: .82rem; font-weight: 600; color: #1e293b; margin-bottom: 18px;
}

/* Container dos meses */
.jrn-cal-wrap {
    display: flex;
    flex-wrap: wrap;
    gap: 20px;
    flex: 1;
}
.cal-month {
    flex: 1;
    min-width: 200px;
}

/* Cabeçalho do mês */
.cal-header {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    font-weight: 800;
    font-size: .85rem;
    color: var(--c-h2);
    margin-bottom: 12px;
    text-transform: uppercase;
    letter-spacing: .5px;
}
.cal-header-dot {
    width: 7px; height: 7px; border-radius: 50%;
    background: var(--c-accent); flex-shrink: 0;
}

/* Linha dias da semana */
.cal-dow-row {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 3px;
    margin-bottom: 4px;
}
.cal-dow-cell {
    text-align: center;
    font-size: .6rem;
    color: #94a3b8;
    font-weight: 700;
    padding: 4px 0;
    text-transform: uppercase;
}

/* Grade de dias */
.cal-grid {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 3px;
}
.cal-day {
    aspect-ratio: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 6px;
    font-size: .78rem;
    font-weight: 500;
    color: #dde3ec;
    position: relative;
    user-select: none;
    transition: filter .12s;
}
.cal-day.cur-month { color: #94a3b8; } /* mesmo mês, fora da viagem */
.cal-day.in-trip   { color: #fff; font-weight: 700; }
.cal-day.trip-first,
.cal-day.trip-last  {
    color: #fff !important; font-weight: 900;
    box-shadow: 0 4px 14px rgba(0,0,0,.28);
    transform: scale(1.18);
    z-index: 2;
    border-radius: 50%;
}
.cal-day.trip-first::before {
    content: '✈';
    position: absolute; top: -14px; left: 50%; transform: translateX(-50%);
    font-size: .6rem; opacity: .9;
}
.cal-day.trip-last::before {
    content: '🏁';
    position: absolute; top: -14px; left: 50%; transform: translateX(-50%);
    font-size: .56rem; opacity: .9;
}
.cal-day.trip-first.trip-last::before { content: '📍'; }

/* Separador antes da legenda */
.jrn-cal-sep {
    height: 1px; background: #f1f5f9; margin: 16px 0;
}

/* Legenda de destinos */
.jrn-legend { display: flex; flex-direction: column; gap: 7px; }
.jrn-leg-item { display: flex; align-items: center; gap: 8px; font-size: .79rem; }
.jrn-leg-dot  { width: 10px; height: 10px; border-radius: 3px; flex-shrink: 0; }
.jrn-leg-name { flex: 1; font-weight: 600; color: #1e293b; min-width: 0; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.jrn-leg-dates { font-size: .7rem; color: #64748b; flex-shrink: 0; }
.jrn-leg-days  { font-size: .68rem; color: #94a3b8; background: #f1f5f9; border-radius: 50px; padding: 1px 8px; flex-shrink: 0; }

/* ── MAPA — card lateral direito ── */
.jrn-map-side { display: flex; flex-direction: column; }
.jrn-map-wrap {
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-md);
    flex: 1;
    min-height: 420px;
    position: relative;
}
#journeyMap { height: 100%; width: 100%; display: block; min-height: 420px; }
.theme-executivo .jrn-map-wrap { border-radius: var(--radius-sm); border: 1px solid #e8ecf0; box-shadow: 0 2px 12px rgba(0,0,0,.08); }
.theme-familiar  .jrn-map-wrap { border-radius: 20px; }
.theme-executivo #journeyMap   { filter: grayscale(15%); }

/* ── LINHA DO TEMPO ── */
.jrn-tl-title {
    font-size: .68rem; font-weight: 700; color: var(--c-accent);
    text-transform: uppercase; letter-spacing: .7px; margin-bottom: 10px;
}
.jrn-timeline { display: flex; flex-direction: column; gap: 14px; }
.jrn-tl-block { }
.jrn-tl-dest-hdr {
    display: flex; align-items: center; gap: 7px; margin-bottom: 5px;
}
.jrn-tl-dest-dot {
    width: 9px; height: 9px; border-radius: 3px;
    background: var(--dest-cor, var(--c-accent)); flex-shrink: 0;
}
.jrn-tl-dest-name {
    font-size: .8rem; font-weight: 700; color: #1e293b; flex: 1; min-width: 0;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
}
.jrn-tl-dest-dur {
    font-size: .68rem; color: #94a3b8;
    background: #f1f5f9; border-radius: 50px; padding: 1px 7px; flex-shrink: 0;
}
.jrn-tl-events {
    list-style: none; padding: 0; margin: 0;
    padding-left: 12px;
    border-left: 2px solid var(--dest-cor, var(--c-accent));
    display: flex; flex-direction: column; gap: 2px;
}
.jrn-tl-event {
    display: flex; align-items: flex-start; gap: 7px;
    font-size: .75rem; padding: 3px 0;
}
.jrn-tl-ev-icon {
    color: var(--dest-cor, var(--c-accent)); font-size: .63rem;
    width: 13px; text-align: center; flex-shrink: 0; margin-top: 2px;
}
.jrn-tl-ev-body { flex: 1; min-width: 0; }
.jrn-tl-ev-label {
    display: block; font-weight: 600; color: #334155;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
}
.jrn-tl-ev-detail { display: block; font-size: .68rem; color: #94a3b8; margin-top: 1px; }
.jrn-tl-ev-date {
    font-size: .67rem; color: #94a3b8; flex-shrink: 0;
    font-variant-numeric: tabular-nums; white-space: nowrap; padding-top: 2px;
}

/* ── HIGHLIGHTS BAR (what's included, shown below hero) ── */
.prop-highlights {
    background: #fff; border-bottom: 1px solid #edf2f7;
    padding: 14px 0;
}
.theme-executivo .prop-highlights { background: var(--c-section-alt); }
.theme-familiar  .prop-highlights { background: var(--c-section-alt); }
.highlights-inner {
    display: flex; flex-wrap: wrap; gap: 10px; align-items: center;
}
.highlight-chip {
    display: inline-flex; align-items: center; gap: 6px;
    background: var(--c-section-alt); border: 1.5px solid var(--c-accent);
    color: var(--c-h2); border-radius: 50px;
    padding: 6px 14px; font-size: .8rem; font-weight: 600;
    white-space: nowrap;
}
.highlight-chip i { color: var(--c-accent); font-size: .78rem; }
.theme-executivo .highlight-chip {
    background: #fff; border-color: rgba(201,168,76,.45);
    border-radius: var(--radius-sm); font-size: .75rem;
}
.theme-familiar .highlight-chip {
    border-radius: 50px; padding: 7px 16px; font-size: .82rem;
}
@@media (max-width:767px) {
    .prop-highlights { padding: 10px 0; }
    .highlights-inner { flex-wrap:nowrap; overflow-x:auto; padding-bottom:2px; scrollbar-width:none; }
    .highlights-inner::-webkit-scrollbar { display:none; }
    .highlight-chip { flex-shrink:0; }
}

/* ── EXECUTIVE BRIEF — compact facts card below hero for Executivo ── */
.exec-brief {
    background: #f8f9fa; border-bottom: 1px solid #e2e8f0;
    padding: 20px 0;
}
.exec-brief-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: 0;
    background: #fff;
    border: 1px solid #e2e8f0;
    border-radius: var(--radius-sm);
    overflow: hidden;
}
.exec-brief-item {
    padding: 16px 20px; border-right: 1px solid #e8ecf0;
    display: flex; flex-direction: column; gap: 2px;
}
.exec-brief-item:last-child { border-right: none; }
.exec-brief-label {
    font-size: .65rem; font-weight: 700; text-transform: uppercase;
    letter-spacing: .6px; color: #94a3b8;
}
.exec-brief-val {
    font-size: .9rem; font-weight: 700; color: var(--c-h2);
    font-family: var(--ff-display);
}
@@media (max-width:767px) {
    .exec-brief-grid { grid-template-columns: repeat(2,1fr); }
    .exec-brief-item:nth-child(even) { border-right: none; }
    .exec-brief-item:nth-child(n+3) { border-top: 1px solid #e8ecf0; }
}

/* ── FAMILIAR SECTION FLOW — destination-first intro ── */
.fam-intro {
    background: var(--c-section-alt);
    padding: 20px 0 10px;
    border-bottom: 1px solid rgba(0,0,0,.07);
}
.fam-intro-chips {
    display: flex; flex-wrap: wrap; gap: 10px; justify-content: center;
}
.fam-intro-chip {
    display: flex; flex-direction: column; align-items: center; gap: 4px;
    background: #fff; border: 1.5px solid transparent; border-radius: 14px;
    padding: 14px 20px; min-width: 80px; cursor: pointer;
    transition: transform .15s, box-shadow .15s, border-color .15s;
    text-decoration: none; box-shadow: var(--shadow-sm);
}
.fam-intro-chip:hover { transform: translateY(-2px); box-shadow: var(--shadow-md); border-color: var(--c-accent); }
.fam-intro-chip-icon { font-size: 1.4rem; }
.fam-intro-chip-label { font-size: .7rem; font-weight: 700; color: var(--c-h2); text-align: center; white-space: nowrap; }

/* ══ BARRA DE PREVIEW (modo agente) ══════════════════════════ */
.preview-bar {
    position: fixed; top: 0; left: 0; right: 0; z-index: 9999;
    background: #1A2B3C; color: #fff;
    padding: 0.55rem 1rem;
    display: flex; align-items: center; gap: 0.75rem; flex-wrap: wrap;
    box-shadow: 0 2px 12px rgba(0,0,0,.35);
    font-family: 'Inter', -apple-system, sans-serif;
    font-size: 0.82rem;
}
.preview-bar-left  { display: flex; align-items: center; gap: 0.6rem; flex: 1; min-width: 0; }
.preview-bar-right { display: flex; align-items: center; gap: 0.45rem; flex-wrap: wrap; margin-left: auto; }
.preview-badge {
    background: #F59E0B; color: #1A2B3C; font-size: 0.7rem; font-weight: 700;
    padding: 0.18rem 0.55rem; border-radius: 50px; white-space: nowrap;
    letter-spacing: .05em; flex-shrink: 0;
}
.preview-bar select {
    background: rgba(255,255,255,.1); border: 1px solid rgba(255,255,255,.25);
    color: #fff; border-radius: 6px; padding: 0.28rem 0.55rem;
    font-size: 0.78rem; cursor: pointer; max-width: 160px;
}
.preview-bar select option { background: #1A2B3C; }
.btn-pb {
    display: inline-flex; align-items: center; gap: 0.3rem;
    padding: 0.3rem 0.75rem; border-radius: 6px; font-size: 0.77rem;
    font-weight: 600; text-decoration: none; border: none;
    cursor: pointer; transition: opacity .2s; white-space: nowrap;
}
.btn-pb:hover { opacity: .82; }
.btn-pb-outline { background: transparent; border: 1.5px solid rgba(255,255,255,.35) !important; color: #fff !important; }
.btn-pb-blue    { background: #005197; color: #fff !important; }
.btn-pb-teal    { background: #2ec4b6; color: #fff !important; }
body.has-preview-bar { padding-top: 46px; }
@@media (max-width: 600px) {
    .preview-bar { padding: 0.45rem 0.6rem; gap: 0.4rem; }
    .preview-bar select { max-width: 110px; }
    .btn-pb .pb-label { display: none; }
}
</style>
}

<div id="scrollBar"></div>

@if (isPreview)
{
<div class="preview-bar" id="previewBar">
    <div class="preview-bar-left">
        <span class="preview-badge">PRÉVIA</span>
        <span class="d-none d-sm-inline" style="opacity:.72;">Esta visualização não é contabilizada como acesso do cliente.</span>
    </div>
    <div class="preview-bar-right">
        @if (layoutsPreview.Any())
        {
            <select id="layoutSelector" title="Trocar layout para visualizar">
                <option value="">Padrão</option>
                @foreach (var lyt in layoutsPreview)
                {
                    if (Model.LayoutId == lyt.Id)
                    {
                        <option value="@lyt.Id" selected>@lyt.Nome</option>
                    }
                    else
                    {
                        <option value="@lyt.Id">@lyt.Nome</option>
                    }
                }
            </select>
            <button id="btnSalvarLayout" class="btn-pb btn-pb-teal" style="display:none">
                <i class="fas fa-save"></i><span class="pb-label"> Salvar layout</span>
            </button>
        }
        <a href="/Proposta/Editar/@Model.Id" class="btn-pb btn-pb-outline">
            <i class="fas fa-pen"></i><span class="pb-label"> Editar</span>
        </a>
        @if (!string.IsNullOrEmpty(linkPublico))
        {
            <button class="btn-pb btn-pb-outline" id="btnCopiarLink" title="Copiar link do cliente">
                <i class="fas fa-copy"></i><span class="pb-label"> Copiar link</span>
            </button>
            <a href="@linkPublico" target="_blank" rel="noopener" class="btn-pb btn-pb-blue">
                <i class="fas fa-external-link-alt"></i><span class="pb-label"> Link do cliente</span>
            </a>
        }
        else
        {
            <span style="opacity:.5;font-size:.75rem;"><i class="fas fa-lock me-1"></i>Link inativo</span>
        }
    </div>
</div>
}

<div class="@themeClass">

<!-- ═══════════════════════════════════════════
     NAV DE SEÇÕES (sticky)
═══════════════════════════════════════════ -->
<nav class="prop-nav">
    <div class="container">
        <div class="d-flex align-items-center justify-content-between gap-3">
            <span class="prop-nav-brand text-truncate">@Model.Titulo</span>
            <ul class="nav nav-pills flex-nowrap overflow-auto gap-1">
                @if (temJornada)     { <li class="nav-item"><a class="nav-link" href="#sec-jornada">Período da viagem</a></li> }
                @if (temPassageiros) { <li class="nav-item"><a class="nav-link" href="#sec-passageiros">Passageiros</a></li> }
                @if (temVoos)        { <li class="nav-item"><a class="nav-link" href="#sec-voos">Voos</a></li> }
                @if (Model.Destinos.Any()) { <li class="nav-item"><a class="nav-link" href="#sec-roteiro">Destinos</a></li> }
                @if (Model.Destinos.Any(d => d.Transportes.Any())) { <li class="nav-item"><a class="nav-link" href="#sec-transportes">Transportes</a></li> }
                @if (temSeguros)     { <li class="nav-item"><a class="nav-link" href="#sec-seguro">Seguro</a></li> }
                @if (temResumo)      { <li class="nav-item"><a class="nav-link" href="#sec-resumo">Resumo</a></li> }
                @if (temCondicoes)   { <li class="nav-item"><a class="nav-link" href="#sec-condicoes">Condições</a></li> }
                @if (temValores)     { <li class="nav-item"><a class="nav-link" href="#sec-valores">Valores</a></li> }
                @if (temAvaliacao)   { <li class="nav-item"><a class="nav-link" href="#sec-avaliacao">Avaliação</a></li> }
                <li class="nav-item"><a class="nav-link" href="#sec-cta">Contato</a></li>
            </ul>
        </div>
    </div>
</nav>

<!-- ═══════════════════════════════════════════
     HERO
═══════════════════════════════════════════ -->
<section class="hero" id="top">
    @if (!string.IsNullOrEmpty(Model.FotoCapa))
    {
        <div class="hero-bg-img" style="background-image:url('@Model.FotoCapa');"></div>
        <div class="hero-overlay"></div>
    }
    else
    {
        <div class="hero-bg"></div>
        <div class="hero-overlay" style="background:linear-gradient(to top,rgba(10,10,30,.7) 0%,rgba(10,10,30,.2) 100%);"></div>
    }

    <div class="hero-content">
        <div class="container">
            <div class="hero-pill">
                <i class="fas fa-map-marked-alt"></i>
                @if (isExecutivo) { <span>Proposta Executiva</span> }
                else if (isFamiliar) { <span>Proposta Familiar ✈️</span> }
                else { <span>Proposta de Viagem</span> }
                &nbsp;·&nbsp; <span>@Model.Usuario.Nome</span>
            </div>

            <h1>@Model.Titulo</h1>

            @if (!string.IsNullOrEmpty(Model.ObservacoesGerais) && isExecutivo)
            {
                <p class="hero-sub mt-2">@(Model.ObservacoesGerais.Length > 120 ? Model.ObservacoesGerais.Substring(0,120) + "…" : Model.ObservacoesGerais)</p>
            }

            <div class="hero-stat-strip">
                @if (Model.DataInicio.HasValue && Model.DataFim.HasValue)
                {
                    var dias = (Model.DataFim.Value - Model.DataInicio.Value).Days + 1;
                    <div class="hero-stat">
                        <strong>@dias</strong>
                        <small>@(dias == 1 ? "dia" : "dias") · @Model.DataInicio.Value.ToString("dd/MM") ao @Model.DataFim.Value.ToString("dd/MM/yy")</small>
                    </div>
                }
                @{
                    // Fonte preferencial: passageiros cadastrados individualmente
                    // Fallback: campos legados (propostas antigas sem passageiros individuais)
                    var _paxNom = Model.PassageirosProposta?.Count ?? 0;
                    var _temCli = Model.Cliente != null;
                    var _usarNom = _paxNom > 0 || _temCli;
                    var totalPax = _usarNom
                        ? (_temCli ? 1 : 0) + _paxNom
                        : Model.NumeroPassageiros + Model.NumeroCriancas;
                    var _criancasLegado = _usarNom ? 0 : Model.NumeroCriancas;
                }
                <div class="hero-stat">
                    <strong>@totalPax</strong>
                    <small>@(totalPax == 1 ? "passageiro" : "passageiros")@(_criancasLegado > 0 ? $" ({_criancasLegado} crianças)" : "")</small>
                </div>
                @if (Model.Destinos.Any())
                {
                    <div class="hero-stat">
                        <strong>@Model.Destinos.Count</strong>
                        <small>@(Model.Destinos.Count == 1 ? "destino" : "destinos")</small>
                    </div>
                }
                @if (temVoos)
                {
                    <div class="hero-stat">
                        <strong>@Model.Voos.Count</strong>
                        <small>@(Model.Voos.Count == 1 ? "voo" : "voos")</small>
                    </div>
                }
            </div>
        </div>
    </div>
</section>

<!-- ═══════════════════════════════════════════
     HIGHLIGHTS BAR — o que está incluído
═══════════════════════════════════════════ -->
@{
    bool _hTemTransp = Model.Destinos.Any(d => d.Transportes.Any());
}
<div class="prop-highlights">
    <div class="container">
        <div class="highlights-inner">
            @if (Model.Destinos.Any())
            {
                <span class="highlight-chip"><i class="fas fa-map-marked-alt"></i>@Model.Destinos.Count @(Model.Destinos.Count == 1 ? "Destino" : "Destinos")</span>
            }
            @if (temVoos)
            {
                <span class="highlight-chip"><i class="fas fa-plane"></i>@Model.Voos.Count @(Model.Voos.Count == 1 ? "Voo" : "Voos")</span>
            }
            @if (Model.Destinos.SelectMany(d => d.Hospedagens).Any())
            {
                var nHosp = Model.Destinos.SelectMany(d => d.Hospedagens).Count();
                <span class="highlight-chip"><i class="fas fa-hotel"></i>@nHosp @(nHosp == 1 ? "Hospedagem" : "Hospedagens")</span>
            }
            @if (Model.Destinos.SelectMany(d => d.Experiencias).Any())
            {
                var nExp = Model.Destinos.SelectMany(d => d.Experiencias).Count();
                <span class="highlight-chip"><i class="fas fa-hiking"></i>@nExp @(nExp == 1 ? "Experiência" : "Experiências")</span>
            }
            @if (_hTemTransp)
            {
                <span class="highlight-chip"><i class="fas fa-car"></i>Transportes</span>
            }
            @if (temSeguros)
            {
                <span class="highlight-chip"><i class="fas fa-shield-alt"></i>Seguro de Viagem</span>
            }
            @if (temAvaliacao)
            {
                <span class="highlight-chip"><i class="fas fa-star"></i>Avaliação Comparativa</span>
            }
        </div>
    </div>
</div>

<!-- ═══════════════════════════════════════════
     EXECUTIVE BRIEF (Executivo only)
═══════════════════════════════════════════ -->
@if (isExecutivo && (Model.DataInicio.HasValue || Model.Destinos.Any()))
{
    <div class="exec-brief">
        <div class="container">
            <div class="exec-brief-grid">
                @if (Model.DataInicio.HasValue && Model.DataFim.HasValue)
                {
                    var _ebDias = (Model.DataFim.Value - Model.DataInicio.Value).Days + 1;
                    <div class="exec-brief-item">
                        <span class="exec-brief-label"><i class="fas fa-calendar me-1"></i>Período</span>
                        <span class="exec-brief-val">@Model.DataInicio.Value.ToString("dd/MM") — @Model.DataFim.Value.ToString("dd/MM/yy")</span>
                    </div>
                    <div class="exec-brief-item">
                        <span class="exec-brief-label"><i class="fas fa-sun me-1"></i>Duração</span>
                        <span class="exec-brief-val">@_ebDias @(_ebDias == 1 ? "dia" : "dias")</span>
                    </div>
                }
                @if (Model.Destinos.Any())
                {
                    <div class="exec-brief-item">
                        <span class="exec-brief-label"><i class="fas fa-map-marker-alt me-1"></i>Roteiro</span>
                        <span class="exec-brief-val">@string.Join(" · ", Model.Destinos.OrderBy(d => d.Ordem).Select(d => d.Nome))</span>
                    </div>
                }
                @{
                    var _ebPax = Model.NumeroPassageiros + Model.NumeroCriancas;
                }
                @if (_ebPax > 0)
                {
                    <div class="exec-brief-item">
                        <span class="exec-brief-label"><i class="fas fa-users me-1"></i>Passageiros</span>
                        <span class="exec-brief-val">@_ebPax @(_ebPax == 1 ? "pessoa" : "pessoas")</span>
                    </div>
                }
                <div class="exec-brief-item">
                    <span class="exec-brief-label"><i class="fas fa-user-tie me-1"></i>Agente</span>
                    <span class="exec-brief-val">@Model.Usuario.Nome</span>
                </div>
            </div>
        </div>
    </div>
}

<!-- ═══════════════════════════════════════════
     FAMILIAR INTRO CHIPS (Familiar only)
═══════════════════════════════════════════ -->
@if (isFamiliar)
{
    <div class="fam-intro">
        <div class="container">
            <div class="fam-intro-chips">
                @if (temJornada)
                {
                    <a class="fam-intro-chip" href="#sec-jornada">
                        <span class="fam-intro-chip-icon">📅</span>
                        <span class="fam-intro-chip-label">Calendário</span>
                    </a>
                }
                @if (Model.Destinos.Any())
                {
                    foreach (var _fiDest in Model.Destinos.OrderBy(d => d.Ordem).Take(4))
                    {
                        <a class="fam-intro-chip" href="#sec-roteiro">
                            <span class="fam-intro-chip-icon">📍</span>
                            <span class="fam-intro-chip-label">@_fiDest.Nome</span>
                        </a>
                    }
                }
                @if (temVoos)
                {
                    <a class="fam-intro-chip" href="#sec-voos">
                        <span class="fam-intro-chip-icon">✈️</span>
                        <span class="fam-intro-chip-label">Voos</span>
                    </a>
                }
                @if (temSeguros)
                {
                    <a class="fam-intro-chip" href="#sec-seguro">
                        <span class="fam-intro-chip-icon">🛡️</span>
                        <span class="fam-intro-chip-label">Seguro</span>
                    </a>
                }
                @if (temAvaliacao)
                {
                    <a class="fam-intro-chip" href="#sec-avaliacao">
                        <span class="fam-intro-chip-icon">⭐</span>
                        <span class="fam-intro-chip-label">Avaliação</span>
                    </a>
                }
                <a class="fam-intro-chip" href="#sec-cta">
                    <span class="fam-intro-chip-icon">💬</span>
                    <span class="fam-intro-chip-label">Contato</span>
                </a>
            </div>
        </div>
    </div>
}

@* ══════════════════════════════════════════════════════
   PRÉ-CÁLCULO: cores por destino e dados da jornada
══════════════════════════════════════════════════════ *@
@{
    var _jrnIc      = System.Globalization.CultureInfo.InvariantCulture;
    var _jrnPtBR    = new System.Globalization.CultureInfo("pt-BR");
    var _jrnPaleta  = new[] { "#667eea","#f59e0b","#10b981","#ef4444","#8b5cf6","#06b6d4","#f97316","#ec4899" };
    var _jrnDestOrd = Model.Destinos.OrderBy(d => d.Ordem).ToList();
    var _jrnCores   = new Dictionary<Guid,string>();
    for (int _jci = 0; _jci < _jrnDestOrd.Count; _jci++)
        _jrnCores[_jrnDestOrd[_jci].Id] = _jrnPaleta[_jci % _jrnPaleta.Length];

    var _jrnStart  = Model.DataInicio;
    var _jrnEnd    = Model.DataFim;
    int? _jrnDias  = (_jrnStart.HasValue && _jrnEnd.HasValue)
        ? (int?)((_jrnEnd.Value.Date - _jrnStart.Value.Date).Days + 1) : null;
    int? _jrnNoites = _jrnDias.HasValue ? _jrnDias.Value - 1 : null;

    var _jrnHotels = _jrnDestOrd
        .SelectMany(d => d.Hospedagens.Select(h => new {
            h.Latitude, h.Longitude,
            NomeHotel = h.Nome,
            NomeDest  = d.Nome,
            Cor = _jrnCores.TryGetValue(d.Id, out var _jcv0) ? _jcv0 : "#667eea"
        }))
        .Where(h => h.Latitude.HasValue && h.Longitude.HasValue)
        .ToList();

    var _apiKey          = ViewBag.GoogleApiKey as string ?? "";
    bool _jrnTemTimeline = _jrnStart.HasValue && _jrnEnd.HasValue;
    bool _jrnTemMapa     = _jrnHotels.Any() && !string.IsNullOrEmpty(_apiKey);
    bool _jrnMostrar     = _jrnTemTimeline || _jrnTemMapa;
}

<!-- ═══════════════════════════════════════════
     JORNADA — calendário real + Google Maps
═══════════════════════════════════════════ -->
@if (_jrnMostrar)
{
<section class="prop-section journey-block" id="sec-jornada" data-aos="fade-up">
    <div class="container">

        <div class="section-head">
            <h2><i class="fas fa-route me-2" style="color:var(--c-accent);"></i>Visão da viagem</h2>
            <div class="section-divider"></div>
        </div>

        @* ── Summary strip ── *@
        @if (_jrnTemTimeline)
        {
            <div class="jrn-summary">
                <div class="jrn-sum-card primary">
                    <i class="fas fa-plane-departure jrn-sum-icon"></i>
                    <div>
                        <span class="jrn-sum-label">Saída</span>
                        <span class="jrn-sum-val">@_jrnStart!.Value.ToString("dd 'de' MMM 'de' yyyy", _jrnPtBR)</span>
                    </div>
                </div>
                @if (_jrnDias.HasValue)
                {
                    <span class="jrn-sum-sep">—</span>
                    <div class="jrn-sum-card">
                        <i class="fas fa-sun jrn-sum-icon"></i>
                        <div>
                            <span class="jrn-sum-label">Duração</span>
                            <span class="jrn-sum-val">@_jrnDias @(_jrnDias == 1 ? "dia" : "dias")@(_jrnNoites.HasValue && _jrnNoites > 0 ? $" · {_jrnNoites} noites" : "")</span>
                        </div>
                    </div>
                    <span class="jrn-sum-sep">—</span>
                }
                <div class="jrn-sum-card primary">
                    <i class="fas fa-plane-arrival jrn-sum-icon"></i>
                    <div>
                        <span class="jrn-sum-label">Retorno</span>
                        <span class="jrn-sum-val">@_jrnEnd!.Value.ToString("dd 'de' MMM 'de' yyyy", _jrnPtBR)</span>
                    </div>
                </div>
            </div>
        }

        @* ── Grid: mapa | calendário+timeline ── *@
        @{
            bool _jrnHasDates = _jrnDestOrd.Any(d =>
                d.DataChegada.HasValue || d.DataSaida.HasValue ||
                d.Hospedagens.Any(h => h.CheckIn.HasValue) ||
                d.Experiencias.Any(e => e.DataInicio.HasValue));
        }
        <div class="journey-grid" style="@(!(_jrnTemTimeline && _jrnTemMapa) ? "grid-template-columns:1fr;" : "")">

            @* ── Google Maps — coluna esquerda (topo no mobile) ── *@
            @if (_jrnTemMapa)
            {
                <div class="jrn-map-side" style="@(!_jrnTemTimeline ? "max-width:700px;margin:0 auto;width:100%;" : "")">
                    <div class="jrn-map-wrap">
                        <div id="journeyMap"></div>
                    </div>
                </div>
            }

            @* ── Calendário + Linha do tempo — coluna direita ── *@
            @if (_jrnTemTimeline)
            {
                <div class="jrn-cal-side">
                    <div class="jrn-cal-card">
                        <div class="jrn-cal-title">
                            <i class="fas fa-calendar-alt me-1"></i>Período da Viagem
                        </div>
                        <div class="jrn-cal-subtitle" id="jrnCalSubtitle"></div>
                        <div class="jrn-cal-wrap" id="journeyCalendar"></div>
                        <div class="jrn-cal-sep" id="jrnCalSep" style="display:none;"></div>
                        <div class="jrn-legend" id="journeyLegend"></div>

                        @* ── Linha do tempo detalhada por destino ── *@
                        @if (_jrnHasDates)
                        {
                            <div class="jrn-cal-sep" style="display:block;margin-top:16px;"></div>
                            <div class="jrn-tl-title"><i class="fas fa-map-marked-alt me-1"></i>Períodos por destino</div>
                            <div class="jrn-timeline">
                                @foreach (var _dest in _jrnDestOrd)
                                {
                                    var _destCor2 = _jrnCores.TryGetValue(_dest.Id, out var _dcCor2) ? _dcCor2 : "#667eea";

                                    @* Build sorted events for this destination *@
                                    var _tlEv = new List<(DateTime Date, string Icon, string Label, string? Detail)>();

                                    if (_dest.DataChegada.HasValue)
                                        _tlEv.Add((_dest.DataChegada.Value, "fa-plane-arrival", "Chegada", null));

                                    foreach (var _hTl in _dest.Hospedagens.Where(h => h.CheckIn.HasValue).OrderBy(h => h.CheckIn))
                                    {
                                        var _hDet = "Check-in: " + _hTl.CheckIn!.Value.ToString("dd MMM", _jrnPtBR);
                                        if (_hTl.CheckOut.HasValue)
                                            _hDet += " · Saída: " + _hTl.CheckOut.Value.ToString("dd MMM", _jrnPtBR);
                                        _tlEv.Add((_hTl.CheckIn!.Value, "fa-bed", _hTl.Nome, _hDet));
                                    }

                                    foreach (var _eTl in _dest.Experiencias.Where(e => e.DataInicio.HasValue).OrderBy(e => e.DataInicio))
                                    {
                                        string? _eDet = null;
                                        if (_eTl.DataInicio!.Value.Hour != 0 || _eTl.DataInicio.Value.Minute != 0)
                                            _eDet = _eTl.DataInicio.Value.ToString("HH:mm");
                                        _tlEv.Add((_eTl.DataInicio!.Value, "fa-star", _eTl.TipoPasseio, _eDet));
                                    }

                                    if (_dest.DataSaida.HasValue)
                                        _tlEv.Add((_dest.DataSaida.Value, "fa-plane-departure", "Partida", null));

                                    if (_tlEv.Count == 0) { continue; }

                                    _tlEv.Sort((a, b) => a.Date.CompareTo(b.Date));

                                    <div class="jrn-tl-block" style="--dest-cor:@_destCor2;">
                                        <div class="jrn-tl-dest-hdr">
                                            <span class="jrn-tl-dest-dot"></span>
                                            <span class="jrn-tl-dest-name">@_dest.Nome</span>
                                            @if (_dest.DataChegada.HasValue && _dest.DataSaida.HasValue)
                                            {
                                                var _noites2 = (int)(_dest.DataSaida.Value.Date - _dest.DataChegada.Value.Date).TotalDays;
                                                <span class="jrn-tl-dest-dur">@_noites2 @(_noites2 == 1 ? "noite" : "noites")</span>
                                            }
                                        </div>
                                        <ul class="jrn-tl-events">
                                            @foreach (var _ev in _tlEv)
                                            {
                                                <li class="jrn-tl-event">
                                                    <i class="fas @_ev.Icon jrn-tl-ev-icon"></i>
                                                    <div class="jrn-tl-ev-body">
                                                        <span class="jrn-tl-ev-label">@_ev.Label</span>
                                                        @if (_ev.Detail != null)
                                                        {
                                                            <span class="jrn-tl-ev-detail">@_ev.Detail</span>
                                                        }
                                                    </div>
                                                    <span class="jrn-tl-ev-date">@_ev.Date.ToString("dd MMM", _jrnPtBR)</span>
                                                </li>
                                            }
                                        </ul>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
            }

        </div>
    </div>
</section>
}

<!-- ═══════════════════════════════════════════
     OBSERVAÇÕES GERAIS  (Padrão / Familiar)
═══════════════════════════════════════════ -->
@if (!string.IsNullOrEmpty(Model.ObservacoesGerais) && !isExecutivo)
{
    <section class="prop-section bg-alt">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-lg-8">
                    <div class="obs-box">
                        <div class="d-flex align-items-center gap-3 mb-3">
                            <div style="width:40px;height:40px;border-radius:var(--radius-sm);background:var(--c-accent);display:flex;align-items:center;justify-content:center;color:#fff;flex-shrink:0;">
                                <i class="fas fa-compass"></i>
                            </div>
                            <h3 class="mb-0" style="font-size:1.2rem;color:var(--c-h2);">Sobre Esta Viagem</h3>
                        </div>
                        <p class="mb-0" style="color:#475569;">@Html.Raw(Model.ObservacoesGerais.Replace("\n","<br>"))</p>
                    </div>
                </div>
            </div>
        </div>
    </section>
}

<!-- ═══════════════════════════════════════════
     PASSAGEIROS
═══════════════════════════════════════════ -->
@if (temPassageiros)
{
    var todosPassageiros = new List<(string Nome, string? FotoPath, string? Papel, int? Idade)>();
    {
        foreach (var pax in Model.PassageirosProposta.OrderBy(p => p.Ordem))
        {
            var relL = pax.Relacionamento.HasValue ? pax.Relacionamento switch {
                RelacionamentoPassageiro.Filho => "Filho",
                RelacionamentoPassageiro.Filha => "Filha",
                RelacionamentoPassageiro.Amigo => "Amigo",
                RelacionamentoPassageiro.Amiga => "Amiga",
                RelacionamentoPassageiro.Esposa => "Esposa",
                RelacionamentoPassageiro.Marido => "Marido",
                RelacionamentoPassageiro.Sogra => "Sogra",
                RelacionamentoPassageiro.Sogro => "Sogro",
                RelacionamentoPassageiro.Cunhado => "Cunhado",
                RelacionamentoPassageiro.Cunhada => "Cunhada",
                RelacionamentoPassageiro.Neto => "Neto",
                RelacionamentoPassageiro.Neta => "Neta",
                RelacionamentoPassageiro.Pai => "Pai",
                RelacionamentoPassageiro.Mae => "Mãe",
                RelacionamentoPassageiro.Irmao => "Irmão",
                RelacionamentoPassageiro.Irma => "Irmã",
                _ => "Acompanhante"
            } : "Acompanhante";
            todosPassageiros.Add((pax.Nome, null, relL, pax.IdadeCalculada));
        }
    }

    @if (isExecutivo)
    {
        <!-- EXECUTIVO: compact horizontal list -->
        <section class="prop-section" id="sec-passageiros">
            <div class="container">
                <div class="section-head">
                    <h2 style="font-size:1.3rem;"><i class="fas fa-users me-2" style="color:var(--c-accent);font-size:.9em;"></i>Passageiros</h2>
                    <div class="section-divider"></div>
                </div>
                <div class="exec-compact-list" style="max-width:600px;">
                    @foreach (var p in todosPassageiros)
                    {
                        <div class="exec-pax-row">
                            <div class="exec-pax-initials">@(p.Nome.Length > 0 ? p.Nome[0].ToString().ToUpper() : "?")</div>
                            <div class="flex-grow-1">
                                <div class="fw-600" style="font-size:.9rem;">@p.Nome</div>
                                <div style="font-size:.78rem;color:#64748b;">
                                    @p.Papel@(p.Idade.HasValue ? $" · {p.Idade} anos" : "")
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </section>
    }
    else if (isFamiliar)
    {
        <!-- FAMILIAR: big warm avatar grid -->
        <section class="prop-section bg-alt" id="sec-passageiros">
            <div class="container">
                <div class="section-head">
                    <h2><i class="fas fa-users me-2" style="color:var(--c-accent);"></i>A Família na Viagem</h2>
                    <div class="section-divider"></div>
                </div>
                <div class="fam-pax-grid">
                    @foreach (var p in todosPassageiros)
                    {
                        <div class="fam-pax-item">
                            <div class="fam-pax-avatar">
                                @if (!string.IsNullOrEmpty(p.FotoPath))
                                {
                                    <img src="@p.FotoPath" alt="@p.Nome" />
                                }
                                else
                                {
                                    @(p.Nome.Length > 0 ? p.Nome[0].ToString().ToUpper() : "?")
                                }
                            </div>
                            <div class="fam-pax-name">@p.Nome</div>
                            <div class="fam-pax-role">@p.Papel@(p.Idade.HasValue ? $" · {p.Idade} anos" : "")</div>
                        </div>
                    }
                </div>
            </div>
        </section>
    }
    else
    {
        <!-- PADRÃO: card list -->
        <section class="prop-section bg-alt" id="sec-passageiros">
            <div class="container">
                <div class="section-head">
                    <h2><i class="fas fa-users me-2" style="color:var(--c-accent);"></i>Passageiros</h2>
                    <div class="section-divider"></div>
                </div>
                <div class="row g-3">
                    @foreach (var p in todosPassageiros)
                    {
                        <div class="col-md-6 col-lg-4">
                            <div class="pax-card">
                                <div class="pax-avatar">
                                    @if (!string.IsNullOrEmpty(p.FotoPath))
                                    {
                                        <img src="@p.FotoPath" alt="@p.Nome" />
                                    }
                                    else
                                    {
                                        @(p.Nome.Length > 0 ? p.Nome[0].ToString().ToUpper() : "?")
                                    }
                                </div>
                                <div class="flex-grow-1 min-w-0">
                                    <div class="fw-700 text-truncate">@p.Nome</div>
                                    <div class="d-flex flex-wrap gap-1 mt-1">
                                        <span class="badge-theme" style="font-size:.7rem;">@p.Papel</span>
                                        @if (p.Idade.HasValue)
                                        {
                                            <span class="badge bg-light text-secondary border" style="font-size:.7rem;">@p.Idade anos</span>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </section>
    }
}

<!-- ═══════════════════════════════════════════
     VOOS
═══════════════════════════════════════════ -->
@{
    var voosIda     = Model.Voos.Where(v => v.TipoVoo == SistemaUsuarios.Models.TipoVoo.Ida).OrderBy(v => v.HorarioSaida ?? DateTime.MaxValue).ThenBy(v => v.Ordem).ToList();
    var voosInterno = Model.Voos.Where(v => v.TipoVoo == SistemaUsuarios.Models.TipoVoo.Interno).OrderBy(v => v.HorarioSaida ?? DateTime.MaxValue).ThenBy(v => v.Ordem).ToList();
    var voosVolta   = Model.Voos.Where(v => v.TipoVoo == SistemaUsuarios.Models.TipoVoo.Volta).OrderBy(v => v.HorarioSaida ?? DateTime.MaxValue).ThenBy(v => v.Ordem).ToList();
    var gruposVoo   = new (System.Collections.Generic.List<SistemaUsuarios.Models.Voo> Voos, string Titulo, string Icone, string Cor)[]
    {
        (voosIda,     "Voo de Ida",    "fas fa-plane-departure", "#2563eb"),
        (voosInterno, "Voos Internos", "fas fa-route",           "#d97706"),
        (voosVolta,   "Voo de Volta",  "fas fa-plane-arrival",   "#16a34a"),
    };
}
@if (temVoos)
{
    <section class="prop-section" id="sec-voos">
        <div class="container">
            <div class="section-head">
                <h2><i class="fas fa-plane-departure me-2" style="color:var(--c-accent);"></i>@(isFamiliar ? "Nossos Voos" : "Voos")</h2>
                <div class="section-divider"></div>
            </div>

            @if (isExecutivo)
            {
                <!-- EXECUTIVO: compact list, separado por tipo -->
                @foreach (var gvoo in gruposVoo)
                {
                    if (gvoo.Voos.Any())
                    {
                        <div class="voo-bloco-titulo" style="color:@gvoo.Cor;">
                            <i class="@gvoo.Icone me-2"></i>@gvoo.Titulo
                        </div>
                        <div class="exec-compact-list mb-4">
                            @foreach (var voo in gvoo.Voos)
                            {
                                var partida = voo.HorarioSaida?.ToString("dd/MM/yyyy") ?? "—";
                                var chegada = voo.HorarioChegada?.ToString("dd/MM/yyyy") ?? "—";
                                var horaP   = voo.HorarioSaida?.ToString(@"HH\:mm") ?? "";
                                var horaC   = voo.HorarioChegada?.ToString(@"HH\:mm") ?? "";
                                bool temBagExec = voo.BagagemItemPessoalDescricao != null || voo.BagagemMaoPeso.HasValue || voo.BagagemDespachadaPeso.HasValue;
                                <div class="exec-compact-row">
                                    <div>
                                        <div class="exec-route">
                                            <span>@(voo.Origem ?? "—")</span>
                                            <span class="exec-route-sep"><i class="fas fa-arrow-right" style="font-size:.7rem;"></i></span>
                                            <span>@(voo.Destino ?? "—")</span>
                                        </div>
                                        <div class="exec-flight-meta mt-2">
                                            @if (!string.IsNullOrEmpty(voo.Companhia))
                                            {
                                                <div class="exec-flight-meta-item"><small>Companhia</small><span>@voo.Companhia @(!string.IsNullOrEmpty(voo.NumeroVoo) ? "· " + voo.NumeroVoo : "")</span></div>
                                            }
                                            <div class="exec-flight-meta-item"><small>Partida</small><span>@partida@(horaP != "" ? " " + horaP : "")</span></div>
                                            <div class="exec-flight-meta-item"><small>Chegada</small><span>@chegada@(horaC != "" ? " " + horaC : "")</span></div>
                                            @if (!string.IsNullOrEmpty(voo.Classe))
                                            {
                                                <div class="exec-flight-meta-item"><small>Classe</small><span>@voo.Classe</span></div>
                                            }
                                            @if (!string.IsNullOrEmpty(voo.Duracao))
                                            {
                                                <div class="exec-flight-meta-item"><small>Duração</small><span>@voo.Duracao</span></div>
                                            }
                                            @if (temBagExec)
                                            {
                                                <div class="exec-flight-meta-item">
                                                    <small>Bagagem</small>
                                                    <span>
                                                        @if (voo.BagagemItemPessoalDescricao != null) { <text>Item pessoal · </text> }
                                                        @if (voo.BagagemMaoPeso.HasValue) { <text>Mão @(voo.BagagemMaoPeso.Value.ToString("0"))kg · </text> }
                                                        @if (voo.BagagemDespachadaPeso.HasValue) { <text>Desp. @(voo.BagagemDespachadaPeso.Value.ToString("0"))kg</text> }
                                                    </span>
                                                </div>
                                            }
                                        </div>
                                        @if (voo.Passageiros.Any())
                                        {
                                            <div style="margin-top:6px;font-size:.78rem;color:#64748b;">
                                                <i class="fas fa-user me-1"></i>@string.Join(", ", voo.Passageiros.Select(p => p.Nome))
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    }
                }
            }
            else
            {
                <!-- PADRÃO / FAMILIAR: rich flight cards, separado por tipo -->
                @foreach (var gvoo in gruposVoo)
                {
                    if (gvoo.Voos.Any())
                    {
                        <div class="voo-bloco-titulo" style="color:@gvoo.Cor;">
                            <i class="@gvoo.Icone me-2"></i>@gvoo.Titulo
                        </div>
                        <div class="row g-3 mb-4">
                            @foreach (var voo in gvoo.Voos)
                            {
                                var partida = voo.HorarioSaida?.ToString("dd/MM/yyyy") ?? "—";
                                var chegada = voo.HorarioChegada?.ToString("dd/MM/yyyy") ?? "—";
                                var horaP   = voo.HorarioSaida?.ToString(@"HH\:mm") ?? "";
                                var horaC   = voo.HorarioChegada?.ToString(@"HH\:mm") ?? "";
                                bool temBag = voo.BagagemItemPessoalDescricao != null || voo.BagagemItemPessoalMedidas != null
                                           || voo.BagagemMaoPeso.HasValue       || voo.BagagemMaoMedidas != null
                                           || voo.BagagemDespachadaPeso.HasValue || voo.BagagemDespachadaMedidas != null;
                                <div class="col-lg-6">
                                    <div class="flight-card">
                                        <div class="flight-header">
                                            <div class="flight-route">
                                                <div>
                                                    <div class="flight-iata">@(voo.Origem ?? "—")</div>
                                                    <div style="font-size:.75rem;opacity:.8;">@partida @horaP</div>
                                                </div>
                                                <div class="flight-arrow flex-grow-1 text-center">
                                                    <i class="fas fa-long-arrow-alt-right fa-lg"></i>
                                                </div>
                                                <div class="text-end">
                                                    <div class="flight-iata">@(voo.Destino ?? "—")</div>
                                                    <div style="font-size:.75rem;opacity:.8;">@chegada @horaC</div>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="flight-body">
                                            <div class="flight-detail">
                                                @if (!string.IsNullOrEmpty(voo.Companhia))
                                                {
                                                    <div class="flight-detail-item"><small>Companhia</small><span>@voo.Companhia</span></div>
                                                }
                                                @if (!string.IsNullOrEmpty(voo.NumeroVoo))
                                                {
                                                    <div class="flight-detail-item"><small>Nº Voo</small><span>@voo.NumeroVoo</span></div>
                                                }
                                                @if (!string.IsNullOrEmpty(voo.Classe))
                                                {
                                                    <div class="flight-detail-item"><small>Classe</small><span>@voo.Classe</span></div>
                                                }
                                                @if (!string.IsNullOrEmpty(voo.Duracao))
                                                {
                                                    <div class="flight-detail-item"><small>Duração</small><span>@voo.Duracao</span></div>
                                                }
                                                @if (voo.Passageiros.Any())
                                                {
                                                    <div class="flight-detail-item">
                                                        <small>Passageiros</small>
                                                        <span>@string.Join(", ", voo.Passageiros.Select(p => p.Nome))</span>
                                                    </div>
                                                }
                                            </div>
                                            @if (!string.IsNullOrEmpty(voo.Observacao))
                                            {
                                                <p class="text-muted small mt-2 mb-0">@voo.Observacao</p>
                                            }
                                            @if (temBag)
                                            {
                                                <div class="bagagem-section">
                                                    <div class="bagagem-section-title"><i class="fas fa-suitcase me-1"></i>Bagagem Permitida</div>
                                                    <div class="bagagem-items">
                                                        @if (voo.BagagemItemPessoalDescricao != null || voo.BagagemItemPessoalMedidas != null)
                                                        {
                                                            <div class="bagagem-item">
                                                                <i class="fas fa-shopping-bag"></i>
                                                                <span>Item pessoal@(voo.BagagemItemPessoalDescricao != null ? ": " + voo.BagagemItemPessoalDescricao : "")@(voo.BagagemItemPessoalMedidas != null ? " (" + voo.BagagemItemPessoalMedidas + ")" : "")</span>
                                                            </div>
                                                        }
                                                        @if (voo.BagagemMaoPeso.HasValue || voo.BagagemMaoMedidas != null)
                                                        {
                                                            <div class="bagagem-item">
                                                                <i class="fas fa-briefcase"></i>
                                                                <span>Mão@(voo.BagagemMaoPeso.HasValue ? ": " + voo.BagagemMaoPeso.Value.ToString("0") + " kg" : "")@(voo.BagagemMaoMedidas != null ? " (" + voo.BagagemMaoMedidas + ")" : "")</span>
                                                            </div>
                                                        }
                                                        @if (voo.BagagemDespachadaPeso.HasValue || voo.BagagemDespachadaMedidas != null)
                                                        {
                                                            <div class="bagagem-item">
                                                                <i class="fas fa-suitcase-rolling"></i>
                                                                <span>Despachada@(voo.BagagemDespachadaPeso.HasValue ? ": " + voo.BagagemDespachadaPeso.Value.ToString("0") + " kg" : "")@(voo.BagagemDespachadaMedidas != null ? " (" + voo.BagagemDespachadaMedidas + ")" : "")</span>
                                                            </div>
                                                        }
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                }
            }
        </div>
    </section>
}

<!-- ═══════════════════════════════════════════
     ROTEIRO — um bloco por destino
═══════════════════════════════════════════ -->
@if (Model.Destinos.Any())
{
    <section class="prop-section bg-alt" id="sec-roteiro">
        <div class="container">
            <div class="section-head">
                <h2><i class="fas fa-map-marked-alt me-2" style="color:var(--c-accent);"></i>@(isFamiliar ? "Nosso Roteiro" : "Roteiro da Viagem")</h2>
                @if (Model.Destinos.Count > 1)
                {
                    <p>@Model.Destinos.Count destinos · @(Model.DataInicio.HasValue && Model.DataFim.HasValue ? ((Model.DataFim.Value - Model.DataInicio.Value).Days + 1) + " dias" : "")</p>
                }
                <div class="section-divider"></div>
            </div>

            @{ var _destinoOrd = Model.Destinos.OrderBy(d => d.Ordem).ToList(); }
            @for (int _di = 0; _di < _destinoOrd.Count; _di++)
            {
                var destino = _destinoOrd[_di];
                var fotoPrincipal = destino.Fotos.FirstOrDefault(f => f.Principal) ?? destino.Fotos.OrderBy(f => f.Ordem).FirstOrDefault();
                var outrasfotos   = destino.Fotos.OrderBy(f => f.Ordem).Where(f => f != fotoPrincipal).ToList();
                bool temHosp = destino.Hospedagens.Any();
                bool temExp  = destino.Experiencias.Any();
                var _destGallId = "gal-d-" + destino.Id.ToString("N");

                @if (_di > 0) { <hr class="destino-sep" /> }
                <div class="destino-wrap" style="margin-bottom:0;">
                    <!-- Cabeçalho do destino -->
                    <div class="d-flex align-items-center gap-3 mb-4">
                        <div class="destino-num">@destino.Ordem</div>
                        <div>
                            <h3 class="mb-0 fw-700" style="color:var(--c-h2);font-family:var(--ff-display);">@destino.Nome</h3>
                            @if (!string.IsNullOrEmpty(destino.Cidade) || !string.IsNullOrEmpty(destino.Pais))
                            {
                                <span class="text-muted small"><i class="fas fa-map-marker-alt me-1"></i>@destino.Cidade@((!string.IsNullOrEmpty(destino.Cidade) && !string.IsNullOrEmpty(destino.Pais)) ? ", " : "")@destino.Pais</span>
                            }
                            @if (destino.DataChegada.HasValue && destino.DataSaida.HasValue)
                            {
                                var dd = (destino.DataSaida.Value - destino.DataChegada.Value).Days + 1;
                                <span class="ms-3 text-muted small"><i class="fas fa-calendar me-1"></i>@destino.DataChegada.Value.ToString("dd/MM") — @destino.DataSaida.Value.ToString("dd/MM") (@dd @(dd==1?"dia":"dias"))</span>
                            }
                        </div>
                    </div>

                    @if (isFamiliar && fotoPrincipal != null)
                    {
                        <!-- FAMILIAR: full-bleed hero image with caption overlay -->
                        <div class="fam-destino-fullbleed"
                             data-gallery-group="@_destGallId"
                             data-gallery-src="@fotoPrincipal.CaminhoFoto"
                             data-gallery-caption="@destino.Nome"
                             style="cursor:zoom-in;">
                            <img src="@fotoPrincipal.CaminhoFoto" alt="@destino.Nome" loading="lazy" />
                            <div class="fam-destino-caption">
                                @if (!string.IsNullOrEmpty(destino.Descricao))
                                {
                                    <p style="font-size:.95rem;opacity:.9;margin-bottom:6px;line-height:1.5;">
                                        @(destino.Descricao.Length > 180 ? destino.Descricao.Substring(0, 180) + "…" : destino.Descricao)
                                    </p>
                                }
                            </div>
                        </div>
                        @if (outrasfotos.Any())
                        {
                            <div class="photo-grid mb-4">
                                @foreach (var f in outrasfotos.Take(8))
                                {
                                    <div class="photo-grid-item"
                                         data-gallery-group="@_destGallId"
                                         data-gallery-src="@f.CaminhoFoto"
                                         data-gallery-caption="@(f.Descricao ?? destino.Nome)"
                                         style="cursor:zoom-in;">
                                        <img src="@f.CaminhoFoto" alt="@f.Descricao" loading="lazy" />
                                    </div>
                                }
                            </div>
                        }
                    }
                    else
                    {
                        <!-- EXECUTIVO / PADRÃO: standard image + text grid -->
                        <div class="row g-4">
                            @if (fotoPrincipal != null)
                            {
                                <div class="col-lg-@(string.IsNullOrEmpty(destino.Descricao) && !outrasfotos.Any() ? "12" : "6")">
                                    <img src="@fotoPrincipal.CaminhoFoto" alt="@destino.Nome"
                                         class="destino-hero-img" loading="lazy"
                                         data-gallery-group="@_destGallId"
                                         data-gallery-src="@fotoPrincipal.CaminhoFoto"
                                         data-gallery-caption="@destino.Nome"
                                         style="cursor:zoom-in;" />
                                </div>
                            }
                            @if (!string.IsNullOrEmpty(destino.Descricao) || outrasfotos.Any())
                            {
                                <div class="col-lg-@(fotoPrincipal != null ? "6" : "12")">
                                    @if (!string.IsNullOrEmpty(destino.Descricao))
                                    {
                                        <p style="color:#475569; line-height:1.75; font-size:@(isExecutivo ? ".9rem" : "1rem");">
                                            @Html.Raw(destino.Descricao.Replace("\n","<br>"))
                                        </p>
                                    }
                                    @if (outrasfotos.Any())
                                    {
                                        <div class="photo-grid">
                                            @foreach (var f in outrasfotos.Take(6))
                                            {
                                                <div class="photo-grid-item"
                                                     data-gallery-group="@_destGallId"
                                                     data-gallery-src="@f.CaminhoFoto"
                                                     data-gallery-caption="@(f.Descricao ?? destino.Nome)"
                                                     style="cursor:zoom-in;">
                                                    <img src="@f.CaminhoFoto" alt="@f.Descricao" loading="lazy" />
                                                </div>
                                            }
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    }

                    <!-- HOSPEDAGEM -->
                    @if (temHosp)
                    {
                        <div class="mt-5">
                            <h4 class="destino-sub-head">
                                <i class="fas fa-hotel" style="color:var(--c-accent);"></i>
                                @(destino.Hospedagens.Count == 1 ? "Hospedagem" : "Hospedagens")
                            </h4>

                            @foreach (var hosp in destino.Hospedagens.OrderBy(h => h.Ordem))
                            {
                                var hospFotos    = hosp.Fotos.OrderBy(f => f.Ordem).ToList();
                                var hospCarId    = $"ch-{hosp.Id:N}";
                                var hospGallId   = "gal-h-" + hosp.Id.ToString("N");
                                var temHospFotos = hospFotos.Any();
                                <div class="p-card hotel-card">
                                    <div class="row g-0">
                                        @if (temHospFotos)
                                        {
                                            <div class="col-md-4" style="min-height:200px;">
                                                @if (hospFotos.Count == 1)
                                                {
                                                    <img src="@hospFotos[0].CaminhoFoto" alt="@hosp.Nome" class="hotel-img" loading="lazy"
                                                         style="height:100%;min-height:200px;cursor:zoom-in;"
                                                         data-gallery-group="@hospGallId"
                                                         data-gallery-src="@hospFotos[0].CaminhoFoto"
                                                         data-gallery-caption="@hosp.Nome" />
                                                }
                                                else
                                                {
                                                    <div id="@hospCarId" class="carousel slide h-100" data-bs-ride="false">
                                                        <div class="carousel-inner h-100">
                                                            @for (int fi = 0; fi < hospFotos.Count; fi++)
                                                            {
                                                                <div class="carousel-item @(fi == 0 ? "active" : "") h-100">
                                                                    <img src="@hospFotos[fi].CaminhoFoto" alt="@hosp.Nome"
                                                                         class="d-block w-100"
                                                                         style="height:100%;min-height:200px;object-fit:cover;cursor:zoom-in;"
                                                                         data-gallery-group="@hospGallId"
                                                                         data-gallery-src="@hospFotos[fi].CaminhoFoto"
                                                                         data-gallery-caption="@hosp.Nome" />
                                                                </div>
                                                            }
                                                        </div>
                                                        <button class="carousel-control-prev" type="button" data-bs-target="#@hospCarId" data-bs-slide="prev">
                                                            <span class="carousel-control-prev-icon"></span>
                                                        </button>
                                                        <button class="carousel-control-next" type="button" data-bs-target="#@hospCarId" data-bs-slide="next">
                                                            <span class="carousel-control-next-icon"></span>
                                                        </button>
                                                        <div class="carousel-counter">
                                                            <span class="cur-slide">1</span>/<span>@hospFotos.Count</span>
                                                        </div>
                                                    </div>
                                                }
                                            </div>
                                        }
                                        <div class="col-md-@(temHospFotos ? "8" : "12")">
                                            <div class="p-4">
                                                <div class="d-flex align-items-start justify-content-between flex-wrap gap-2 mb-2">
                                                    <div>
                                                        <div class="d-flex align-items-baseline gap-2 flex-wrap">
                                                            <h5 class="fw-700 mb-0">@hosp.Nome</h5>
                                                            @if (hosp.NumeroEstrelas.HasValue && hosp.NumeroEstrelas > 0)
                                                            {
                                                                <span class="hosp-stars-pub">@for (int _s = 0; _s < hosp.NumeroEstrelas; _s++) { <i class="fas fa-star"></i> }</span>
                                                            }
                                                        </div>
                                                        @if (!string.IsNullOrEmpty(hosp.Endereco) || (hosp.Latitude.HasValue && hosp.Longitude.HasValue))
                                                        {
                                                            <div class="d-flex align-items-center gap-2 flex-wrap mt-1">
                                                                @if (!string.IsNullOrEmpty(hosp.Endereco))
                                                                {
                                                                    <small class="text-muted"><i class="fas fa-map-pin me-1"></i>@hosp.Endereco</small>
                                                                }
                                                                @if (hosp.Latitude.HasValue && hosp.Longitude.HasValue)
                                                                {
                                                                    <a href="https://www.google.com/maps?q=@hosp.Latitude.Value.ToString("F6", System.Globalization.CultureInfo.InvariantCulture),@hosp.Longitude.Value.ToString("F6", System.Globalization.CultureInfo.InvariantCulture)"
                                                                       target="_blank" rel="noopener noreferrer"
                                                                       class="small text-decoration-none"
                                                                       style="color:var(--c-accent);">
                                                                        <i class="fas fa-map-marked-alt me-1"></i>Ver no mapa
                                                                    </a>
                                                                }
                                                            </div>
                                                        }
                                                    </div>
                                                    <div class="d-flex gap-2 flex-wrap">
                                                        @if (hosp.Categoria != default)
                                                        {
                                                            <span class="badge-theme">@hosp.Categoria.ToString()</span>
                                                        }
                                                        @if (hosp.TipoPensao != default)
                                                        {
                                                            <span class="badge bg-light text-secondary border pensao-badge">@hosp.TipoPensao.ToString()</span>
                                                        }
                                                    </div>
                                                </div>

                                                @if (hosp.CheckIn.HasValue || hosp.CheckOut.HasValue)
                                                {
                                                    <div class="d-flex gap-4 mb-3">
                                                        @if (hosp.CheckIn.HasValue)
                                                        {
                                                            <div><small class="text-muted d-block">Check-in</small><strong>@hosp.CheckIn.Value.ToString("dd/MM/yyyy HH:mm")</strong></div>
                                                        }
                                                        @if (hosp.CheckOut.HasValue)
                                                        {
                                                            <div><small class="text-muted d-block">Check-out</small><strong>@hosp.CheckOut.Value.ToString("dd/MM/yyyy HH:mm")</strong></div>
                                                        }
                                                    </div>
                                                }

                                                @if (!string.IsNullOrEmpty(hosp.Descricao))
                                                {
                                                    var _hospDescPub = System.Text.RegularExpressions.Regex.Replace(
                                                        System.Net.WebUtility.HtmlEncode(hosp.Descricao),
                                                        @"&lt;(/?b|br\s*/?)&gt;",
                                                        m => "<" + m.Groups[1].Value + ">"
                                                    ).Replace("\r", "").Replace("\n", "<br>");
                                                    <p class="text-muted small mb-3">@Html.Raw(_hospDescPub)</p>
                                                }

                                                @if (hosp.Comodidades.Any())
                                                {
                                                    <div class="mb-3">
                                                        @foreach (var c in hosp.Comodidades)
                                                        {
                                                            <span class="comod-chip"><i class="fas fa-check-circle" style="color:var(--c-accent);font-size:.7rem;"></i>@c.Nome</span>
                                                        }
                                                    </div>
                                                }

                                                @if (!string.IsNullOrEmpty(hosp.Reserva))
                                                {
                                                    <div class="small text-muted"><i class="fas fa-ticket-alt me-1"></i>Reserva: <strong>@hosp.Reserva</strong></div>
                                                }
                                            </div>
                                        </div>
                                    </div>

                                    <!-- Acomodações -->
                                    @if (hosp.Acomodacoes.Any())
                                    {
                                        <div class="px-4 pb-4">
                                            <h6 class="fw-600 text-muted mb-2" style="font-size:.85rem;text-transform:uppercase;letter-spacing:.5px;">
                                                <i class="fas fa-bed me-1"></i>Acomodações
                                            </h6>
                                            <div class="acomoda-row">
                                                @foreach (var ac in hosp.Acomodacoes.OrderBy(a => a.Ordem))
                                                {
                                                    var acFotos  = ac.Fotos.OrderBy(f => f.Ordem).ToList();
                                                    var acCarId  = $"ca-{ac.Id:N}";
                                                    var acGallId = "gal-ac-" + ac.Id.ToString("N");
                                                    <div class="acomoda-card">
                                                        @if (acFotos.Count == 1)
                                                        {
                                                            <img src="@acFotos[0].CaminhoFoto" alt="@ac.Nome" class="acomoda-img" loading="lazy"
                                                                 data-gallery-group="@acGallId"
                                                                 data-gallery-src="@acFotos[0].CaminhoFoto"
                                                                 data-gallery-caption="@ac.Nome"
                                                                 style="cursor:zoom-in;" />
                                                        }
                                                        else if (acFotos.Count > 1)
                                                        {
                                                            <div id="@acCarId" class="carousel slide" data-bs-ride="false" style="position:relative;">
                                                                <div class="carousel-inner">
                                                                    @for (int fi = 0; fi < acFotos.Count; fi++)
                                                                    {
                                                                        <div class="carousel-item @(fi == 0 ? "active" : "")">
                                                                            <img src="@acFotos[fi].CaminhoFoto" alt="@ac.Nome"
                                                                                 class="d-block w-100 acomoda-img"
                                                                                 data-gallery-group="@acGallId"
                                                                                 data-gallery-src="@acFotos[fi].CaminhoFoto"
                                                                                 data-gallery-caption="@ac.Nome"
                                                                                 style="cursor:zoom-in;" />
                                                                        </div>
                                                                    }
                                                                </div>
                                                                <button class="carousel-control-prev" type="button" data-bs-target="#@acCarId" data-bs-slide="prev">
                                                                    <span class="carousel-control-prev-icon"></span>
                                                                </button>
                                                                <button class="carousel-control-next" type="button" data-bs-target="#@acCarId" data-bs-slide="next">
                                                                    <span class="carousel-control-next-icon"></span>
                                                                </button>
                                                                <div class="carousel-counter">
                                                                    <span class="cur-slide">1</span>/<span>@acFotos.Count</span>
                                                                </div>
                                                            </div>
                                                        }
                                                        <div class="p-3">
                                                            <div class="fw-600 mb-1">@ac.Nome</div>
                                                            @if (!string.IsNullOrEmpty(ac.Descricao))
                                                            {
                                                                <p class="text-muted small mb-1">@ac.Descricao</p>
                                                            }
                                                            @if (ac.Comodidades.Any())
                                                            {
                                                                <div class="d-flex flex-wrap gap-1 mt-1">
                                                                    @foreach (var com in ac.Comodidades.OrderBy(c => c.Ordem))
                                                                    {
                                                                        <span class="badge bg-light text-dark border"
                                                                              style="font-size:.7rem;font-weight:500;">
                                                                            @com.Nome
                                                                        </span>
                                                                    }
                                                                </div>
                                                            }
                                                        </div>
                                                    </div>
                                                }
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    }

                    <!-- EXPERIÊNCIAS -->
                    @if (temExp)
                    {
                        // Separa experiências com e sem data, ordena com data por DataInicio
                        var expComData   = destino.Experiencias.Where(e => e.DataInicio.HasValue)
                                                               .OrderBy(e => e.DataInicio).ToList();
                        var expSemData   = destino.Experiencias.Where(e => !e.DataInicio.HasValue)
                                                               .OrderBy(e => e.Ordem).ToList();
                        var expPorDia    = expComData.GroupBy(e => e.DataInicio!.Value.Date)
                                                     .OrderBy(g => g.Key).ToList();
                        bool temDayByDay = expPorDia.Any();
                        <div class="mt-5">
                            <h4 class="destino-sub-head">
                                <i class="fas fa-star" style="color:var(--c-accent);"></i>
                                @(isFamiliar ? "Aventuras & Experiências" : "Experiências")
                            </h4>

                            @* ── Day by day: experiências com data agrupadas por dia ── *@
                            @if (temDayByDay)
                            {
                                <div class="mb-4">
                                    @foreach (var dia in expPorDia)
                                    {
                                        <div class="mb-4">
                                            <div class="d-flex align-items-center gap-2 mb-3">
                                                <span class="badge rounded-pill px-3 py-2"
                                                      style="background:var(--c-accent);color:#fff;font-size:.8rem;font-weight:700;letter-spacing:.02em;">
                                                    <i class="fas fa-calendar-day me-1"></i>
                                                    @dia.Key.ToString("dd 'de' MMMM", new System.Globalization.CultureInfo("pt-BR"))
                                                </span>
                                                <hr class="flex-grow-1 m-0" style="border-color:var(--c-divider);opacity:.3;" />
                                            </div>
                                            <div class="row g-3">
                                                @foreach (var exp in dia.OrderBy(e => e.DataInicio))
                                                {
                                                    var expFotos  = exp.Imagens.OrderBy(i => i.Ordem).ToList();
                                                    var embedUrl  = EmbedUrl(exp.VideoUrl);
                                                    var expCarId  = $"ce-{exp.Id:N}";
                                                    var expGallId = "gal-e-" + exp.Id.ToString("N");
                                                    <div class="col-md-6 col-lg-4">
                                                        <div class="p-card exp-card h-100 d-flex flex-column">
                                                            @if (expFotos.Count == 1)
                                                            {
                                                                <img src="@expFotos[0].CaminhoImagem" alt="@exp.TipoPasseio"
                                                                     class="exp-img" loading="lazy"
                                                                     data-gallery-group="@expGallId"
                                                                     data-gallery-src="@expFotos[0].CaminhoImagem"
                                                                     data-gallery-caption="@exp.TipoPasseio"
                                                                     style="cursor:zoom-in;" />
                                                            }
                                                            else if (expFotos.Count > 1)
                                                            {
                                                                <div id="@expCarId" class="carousel slide" data-bs-ride="false" style="position:relative;">
                                                                    <div class="carousel-inner">
                                                                        @for (int fi = 0; fi < expFotos.Count; fi++)
                                                                        {
                                                                            <div class="carousel-item @(fi == 0 ? "active" : "")">
                                                                                <img src="@expFotos[fi].CaminhoImagem" alt="@exp.TipoPasseio"
                                                                                     class="d-block w-100 exp-img"
                                                                                     data-gallery-group="@expGallId"
                                                                                     data-gallery-src="@expFotos[fi].CaminhoImagem"
                                                                                     data-gallery-caption="@exp.TipoPasseio"
                                                                                     style="cursor:zoom-in;" />
                                                                            </div>
                                                                        }
                                                                    </div>
                                                                    <button class="carousel-control-prev" type="button" data-bs-target="#@expCarId" data-bs-slide="prev">
                                                                        <span class="carousel-control-prev-icon"></span>
                                                                    </button>
                                                                    <button class="carousel-control-next" type="button" data-bs-target="#@expCarId" data-bs-slide="next">
                                                                        <span class="carousel-control-next-icon"></span>
                                                                    </button>
                                                                    <div class="carousel-counter">
                                                                        <span class="cur-slide">1</span>/<span>@expFotos.Count</span>
                                                                    </div>
                                                                </div>
                                                            }
                                                            else if (!string.IsNullOrEmpty(embedUrl))
                                                            {
                                                                <div style="position:relative;padding-top:56%;overflow:hidden;">
                                                                    <iframe src="@embedUrl" frameborder="0" allowfullscreen
                                                                            style="position:absolute;top:0;left:0;width:100%;height:100%;"></iframe>
                                                                </div>
                                                            }
                                                            <div class="p-3 flex-grow-1 d-flex flex-column">
                                                                <div class="d-flex justify-content-between align-items-start mb-1">
                                                                    <h6 class="fw-700 mb-0">@exp.TipoPasseio</h6>
                                                                    @if (exp.Valor.HasValue)
                                                                    {
                                                                        <span class="exp-valor"><i class="fas fa-tag" style="font-size:.65rem;"></i>R$ @exp.Valor.Value.ToString("N2")</span>
                                                                    }
                                                                </div>
                                                                <div class="mb-2" style="font-size:.78rem;color:var(--c-accent);font-weight:600;">
                                                                    <i class="fas fa-clock me-1" style="font-size:.7rem;"></i>
                                                                    @exp.DataInicio!.Value.ToString("HH:mm")
                                                                    @if (exp.DataFim.HasValue)
                                                                    {
                                                                        <text> — @exp.DataFim.Value.ToString("HH:mm")</text>
                                                                    }
                                                                </div>
                                                                @if (!string.IsNullOrEmpty(exp.Descricao))
                                                                {
                                                                    <p class="text-muted small mb-0 flex-grow-1">@exp.Descricao</p>
                                                                }
                                                            </div>
                                                        </div>
                                                    </div>
                                                }
                                            </div>
                                        </div>
                                    }
                                </div>
                            }

                            @* ── Experiências sem data (ou todas, se nenhuma tem data) ── *@
                            @if (expSemData.Any())
                            {
                                @if (temDayByDay)
                                {
                                    <div class="d-flex align-items-center gap-2 mb-3">
                                        <span class="badge rounded-pill px-3 py-2"
                                              style="background:#6c757d;color:#fff;font-size:.8rem;font-weight:700;">
                                            <i class="fas fa-star me-1"></i>Outras experiências
                                        </span>
                                        <hr class="flex-grow-1 m-0" style="border-color:var(--c-divider);opacity:.3;" />
                                    </div>
                                }
                                <div class="row g-3">
                                    @foreach (var exp in expSemData)
                                    {
                                        var expFotos  = exp.Imagens.OrderBy(i => i.Ordem).ToList();
                                        var embedUrl  = EmbedUrl(exp.VideoUrl);
                                        var expCarId  = $"ce-{exp.Id:N}";
                                        var expGallId = "gal-e-" + exp.Id.ToString("N");
                                        <div class="col-md-6 col-lg-4">
                                            <div class="p-card exp-card h-100 d-flex flex-column">
                                                @if (expFotos.Count == 1)
                                                {
                                                    <img src="@expFotos[0].CaminhoImagem" alt="@exp.TipoPasseio"
                                                         class="exp-img" loading="lazy"
                                                         data-gallery-group="@expGallId"
                                                         data-gallery-src="@expFotos[0].CaminhoImagem"
                                                         data-gallery-caption="@exp.TipoPasseio"
                                                         style="cursor:zoom-in;" />
                                                }
                                                else if (expFotos.Count > 1)
                                                {
                                                    <div id="@expCarId" class="carousel slide" data-bs-ride="false" style="position:relative;">
                                                        <div class="carousel-inner">
                                                            @for (int fi = 0; fi < expFotos.Count; fi++)
                                                            {
                                                                <div class="carousel-item @(fi == 0 ? "active" : "")">
                                                                    <img src="@expFotos[fi].CaminhoImagem" alt="@exp.TipoPasseio"
                                                                         class="d-block w-100 exp-img"
                                                                         data-gallery-group="@expGallId"
                                                                         data-gallery-src="@expFotos[fi].CaminhoImagem"
                                                                         data-gallery-caption="@exp.TipoPasseio"
                                                                         style="cursor:zoom-in;" />
                                                                </div>
                                                            }
                                                        </div>
                                                        <button class="carousel-control-prev" type="button" data-bs-target="#@expCarId" data-bs-slide="prev">
                                                            <span class="carousel-control-prev-icon"></span>
                                                        </button>
                                                        <button class="carousel-control-next" type="button" data-bs-target="#@expCarId" data-bs-slide="next">
                                                            <span class="carousel-control-next-icon"></span>
                                                        </button>
                                                        <div class="carousel-counter">
                                                            <span class="cur-slide">1</span>/<span>@expFotos.Count</span>
                                                        </div>
                                                    </div>
                                                }
                                                else if (!string.IsNullOrEmpty(embedUrl))
                                                {
                                                    <div style="position:relative;padding-top:56%;overflow:hidden;">
                                                        <iframe src="@embedUrl" frameborder="0" allowfullscreen
                                                                style="position:absolute;top:0;left:0;width:100%;height:100%;"></iframe>
                                                    </div>
                                                }
                                                <div class="p-3 flex-grow-1 d-flex flex-column">
                                                    <div class="d-flex justify-content-between align-items-start mb-2">
                                                        <h6 class="fw-700 mb-0">@exp.TipoPasseio</h6>
                                                        @if (exp.Valor.HasValue)
                                                        {
                                                            <span class="exp-valor"><i class="fas fa-tag" style="font-size:.65rem;"></i>R$ @exp.Valor.Value.ToString("N2")</span>
                                                        }
                                                    </div>
                                                    @if (!string.IsNullOrEmpty(exp.Descricao))
                                                    {
                                                        <p class="text-muted small mb-0 flex-grow-1">@exp.Descricao</p>
                                                    }
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    }

                    @if (destino.Ordem < Model.Destinos.Count)
                    {
                        <hr class="my-5" style="border-color:var(--c-divider);opacity:.25;" />
                    }
                </div>
            }
        </div>
    </section>
}

<!-- ═══════════════════════════════════════════
     TRANSPORTES (por destino)
═══════════════════════════════════════════ -->
@{
    var todosTransportes = Model.Destinos
        .OrderBy(d => d.Ordem)
        .SelectMany(d => d.Transportes.OrderBy(t => t.Ordem).Select(t => new { Destino = d, Transporte = t }))
        .ToList();
}
@if (todosTransportes.Any())
{
    <section class="prop-section @(isExecutivo ? "bg-alt" : "")" id="sec-transportes">
        <div class="container">
            <div class="section-head">
                <h2><i class="fas fa-car me-2" style="color:var(--c-accent);"></i>@(isFamiliar ? "Como Vamos nos Mover" : "Transportes")</h2>
                @if (!isExecutivo) { <p>Deslocamentos e transfers incluídos na proposta</p> }
                <div class="section-divider"></div>
            </div>

            @if (isExecutivo)
            {
                <!-- EXECUTIVO: compact list grouped by destino -->
                @foreach (var grp in todosTransportes.GroupBy(x => x.Destino.Id))
                {
                    var dest = grp.First().Destino;
                    <div class="mb-4">
                        @if (Model.Destinos.Count > 1)
                        {
                            <h5 class="fw-600 mb-3" style="color:var(--c-h2);font-size:.95rem;">
                                <i class="fas fa-map-marker-alt me-2" style="color:var(--c-accent);"></i>@dest.Nome
                            </h5>
                        }
                        <div class="exec-compact-list">
                            @foreach (var item in grp)
                            {
                                var t = item.Transporte;
                                var tFoto = t.Imagens.OrderBy(i => i.Ordem).FirstOrDefault();
                                <div class="exec-compact-row">
                                    <div>
                                        <div class="fw-600" style="font-size:.9rem;">@t.Titulo</div>
                                        @if (!string.IsNullOrEmpty(t.Descricao))
                                        {
                                            <div style="font-size:.78rem;color:#64748b;margin-top:2px;">@t.Descricao</div>
                                        }
                                    </div>
                                    @if (t.Valor.HasValue)
                                    {
                                        <div style="font-weight:600;font-size:.85rem;color:var(--c-h2);white-space:nowrap;">
                                            R$ @t.Valor.Value.ToString("N2")
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                }
            }
            else
            {
                <!-- PADRÃO / FAMILIAR: cards with image -->
                <div class="row g-3">
                    @foreach (var item in todosTransportes)
                    {
                        var t = item.Transporte;
                        var tFoto = t.Imagens.OrderBy(i => i.Ordem).FirstOrDefault();
                        <div class="col-md-6 col-lg-4">
                            <div class="transporte-card h-100 d-flex flex-column">
                                @if (tFoto != null)
                                {
                                    <img src="@tFoto.CaminhoImagem" alt="@t.Titulo"
                                         class="transporte-img"
                                         onclick="openLightbox('@tFoto.CaminhoImagem','@t.Titulo')"
                                         style="cursor:zoom-in;" />
                                }
                                else
                                {
                                    <div class="transporte-header">
                                        <i class="fas fa-car-side"></i>
                                        <span class="fw-600">@t.Titulo</span>
                                        @if (Model.Destinos.Count > 1)
                                        {
                                            <span style="font-size:.75rem;opacity:.75;margin-left:auto;">@item.Destino.Nome</span>
                                        }
                                    </div>
                                }
                                <div class="transporte-body flex-grow-1">
                                    @if (tFoto != null)
                                    {
                                        <div class="fw-600 mb-1">@t.Titulo</div>
                                        @if (Model.Destinos.Count > 1)
                                        {
                                            <div style="font-size:.75rem;color:#94a3b8;margin-bottom:6px;">
                                                <i class="fas fa-map-marker-alt me-1"></i>@item.Destino.Nome
                                            </div>
                                        }
                                    }
                                    @if (!string.IsNullOrEmpty(t.Descricao))
                                    {
                                        <p class="text-muted small mb-0">@t.Descricao</p>
                                    }
                                    @if (t.Valor.HasValue)
                                    {
                                        <div class="exp-valor mt-2"><i class="fas fa-tag" style="font-size:.65rem;"></i>R$ @t.Valor.Value.ToString("N2")</div>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </section>
}


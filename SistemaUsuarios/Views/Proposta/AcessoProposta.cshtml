@{
    Layout = "_LayoutPublico";
    ViewData["Title"] = "Acesso à Proposta";
    var propostaId = (Guid)ViewBag.PropostaId;
    var titulo     = ViewBag.Titulo as string ?? "Proposta de Viagem";
    var fotoCapa   = ViewBag.FotoCapa as string;
    var erro       = ViewBag.Erro as string;
    var bloqueado  = (bool)(ViewBag.Bloqueado ?? false);
}

@section Styles {
<style>
:root {
    --c-brand: #3b2d8a;
    --c-brand2: #1a6eb5;
    --c-accent: #667eea;
}

* { box-sizing: border-box; margin: 0; padding: 0; }
body { font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif; }

/* ── Hero de fundo ──────────────────────────────────── */
.gate-wrapper {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 24px 16px;
    position: relative;
    background: linear-gradient(135deg, var(--c-brand) 0%, var(--c-brand2) 100%);
    overflow: hidden;
}

@if (!string.IsNullOrEmpty(fotoCapa))
{
    @:.gate-wrapper {
    @:    background: linear-gradient(rgba(20,15,50,.72), rgba(10,30,70,.82)),
    @:                url('@fotoCapa') center/cover no-repeat;
    @:}
}

/* partículas decorativas */
.gate-wrapper::before {
    content: '';
    position: absolute;
    inset: -40%;
    background: radial-gradient(circle at 70% 30%, rgba(255,255,255,.06) 0%, transparent 55%),
                radial-gradient(circle at 25% 75%, rgba(255,255,255,.04) 0%, transparent 45%);
    pointer-events: none;
}

/* ── Card central ───────────────────────────────────── */
.gate-card {
    position: relative;
    width: 100%;
    max-width: 460px;
    background: rgba(255,255,255,.97);
    border-radius: 24px;
    box-shadow: 0 32px 80px rgba(0,0,0,.35);
    padding: 48px 40px 40px;
    text-align: center;
    backdrop-filter: blur(8px);
}

@@media (max-width: 480px) {
    .gate-card { padding: 36px 24px 32px; }
}

/* ── Ícone cadeado ──────────────────────────────────── */
.gate-icon {
    width: 72px;
    height: 72px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--c-brand) 0%, var(--c-brand2) 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 24px;
    font-size: 1.6rem;
    color: #fff;
    box-shadow: 0 8px 24px rgba(59,45,138,.35);
}

/* ── Título e subtítulo ─────────────────────────────── */
.gate-title {
    font-size: 1.4rem;
    font-weight: 700;
    color: #1a1a2e;
    margin-bottom: 6px;
    line-height: 1.3;
}

.gate-sub {
    font-size: .88rem;
    color: #6c757d;
    margin-bottom: 32px;
    line-height: 1.5;
}

/* ── Divider ────────────────────────────────────────── */
.gate-divider {
    width: 40px;
    height: 3px;
    border-radius: 2px;
    background: linear-gradient(90deg, var(--c-brand), var(--c-brand2));
    margin: 0 auto 28px;
}

/* ── Input do código ────────────────────────────────── */
.code-input-wrapper {
    position: relative;
    margin-bottom: 20px;
}

.code-input {
    width: 100%;
    padding: 16px 20px;
    font-size: 1.3rem;
    font-weight: 700;
    letter-spacing: .35em;
    text-transform: uppercase;
    text-align: center;
    border: 2px solid #e0e0ef;
    border-radius: 12px;
    outline: none;
    transition: border-color .2s, box-shadow .2s;
    color: #1a1a2e;
    background: #fafafe;
}

.code-input::placeholder {
    letter-spacing: .1em;
    font-weight: 400;
    color: #b0b0c8;
    font-size: 1rem;
}

.code-input:focus {
    border-color: var(--c-accent);
    box-shadow: 0 0 0 3px rgba(102,126,234,.18);
    background: #fff;
}

.code-input.is-invalid {
    border-color: #dc3545;
    box-shadow: 0 0 0 3px rgba(220,53,69,.12);
}

/* ── Mensagem de erro ───────────────────────────────── */
.gate-error {
    display: flex;
    align-items: center;
    gap: 8px;
    background: #fff5f5;
    border: 1px solid #fecaca;
    border-radius: 10px;
    padding: 12px 16px;
    margin-bottom: 20px;
    text-align: left;
    font-size: .84rem;
    color: #c0392b;
}

.gate-error i { flex-shrink: 0; font-size: .9rem; }

/* ── Botão ──────────────────────────────────────────── */
.gate-btn {
    width: 100%;
    padding: 15px 24px;
    border: none;
    border-radius: 12px;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    transition: transform .15s, box-shadow .15s, opacity .15s;
    background: linear-gradient(135deg, var(--c-brand) 0%, var(--c-brand2) 100%);
    color: #fff;
    box-shadow: 0 6px 20px rgba(59,45,138,.3);
    letter-spacing: .02em;
}

.gate-btn:hover:not(:disabled) {
    transform: translateY(-1px);
    box-shadow: 0 10px 28px rgba(59,45,138,.4);
}

.gate-btn:active { transform: translateY(0); }

.gate-btn:disabled {
    opacity: .55;
    cursor: not-allowed;
    transform: none;
    box-shadow: none;
}

/* ── Rodapé do card ─────────────────────────────────── */
.gate-footer {
    margin-top: 28px;
    font-size: .78rem;
    color: #aaa;
    line-height: 1.5;
}

/* ── Estado bloqueado ───────────────────────────────── */
.gate-blocked {
    background: #fff8f0;
    border: 1px solid #fddcaa;
    border-radius: 12px;
    padding: 20px;
    text-align: center;
    color: #8a5700;
    font-size: .88rem;
}

.gate-blocked i { font-size: 1.8rem; color: #f59e0b; margin-bottom: 10px; display: block; }

/* ── Spinner no submit ──────────────────────────────── */
.spinner-border-sm {
    width: 1rem;
    height: 1rem;
    border-width: .15em;
}
</style>
}

<div class="gate-wrapper">
    <div class="gate-card">

        <div class="gate-icon">
            @if (bloqueado)
            {
                <i class="fas fa-ban"></i>
            }
            else
            {
                <i class="fas fa-lock"></i>
            }
        </div>

        <h1 class="gate-title">@titulo</h1>
        <div class="gate-divider"></div>
        <p class="gate-sub">
            Esta proposta está protegida.<br>
            Informe o código de acesso fornecido pelo seu agente de viagens.
        </p>

        @if (bloqueado)
        {
            <div class="gate-blocked">
                <i class="fas fa-clock"></i>
                <strong>Acesso temporariamente suspenso</strong><br>
                @(erro ?? "Aguarde alguns minutos e tente novamente.")
            </div>
        }
        else
        {
            @if (!string.IsNullOrEmpty(erro))
            {
                <div class="gate-error">
                    <i class="fas fa-exclamation-circle"></i>
                    <span>@erro</span>
                </div>
            }

            <form method="post" asp-controller="Proposta" asp-action="AcessoProposta"
                  asp-route-id="@propostaId" id="gateForm" novalidate>
                @Html.AntiForgeryToken()

                <div class="code-input-wrapper">
                    <input type="text"
                           name="codigo"
                           id="codigoInput"
                           class="code-input @(!string.IsNullOrEmpty(erro) ? "is-invalid" : "")"
                           placeholder="XXX-000"
                           autocomplete="off"
                           autocorrect="off"
                           autocapitalize="characters"
                           spellcheck="false"
                           maxlength="7"
                           autofocus
                           required />
                </div>

                <button type="submit" class="gate-btn" id="submitBtn">
                    <span id="btnText"><i class="fas fa-arrow-right me-2"></i>Acessar proposta</span>
                    <span id="btnSpinner" class="d-none">
                        <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                        Verificando...
                    </span>
                </button>
            </form>
        }

        <div class="gate-footer">
            <i class="fas fa-shield-alt me-1"></i>
            Acesso seguro · Seus dados estão protegidos
        </div>
    </div>
</div>

@section Scripts {
<script>
(function () {
    var input = document.getElementById('codigoInput');
    var form  = document.getElementById('gateForm');
    var btn   = document.getElementById('submitBtn');
    var txt   = document.getElementById('btnText');
    var spin  = document.getElementById('btnSpinner');

    if (!input) return;

    // Formata entrada: inserir dash após 3 chars, limpar confusos
    input.addEventListener('input', function () {
        var raw = this.value.replace(/[^A-Za-z0-9]/g, '').toUpperCase().slice(0, 6);
        if (raw.length > 3) {
            this.value = raw.slice(0, 3) + '-' + raw.slice(3);
        } else {
            this.value = raw;
        }
    });

    // Spinner no submit
    if (form) {
        form.addEventListener('submit', function () {
            if (btn)  btn.disabled = true;
            if (txt)  txt.classList.add('d-none');
            if (spin) spin.classList.remove('d-none');
        });
    }
})();
</script>
}

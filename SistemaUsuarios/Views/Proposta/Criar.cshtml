@model SistemaUsuarios.Models.ViewModels.PropostaViewModel

<div class="container-fluid" id="proposta-edit-page">

    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/Proposta">Propostas</a></li>
            <li class="breadcrumb-item active">Nova Proposta</li>
        </ol>
    </nav>

    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h3 class="mb-0"><i class="fas fa-plus-circle me-2 text-primary"></i>Nova Proposta</h3>
            <small class="text-muted">Preencha os dados iniciais e clique em "Criar Proposta" para começar.</small>
        </div>
        <div>
            <a href="/Proposta" class="btn btn-sm btn-outline-secondary">
                <i class="fas fa-arrow-left me-1"></i>Propostas
            </a>
        </div>
    </div>

    <!-- Abas — apenas "Dados" ativo; demais desabilitadas até a proposta existir -->
    <ul class="nav nav-pills mb-4" id="editarTabs" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active"
                    id="tab-dados" data-bs-toggle="pill" data-bs-target="#pane-dados"
                    type="button" role="tab">
                <i class="fas fa-file-alt me-1"></i>Dados
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link disabled" type="button"
                    title="Crie a proposta para liberar esta etapa" tabindex="-1" aria-disabled="true">
                <i class="fas fa-users me-1"></i>Passageiros
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link disabled" type="button"
                    title="Crie a proposta para liberar esta etapa" tabindex="-1" aria-disabled="true">
                <i class="fas fa-plane me-1"></i>Aéreo
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link disabled" type="button"
                    title="Crie a proposta para liberar esta etapa" tabindex="-1" aria-disabled="true">
                <i class="fas fa-map-marked-alt me-1"></i>Destinos &amp; Hospedagens
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link disabled" type="button"
                    title="Crie a proposta para liberar esta etapa" tabindex="-1" aria-disabled="true">
                <i class="fas fa-shield-alt me-1"></i>Seguro
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link disabled" type="button"
                    title="Crie a proposta para liberar esta etapa" tabindex="-1" aria-disabled="true">
                <i class="fas fa-check-double me-1"></i>Revisão
            </button>
        </li>
    </ul>

    <div class="tab-content" id="editarTabsContent">
        <div class="tab-pane fade show active" id="pane-dados" role="tabpanel">

            <form asp-action="Criar" method="post" enctype="multipart/form-data" id="formProposta">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row">
                    <!-- Formulário principal -->
                    <div class="col-md-8">

                        <!-- Card: Informações da Viagem -->
                        <div class="card mb-4">
                            <div class="card-header bg-primary text-white">
                                <h5 class="mb-0"><i class="fas fa-info-circle me-2"></i>Informações da Viagem</h5>
                            </div>
                            <div class="card-body">
                                <div class="mb-3">
                                    <label asp-for="Titulo" class="form-label fw-bold">
                                        <span class="text-danger">*</span> @Html.DisplayNameFor(m => m.Titulo)
                                    </label>
                                    <input asp-for="Titulo" class="form-control form-control-lg"
                                           placeholder="Ex: Viagem dos Sonhos - Europa 2024"
                                           maxlength="500" required />
                                    <span asp-validation-for="Titulo" class="text-danger"></span>
                                </div>

                                <div class="row">
                                    <div class="col-md-6 mb-3">
                                        <label asp-for="DataInicio" class="form-label fw-bold">
                                            <i class="fas fa-calendar-alt me-1"></i>Data de Início
                                        </label>
                                        <input asp-for="DataInicio" class="form-control" type="date" id="DataInicio" />
                                        <span asp-validation-for="DataInicio" class="text-danger"></span>
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <label asp-for="DataFim" class="form-label fw-bold">
                                            <i class="fas fa-calendar-check me-1"></i>Data de Fim
                                        </label>
                                        <input asp-for="DataFim" class="form-control" type="date" id="DataFim" />
                                        <span asp-validation-for="DataFim" class="text-danger"></span>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-6 mb-3">
                                        <label asp-for="NumeroPassageiros" class="form-label fw-bold">
                                            <span class="text-danger">*</span> <i class="fas fa-users me-1"></i>Passageiros
                                        </label>
                                        <input asp-for="NumeroPassageiros" class="form-control" type="number"
                                               min="1" max="50" value="1" required />
                                        <span asp-validation-for="NumeroPassageiros" class="text-danger"></span>
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <label asp-for="NumeroCriancas" class="form-label fw-bold">
                                            <i class="fas fa-child me-1"></i>Crianças
                                        </label>
                                        <input asp-for="NumeroCriancas" class="form-control" type="number"
                                               min="0" max="20" value="0" />
                                        <span asp-validation-for="NumeroCriancas" class="text-danger"></span>
                                    </div>
                                </div>

                                <div class="mb-3">
                                    <label class="form-label fw-bold">
                                        <i class="fas fa-camera me-1"></i>Foto de Capa
                                        <span class="text-muted fw-normal">(Opcional)</span>
                                    </label>
                                    <input asp-for="FotoCapaUpload" class="form-control" type="file"
                                           accept="image/*" id="fotoCapa" />
                                    <div class="form-text">JPG, PNG, GIF — máx. 5 MB. Pode ser adicionada depois.</div>
                                    <span asp-validation-for="FotoCapaUpload" class="text-danger"></span>
                                    <div id="previewCapa" class="mt-2" style="display:none;">
                                        <img id="imagemPreview" class="img-thumbnail" style="max-height:150px;" />
                                        <button type="button" class="btn btn-sm btn-outline-danger mt-1" onclick="removerFoto()">
                                            <i class="fas fa-times me-1"></i>Cancelar
                                        </button>
                                    </div>
                                </div>

                                <div class="mb-3">
                                    <label asp-for="ObservacoesGerais" class="form-label fw-bold">
                                        <i class="fas fa-sticky-note me-1"></i>Observações Gerais
                                        <span class="text-muted fw-normal">(Opcional)</span>
                                    </label>
                                    <textarea asp-for="ObservacoesGerais" class="form-control" rows="4"
                                              placeholder="Descreva detalhes importantes sobre a viagem..."></textarea>
                                </div>
                            </div>
                        </div>

                        <!-- Card: Configurações -->
                        <div class="card mb-4">
                            <div class="card-header">
                                <h5 class="mb-0"><i class="fas fa-cog me-2"></i>Configurações</h5>
                            </div>
                            <div class="card-body">
                                <div class="row">
                                    <div class="col-md-6 mb-3">
                                        <label asp-for="LayoutId" class="form-label fw-bold">Layout</label>
                                        <select asp-for="LayoutId" class="form-control">
                                            <option value="">Layout Padrão</option>
                                            @if (ViewBag.Layouts != null)
                                            {
                                                @foreach (var layout in (List<SistemaUsuarios.Models.Layout>)ViewBag.Layouts)
                                                {
                                                    <option value="@layout.Id">@layout.Nome</option>
                                                }
                                            }
                                        </select>
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <label asp-for="DataExpiracaoLink" class="form-label fw-bold">
                                            <i class="fas fa-clock me-1"></i>Expiração do Link
                                        </label>
                                        <input asp-for="DataExpiracaoLink" class="form-control" type="datetime-local" />
                                        <div class="form-text">Deixe em branco para nunca expirar</div>
                                    </div>
                                </div>
                                <div class="form-check form-switch">
                                    <input asp-for="LinkPublicoAtivo" class="form-check-input" checked />
                                    <label asp-for="LinkPublicoAtivo" class="form-check-label fw-bold">
                                        <i class="fas fa-link me-1"></i>Link Público Ativo
                                    </label>
                                    <div class="form-text">O cliente poderá acessar a proposta via link</div>
                                </div>
                            </div>
                        </div>

                    </div><!-- /col-md-8 -->

                    <!-- Sidebar -->
                    <div class="col-md-4">

                        <div class="card mb-4 sticky-top" style="top:20px;">
                            <div class="card-header bg-light">
                                <h6 class="mb-0"><i class="fas fa-info me-2"></i>Informações</h6>
                            </div>
                            <div class="card-body">
                                <div class="mb-2">
                                    <small class="text-muted">Status</small>
                                    <p class="mb-0">
                                        <span class="badge bg-secondary">Rascunho</span>
                                    </p>
                                </div>
                                <div class="mb-2">
                                    <small class="text-muted">Título</small>
                                    <p class="mb-0 fw-semibold" id="previewTituloTexto">Digite um título...</p>
                                </div>
                                <div class="mb-0">
                                    <small class="text-muted">Data de criação</small>
                                    <p class="mb-0 text-muted small">Será definida ao salvar</p>
                                </div>
                            </div>
                        </div>

                        <div class="card mb-3">
                            <div class="card-body">
                                <div class="d-grid gap-2">
                                    <button type="submit" class="btn btn-primary btn-lg" id="btnSalvar">
                                        <i class="fas fa-plus me-2"></i>Criar Proposta
                                    </button>
                                    <a href="/Proposta" class="btn btn-outline-secondary">
                                        <i class="fas fa-times me-2"></i>Cancelar
                                    </a>
                                </div>
                                <div class="mt-3 p-2 bg-light rounded">
                                    <small class="text-muted">
                                        <i class="fas fa-lightbulb me-1"></i>
                                        Apenas o título e o número de passageiros são obrigatórios. Os demais campos podem ser preenchidos depois.
                                    </small>
                                </div>
                            </div>
                        </div>

                    </div><!-- /col-md-4 -->
                </div><!-- /row -->
            </form>

        </div><!-- /pane-dados -->
    </div><!-- /tab-content -->

</div><!-- /container-fluid -->

@* ── AI Copilot Panel (null = nova proposta, sem ID ainda) ── *@
@await Html.PartialAsync("_CopilotPanel", (Guid?)null)

@section Scripts {
    <script src="~/js/copilot.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {

            // Preview em tempo real do título na sidebar
            var tituloInput = document.getElementById('Titulo');
            if (tituloInput) {
                tituloInput.addEventListener('input', function () {
                    var el = document.getElementById('previewTituloTexto');
                    if (el) el.textContent = this.value || 'Digite um título...';
                });
            }

            // Preview da foto de capa
            var fotoCapa = document.getElementById('fotoCapa');
            if (fotoCapa) {
                fotoCapa.addEventListener('change', function () {
                    var file = this.files[0];
                    if (!file) { document.getElementById('previewCapa').style.display = 'none'; return; }

                    if (file.size > 5 * 1024 * 1024) {
                        alert('Arquivo muito grande. Máximo 5 MB permitido.');
                        this.value = '';
                        document.getElementById('previewCapa').style.display = 'none';
                        return;
                    }
                    var allowed = ['image/jpeg', 'image/jpg', 'image/png', 'image/gif'];
                    if (!allowed.includes(file.type)) {
                        alert('Tipo de arquivo não permitido. Use JPG, PNG ou GIF.');
                        this.value = '';
                        document.getElementById('previewCapa').style.display = 'none';
                        return;
                    }
                    var reader = new FileReader();
                    reader.onload = function (e) {
                        document.getElementById('imagemPreview').src = e.target.result;
                        document.getElementById('previewCapa').style.display = 'block';
                    };
                    reader.readAsDataURL(file);
                });
            }

            // Validação de datas
            function validarDatas() {
                var inicio = document.getElementById('DataInicio').value;
                var fim = document.getElementById('DataFim').value;
                if (inicio && fim && new Date(inicio) > new Date(fim)) {
                    alert('A data de fim deve ser posterior à data de início.');
                    document.getElementById('DataFim').value = '';
                }
            }
            document.getElementById('DataInicio').addEventListener('change', validarDatas);
            document.getElementById('DataFim').addEventListener('change', validarDatas);

            // Spinner no submit
            document.getElementById('formProposta').addEventListener('submit', function () {
                var btn = document.getElementById('btnSalvar');
                btn.disabled = true;
                btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Criando proposta...';
                setTimeout(function () {
                    if (btn.disabled) {
                        btn.disabled = false;
                        btn.innerHTML = '<i class="fas fa-plus me-2"></i>Criar Proposta';
                    }
                }, 10000);
            });
        });

        function removerFoto() {
            document.getElementById('fotoCapa').value = '';
            document.getElementById('previewCapa').style.display = 'none';
        }
    </script>
}
